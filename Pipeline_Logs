# =============================================================================
#  Governance - DRY-RUN job  (READ-ONLY preview)
# =============================================================================
#  Prints every write that WOULD be made, with full payloads, but sends no
#  write requests to GitLab. Use this before every apply.
#
#  Runs when: RUN_GOVERNANCE=true AND GOV_MODE=dryrun
#  Safe to run on any branch.
#
#  NOTE: dry-run cannot exercise the push-rule JSON/form-encoding fallback or
#  resolve real protected-branch IDs, since they may not exist yet, so
#  approval-rule payloads show placeholder ids. That is expected.
# =============================================================================

governance:dryrun:
  extends: .governance_base
  script:
    - 'echo "===== GOVERNANCE DRY-RUN - no changes ====="'
    - 'python3 "$GOV_SCRIPT" $GOV_FLAG "$GOV_TARGET" --dry-run'
    - 'echo "===== DRY-RUN COMPLETE - no changes were made ====="'
  rules:
    - if: '$RUN_GOVERNANCE == "true" && $GOV_MODE == "dryrun"'
      when: always
    - when: never
