    paths:
      - .composer-cache/

  before_script:
    - php --version

    # ── Download Composer from Artifactory ─────────────────────────
    - |
      echo "Downloading Composer from JFrog..."

      curl -k -u "${JF_USER}:${JF_TOKEN}" \
        "https://artifactory.jfrog.sbi/artifactory/itepaypg-sbiepay2-generic-local/tools/composer/composer.phar" \
        -o composer.phar

      echo "Checking composer file..."
      ls -lh composer.phar

      SIZE=$(stat -c%s composer.phar)
      echo "File size: $SIZE"

      if [ "$SIZE" -lt 1000000 ]; then
        echo "ERROR: Invalid composer.phar (wrong path or access issue)"
        echo "Content:"
        cat composer.phar
        exit 1
      fi

      chmod +x composer.phar
      mv composer.phar composer
      export PATH="$CI_PROJECT_DIR:$PATH"

      composer --version

    # ── Configure Composer to use Artifactory ──────────────────────
    - composer config --global repos.packagist composer https://artifactory.jfrog.sbi/artifactory/api/composer/itepaypg-sbiepay2-php-virtual
    - composer config --global http-basic.artifactory.jfrog.sbi "${JF_USER}" "${JF_TOKEN}"

  script:
    - |
      set -eo pipefail

      echo "===== SYSTEM INFO ====="
      free -h || true
      df -h || true

      echo "===== INSTALLING DEPENDENCIES ====="

      composer install \
        --no-dev \
        --optimize-autoloader \
        --no-interaction \
        --prefer-dist

      if [ ! -d "vendor" ]; then
        echo "ERROR: vendor folder not created"
        exit 1
      fi

      echo "Vendor count: $(ls vendor | wc -l)"
      echo "Build complete"

  artifacts:
    paths:
      - vendor/
    expire_in: 1 day
