# --- Copy Gradle (offline setup) ---
COPY gradle-9.3.0 /opt/gradle-9.3.0

# --- Create symlink ---
RUN ln -s /opt/gradle-${GRADLE_VERSION} /opt/gradle

ENV GRADLE_HOME=/opt/gradle
ENV PATH=$PATH:$GRADLE_HOME/bin

# --- Create non-root user ---
RUN useradd -u 1001 -m gradle

# --- Gradle cache ---
ENV GRADLE_USER_HOME=/home/gradle/.gradle

RUN mkdir -p $GRADLE_USER_HOME \
    && chown -R gradle:gradle /home/gradle /opt/gradle*

# --- Import certificate ---
COPY jfrog-chain.crt /tmp/

RUN keytool -import -trustcacerts \
    -cacerts \
    -file /tmp/jfrog-chain.crt \
    -alias sbi-internal \
    -storepass changeit -noprompt \
    && rm -f /tmp/jfrog-chain.crt

# --- Switch user ---
USER gradle
WORKDIR /workspace

CMD ["gradle", "--version"]
