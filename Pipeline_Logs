      printf '    },\n' >> "$COMPOSER_HOME/config.json"
      printf '    "repositories": {\n' >> "$COMPOSER_HOME/config.json"
      printf '        "packagist": {\n' >> "$COMPOSER_HOME/config.json"
      printf '            "type": "composer",\n' >> "$COMPOSER_HOME/config.json"
      printf '            "url": "%s"\n' "$REPO_URL" >> "$COMPOSER_HOME/config.json"
      printf '        }\n' >> "$COMPOSER_HOME/config.json"
      printf '    }\n' >> "$COMPOSER_HOME/config.json"
      printf '}\n' >> "$COMPOSER_HOME/config.json"

      echo "── Writing auth.json ──"
      printf '{\n' > "$COMPOSER_HOME/auth.json"
      printf '    "http-basic": {\n' >> "$COMPOSER_HOME/auth.json"
      printf '        "artifactory.jfrog.sbi": {\n' >> "$COMPOSER_HOME/auth.json"
      printf '            "username": "%s",\n' "$JF_USER" >> "$COMPOSER_HOME/auth.json"
      printf '            "password": "%s"\n' "$JF_TOKEN" >> "$COMPOSER_HOME/auth.json"
      printf '        },\n' >> "$COMPOSER_HOME/auth.json"
      printf '        "artifactory.jfrog.sbi:443": {\n' >> "$COMPOSER_HOME/auth.json"
      printf '            "username": "%s",\n' "$JF_USER" >> "$COMPOSER_HOME/auth.json"
      printf '            "password": "%s"\n' "$JF_TOKEN" >> "$COMPOSER_HOME/auth.json"
      printf '        }\n' >> "$COMPOSER_HOME/auth.json"
      printf '    }\n' >> "$COMPOSER_HOME/auth.json"
      printf '}\n' >> "$COMPOSER_HOME/auth.json"

