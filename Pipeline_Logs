.build:
  stage: build

  image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-virtual/ubi9/php-82:1-1778488703

  variables:
    COMPOSER_HOME: "${CI_PROJECT_DIR}/.composer"
    COMPOSER_CACHE_DIR: "${CI_PROJECT_DIR}/.composer-cache"

    COMPOSER_AUTH: >
      {
        "http-basic": {
          "artifactory.jfrog.sbi": {
            "username": "${JF_USER}",
            "password": "${JF_TOKEN}"
          },
          "artifactory.jfrog.sbi:443": {
            "username": "${JF_USER}",
            "password": "${JF_TOKEN}"
          }
        }
      }

  cache:
    key: "${CI_PROJECT_NAME}-composer-${CI_COMMIT_REF_SLUG}"
    paths:
      - .composer-cache/
      - vendor/

  before_script:
    - git config --global --add safe.directory "${CI_PROJECT_DIR}"

    - php --version

    - |
      set -euo pipefail

      echo "── Downloading Composer from JFrog ──"

      curl --fail -k \
        -u "${JF_USER}:${JF_TOKEN}" \
        -o composer.phar \
        "https://artifactory.jfrog.sbi/artifactory/itepaypg-sbiepay2-php-virtual/composer.phar"

      chmod +x composer.phar

      php composer.phar --version

    - |
      set -euo pipefail

      echo "── Probing packages.json endpoints ──"

      mkdir -p /tmp/composer-repo

      echo "--- Attempt 1: api/composer endpoint ---"
      curl -sk \
        -u "${JF_USER}:${JF_TOKEN}" \
        -w "\nHTTP_STATUS:%{http_code}\nCONTENT_LENGTH:%{size_download}\n" \
        "https://artifactory.jfrog.sbi/artifactory/api/composer/itepaypg-sbiepay2-php-virtual/packages.json" \
        | tail -20

      echo "--- Attempt 2: direct virtual repo endpoint ---"
      curl -sk \
        -u "${JF_USER}:${JF_TOKEN}" \
        -w "\nHTTP_STATUS:%{http_code}\nCONTENT_LENGTH:%{size_download}\n" \
        "https://artifactory.jfrog.sbi/artifactory/itepaypg-sbiepay2-php-virtual/packages.json" \
        | tail -20

      echo "── Fetching packages.json (api/composer) ──"
      curl --fail -sk \
        -u "${JF_USER}:${JF_TOKEN}" \
        -o /tmp/composer-repo/packages.json \
        "https://artifactory.jfrog.sbi/artifactory/api/composer/itepaypg-sbiepay2-php-virtual/packages.json"

      echo "Raw size: $(wc -c < /tmp/composer-repo/packages.json) bytes"
      echo "First 300 chars:"
      head -c 300 /tmp/composer-repo/packages.json

      # Strip the /repos/ segment from all download URLs
      sed -i \
        's|/itepaypg-sbiepay2-php-virtual/repos/|/itepaypg-sbiepay2-php-virtual/|g' \
        /tmp/composer-repo/packages.json

      echo "── Verifying patched URL sample ──"
      grep -o '"url":"https://[^"]*' /tmp/composer-repo/packages.json | head -5 || echo "WARNING: No URLs found in packages.json"

  script:

    - |
      set -euo pipefail

      echo "── Configuring Composer ──"

      mkdir -p "${COMPOSER_HOME}"
      mkdir -p "${COMPOSER_CACHE_DIR}"

      php composer.phar config -g repo.packagist false

      php composer.phar config -g repositories.jfrog composer \
        "file:///tmp/composer-repo"

      php composer.phar config -g secure-http true
      php composer.phar config -g cafile "${JF_ARTIFACTORY_CERT}"

      php composer.phar config -g preferred-install dist
      php composer.phar config -g github-protocols https
      php composer.phar config -g use-github-api false
      php composer.phar config -g source-fallback false

      echo "── Composer Global Config ──"

      php composer.phar config --global --list

    - |
      set -euo pipefail

      echo "===== INSTALLING DEPENDENCIES ====="

      php composer.phar install \
        --prefer-dist \
        --no-dev \
        --no-interaction \
        --no-progress \
        --optimize-autoloader \
        --no-cache \
        --no-scripts \
        --no-source-fallback \
        -vvv

  artifacts:
    expire_in: 1 day

    paths:
      - vendor/
      - composer.lock
