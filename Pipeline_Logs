# cicd-templates/.gitlab-ci.yml
# Self-validation pipeline — runs on every commit to cicd-templates repo
# Validates YAML syntax + shell scripts before app repos consume changes

stages:
  - lint
  - validate

yaml-lint:
  stage: lint
  image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-local/custom-ci/rhelgit-oc-helm:1.0
  tags:
    - common_runner
  script:
    - pip install yamllint --quiet
    - |
      echo "Running yamllint on all pipeline files..."
      find . -name "*.yml" -not -path "./.git/*" -not -path "./config/*" | \
        xargs yamllint -d '{extends: relaxed, rules: {line-length: {max: 200}}}' && \
        echo "✅ YAML lint passed" || echo "⚠️ YAML lint warnings (non-blocking)"
  allow_failure: true

shell-lint:
  stage: lint
  image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-local/custom-ci/rhelgit-oc-helm:1.0
  tags:
    - common_runner
  script:
    - |
      if command -v shellcheck &>/dev/null; then
        find scripts/ -name "*.sh" | xargs shellcheck -S warning && echo "✅ Shell lint passed"
      else
        echo "shellcheck not available in this image — installing"
        dnf install -y shellcheck 2>/dev/null || yum install -y shellcheck 2>/dev/null || \
          (echo "⚠️ shellcheck not installable — skipping" && exit 0)
        find scripts/ -name "*.sh" | xargs shellcheck -S warning
      fi
  allow_failure: true

gitlab-ci-lint:
  stage: validate
  image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-local/custom-ci/rhelgit-oc-helm:1.0
  tags:
    - common_runner
  script:
    - |
      echo "Validating orchestrator templates via GitLab CI Lint API..."
      for f in templates/ci/backend/java.yml templates/ci/backend/java.library.yml \
               templates/cd/deploy.dynamic.yml templates/cd/deploy.config.yml; do
        echo "Linting: $f"
        RESULT=$(curl -sf --header "PRIVATE-TOKEN: $GIT_PAT" \
          --form "content=<$f" \
          "https://gitlab.sbi/api/v4/projects/$CI_PROJECT_ID/ci/lint" 2>/dev/null || echo '{"valid":false}')
        VALID=$(echo "$RESULT" | python3 -c "import sys,json; print(json.load(sys.stdin).get('valid','false'))")
        if [ "$VALID" == "True" ]; then
          echo "✅ $f"
        else
          echo "⚠️ $f — check manually"
        fi
      done
  allow_failure: true
