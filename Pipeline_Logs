def build_dashboard(wb, rows):
    ws = wb.create_sheet("📊 Dashboard")
    ws.sheet_view.showGridLines = False
    ws.column_dimensions["A"].width = 3
    ws.column_dimensions["B"].width = 30
    ws.column_dimensions["C"].width = 18
    ws.column_dimensions["D"].width = 3
    ws.column_dimensions["E"].width = 30
    ws.column_dimensions["F"].width = 18

    # Title
    ws.merge_cells("B1:F1")
    t = ws["B1"]
    t.value     = "GitLab Repository Audit — Migration Dashboard"
    t.font      = Font(name="Arial", bold=True, color=C_WHITE, size=14)
    t.fill      = PatternFill("solid", start_color=C_HEADER_DARK, fgColor=C_HEADER_DARK)
    t.alignment = Alignment(horizontal="center", vertical="center")
    ws.row_dimensions[1].height = 32

    # Sub-title
    ws.merge_cells("B2:F2")
    s2 = ws["B2"]
    s2.value     = f"Source: {GITLAB_URL}  |  Group: {TARGET_GROUP or 'All Projects'}  |  Generated: {datetime.now().strftime('%Y-%m-%d %H:%M')}"
    s2.font      = Font(name="Arial", italic=True, color=C_WHITE, size=9)
    s2.fill      = PatternFill("solid", start_color=C_HEADER_MED, fgColor=C_HEADER_MED)
    s2.alignment = Alignment(horizontal="center", vertical="center")
    ws.row_dimensions[2].height = 18

    # Metric cards
    total    = len(rows)
    high     = sum(1 for r in rows if r["risk"] == "HIGH")
    medium   = sum(1 for r in rows if r["risk"] == "MEDIUM")
    low      = sum(1 for r in rows if r["risk"] == "LOW")
    archived = sum(1 for r in rows if r["risk"] == "ARCHIVED")

    total_mrs_open    = sum(r["mrs_open"]     for r in rows)
    total_issues_open = sum(r["issues_open"]  for r in rows)
    total_epics       = rows[0]["group_epics"] if rows else 0
    total_pipelines   = sum(r["pipelines"]    for r in rows)
    total_branches    = sum(r["branches"]     for r in rows)
    total_tags        = sum(r["tags"]         for r in rows)
    total_releases    = sum(r["releases"]     for r in rows)
    total_members     = sum(r["members"]      for r in rows)
    total_webhooks    = sum(r["webhooks"]     for r in rows)
    total_envs        = sum(r["environments"] for r in rows)

    cards_left = [
        ("Total Repositories",  total,             C_HEADER_DARK, C_WHITE),
        ("HIGH Risk",           high,              C_HIGH,        C_HIGH_TXT),
        ("MEDIUM Risk",         medium,            C_MEDIUM,      C_MEDIUM_TXT),
        ("LOW Risk",            low,               C_LOW,         C_LOW_TXT),
        ("Archived",            archived,          C_ARCHIVED,    C_ARCHIVED_TXT),
        ("Total Open MRs",      total_mrs_open,    C_HEADER_MED,  C_WHITE),
        ("Total Open Issues",   total_issues_open, C_HEADER_MED,  C_WHITE),
        ("Group Epics",         total_epics,       C_HEADER_MED,  C_WHITE),
    ]
    cards_right = [
        ("Total Pipelines",     total_pipelines,   C_ACCENT,      C_WHITE),
        ("Total Branches",      total_branches,    C_ACCENT,      C_WHITE),
        ("Total Tags",          total_tags,        C_ACCENT,      C_WHITE),
        ("Total Releases",      total_releases,    C_ACCENT,      C_WHITE),
        ("Total Environments",  total_envs,        C_ACCENT,      C_WHITE),
        ("Total Members",       total_members,     C_ACCENT,      C_WHITE),
        ("Total Webhooks",      total_webhooks,    C_ACCENT,      C_WHITE),
        ("Repos with CI/CD",    sum(1 for r in rows if r["ci_enabled"]=="Yes"), C_ACCENT, C_WHITE),
    ]

    def write_card(ws, row, label_col, val_col, label, value, bg, fg):
        ws.row_dimensions[row].height   = 28
        ws.row_dimensions[row+1].height = 28
        lc = ws.cell(row=row,   column=label_col, value=label)
        vc = ws.cell(row=row+1, column=val_col,   value=value)
        for cell in (lc, vc):
            cell.fill      = PatternFill("solid", start_color=bg, fgColor=bg)
            cell.border    = BORDER_THIN
            cell.alignment = Alignment(horizontal="center", vertical="center")
        lc.font = Font(name="Arial", bold=False, color=fg, size=9)
        vc.font = Font(name="Arial", bold=True,  color=fg, size=16)

    start_row = 4
    for i, (label, value, bg, fg) in enumerate(cards_left):
        r = start_row + i * 3
        ws.merge_cells(start_row=r,   start_column=2, end_row=r,   end_column=3)
        ws.merge_cells(start_row=r+1, start_column=2, end_row=r+1, end_column=3)
        write_card(ws, r, 2, 2, label, value, bg, fg)

    for i, (label, value, bg, fg) in enumerate(cards_right):
        r = start_row + i * 3
        ws.merge_cells(start_row=r,   start_column=5, end_row=r,   end_column=6)
        ws.merge_cells(start_row=r+1, start_column=5, end_row=r+1, end_column=6)
        write_card(ws, r, 5, 5, label, value, bg, fg)

    # Legend
    legend_row = start_row + len(cards_left) * 3 + 2
    ws.merge_cells(start_row=legend_row, start_column=2,
                   end_row=legend_row,   end_column=6)
    lh = ws.cell(row=legend_row, column=2, value="Migration Risk Legend")
    lh.font      = Font(name="Arial", bold=True, color=C_WHITE, size=10)
    lh.fill      = PatternFill("solid", start_color=C_HEADER_DARK, fgColor=C_HEADER_DARK)
    lh.alignment = Alignment(horizontal="center", vertical="center")
    ws.row_dimensions[legend_row].height = 22

    legend_items = [
        ("HIGH",     "CI/CD pipelines present OR open MRs exist",              C_HIGH,     C_HIGH_TXT),
        ("MEDIUM",   "Issues / Wiki / Packages enabled (no open MRs / CI)",    C_MEDIUM,   C_MEDIUM_TXT),
        ("LOW",      "Simple repository — no active features",                 C_LOW,      C_LOW_TXT),
