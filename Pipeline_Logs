```python
import urllib.request, json, ssl

GITLAB_URL = "https://gitlab.sbi"
TOKEN      = "glpat-zzGKdsrRgYsTuTSYsMtM"
TOP_GROUP  = "itepaypg-sbiepay2"

ssl_ctx = ssl._create_unverified_context()

def get(url):
    req = urllib.request.Request(url)
    req.add_header("PRIVATE-TOKEN", TOKEN)
    resp = urllib.request.urlopen(req, context=ssl_ctx)
    return json.loads(resp.read())

# Search all subgroups recursively
print("=" * 65)
print(f"  Searching all subgroups under: {TOP_GROUP}")
print("=" * 65)

url = f"{GITLAB_URL}/api/v4/groups/{TOP_GROUP}/subgroups?per_page=100&all_available=true"
subgroups = get(url)

print(f"\n  Direct subgroups found: {len(subgroups)}\n")
for g in subgroups:
    print(f"  ID={g['id']:<6}  name={g['name']:<50}  path={g['full_path']}")

# Also search by keyword
print("\n" + "=" * 65)
print("  Searching by keyword: ldap, epay-gitlab, bank, vendor")
print("=" * 65)

for keyword in ["ldap", "epay-gitlab", "bank-app", "vendor-app", "LDAP"]:
    url = f"{GITLAB_URL}/api/v4/groups?search={keyword}&per_page=50"
    results = get(url)
    if results:
        print(f"\n  --- keyword: '{keyword}' ---")
        for g in results:
            print(f"  ID={g['id']:<6}  name={g['name']:<50}  path={g['full_path']}")

# Also check LDAP-membership group specifically
print("\n" + "=" * 65)
print("  Checking itepaypg-sbiepay2 subgroups (all levels)")
print("=" * 65)

url2 = f"{GITLAB_URL}/api/v4/groups?per_page=100&all_available=true"
req2 = urllib.request.Request(url2)
req2.add_header("PRIVATE-TOKEN", TOKEN)
resp2 = urllib.request.urlopen(req2, context=ssl_ctx)
all_groups = json.loads(resp2.read())

print(f"\n  All visible groups ({len(all_groups)} total):\n")
for g in sorted(all_groups, key=lambda x: x.get("full_path", "")):
    print(f"  ID={g['id']:<6}  name={g['name']:<50}  path={g['full_path']}")
```

Run it:
```cmd
python311\python.exe find_ldap_groups.py
```

