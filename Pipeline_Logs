# templates/ci/backend/java.yml
# CI orchestrator for Java/Gradle MICROSERVICE repos (produce container image → OCP)
# For library/utility repos (produce JARs → JFrog), use java.library.yml
#
# App repo .gitlab-ci.yml:
#   include:
#     - project: 'itepaypg-sbiepay2/infra/devops/cicd-templates'
#       ref: main
#       file: 'templates/ci/backend/java.yml'
#   variables:
#     RELEASE_NAME: txn
#     CHART_NAME:   transactionservice

default:
  tags:
    - common_runner

include:
  - local: 'ci/version/semver.yml'
  - local: 'ci/build/java.gradle.yml'
  - local: 'ci/test/java.unit.yml'
  - local: 'ci/image/image.build.yml'
  - local: 'ci/image/image.push.yml'
  - local: 'ci/release/tag.yml'
  - local: 'ci/deploy/trigger.cd.yml'
  - local: 'ci/deploy/deploy.jobs.yml'

stages:
  - version       # version generation
  - build         # gradle compile
  - test          # unit + integration
  - sast          # gitlab sast + fortify
  - security      # sca + secrets + iac + license + sbom
  - image-build   # podman build (local only — no push)
  - image-scan    # trivy + xray + rhacs (gate before sign)
  - image-push    # push to JFrog (only after scan + sign)
  - release       # rc-tag (release/*) or prod-tag (main) — auto on merge
  - deploy        # trigger buttons → deployment repo CD pipeline

variables:
  CI_TEMPLATE_REGISTRY_HOST:           "artifactory.jfrog.sbi:443"
  CI_TEMPLATE_REGISTRY_HOST_PREPROD:   "epaynonprod-registry-quay-quay-enterprise.apps.preprod.epay.sbi"
  CI_TEMPLATE_REGISTRY_HOST_PREPRODDC: "dc-preprod-registry-quay-quay-enterprise.apps.dcpreprod.epay.sbi"
  CI_TEMPLATE_REGISTRY_HOST_PRODDR:    "epayproddr-registry-quay-quay-enterprise.apps.dr.prod.epay.sbi"
  CI_TEMPLATE_REGISTRY_HOST_PRODDC:    "proddc-registry-route-quay-enterprise.apps.dc.prod.epay.sbi"
  GIT_STRATEGY: clone
  RELEASE_NAME: ""
  CHART_NAME:   ""
  IMAGE_NAME:   "itepaypg-sbiepay2-docker-local/app/backend/${CI_PROJECT_NAME}"
  BASE_IMAGE_DEV_ENV:    "artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-local/redhat-baseimage/openjdk-21-runtime:1.23-6.1758133907"
  BASE_IMAGE_HIGHER_ENV: "artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-virtual/ubi9/openjdk-21-runtime:1.24-2.1776357031"

# Branch + MR filter — applied to all jobs via extends
.rules:
  rules:
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event" && $CI_MERGE_REQUEST_TARGET_BRANCH_NAME =~ /^(main|develop|release)(\/.*)*$/'
    - if: '$CI_COMMIT_BRANCH =~ /^(main|develop|release|hotfix|bugfix|feature)(\/.*)*$/'
    - when: never
# ── Stage: build ───────────────────────────────────────────────────────────────
build:
  extends: [.build, .rules]

# ── Stage: test ────────────────────────────────────────────────────────────────
test:
  extends: [.test, .rules]

# # ── Stage: image-build ─────────────────────────────────────────────────────────
image:build:
  extends: [.image_build, .rules]

# # ── Stage: image-push ──────────────────────────────────────────────────────────
image:push:
  extends: [.image_push, .rules]



------------------------------------------------------------ trigger.cd.yml 

.trigger_cd:
  stage: deploy
  variables:
    DEPLOYMENT_BRANCH: "feature/deploy-cicd"
    # DEPLOYMENT_BRANCH: "deploy_cicd"
    SERVICE_NAME: "${CI_PROJECT_NAME}"
    VERSION: "${VERSION}"
  trigger:
    project: "itepaypg-sbiepay2/infra/devops/deployment"
    branch:  "$DEPLOYMENT_BRANCH"
    strategy: depend            # CI pipeline waits for CD result — pass/fail shown inline
    forward:
      pipeline_variables: true  # forwards VERSION, ENV, SERVICE_NAME, CHART_NAME etc.
      yaml_variables: true
	  
----------------------------

# ── DEV — auto on develop push ────────────────────────────────────────────────  deploy-jobs.yml
deploy-dev:
  extends: .trigger_cd
  variables:
    ENV:          dev
    SERVICE_NAME: "$CI_PROJECT_NAME"
    CHART_NAME:   "$CHART_NAME"
  rules:
    - if: '$CI_COMMIT_BRANCH == "develop" && $CI_PIPELINE_SOURCE == "push"'
      when: on_success
    - if: '$CI_COMMIT_BRANCH == "feature/deploy-cicd" && $CI_PIPELINE_SOURCE == "push"'
      when: on_success
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event" && $CI_MERGE_REQUEST_SOURCE_BRANCH_NAME =~ /^feature\/.*$/ && $CI_MERGE_REQUEST_TARGET_BRANCH_NAME == "develop"'
      when: on_success
    - when: never
