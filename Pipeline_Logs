# ci/release/tag.yml  |  Stage: release
# ──────────────────────────────────────────────────────────────────────────────
# Creates git tags on post-merge PUSH pipelines only — never on MR pipelines.
#
# Active job:
#   create-prod-tag   auto on push to main — tags the production release.
#
# ── Tag format: BARE semver (1.2.0) — no 'v' prefix ───────────────────────────
# Must stay consistent with ci/version/semver.yml, whose idempotency guard and
# LAST_TAG lookup both match bare-only. A v-prefixed tag here would be invisible
# to semver.yml and cause the next main pipeline to double-bump.
#
# VERSION arrives from ci/version/semver.yml via the version.env dotenv artifact.
# This job never computes a version — it only persists the one already computed.
#
# ── Why the prod tag matters beyond record-keeping ────────────────────────────
# The tag is the input to the NEXT main pipeline's bump (last_tag + bump), so it
# is also the concurrency lock for the whole versioning model. Guards:
#   resource_group   serialises tag jobs across concurrent main pipelines
#   interruptible    a newer pipeline must never cancel a tag push mid-flight
#   allow_failure    false — the deploy stage must not unlock without the tag
#   same-commit      tag already on this commit → idempotent skip (safe retry)
#   other-commit     tag exists elsewhere → fail; a parallel release won the race
#
# Requires: GITLAB_CI_DEPLOY_TOKEN (masked + protected) with write_repository,
# from an account permitted to push to protected tags.
# ──────────────────────────────────────────────────────────────────────────────

.git_tag_base:
  stage: release
  image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-local/custom-ci/rhelgit-oc-helm:1.0
  tags:
    - common_runner
  before_script:
    - git config --global http.sslVerify false
    - git config --global --add safe.directory '*'
    - git config --global user.name "ci"
    - git config --global user.email "ci.cedge@sbi.co.in"
    - git remote set-url origin "https://oauth2:$GITLAB_CI_DEPLOY_TOKEN@gitlab.sbi/$CI_PROJECT_PATH.git"
    - git fetch --tags

# ── RC tag — DISABLED ─────────────────────────────────────────────────────────
# Release branch names carry no version (release/minor-DM…-EPAY-…), and a
# release/* push is versioned <branch>-<sha>, so there is no RC number to tag.
# Kept for reference only.
# create-rc-tag:
#   extends: .git_tag_base
#   script:
#     - |
#       RELEASE_VERSION=$(echo "$CI_COMMIT_BRANCH" | sed 's|release/||')
#       RC_COUNT=$(git tag -l "${RELEASE_VERSION}-rc.*" | wc -l)
#       NEW_RC=$((RC_COUNT + 1))
#       RC_TAG="${RELEASE_VERSION}-rc.${NEW_RC}"
#       git tag -a "$RC_TAG" -m "RC ${NEW_RC} — auto on merge to $CI_COMMIT_BRANCH"
#       git push origin "$RC_TAG"
#   rules:
#     - if: '$CI_COMMIT_BRANCH =~ /^release\/.*/ && $CI_PIPELINE_SOURCE == "push"'
#       when: on_success
#     - when: never

# ── Prod tag — auto on push to main ───────────────────────────────────────────
create-prod-tag:
  extends: .git_tag_base
  resource_group: prod-tag-lock      # serialise concurrent main pipelines
  interruptible: false               # never cancel a tag push mid-flight
  allow_failure: false               # deploy must not unlock without the tag
  script:
    - |
      set -eo pipefail
      # Only a clean X.Y.Z is tagged — any other VERSION means a non-main path.
      if ! echo "$VERSION" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+$'; then
        echo "VERSION '$VERSION' is not a clean X.Y.Z — nothing to tag. Skipping."
        exit 0
      fi
      PROD_TAG="${VERSION}"
      echo "Creating production tag: $PROD_TAG"
      if git rev-parse "$PROD_TAG" >/dev/null 2>&1; then
        EXISTING_SHA=$(git rev-parse "${PROD_TAG}^{commit}")
        # Same commit → this is a retry; nothing to do.
        if [ "$EXISTING_SHA" = "$CI_COMMIT_SHA" ]; then
          echo "Tag $PROD_TAG already on this commit — idempotent skip."
          exit 0
        fi
        # Different commit → a parallel release took this number. Never overwrite.
        echo "❌ ERROR: $PROD_TAG exists on a DIFFERENT commit ($EXISTING_SHA)." >&2
        echo "   Parallel release raced us. Re-run the FULL pipeline to recompute." >&2
        exit 1
      fi
      git tag -a "$PROD_TAG" -m "Production ${VERSION} — merged to main [$(date -u '+%Y-%m-%d %H:%M UTC')] | pipeline ${CI_PIPELINE_ID}"
      git push origin "$PROD_TAG"
      echo "✅ Production tag created: $PROD_TAG"
  rules:
    - if: '$CI_COMMIT_BRANCH == "main" && $CI_PIPELINE_SOURCE == "push"'
      when: on_success
    - when: never





