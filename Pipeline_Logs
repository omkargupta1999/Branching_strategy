def run_one(project, mode_verify, mode_dry_run):
    """Apply (or verify/dry-run) governance on ONE project. Returns (pid, ppath).
       On any API error the underlying calls sys.exit(1) -> fail-stop."""
    mode = "VERIFY" if mode_verify else ("DRY-RUN" if mode_dry_run else "APPLY")
    log("=" * 65)
    log("  GitLab Repo Governance")
    log(f"  Target  : {GITLAB_URL}")
    log(f"  Project : {project}")
    log(f"  Mode    : {mode}")
    log(f"  Time    : {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    log("=" * 65)

    pid, ppath = resolve_project(project)
    log(f"\nResolved project -> id={pid}  path={ppath}")

    log("\nValidating GitLab group IDs (read-only)...")
    groups = resolve_groups()
    for n, i in groups.items():
        log(f"  {n} -> {i}")

    if mode_verify:
        verify(pid, groups)
    else:
        apply_group_invites(pid, mode_dry_run)
        apply_push_rules(pid, mode_dry_run)
        apply_protected_branches(pid, groups, mode_dry_run)
        apply_approval_rules(pid, groups, mode_dry_run)
        apply_project_settings(pid, mode_dry_run)
        if not mode_dry_run:
            verify(pid, groups)

    log(f"\nDone. Scope was project id={pid} only.")
    return pid, ppath


def load_batch_file(path):
    """Read project IDs/paths, one per line. Blank lines and #comments ignored."""
    ids = []
    with open(path, encoding="utf-8") as f:
        for raw in f:
            line = raw.strip()
            if not line or line.startswith("#"):
                continue
            # Strip any inline comment so annotated lines like
            # "2823    # itepaypg-sbiepay2/.../epay_admin_service" work too.
            # We take the first whitespace- or #-delimited token as the ID/path.
            token = line.split("#", 1)[0].strip().split()[0]
            if token:
                ids.append(token)
    return ids


def main():
    ap = argparse.ArgumentParser(description="Apply governance to one repo, or "
                                 "many via --batch (fail-stop on first error).")
    ap.add_argument("--project", default=TARGET_PROJECT,
                    help="Full project path or numeric ID (single-repo mode)")
    ap.add_argument("--batch", metavar="FILE",
                    help="Path to a text file of project IDs/paths, one per line "
                         "(# comments allowed). Runs each in order; STOPS on first error.")
    ap.add_argument("--dry-run", action="store_true", help="Show writes; change nothing")
    ap.add_argument("--verify",  action="store_true", help="Read current state only")
    args = ap.parse_args()

    # ---------------- BATCH MODE ----------------
    if args.batch:
        targets = load_batch_file(args.batch)
        if not targets:
            print(f"[ERROR] No project IDs found in {args.batch}")
            sys.exit(1)
        total = len(targets)
        done = []   # (project, pid, path) successfully completed
        print("=" * 65)
        print(f"  BATCH MODE — {total} repos — FAIL-STOP on first error")
        print(f"  File: {args.batch}")
        print("=" * 65)
        for idx, project in enumerate(targets, 1):
            log("")
            log("#" * 65)
            log(f"#  BATCH {idx}/{total}: {project}")
            log("#" * 65)
            # If any step fails, the API helper sys.exit(1)s here -> batch halts.
            pid, ppath = run_one(project, args.verify, args.dry_run)
            done.append((project, pid, ppath))

        # Reached here only if ALL succeeded.
        log("")
        log("=" * 65)
        log(f"  BATCH COMPLETE — {len(done)}/{total} repos succeeded")
        log("=" * 65)
        for project, pid, ppath in done:
            log(f"  OK  {ppath} (id={pid})")

        out_file = f"governance_BATCH_{TIMESTAMP}.txt"
        with open(out_file, "w", encoding="utf-8") as f:
            f.write("\n".join(_log_lines))
        print(f"\n  -> {out_file} written (consolidated batch audit log).")
        return

    # ---------------- SINGLE-REPO MODE ----------------
    pid, ppath = run_one(args.project, args.verify, args.dry_run)

    out_file = f"governance_{ppath.split('/')[-1]}_{TIMESTAMP}.txt"
    with open(out_file, "w", encoding="utf-8") as f:
        f.write("\n".join(_log_lines))
    print(f"\n  -> {out_file} written.")
    mode = "VERIFY" if args.verify else ("DRY-RUN" if args.dry_run else "APPLY")
    if mode == "APPLY":
        print("  Changes were limited to the single project above.")
    else:
        print("  READ-ONLY: no changes made to GitLab.")


if __name__ == "__main__":
    main()













