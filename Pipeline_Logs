def verify(pid, groups):
    log("\n=== VERIFY (read-only) ===")
    id_to_name = {v: k for k, v in groups.items()}
    invite_name = {inv["id"]: inv["name"] for inv in GROUP_INVITES}

    log("Shared groups (project members):")
    proj0 = api_get(f"/projects/{pid}")
    for g in (proj0.get("shared_with_groups", []) if proj0 else []):
        gid = g.get("group_id")
        log(f"  {invite_name.get(gid, g.get('group_name', gid))}: "
            f"access level {g.get('group_access_level')}")

    log("Protected branches:")
    pb_by_name = {pb.get("name"): pb
                  for pb in (api_get_all(f"/projects/{pid}/protected_branches") or [])}
    for spec in PROTECTED_BRANCHES:
        pb = pb_by_name.get(spec["name"])
        if not pb:
            log(f"  MISSING: {spec['name']}")
            continue
        push  = pb.get("push_access_levels", [])
        merge = pb.get("merge_access_levels", [])
        push_ok = bool(push) and all(p.get("access_level") == NO_ACCESS for p in push)
        merge_grp = [id_to_name.get(m.get("group_id"), m.get("group_id"))
                     for m in merge if m.get("group_id")]
        log(f"  {spec['name']}: push={'No one' if push_ok else push} | merge groups={merge_grp}")

    log("Approval rules:")
    for r in (api_get_all(f"/projects/{pid}/approval_rules") or []):
        grp      = [id_to_name.get(g.get("id"), g.get("name")) for g in r.get("groups", [])]
        branches = [b.get("name") for b in r.get("protected_branches", [])]
        log(f"  {r.get('name')}: required={r.get('approvals_required')} | groups={grp} | branches={branches}")

    proj = api_get(f"/projects/{pid}")
    log(f"Pipelines must succeed: {proj.get('only_allow_merge_if_pipeline_succeeds')}")

    log("Push rules:")
    pr = api_get(f"/projects/{pid}/push_rule")
    if pr:
        log(f"  branch_name_regex   : {pr.get('branch_name_regex')}")
        log(f"  commit_message_regex: {pr.get('commit_message_regex')}")
    else:
        log("  MISSING: no push rules set")

