# ci/image/image.push.yml  |  Stage: image-push
# Pushes image to JFrog Artifactory ONLY after scan + sign passed
# Gate: needs image:sign — will not run if signing failed

variables:
  JF_SERVER_ID: "epay-server"

.image_podman_setup: &image_podman_setup
  - mkdir -p /etc/containers/certs.d/${CI_TEMPLATE_REGISTRY_HOST}
  - cp "$ARTIFACTORY_CERT" /etc/containers/certs.d/${CI_TEMPLATE_REGISTRY_HOST}/ca.crt
  - cp "$ARTIFACTORY_CERT" /etc/pki/ca-trust/source/anchors/artifactory.crt
  - update-ca-trust extract
  - podman login "$CI_TEMPLATE_REGISTRY_HOST" -u "$JF_USER" -p "$JF_TOKEN" ##Added
  - |
    jf config add \
      --url="$JF_URL" \
      --xray-url="$JF_XRAY_URL" \
      --user="$JF_USER" \
      --access-token="$JF_TOKEN" \
      --interactive=false "$JF_SERVER_ID"     
  - jf config use "$JF_SERVER_ID"

.image_push:
  stage: image-push
  image: artifactory.jfrog.sbi:443/dso-docker-base-images/ubi9/podman-jf:9.7
  tags:
    - common_runner
  before_script: *image_podman_setup
    # - mkdir -p /etc/containers/certs.d/${CI_TEMPLATE_REGISTRY_HOST}
    # - cp "$ARTIFACTORY_CERT" /etc/containers/certs.d/${CI_TEMPLATE_REGISTRY_HOST}/ca.crt
    # - podman login "$CI_TEMPLATE_REGISTRY_HOST" -u "$JF_USER" -p "$JF_TOKEN"
  script:
    - |
      IMAGE_REF="$CI_TEMPLATE_REGISTRY_HOST/$IMAGE_NAME:$VERSION"
      echo "Loading TAR..."
      podman load -i "$TAR_NAME"
      echo "Pushing: $IMAGE_REF"
      podman push "$IMAGE_REF" --tls-verify=false
      echo "PUSHED_IMAGE=$IMAGE_REF" >> push.env
      echo "✅ Pushed: $IMAGE_REF"
  artifacts:
    reports:
      dotenv: push.env
    expire_in: 1 week
