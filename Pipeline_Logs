ARG BASE_IMAGE_DEV_ENV
FROM ${BASE_IMAGE_DEV_ENV}

ARG ENV
ARG VERSION

ENV ENV=$ENV
ENV VERSION=$VERSION

COPY ./epaycert.cer  /tmp
COPY ./sms.cer       /tmp

COPY build/libs/epay_reports_service-${VERSION}.jar .

ENTRYPOINT sh -c 'java -jar "epay_reports_service-$VERSION.jar"'

USER root

RUN mkdir -p /home/default/merchantreports && \
    chmod 777 -R /home/default/merchantreports

# Resolve cacerts path dynamically — openjdk-21-runtime (UBI9) stores it at
# /etc/pki/java/cacerts, not /usr/lib/jvm/java-21/lib/security/cacerts.
# -noprompt suppresses the verbose certificate dump and trust prompt entirely.
RUN CACERTS=$(find /usr/lib/jvm -name "cacerts" 2>/dev/null | head -1) && \
    [ -z "$CACERTS" ] && CACERTS=/etc/pki/java/cacerts ; \
    keytool -import -trustcacerts -noprompt \
      -file /tmp/epaycert.cer \
      -keystore "$CACERTS" \
      -alias S3_EPAY_CERT \
      -storepass changeit && \
    keytool -import -trustcacerts -noprompt \
      -file /tmp/sms.cer \
      -keystore "$CACERTS" \
      -alias DEV_EPAY_SMS \
      -storepass changeit
