  script:
    - |
      set -eo pipefail
      export PATH="$CI_PROJECT_DIR:$PATH"
      export COMPOSER_HOME="${CI_PROJECT_DIR}/.composer-home"

      echo "===== SYSTEM INFO ====="
      free -h || true
      df -h   || true

      echo "===== INSTALLING DEPENDENCIES ====="
      composer install \
        --no-dev \
        --optimize-autoloader \
        --no-interaction \
        --prefer-dist \
        --no-scripts \
        --no-source-fallback \
        -vvv

      if [ ! -d "vendor" ]; then
        echo "ERROR: vendor directory not created"
        exit 1
      fi

      echo "Vendor count: $(ls vendor | wc -l)"
      echo "===== BUILD COMPLETE ====="

  artifacts:
    paths:
      - vendor/
    expire_in: 1 day
