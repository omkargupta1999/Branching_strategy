# =============================================================================
#  Governance - VERIFY job  (READ-ONLY)
# =============================================================================
#  Reads the current state of the target repo(s) and prints a compliance
#  report. Makes NO changes to GitLab whatsoever.
#
#  Runs when: RUN_GOVERNANCE=true AND GOV_MODE=verify
#  Safe to run on any branch, at any time.
# =============================================================================

governance:verify:
  extends: .governance_base
  script:
    - 'echo "===== GOVERNANCE VERIFY - read-only ====="'
    - 'python3 "$GOV_SCRIPT" $GOV_FLAG "$GOV_TARGET" --verify'
    - 'echo "===== VERIFY COMPLETE - no changes were made ====="'
  rules:
    - if: '$RUN_GOVERNANCE == "true" && $GOV_MODE == "verify"'
      when: always
    - when: never









