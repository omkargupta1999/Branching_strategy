# templates/ci/backend/java.yml
# ──────────────────────────────────────────────────────────────────────────────
# CI orchestrator for Java/Gradle MICROSERVICE repos (build a container image → OCP).
# For library/utility repos (publish JARs → JFrog), use java.library.yml instead.
#
# App repo .gitlab-ci.yml:
#   include:
#     - project: 'itepaypg-sbiepay2/infra/devops/cicd-templates'
#       ref: main
#       file: 'templates/ci/backend/java.yml'
#   variables:
#     RELEASE_NAME: txn
#     CHART_NAME:   transactionservice
#
# ── Active pipeline today ─────────────────────────────────────────────────────
#   version → build → test → sast(fortify) → image-build → image-push
#           → release(prod tag on main) → deploy(trigger jobs)
#
# SCA, secrets, IaC, license, SBOM, image scanning and image signing are defined
# in this repo but NOT included below; their stage names are commented out of
# `stages:` too. Re-enable the include and the stage together.
#
# ── Stage matrix (source → target) ────────────────────────────────────────────
#   Source     Target            MR pipeline                          Post-merge push
#   ────────── ───────────────── ──────────────────────────────────── ──────────────────────────────
#   feature/*  develop           version,build,test,sast,             same + deploy-dev (AUTO)
#                                image-build,image-push,deploy-dev
#   feature/*  feature/*         version,build,test,sast              same
#   bugfix/*   feature/*         version,build,test,sast              same
#   develop    sit-integration   version,build,test,sast,             same + deploy-sit (AUTO)
#                                image-build,image-push,deploy-sit
#   feature/*  release/*         version,build,test,sast,             same + uat,int,perf,
#   bugfix/*   release/*         image-build,image-push,deploy-uat    pre-prod-dc,pre-prod-dr
#   hotfix/*   main              version,build,test,sast,image-build, same + prod-dc,prod-dr,int
#                                image-push,pre-prod + pre-prod-dc
#   release/*  main              version,build,test,sast,image-build, same + prod-dc,prod-dr,int
#                                image-push,prod-dc,prod-dr,int
#
# All deploy jobs are MANUAL except deploy-dev (develop push) and deploy-sit
# (sit-integration push), which are AUTO. See ci/deploy/deploy.jobs.yml.
#
# ── Branch naming (enforced by the GitLab Push Rule, not by CI) ───────────────
#   main | develop | sit-integration
#   release/(major|minor)-DM<digits>-EPAY-<desc>
#   feature|bugfix|hotfix/EPAY-<digits>-<desc>
# main and sit-integration are protected — MR only, no direct push.
# ──────────────────────────────────────────────────────────────────────────────

