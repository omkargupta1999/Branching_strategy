# ops/drill/drill.maintenance.yml
# Maintenance page ON/OFF — GitOps approach
# Clones deployment repo → updates epay_maintenance_fe/values.yaml → git push → ArgoCD syncs
#
# Called by: templates/cd/deploy.drill.yml
# Trigger:   DRILL_TIER variable set at pipeline run time
#
# What it changes:
#   replicaCount:        1 (ON) or 0 (OFF)
#   maintenance.enabled: true (ON) or false (OFF)
#
# ENV_LIST drives which environments are updated:
#   preprod: pre-prod-dc pre-prod
#
# FIX (v2): Each environment is committed AND pushed independently so that
#   the deployment repo pipeline fires once per environment — not once total.
#   Previously all changes were batched into a single push which caused only
#   the first environment's pipeline to trigger.

.drill_git_setup:
  image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-local/custom-ci/rhelgit-oc-helm:1.0
  tags:
    - common_runner
  variables:
    DEPLOYMENT_BRANCH: "main"
  before_script:
    - git config --global http.sslVerify false
    - git config --global user.name "ci"
    - git config --global user.email "ci.cedge@sbi.co.in"

# ── Shared script — reused by all maintenance jobs via YAML anchor ──────────
# KEY CHANGE: git push is now INSIDE the for-loop, immediately after each
# per-environment commit.  This ensures:
#   • Each push contains exactly ONE environment's changed file.
#   • The deployment repo pipeline fires once per push → once per environment.
#   • A rebase-retry loop guards against concurrent push conflicts.
.maintenance_script: &maintenance_script
  - |
    set -eo pipefail

    git clone "https://oauth2:$GITLAB_CI_DEPLOY_TOKEN@gitlab.sbi/itepaypg-sbiepay2/infra/devops/deployment.git" deployment
    cd deployment
    git checkout "$DEPLOYMENT_BRANCH"

    for TARGET_ENV in $ENV_LIST; do
      FILE="${TARGET_ENV}/charts/${MAINTENANCE_CHART}/values.yaml"
      echo "──────────────────────────────────────────"
      echo "Processing environment : $TARGET_ENV"
      echo "Target file            : $FILE"

      [ -f "$FILE" ] || { echo "ERROR: $FILE not found"; exit 1; }

      # ── Patch replicaCount ──────────────────────────────────────────────
      sed -i -E \
        "s/^([[:space:]]*)replicaCount:.*/\1replicaCount: ${REPLICA_COUNT}/" \
        "$FILE"

      # ── Patch maintenance.enabled ───────────────────────────────────────
      sed -i -E \
        "/^[[:space:]]*maintenance:/,/^[^[:space:]]/ \
         s/^([[:space:]]*)enabled:.*/\1enabled: ${MAINTENANCE_ENABLED}/" \
        "$FILE"

      # ── Commit (only this environment's file) ───────────────────────────
      git add "$FILE"
      if git diff --cached --quiet; then
        echo "No changes detected for ${TARGET_ENV} — skipping commit & push"
        continue
      fi

      git commit \
        -m "drill(${TARGET_ENV}): maintenance=${MAINTENANCE_ENABLED} replicas=${REPLICA_COUNT}"

      # ── Push immediately — one push per env = one pipeline trigger ───────
      # Retry with rebase to handle concurrent pushes from other jobs.
      PUSHED=false
      for i in 1 2 3; do
        if git push origin "$DEPLOYMENT_BRANCH"; then
          PUSHED=true
          break
        fi
        echo "Push attempt $i/3 failed — pulling with rebase and retrying…"
        git pull --rebase origin "$DEPLOYMENT_BRANCH"
        sleep 3
      done

      if [ "$PUSHED" = "false" ]; then
        echo "ERROR: All push attempts failed for ${TARGET_ENV}"
        exit 1
      fi

      echo "✅ Push successful — deployment pipeline triggered for: ${TARGET_ENV}"
    done

    echo "══════════════════════════════════════════"
    echo "✅ Maintenance ${MAINTENANCE_ENABLED} applied to all envs: $ENV_LIST"

# ── Preprod ──────────────────────────────────────────────────────────────────
PreProd_Maintenance_ON:
  extends: .drill_git_setup
  stage: Maintenance_Page
  when: manual
  variables:
    GIT_STRATEGY:        none
    ENV_LIST:            "pre-prod-dc pre-prod"
    REPLICA_COUNT:       "1"
    MAINTENANCE_ENABLED: "true"
  rules:
    - if: '$DRILL_TIER == "preprod"'
  script: *maintenance_script

PreProd_Maintenance_OFF:
  extends: .drill_git_setup
  stage: Maintenance_Page
  when: manual
  variables:
    GIT_STRATEGY:        none
    ENV_LIST:            "pre-prod-dc pre-prod"
    REPLICA_COUNT:       "0"
    MAINTENANCE_ENABLED: "false"
  rules:
    - if: '$DRILL_TIER == "preprod"'
  script: *maintenance_script
