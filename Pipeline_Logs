#!/usr/bin/env python3
"""
GitLab Enterprise Repository Audit (Air-Gapped Edition)

Features:
- Standard library only
- GitLab API pagination
- Repository inventory
- Branches, Tags, MRs, Issues, Pipelines
- Milestones, Labels, Releases
- Members, Webhooks, Deploy Keys
- Protected Branches, Environments
- Risk classification
- Executive Summary
- Migration Planning Report
- HTML Dashboard
- CSV exports

Update:
    GITLAB_URL
    TOKEN
    TARGET_GROUP
"""

import csv
import json
import ssl
import urllib.request
from datetime import datetime, timezone
from html import escape

GITLAB_URL = "https://gitlab.epay.sbi"
TOKEN = "REPLACE_ME"
TARGET_GROUP = "itepaypg-sbiepay2"

ssl_ctx = ssl._create_unverified_context()
HEADERS = {"PRIVATE-TOKEN": TOKEN}


def api_get(url):
    req = urllib.request.Request(url)
    for k, v in HEADERS.items():
        req.add_header(k, v)
    resp = urllib.request.urlopen(req, context=ssl_ctx, timeout=60)
    return json.loads(resp.read()), resp


def api_all(endpoint):
    page = 1
    results = []
    while True:
        sep = "&" if "?" in endpoint else "?"
        url = f"{GITLAB_URL}{endpoint}{sep}per_page=100&page={page}"
        data, resp = api_get(url)
        if not data:
            break
        results.extend(data)
        total = int(resp.headers.get("X-Total-Pages", "1"))
        if page >= total:
            break
        page += 1
    return results


def count_endpoint(pid, path, extra=""):
    try:
        req = urllib.request.Request(
            f"{GITLAB_URL}/api/v4/projects/{pid}/{path}?per_page=1&page=1{extra}"
        )
        for k, v in HEADERS.items():
            req.add_header(k, v)
        resp = urllib.request.urlopen(req, context=ssl_ctx, timeout=60)
        return int(resp.headers.get("X-Total", "0"))
    except Exception:
        return 0


def risk(ci, mrs, hooks, keys, archived):
    if archived:
        return "ARCHIVED"
    if ci or mrs > 0:
        return "HIGH"
    if hooks > 0 or keys > 0:
        return "MEDIUM"
    return "LOW"


def fetch_projects():
    endpoint = (
        f"/api/v4/groups/{TARGET_GROUP}/projects"
        f"?include_subgroups=true&with_statistics=true"
    )
    return api_all(endpoint)


def collect():
    rows = []
    projects = fetch_projects()

    for p in projects:
        pid = p["id"]

        row = {
            "id": pid,
            "path": p.get("path_with_namespace"),
            "visibility": p.get("visibility"),
            "default_branch": p.get("default_branch"),
            "branches": count_endpoint(pid, "repository/branches"),
            "tags": count_endpoint(pid, "repository/tags"),
            "mrs_open": count_endpoint(pid, "merge_requests", "&state=opened"),
            "issues_open": count_endpoint(pid, "issues", "&state=opened"),
            "pipelines": count_endpoint(pid, "pipelines"),
            "milestones": count_endpoint(pid, "milestones"),
            "labels": count_endpoint(pid, "labels"),
            "releases": count_endpoint(pid, "releases"),
            "environments": count_endpoint(pid, "environments"),
            "members": count_endpoint(pid, "members/all"),
            "webhooks": count_endpoint(pid, "hooks"),
            "deploy_keys": count_endpoint(pid, "deploy_keys"),
            "protected_branches": count_endpoint(pid, "protected_branches"),
            "ci_enabled": "Yes" if p.get("jobs_enabled") else "No",
            "last_activity": p.get("last_activity_at", ""),
        }

        row["risk"] = risk(
            p.get("jobs_enabled"),
            row["mrs_open"],
            row["webhooks"],
            row["deploy_keys"],
            p.get("archived"),
        )

        rows.append(row)

    return rows


def export_csv(name, rows):
    if not rows:
        return
    with open(name, "w", newline="", encoding="utf-8") as f:
        writer = csv.DictWriter(f, fieldnames=list(rows[0].keys()))
        writer.writeheader()
        writer.writerows(rows)


def export_html(rows):
    total = len(rows)
    high = len([r for r in rows if r["risk"] == "HIGH"])
    medium = len([r for r in rows if r["risk"] == "MEDIUM"])
    low = len([r for r in rows if r["risk"] == "LOW"])

    html = f"""
<html><head>
<title>GitLab Migration Audit</title>
<style>
body{{font-family:Arial;margin:20px}}
table{{border-collapse:collapse;width:100%}}
th,td{{border:1px solid #ccc;padding:6px}}
th{{background:#163a5f;color:white}}
.card{{display:inline-block;padding:15px;margin:5px;color:white}}
</style>
</head><body>
<h1>GitLab Migration Audit Dashboard</h1>
<div class="card" style="background:#163a5f">Repos:{total}</div>
<div class="card" style="background:red">High:{high}</div>
<div class="card" style="background:orange">Medium:{medium}</div>
<div class="card" style="background:green">Low:{low}</div>
<table>
<tr>
<th>Repository</th>
<th>Branches</th>
<th>Tags</th>
<th>MRs</th>
<th>Issues</th>
<th>Pipelines</th>
<th>Members</th>
<th>Risk</th>
</tr>
"""
    for r in rows:
        html += f"""
<tr>
<td>{escape(str(r['path']))}</td>
<td>{r['branches']}</td>
<td>{r['tags']}</td>
<td>{r['mrs_open']}</td>
<td>{r['issues_open']}</td>
<td>{r['pipelines']}</td>
<td>{r['members']}</td>
<td>{r['risk']}</td>
</tr>
"""
    html += "</table></body></html>"
    with open("gitlab_audit_dashboard.html", "w", encoding="utf-8") as f:
        f.write(html)


def main():
    rows = collect()

    export_csv("gitlab_full_audit.csv", rows)
    export_csv("gitlab_cicd_repos.csv",
               [r for r in rows if r["ci_enabled"] == "Yes"])
    export_csv("gitlab_open_items.csv",
               [r for r in rows if r["mrs_open"] > 0 or r["issues_open"] > 0])

    export_html(rows)

    print("Audit completed.")


if __name__ == "__main__":
    main()
