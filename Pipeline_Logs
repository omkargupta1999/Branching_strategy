apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ .Release.Name }}-{{ .Values.configMap.nameSuffix }}
  namespace: {{ .Release.Namespace }}
  labels:
    {{ include "epaylite-bridge-txn-service.labels" . | nindent 4 }}
{{ if $.Values.configMap.additionalLabels }}
    {{ toYaml $.Values.configMap.additionalLabels | nindent 4 }}
{{ end }}
{{ if $.Values.configMap.annotations }}
  annotations:
    {{ toYaml $.Values.configMap.annotations | nindent 4 }}
{{ end }}
data:
  application.yaml: |
  
    #SERVER CONFIG
    server:
      servlet:
        context-path: /epaylite-bridge-txn-service
      port: 8099  
    spring:
      profiles:
        active: dev
      application:
        name: epaylite-brige-txn-service
    security:
      cors:
        allowed:
          origins: "*"
        origin: "*"
    # Db connectivity
      datasource:
        driver-class-name: oracle.jdbc.OracleDriver
        url: jdbc:oracle:thin:@(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=epaydbscandev.sbiepay.sbi)(PORT=1524))(CONNECT_DATA= (SERVER=DEDICATED) (SERVICE_NAME=epaydbdev.sbiepay.sbi)))
        username: ${DB_USERNAME}
        password: ${DB_PASSWORD}
        hikari:
          maxLifetime: 300000
          idleTimeout: 240000
          keepaliveTime: 120000
      jpa:
        database-platform: org.hibernate.dialect.OracleDialect
        hibernate.ddl-auto: none
        show-sql: false
        properties:
          hibernate:
            format_sql: true
          type:
            preferred_instant_jdbc_type: TIMESTAMP
          jdbc:
            time_zone: UTC
        defer-datasource-initialization: true
      autoconfigure:
        exclude: org.springframework.boot.autoconfigure.security.servlet.SecurityAutoConfiguration,org.springframework.boot.actuate.autoconfigure.security.servlet.ManagementWebSecurityAutoConfiguration  
      main:
        allow-bean-definition-overriding: true
    app:
      redirect:
        baseurl: https://dev.epay.sbi/epaylite-bridge-txn-service
    epay:
      encryption:
        default-key: default-secret-key-32-characters-long
      algorithm: AES
    merchant:
      config:
        cache-enabled: true
        cache-ttl-minutes: 60
    audit:
      enabled: true
      mask-sensitive-data: true
      log-request-payload: true
      log-response-payload: true
    # SBIEpay API Configuration
    sbiepay:
      api:
        base-url: http://txn-transactionservice.dev-transaction.svc.cluster.local:9092
        timeout: 5s
        max-retries: 2
        epay-order-create-url: /api/transaction/v1/order/create
        epay-order-status-url: /api/transaction/v1/order/status
        access-token-url: /api/transaction/v1/token/access
    # Resilience4j Configuration
    resilience4j:
      circuitbreaker:
        instances:
          sbiepayApi:
            registerHealthIndicator: true
            failureRateThreshold: 50
            waitDurationInOpenState: 30s
            slidingWindowSize: 10
            minimumNumberOfCalls: 5
      retry:
        instances:
          sbiepayApi:
            maxAttempts: 3
            waitDuration: 2s
    # Actuator Configuration (for monitoring circuit breakers)
    management:
      endpoints:
        web:
          exposure:
            include: health,info,metrics,prometheus,circuitbreakers
        health:
          show-details: always
      health:
        circuitbreakers:
          enabled: true
      metrics:
        export:
          prometheus:
            enabled: true
    # Swagger/OpenAPI Configuration (Temporarily disabled due to Spring Boot 2.7 compatibility)
    # Access at https://merchant.sbiuat.bank.in/swagger-ui/ once enabled
    springfox:
      documentation:
        enabled: false
        swagger-ui:
          enabled: false   
