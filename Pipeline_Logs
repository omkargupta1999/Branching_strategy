".scale_script":
- |
  set -eo pipefail

  git clone "$DEPLOYMENT_REPO_URL" deployment
  cd deployment
  git checkout "$DEPLOYMENT_BRANCH"

  IFS=',' read -ra SERVICES <<< "$CHARTS"
  CHANGED=false

  for SERVICE in "${SERVICES[@]}"; do
    FILE="${TARGET_ENV}/charts/${SERVICE}/values.yaml"
    echo "Processing: $FILE"
    [ -f "$FILE" ] || { echo "WARNING: $FILE not found — skipping"; continue; }

    sed -i -E \
      "s/^([[:space:]]*)replicaCount:[[:space:]]*[0-9]+/\1replicaCount: ${REPLICA_COUNT}/" \
      "$FILE"
    sed -i -E \
      "/^[[:space:]]*autoscaling:/,/^[^[:space:]]/ \
       s/^([[:space:]]*)enabled:[[:space:]]*(true|false)/\1enabled: ${AUTOSCALING_ENABLED}/" \
      "$FILE"

    if ! git diff --quiet "$FILE"; then
      git add "$FILE"
      CHANGED=true
