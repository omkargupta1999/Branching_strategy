def esc(val):
    """HTML-escape a value for safe table output."""
    return (str(val)
            .replace("&", "&amp;")
            .replace("<", "&lt;")
            .replace(">", "&gt;"))


def risk_badge(risk):
    colours = {
        "HIGH":     ("#FF4C4C", "#7B0000"),
        "MEDIUM":   ("#FFA500", "#5C3300"),
        "LOW":      ("#90EE90", "#1A4D1A"),
        "ARCHIVED": ("#B0B0B0", "#3D3D3D"),
    }
    bg, fg = colours.get(risk, ("#eee", "#333"))
    return (f'<span style="background:{bg};color:{fg};padding:2px 8px;'
            f'border-radius:4px;font-weight:bold;font-size:11px;">{esc(risk)}</span>')


def tbl(headers, rows, row_style_fn=None):
    """Build an HTML table string."""
    out = ['<div style="overflow-x:auto"><table>',
           "<thead><tr>",
           "".join(f"<th>{esc(h)}</th>" for h in headers),
           "</tr></thead><tbody>"]
    for i, row in enumerate(rows):
        bg = "#f8f9fa" if i % 2 == 0 else "#ffffff"
        out.append(f'<tr style="background:{bg}">')
        for j, cell in enumerate(row):
            val = cell
            # Risk column — auto-detect by header or value
            if (str(cell) in ("HIGH", "MEDIUM", "LOW", "ARCHIVED") and
                    str(cell) in ("HIGH", "MEDIUM", "LOW", "ARCHIVED")):
                val = risk_badge(str(cell))
            elif isinstance(cell, int) and cell > 0 and j > 0:
                val = f'<strong>{cell}</strong>'
            else:
                val = esc(str(cell))
            out.append(f"<td>{val}</td>")
        out.append("</tr>")
    out.append("</tbody></table></div>")
    return "".join(out)


