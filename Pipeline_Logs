apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ .Release.Name }}-{{ .Values.configMap.nameSuffix }}
  namespace: {{ .Release.Namespace }}
  labels:
    {{ include "epaylite-bridge-status-service.labels" . | nindent 4 }}
{{ if $.Values.configMap.additionalLabels }}
    {{ toYaml $.Values.configMap.additionalLabels | nindent 4 }}
{{ end }}
{{ if $.Values.configMap.annotations }}
  annotations:
    {{ toYaml $.Values.configMap.annotations | nindent 4 }}
{{ end }}
data:
  application.properties: |
  
    server.servlet.context-path=/epaylite-bridge-status-service
    server.port=8100
    server.ssl.enabled=false
    server.max-http-request-header-size=128KB
    
    security.cors.origin=*
    security.allowed.origins=*
    
    spring.profiles.active=dev
    spring.application.name=/epaylite-bridge-status-service
    
    spring.datasource.url=jdbc:oracle:thin:@(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=epaydbscandev.sbiepay.sbi)(PORT=1524))(CONNECT_DATA= (SERVER=DEDICATED) (SERVICE_NAME=epaydbdev.sbiepay.sbi)))
    spring.datasource.username=${DB_USERNAME}
    spring.datasource.password=${DB_PASSWORD}
    spring.datasource.driver-class-name=oracle.jdbc.OracleDriver
    spring.datasource.hikari.maxLifetime=300000
    spring.datasource.hikari.idleTimeout=240000
    spring.datasource.hikari.keepaliveTime=120000
    spring.jpa.database-platform=org.hibernate.dialect.OracleDialect
    spring.jpa.hibernate.ddl-auto=none
    spring.jpa.show-sql=false
    spring.jpa.properties.hibernate.format_sql=true
    spring.jpa.properties.hibernate.type.preferred_instant_jdbc_type=TIMESTAMP
    spring.jpa.properties.hibernate.jdbc.time_zone=UTC
    spring.jpa.defer-datasource-initialization=true
    spring.autoconfigure.exclude=org.springframework.boot.autoconfigure.security.servlet.SecurityAutoConfiguration,org.springframework.boot.actuate.autoconfigure.security.servlet.ManagementWebSecurityAutoConfiguration
    spring.main.allow-bean-definition-overriding=true
    
    app.redirect.baseurl=https://dev.epay.sbi/epaylite-bridge-txn-service
    
    epay.encryption.default-key=default-secret-key-32-characters-long
    epay.encryption.algorithm=AES
    merchant.config.cache-enabled=true
    merchant.config.cache-ttl-minutes=60
    
    audit.enabled=true
    audit.mask-sensitive-data=true
    audit.log-request-payload=true
    audit.log-response-payload=true
    
    sbiepay.api.base-url=https://uat.epay.sbi
    sbiepay.api.connect-timeout=10000
    sbiepay.api.read-timeout=30000
    sbiepay.api.epayOrderCreateUrl=/api/transaction/v1/order/create
    sbiepay.api.epayOrderStatusUrl=/api/transaction/v1/order/status
    sbiepay.api.accessTokenUrl=/api/transaction/v1/token/access
    
    resilience4j.circuitbreaker.instances.sbiepayApi.registerHealthIndicator=true
    resilience4j.circuitbreaker.instances.sbiepayApi.failureRateThreshold=50
    resilience4j.circuitbreaker.instances.sbiepayApi.waitDurationInOpenState=30s
    resilience4j.circuitbreaker.instances.sbiepayApi.slidingWindowSize=10
    resilience4j.circuitbreaker.instances.sbiepayApi.minimumNumberOfCalls=5
    resilience4j.retry.instances.sbiepayApi.maxAttempts=3
    resilience4j.retry.instances.sbiepayApi.waitDuration=2s
    
    management.endpoints.web.exposure.include=health,info,metrics,prometheus,circuitbreakers
    management.health.circuitbreakers.enabled=true
    management.endpoint.health.show-details=always
    
    springfox.documentation.enabled=false
    springfox.documentation.swagger-ui.enabled=false
    
    adapter.callback.base-url=https://merchant.sbiuat.bank.in/api/legacy/payment
    adapter.callback.endpoint=/payment-redirect-callback
    adapter.callback.session-timeout-minutes=30
    adapter.callback.max-callback-attempts=3
    adapter.callback.enable-ssl-validation=true
    
    payment.session.timeout-minutes=30
    payment.session.max-attempts=3
    payment.session.cleanup-schedule-minutes=60
