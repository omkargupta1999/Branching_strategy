# ── Purpose ───────────────────────────────────────────────────────────────────
# Shared hidden job used by all image lifecycle stages:
#
#   image-build
#   image-scan
#   image-retag
#   image-push
#
# Centralises:
#   • Podman image
#   • Runner tags
#   • Artifactory certificate trust
#   • Podman registry authentication
#   • JFrog CLI configuration
#
# Any change to certificate handling, registry login,
# JFrog CLI setup, or base image is done once here and
# automatically inherited by all image-related stages.
#
# ── Container Image ───────────────────────────────────────────────────────────
# podman-jf:9.7
#
# Contains:
#   • Podman
#   • JFrog CLI
#   • UBI9 base
#
# Used by:
#   • image-build
#   • image-scan
#   • image-retag
#   • image-push
#
# ── Registry TLS Trust ───────────────────────────────────────────────────────
# Internal Artifactory uses SBI internal CA.
#
# Podman requires CA certificate under:
#   /etc/containers/certs.d/<registry-host>/ca.crt
#
# System trust store also updated to ensure:
#   • podman
#   • curl
#   • jfrog cli
# trust the registry endpoint.
#
# CI Variable:
#   ARTIFACTORY_CERT
#
# Type:
#   File variable
#
# ── JFrog CLI Configuration ──────────────────────────────────────────────────
# JFrog CLI configured once and reused by:
#
#   jf scan
#   jf rt
#   jf xr
#
# Credentials sourced from GitLab protected variables:
#
#   JF_URL
#   JF_XRAY_URL
#   JF_USER
#   JF_TOKEN
#
# ── Podman Authentication ────────────────────────────────────────────────────
# Login performed once during before_script.
#
# Required for:
#
#   podman build
#   podman pull
#   podman push
#
# Registry:
#   $CI_TEMPLATE_REGISTRY_HOST
#
# ─────────────────────────────────────────────────────────────────────────────
variables:
  JF_SERVER_ID: "epay-server"

.setup_jfrog_podman:
  image: artifactory.jfrog.sbi:443/dso-docker-base-images/ubi9/podman-jf:9.7

  tags:
    - common_runner

  before_script:

    # ── Configure Podman Registry Trust ──────────────────────────────────────
    - mkdir -p /etc/containers/certs.d/${CI_TEMPLATE_REGISTRY_HOST}

    - cp "$ARTIFACTORY_CERT" /etc/containers/certs.d/${CI_TEMPLATE_REGISTRY_HOST}/ca.crt

    # ── Configure System Trust Store ─────────────────────────────────────────
    - cp "$ARTIFACTORY_CERT" /etc/pki/ca-trust/source/anchors/artifactory.crt

    - update-ca-trust extract

    # ── Configure JFrog CLI Certificate Trust ────────────────────────────────
    - mkdir -p ~/.jfrog/security/certs

    - cp "$ARTIFACTORY_CERT" ~/.jfrog/security/certs/artifactory.crt

    # ── Registry Authentication ──────────────────────────────────────────────
    - podman login "$CI_TEMPLATE_REGISTRY_HOST" -u "$JF_USER" -p "$JF_TOKEN"

    # ── Configure JFrog CLI ──────────────────────────────────────────────────
    - |
      jf config add \
        --url="$JF_URL" \
        --xray-url="$JF_XRAY_URL" \
        --user="$JF_USER" \
        --access-token="$JF_TOKEN" \
        --interactive=false \
        "$JF_SERVER_ID"

    - jf config use "$JF_SERVER_ID"

    # ── Verify JFrog CLI Configuration ──────────────────────────────────────
    - jf config show


