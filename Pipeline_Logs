ARG BASE_IMAGE_DEV_ENV
FROM ${BASE_IMAGE_DEV_ENV}

ARG ENV
ARG VERSION

ENV ENV=$ENV
ENV VERSION=$VERSION

# FIX 1: Relative path (no leading /)
COPY build/libs/epay_merchant_service-${VERSION}.jar .

ENTRYPOINT sh -c 'java -jar "epay_merchant_service-$VERSION.jar"'

COPY ./sms.cer /tmp

USER root

RUN mkdir -p /home/default/merchantreports && \
    chmod 777 -R /home/default/merchantreports

# FIX 2: Removed "RUN cd ..." (no-op in Dockerfile, path doesn't exist anyway)
# FIX 3: Dynamic cacerts resolution — openjdk-21-runtime (UBI9) uses /etc/pki/java/cacerts
# FIX 4: -noprompt suppresses verbose certificate dump in build logs
RUN CACERTS=$(find /usr/lib/jvm -name "cacerts" 2>/dev/null | head -1) && \
    [ -z "$CACERTS" ] && CACERTS=/etc/pki/java/cacerts ; \
    keytool -import -trustcacerts -noprompt \
      -file /tmp/sms.cer \
      -keystore "$CACERTS" \
      -alias DEV_EPAY_SMS \
      -storepass changeit
