ARG BASE_IMAGE_DEV_ENV
FROM ${BASE_IMAGE_DEV_ENV}

ARG ENV
ARG VERSION

ENV ENV=$ENV
ENV VERSION=$VERSION

COPY ./epaycert.cer  /tmp
COPY ./sms.cer  /tmp

COPY build/libs/epay_reports_service-${VERSION}.jar .

ENTRYPOINT sh -c 'java -jar "epay_reports_service-$VERSION.jar"'

USER root

RUN mkdir -p /home/default/merchantreports && \
    chmod 777 -R /home/default/merchantreports

# On UBI9 openjdk-21-runtime, cacerts lives at /etc/pki/java/cacerts.
# /usr/lib/jvm/java-21/lib/security/cacerts does NOT exist in runtime images.
# We resolve the real path dynamically so this works across any minor version bump.
RUN CACERTS=$(find /usr/lib/jvm -name "cacerts" 2>/dev/null | head -1) && \
    [ -z "$CACERTS" ] && CACERTS=/etc/pki/java/cacerts && \
    echo "Using cacerts at: $CACERTS" && \
    yes | keytool -import -trustcacerts \
      -file /tmp/epaycert.cer \
      -keystore "$CACERTS" \
      -alias S3_EPAY_CERT \
      -storepass changeit && \
    yes | keytool -import -trustcacerts \
      -file /tmp/sms.cer \
      -keystore "$CACERTS" \
      -alias DEV_EPAY_SMS \
      -storepass changeit
