# cd/publish/values.update.yml
# Stage: publish
# Updates image tag in deployment repo values.yaml â€” git commit + push
# Runs in DEPLOYMENT REPO pipeline (triggered from app repo CI)
# Migrated from: cd/commit/commit.yml (renamed: commit â†’ publish, update-tag â†’ values:update)
.update_tag:
  stage: publish
  tags:
    - deploy_runner
  image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-local/custom-ci/rhelgit-oc-helm:1.0
  before_script:
    - git config --global http.sslVerify false
    - git config --global --add safe.directory '*'
    - git config --global user.name "ci"
    - git config --global user.email "ci.cedge@sbi.co.in"
    - git remote set-url origin "https://oauth2:$GITLAB_CI_DEPLOY_TOKEN@gitlab.sbi/$CI_PROJECT_PATH.git"
  script:
    - |
      set -eo pipefail
      echo "========== DEBUG =========="
      echo "SERVICE_NAME=$SERVICE_NAME"
      echo "ENV=$ENV"
      echo "VERSION=$VERSION"
      echo "CHART_NAME=$CHART_NAME"
      echo "RELEASE_NAME=$RELEASE_NAME"
      echo "==========================="

      if [ -z "$SERVICE_NAME" ] || \
         [ -z "$ENV" ] || \
         [ -z "$VERSION" ]; then
        echo "ERROR: Required variables missing"
        exit 1
      fi

      
      TAG=$VERSION
      SERVICE_PATH="${ENV}/charts/${SERVICE_NAME}"
      echo "Updating $SERVICE_PATH/values.yaml â†’ image tag: $TAG"
      echo "SERVICE_PATH=$SERVICE_PATH"
      ls -ltrh $SERVICE_PATH
      git fetch origin ##
      git checkout $CI_COMMIT_BRANCH ##
      # retry rebase
      for i in 1 2 3; do
        git pull --rebase origin $CI_COMMIT_BRANCH && break 
        echo "Rebase failed...retrying ($i)"
        sleep 2
        if [ $i -eq 3 ]; then
        echo "Rebase failed after retries"
        exit 1
        fi
      done
      #git fetch
      #git checkout $CI_COMMIT_BRANCH
      # Anchor to start-of-line so ONLY the active "tag:" line is rewritten and
      # commented "#tag:" decoy lines are left untouched. This keeps each commit
      # to a single-line diff, which is what makes GitLab web "Revert" work
      # cleanly for the most recent deploy of a service.
      sed -i -E "s|^([[:space:]]*)tag:[[:space:]].*|\1tag: \"${TAG}\"|" "$SERVICE_PATH/values.yaml"
      git add $SERVICE_PATH/values.yaml
      if [[ $(git status --porcelain) ]]; then
        git commit -m "chore: update image tag to $TAG [skip ci]"
        for i in 1 2 3; do
          git push origin $CI_COMMIT_BRANCH && break
          echo "Push failed...retrying ($i)"
          sleep 2
          git pull --rebase origin $CI_COMMIT_BRANCH
          if [ $i -eq 3 ]; then
            echo "Push failed after retries"
            exit 1
          fi
        done
        echo "âś… values.yaml updated: $SERVICE_PATH â†’ $TAG"
      else
        echo "No changes â€” image tag already $TAG"
      fi
      cat $SERVICE_PATH/values.yaml
