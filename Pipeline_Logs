#!/usr/bin/env python3
"""
=============================================================================
 Script      : fetch_repo_tree.py
 Purpose     : Fetch all repository names and their full paths from GitLab
               and display them in a structured tree format.

 READ-ONLY   : ONLY HTTP GET requests. Zero writes to GitLab.

 Dependencies: NONE — Python standard library only (no pip required)
               Works on Python 3.6+ / RHEL air-gapped environment.

 Output      :
   Console   — Live tree printed to terminal
   repo_tree_<timestamp>.txt  — Tree structure (plain text)
   repo_list_<timestamp>.csv  — Flat list with path details

 Usage       :
   1. Set TOKEN and TARGET_GROUP below.
   2. python3 fetch_repo_tree.py
=============================================================================
"""

import urllib.request
import urllib.error
import json
import csv
import ssl
import sys
import os
from datetime import datetime

# =============================================================================
#  CONFIGURATION — Edit only this block
# =============================================================================

GITLAB_URL   = "https://gitlab.epay.sbi"   # Source GitLab instance
TOKEN        = ""                            # Admin PAT (glpat-...)

# Set to your group path to scope, or "" for ALL projects instance-wide
TARGET_GROUP = "itepaypg-sbiepay2"

# =============================================================================
#  SETUP
# =============================================================================

if not TOKEN:
    print("[ERROR] TOKEN is not set. Fill in your admin Personal Access Token.")
    sys.exit(1)

TIMESTAMP = datetime.now().strftime("%Y%m%d_%H%M%S")
HEADERS   = {"PRIVATE-TOKEN": TOKEN}
ssl_ctx   = ssl._create_unverified_context()

# =============================================================================
#  API HELPERS — GET ONLY
# =============================================================================

def api_get(url):
    """Single HTTP GET. No data= body = never a POST."""
    req = urllib.request.Request(url)      # GET — no data parameter
    for k, v in HEADERS.items():
        req.add_header(k, v)
    try:
        resp = urllib.request.urlopen(req, context=ssl_ctx)
        return json.loads(resp.read()), resp
    except urllib.error.HTTPError as e:
        if e.code == 401:
            print("\n[ERROR] 401 Unauthorized — TOKEN invalid or empty.")
            sys.exit(1)
        if e.code == 403:
            print("\n[ERROR] 403 Forbidden — token lacks admin scope.")
            sys.exit(1)
        if e.code == 404:
            print(f"\n[ERROR] 404 Not Found — check TARGET_GROUP value.")
            sys.exit(1)
        return [], None
    except Exception as e:
        print(f"\n[WARN] {url} — {e}")
        return [], None


def api_all(endpoint):
    """Paginate all pages of a GET endpoint. Returns full list."""
    results, page = [], 1
    while True:
        sep  = "&" if "?" in endpoint else "?"
        url  = f"{GITLAB_URL}{endpoint}{sep}per_page=100&page={page}"
        data, resp = api_get(url)
        if not data:
            break
        results.extend(data)
        if resp:
            try:
                total = int(resp.headers.get("X-Total-Pages", "1"))
                if page >= total:
                    break
            except ValueError:
                break
        page += 1
    return results


# =============================================================================
#  FETCH PROJECTS
# =============================================================================

print("=" * 65)
print("  GitLab Repository Tree")
print(f"  Source : {GITLAB_URL}")
print(f"  Group  : {TARGET_GROUP or 'ALL (instance-wide)'}")
print("=" * 65)
print()

if TARGET_GROUP:
    ep = (f"/api/v4/groups/{TARGET_GROUP}/projects"
          f"?include_subgroups=true&with_statistics=false")
else:
    ep = "/api/v4/projects"

print("Fetching repositories ...")
projects = api_all(ep)

if not projects:
    print("[ERROR] No projects returned. Check TOKEN and TARGET_GROUP.")
    sys.exit(1)

print(f"  → {len(projects)} repositories found.\n")

# =============================================================================
#  BUILD NAMESPACE TREE
#  Structure:  { "group/subgroup": [ {id, name, path, ...}, ... ] }
# =============================================================================

tree = {}   # namespace_path -> list of projects

for p in projects:
    ns = p.get("namespace", {}).get("full_path", "unknown")
    if ns not in tree:
        tree[ns] = []
    tree[ns].append({
        "id":            p.get("id"),
        "name":          p.get("name", ""),
        "path":          p.get("path", ""),
        "full_path":     p.get("path_with_namespace", ""),
        "visibility":    p.get("visibility", ""),
        "default_branch":p.get("default_branch") or "N/A",
        "archived":      p.get("archived", False),
        "empty":         p.get("empty_repo", False),
        "last_activity": (p.get("last_activity_at") or "")[:10],
        "http_url":      p.get("http_url_to_repo", ""),
        "ssh_url":       p.get("ssh_url_to_repo", ""),
        "description":   (p.get("description") or "").strip(),
    })

# Sort namespaces and repos within each namespace
sorted_ns = sorted(tree.keys())
for ns in sorted_ns:
    tree[ns].sort(key=lambda r: r["name"].lower())

# =============================================================================
#  RENDER TREE — Console + Text file
# =============================================================================

TREE_FILE = f"repo_tree_{TIMESTAMP}.txt"

lines = []   # collected for both console and file

def add(line=""):
    lines.append(line)
    print(line)


# Header
add("=" * 65)
add(f"  GITLAB REPOSITORY TREE")
add(f"  Source  : {GITLAB_URL}")
add(f"  Group   : {TARGET_GROUP or 'ALL (instance-wide)'}")
add(f"  Total   : {len(projects)} repositories")
add(f"  Groups  : {len(sorted_ns)} namespaces")
add(f"  Generated: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
add("=" * 65)
add()

# Tree rendering
for ns_idx, ns in enumerate(sorted_ns):
    repos     = tree[ns]
    is_last_ns = (ns_idx == len(sorted_ns) - 1)

    # ── Namespace header ──────────────────────────────────────────
    ns_connector = "└── " if is_last_ns else "├── "
    add(f"{ns_connector}[{ns}]  ({len(repos)} repo{'s' if len(repos) != 1 else ''})")

    ns_prefix = "    " if is_last_ns else "│   "

    for repo_idx, r in enumerate(repos):
        is_last_repo = (repo_idx == len(repos) - 1)
        repo_connector = "└── " if is_last_repo else "├── "

        # Flags
        flags = []
        if r["archived"]: flags.append("ARCHIVED")
        if r["empty"]:    flags.append("EMPTY")
        flag_str = f"  [{', '.join(flags)}]" if flags else ""

        # Visibility icon
        vis = {"public": "🌐", "internal": "🔒", "private": "🔐"}.get(
            r["visibility"], "")

        # Main repo line
        add(f"{ns_prefix}{repo_connector}{r['name']}{flag_str}")

        # Detail lines under each repo
        repo_prefix = ns_prefix + ("    " if is_last_repo else "│   ")

        add(f"{repo_prefix}├─ ID          : {r['id']}")
        add(f"{repo_prefix}├─ Path        : {r['full_path']}")
        add(f"{repo_prefix}├─ Branch      : {r['default_branch']}")
        add(f"{repo_prefix}├─ Visibility  : {r['visibility']}")
        add(f"{repo_prefix}├─ Last Active : {r['last_activity'] or 'N/A'}")
        add(f"{repo_prefix}├─ HTTP URL    : {r['http_url']}")
        add(f"{repo_prefix}└─ SSH URL     : {r['ssh_url']}")
        if r["description"]:
            add(f"{repo_prefix}   Description : {r['description'][:80]}")
        add(f"{repo_prefix}")

    add()

# Footer summary
add("=" * 65)
add(f"  SUMMARY")
add("=" * 65)
add(f"  {'Total Repositories':<28}: {len(projects)}")
add(f"  {'Total Namespaces':<28}: {len(sorted_ns)}")
add(f"  {'Archived Repos':<28}: {sum(1 for p in projects if p.get('archived'))}")
add(f"  {'Empty Repos':<28}: {sum(1 for p in projects if p.get('empty_repo'))}")
add(f"  {'Private':<28}: {sum(1 for p in projects if p.get('visibility')=='private')}")
add(f"  {'Internal':<28}: {sum(1 for p in projects if p.get('visibility')=='internal')}")
add(f"  {'Public':<28}: {sum(1 for p in projects if p.get('visibility')=='public')}")
add("=" * 65)
add()

# Namespace breakdown
add("  REPOS PER NAMESPACE")
add("-" * 65)
for ns in sorted_ns:
    count = len(tree[ns])
    bar   = "█" * count
    add(f"  {ns:<45} {count:>3}  {bar}")
add()

# Write tree to text file
with open(TREE_FILE, "w", encoding="utf-8") as f:
    f.write("\n".join(lines))

print(f"  → {TREE_FILE} written.")

# =============================================================================
#  FLAT CSV — one row per repo
# =============================================================================

CSV_FILE = f"repo_list_{TIMESTAMP}.csv"

CSV_HEADERS = [
    "Sr.",
    "Project ID",
    "Repository Name",
    "Full Path",
    "Namespace / Group",
    "Visibility",
    "Default Branch",
    "Last Activity",
    "Archived",
    "Empty Repo",
    "Description",
    "HTTP URL",
    "SSH URL",
]

csv_rows = []
sr = 1
sr = 1
for ns in sorted_ns:
    for r in tree[ns]:
        csv_rows.append([
            sr,
            r["id"],
            r["name"],
            r["full_path"],
            ns,
            r["visibility"],
            r["default_branch"],
            r["last_activity"],
            "Yes" if r["archived"] else "No",
            "Yes" if r["empty"]    else "No",
            r["description"],
            r["http_url"],
            r["ssh_url"],
        ])
        sr += 1

with open(CSV_FILE, "w", newline="", encoding="utf-8") as f:
    w = csv.writer(f)
    w.writerow(CSV_HEADERS)
    w.writerows(csv_rows)

print(f"  → {CSV_FILE} written.")

# =============================================================================
#  DONE
# =============================================================================

print()
print("=" * 65)
print("  OUTPUT FILES")
print(f"  {TREE_FILE:<40} Tree structure")
print(f"  {CSV_FILE:<40} Flat CSV list")
print()
print("  READ-ONLY: No changes made to GitLab.")
print("=" * 65)
