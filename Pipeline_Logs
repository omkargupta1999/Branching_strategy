  stage: build
  image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-local/custom-ci/gradle-9.3.0-jdk-21:1.24-2.1776357031
  #image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-virtual/custom-ci/epay-build-java-gradle:1.0.0
  #image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-local/custom-ci/epay-build-java:1.0.0
  tags:
    - common_runner
  variables:
    GRADLE_OPTS:      "-Dorg.gradle.daemon=false"
    GRADLE_USER_HOME: "${CI_PROJECT_DIR}/.gradle"
    # GRADLE_USER_HOME keeps Gradle metadata inside project dir (predictable path)
    # Not cached — JFrog Artifactory on LAN is fast enough for air-gap environment
  before_script:
     - java -version
     - gradle --version
    # # ── Trust JFrog internal CA ────────────────────────────────────────────
    # # update-ca-trust on UBI9 updates OS + Java trust stores simultaneously
    # # $JAVA_HOME/lib/security/cacerts symlinked to /etc/pki/java/cacerts on RHEL/UBI
    # - cp "$ARTIFACTORY_CERT" /etc/pki/ca-trust/source/anchors/jfrog-internal.crt
    # - update-ca-trust extract
    # ── JVM / Gradle ─────────────────────────────────────────────────────────────
    # JVM has no SSL_CERT_FILE env var — needs explicit truststore
    # Approach: copy default cacerts to /tmp (readable) → add JFrog cert → point JVM to /tmp copy
    # ── JVM / Gradle ─────────────────────────────────────────────────────────────
    # JVM has no SSL_CERT_FILE env var — needs explicit truststore
    # Approach: copy default cacerts to /tmp (readable) → add JFrog cert → point JVM to /tmp copy
     - cp "$JAVA_HOME/lib/security/cacerts" /tmp/cacerts-custom
     - keytool -importcert \
        -keystore /tmp/cacerts-custom \
        -storepass changeit \
        -alias jfrog-internal \
        -file "$ARTIFACTORY_CERT" \
        -noprompt 2>/dev/null || true 
        # || true = idempotent if alias exists
     - export GRADLE_OPTS="-Djavax.net.ssl.trustStore=/tmp/cacerts-custom -Djavax.net.ssl.trustStorePassword=changeit"
    # /tmp is always writable by any user ✅
    # keytool is in epay-build-java image ✅
    
  script:
    - |
      set -eo pipefail

      # ── Validate VERSION ──────────────────────────────────────────────────
      if [ -z "$VERSION" ]; then
        echo "❌ ERROR: VERSION is empty — semver.yml dotenv artifact not loaded"
        echo "   Check: semver.yml is included before java.gradle.yml in orchestrator"
        exit 1
      fi
      echo "Building VERSION: ${VERSION}"

      # ── Gradle build ──────────────────────────────────────────────────────
      # Dependencies resolved from JFrog via settings.gradle in app repo
      # -x test: unit tests run separately in test stage (java.unit.yml)
      # -Pversion: sets project version used in bootJar archiveFileName
      gradle build -x test -Pversion="${VERSION}"

      # Alternative (jf gradle — needs epay-jf image with jf config):
      # jf gradle build -x test -Pversion="${VERSION}"

      # ── Verify output ─────────────────────────────────────────────────────
      echo "Build output:"
      ls -lh build/libs/

      if [ -z "$(ls -A build/libs/*.jar 2>/dev/null)" ]; then
        echo "❌ ERROR: No JAR found in build/libs/ — build may have failed silently"
        exit 1
      fi

      # ── Build metadata for downstream stages ─────────────────────────────
      # JAR_FILE: consumed by image-build for COPY instruction
      # BUILD_TIME: consumed by image-build for OCI labels
      JAR_FILE=$(ls build/libs/*.jar | grep -v plain | head -1)
      echo "JAR_FILE=${JAR_FILE}"                      >> build.env
      echo "BUILD_TIME=$(date -u +%Y-%m-%dT%H:%M:%SZ)"  >> build.env

  artifacts:
    paths:
      - build/libs/
    reports:
      dotenv: build.env
    when: on_success
    expire_in: 1 day

