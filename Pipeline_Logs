# ci/image/image.build.yml  |  Stage: image-build
# Podman build — LOCAL ONLY. No push to registry until scan + sign pass.
# Image pushed in image.push.yml after image-scan and image-attest stages complete.

include:
  - local: ci/image/image.podman.setup.yml

.image_build:
  extends: .setup_jfrog_podman
  stage: image-build
  allow_failure: false
  script:
    - |
      echo "VERSION=$VERSION"

      # CHANGE: support both backend + frontend
      if [ -d "build/libs" ]; then
        echo "Backend build detected"
        ls -l build/libs
      elif [ -d "dist" ]; then
        echo "Frontend build detected"
        ls -l dist
      elif [ -f "app.py" ]; then
        echo "Python app detected"
        ls -l app.py
      elif [ -d "vendor" ]; then
        echo "PHP build detected"
        echo "Vendor packages: $(ls vendor | wc -l)"
      else
        echo "No build output found"
        exit 1
      fi

      TAG="$VERSION"
      echo "Generated Tag.. ${TAG}"
      COMPUTED_IMAGE_TAG="$CI_TEMPLATE_REGISTRY_HOST/$IMAGE_NAME:$TAG"
      echo "Image: $COMPUTED_IMAGE_TAG"
      echo "TAG=${TAG}" >> image.env
      echo "VERSION=$VERSION" >> image.env
      echo "COMPUTED_IMAGE_TAG=$COMPUTED_IMAGE_TAG" >> image.env
      echo "IMAGE_NAME=$IMAGE_NAME" >> image.env
      echo "BASE_IMAGE_DEV_ENV=$BASE_IMAGE_DEV_ENV" >> image.env

      podman build \
        -t "$COMPUTED_IMAGE_TAG" \
        -f Dockerfile \
        --build-arg ENV=$ENV \
        --build-arg VERSION=$TAG \
        --build-arg BASE_IMAGE_DEV_ENV=$BASE_IMAGE_DEV_ENV \
        --tls-verify=false
      TAR_NAME="$CI_PROJECT_NAME.tar"
      podman save -o "${TAR_NAME}" "${COMPUTED_IMAGE_TAG}"
      echo "Image built and saved to $TAR_NAME"
      echo "TAR_NAME=$TAR_NAME" >> image.env
    # - echo "IMAGE_FULL=$CI_TEMPLATE_REGISTRY_HOST/$IMAGE_NAME:$VERSION" >> image.env
    # - echo " Build complete — NOT pushed yet. Awaiting scan + sign."
  artifacts:
    paths:
      - "*.tar"
    reports:
      dotenv: image.env
    expire_in: 1 day

image:build:
  extends: .image_build
  # ## Added below rule so that image build stage should stop on direct push to feature and bugfix
  rules:
    # Any MR targeting a feature branch — no image is built
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event" &&
            $CI_MERGE_REQUEST_TARGET_BRANCH_NAME =~ /^feature(\/.*)*$/'
      when: never
    # Skip building an image for direct pushes to feature and bugfix branches
    - if: '$CI_PIPELINE_SOURCE == "push" && $CI_COMMIT_BRANCH =~ /^(feature|bugfix|hotfix)(\/.*)*$/'
      when: never
    # EXCEPTION FIRST: hotfix/* → main MR still builds (needs the pre-prod smoke
    # image before merge). This rule is placed BEFORE the release/main block so
    # hotfix matches here and never reaches the block below.
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event" &&
            $CI_MERGE_REQUEST_TARGET_BRANCH_NAME == "main" &&
            $CI_MERGE_REQUEST_SOURCE_BRANCH_NAME =~ /^hotfix\/.*$/'
      when: on_success
    # MR into release/* or main → run ONLY up to sast; the candidate/prod image
    # is built on the POST-MERGE push, not on the MR. (hotfix already allowed above)
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event" &&
            $CI_MERGE_REQUEST_TARGET_BRANCH_NAME =~ /^(main|release)(\/.*)*$/'
      when: never
    # MR into develop / sit-integration
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event" &&
            $CI_MERGE_REQUEST_TARGET_BRANCH_NAME =~ /^(develop|sit-integration)$/'
      when: on_success
    # Branch pushes (feature/* already excluded above)
    - if: '$CI_COMMIT_BRANCH =~ /^(main|develop|sit-integration|release|hotfix|bugfix)(\/.*)*$/'
      when: on_success
    - when: never
