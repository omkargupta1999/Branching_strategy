# EXCEL REPORT
# ─────────────────────────────────────────────
def write_excel(all_results, drift_records, orphan_records, board_results,
                src_ver, tgt_ver, missing_epics_detail):
    if not EXCEL_AVAILABLE:
        print("[WARN] openpyxl not available — skipping Excel output.")
        return None

    path = OUTPUT_DIR / f"epic_migration_report_{RUN_TS}.xlsx"
    wb   = openpyxl.Workbook()

    # ── colour palette ──────────────────────────────
    RED    = PatternFill("solid", fgColor="FF4C4C")
    AMBER  = PatternFill("solid", fgColor="FFA500")
    GREEN  = PatternFill("solid", fgColor="70AD47")
    BLUE   = PatternFill("solid", fgColor="1F4E79")
    LBLUE  = PatternFill("solid", fgColor="BDD7EE")
    GREY   = PatternFill("solid", fgColor="F2F2F2")
    WHITE_FONT = Font(color="FFFFFF", bold=True)
    BOLD   = Font(bold=True)

    def hdr_row(ws, row_num, values, fill=BLUE):
        for col, val in enumerate(values, 1):
            c = ws.cell(row=row_num, column=col, value=val)
            c.fill = fill
            c.font = WHITE_FONT
            c.alignment = Alignment(horizontal="center", wrap_text=True)

    def auto_width(ws, min_w=12, max_w=60):
        for col in ws.columns:
            length = max(len(str(c.value or "")) for c in col)
            ws.column_dimensions[get_column_letter(col[0].column)].width = \
                min(max(length + 2, min_w), max_w)

    # ── Sheet 1: Summary ─────────────────────────────
    ws = wb.active
    ws.title = "Summary"
    ws.merge_cells("A1:H1")
    title_cell = ws["A1"]
    title_cell.value = "GitLab Epic Migration Validation Report — SBIePay ITEPAYPG-SBIePay2"
    title_cell.fill = BLUE
    title_cell.font = Font(color="FFFFFF", bold=True, size=13)
    title_cell.alignment = Alignment(horizontal="center")
    ws.row_dimensions[1].height = 28

    meta = [
        ("Run Timestamp",      RUN_TS),
        ("Source GitLab",      SOURCE_URL),
        ("Target GitLab",      TARGET_URL),
        ("Source Version",     src_ver),
        ("Target Version",     tgt_ver),
        ("Source Top Group",   SOURCE_TOP_GROUP),
        ("Target Top Group",   TARGET_TOP_GROUP),
    ]
    for r, (k, v) in enumerate(meta, 3):
        ws.cell(row=r, column=1, value=k).font = BOLD
        ws.cell(row=r, column=2, value=v)

    ws.cell(row=10, column=1, value="Group").font = BOLD
    hdr_row(ws, 11,
            ["Group", "Src Total", "Tgt Total", "Src Open", "Tgt Open",
             "Src Closed", "Tgt Closed", "Status"])

    for r, res in enumerate(all_results, 12):
        ok = res["count_match"] and not res["missing_iids"]
        status = "✅ OK" if ok else ("⚠ DRIFT" if res["drift"] else "❌ MISSING")
        fill = GREEN if ok else (AMBER if res["drift"] else RED)
        vals = [res["group"], res["src_total"], res["tgt_total"],
                res["src_open"], res["tgt_open"],
                res["src_closed"], res["tgt_closed"], status]
        for col, val in enumerate(vals, 1):
            c = ws.cell(row=r, column=col, value=val)
            if col == 8:
                c.fill = fill
                c.font = Font(bold=True)
    auto_width(ws)

    # ── Sheet 2: Missing Epics ───────────────────────
    ws2 = wb.create_sheet("Missing Epics")
    hdr_row(ws2, 1, ["Group", "Missing IIDs (source has, target missing)", "Source Epic Count", "Target Epic Count"])
    r = 2
    for res in all_results:
        if res["missing_iids"]:
            ws2.cell(row=r, column=1, value=res["group"])
            ws2.cell(row=r, column=2, value=str(res["missing_iids"]))
            ws2.cell(row=r, column=3, value=res["src_total"])
            ws2.cell(row=r, column=4, value=res["tgt_total"])
            for col in range(1, 5):
                ws2.cell(row=r, column=col).fill = RED if res["missing_iids"] else GREY
            r += 1
    if r == 2:
        ws2.cell(row=2, column=1, value="✅ No missing epics detected").fill = GREEN
    for row in missing_epics_detail:
        ws2.append([row.get("group"), row.get("iid"), row.get("title"),
                    row.get("state"), row.get("created_at")])
    auto_width(ws2)

    # ── Sheet 3: Attribute Drift ─────────────────────
    ws3 = wb.create_sheet("Attribute Drift")
    hdr_row(ws3, 1, ["Group", "Epic IID", "Title", "Drift Description"])
    for r, d in enumerate(drift_records, 2):
        ws3.cell(row=r, column=1, value=d["group"])
        ws3.cell(row=r, column=2, value=d["epic_iid"])
        ws3.cell(row=r, column=3, value=d["title"])
        ws3.cell(row=r, column=4, value=d["drift"])
        ws3.cell(row=r, column=4).fill = AMBER
    if not drift_records:
        ws3.cell(row=2, column=1, value="✅ No attribute drift detected").fill = GREEN
    auto_width(ws3)

    # ── Sheet 4: Orphaned Epics ──────────────────────
    ws4 = wb.create_sheet("Orphaned Epics")
    hdr_row(ws4, 1, ["Group", "Epic IID", "Title", "Orphan parent_id", "Issue"])
    for r, o in enumerate(orphan_records, 2):
        ws4.cell(row=r, column=1, value=o["group"])
        ws4.cell(row=r, column=2, value=o["epic_iid"])
        ws4.cell(row=r, column=3, value=o["title"])
        ws4.cell(row=r, column=4, value=o["parent_id"])
        ws4.cell(row=r, column=5, value=o["issue"])
        for c in range(1, 6):
            ws4.cell(row=r, column=c).fill = RED
    if not orphan_records:
        ws4.cell(row=2, column=1, value="✅ No orphaned epics detected").fill = GREEN
    auto_width(ws4)

    # ── Sheet 5: Epic Boards ─────────────────────────
    ws5 = wb.create_sheet("Epic Boards")
    hdr_row(ws5, 1, ["Group", "Src Board Count", "Tgt Board Count", "Missing Boards", "Extra Boards"])
    for r, b in enumerate(board_results, 2):
        ws5.cell(row=r, column=1, value=b["group"])
        ws5.cell(row=r, column=2, value=b["src_count"])
        ws5.cell(row=r, column=3, value=b["tgt_count"])
        ws5.cell(row=r, column=4, value=str(b["missing"]) if b["missing"] else "—")
        ws5.cell(row=r, column=5, value=str(b["extra"])   if b["extra"]   else "—")
        status_fill = RED if b["missing"] else GREEN
        ws5.cell(row=r, column=4).fill = status_fill
    auto_width(ws5)

    # ── Sheet 6: Root Cause Matrix ───────────────────
    ws6 = wb.create_sheet("Root Cause Matrix")
    hdr_row(ws6, 1, ["#", "Symptom", "Probable Cause", "Validation Command", "Remediation"])
    matrix = [
        (1, "Epic count mismatch",
         "Epics not included in group export if exported at project level only",
         "GET /groups/:id/epics on both instances",
         "Re-export at group level with subgroups; use Direct Transfer API"),
        (2, "Epic hierarchy broken / parent_id null",
         "GitLab Export/Import resets parent_id for cross-group parents; known limitation",
         "Compare parent_id fields via API on both instances",
         "Re-link parent epics manually via API or UI post-migration"),
        (3, "Epic boards missing",
         "Epic boards are NOT included in GitLab Export/Import — documented limitation",
         "GET /groups/:id/epic_boards on target (expect 0 or default)",
         "Recreate boards manually or via API script on target"),
        (4, "Orphaned epics (parent set but parent missing)",
         "Parent epic not migrated; cross-group parent reference broke",
         "Run orphan detection script on target group",
         "Identify and migrate missing parent epics; re-link"),
        (5, "Epic labels missing",
         "Group-level labels may not fully migrate with Export/Import",
         "GET /groups/:id/labels on both; diff label names",
         "Create missing labels via POST /groups/:id/labels on target"),
        (6, "Epic milestones lost",
         "Group milestones may not carry over; milestone IDs differ across instances",
         "GET /groups/:id/milestones diff; check epic.milestone field",
         "Re-create milestones on target; re-assign to epics via API"),
        (7, "Epic-issue links missing",
         "Epic-issue associations may not migrate correctly",
         "GET /groups/:id/epics/:iid/issues on both; compare counts",
         "Re-add issues to epics via POST /groups/:id/epics/:iid/issues"),
        (8, "Epics converted to Work Items on target",
         "GitLab 17.x converting Epics to Work Items; different API path",
         "Check if /groups/:id/work_items contains migrated epics",
         "Use Work Items API on target; adjust tooling accordingly"),
        (9, "Extra epics on target",
         "Migration ran multiple times; duplicate imports",
         "Compare epic IIDs and titles across both instances",
         "Identify duplicates and archive/delete extra epics on target"),
        (10, "Epic dates lost (start/due)",
         "Fixed date fields not preserved in older export formats",
         "Compare start_date/due_date per epic IID",
         "Restore dates via PUT /groups/:id/epics/:iid on target"),
    ]
    for r, row in enumerate(matrix, 2):
        for col, val in enumerate(row, 1):
            ws6.cell(row=r, column=col, value=val)
        ws6.cell(row=r, column=1).fill = LBLUE
    auto_width(ws6)

    wb.save(path)
    return path

# ─────────────────────────────────────────────
# MAIN ORCHESTRATOR
# ─────────────────────────────────────────────
def main(recreate_boards_flag=False, dry_run_flag=True):
    print("=" * 70)
    print("  GitLab Epic Migration Validator — SBIePay")
    print(f"  Run: {RUN_TS}")
    print("=" * 70)

    # Version check
    print("\n[1/7] Checking GitLab versions...")
    src_ver, src_rev = get_version(SOURCE_URL, SOURCE_TOKEN)
    tgt_ver, tgt_rev = get_version(TARGET_URL, TARGET_TOKEN)
    print(f"  Source: {src_ver} ({src_rev})")
    print(f"  Target: {tgt_ver} ({tgt_rev})")

    # Group enumeration
    print("\n[2/7] Enumerating groups on source...")
    src_groups = get_all_groups(SOURCE_URL, SOURCE_TOKEN, SOURCE_TOP_GROUP)
    print(f"  Source top group: {SOURCE_TOP_GROUP}  ({len(src_groups)} groups)")

    print("[2/7] Enumerating groups on target...")
    tgt_groups = get_all_groups(TARGET_URL, TARGET_TOKEN, TARGET_TOP_GROUP)
    print(f"  Target top group: {TARGET_TOP_GROUP}  ({len(tgt_groups)} groups)")

    # Pair by RELATIVE path beneath the top group. Renamed subgroups are
    # remapped via GROUP_PATH_MAP so source/target still match.
    def resolve_target_rel(src_rel):
        """Translate a source rel_path to its expected target rel_path."""
        if src_rel in GROUP_PATH_MAP:
            return GROUP_PATH_MAP[src_rel]
        if MAP_CHILDREN_BY_PREFIX:
            # Longest matching parent prefix wins (handle nested renames).
            for old_prefix in sorted(GROUP_PATH_MAP, key=len, reverse=True):
                if src_rel.startswith(old_prefix + "/"):
                    new_prefix = GROUP_PATH_MAP[old_prefix]
                    return new_prefix + src_rel[len(old_prefix):]
        return src_rel  # no rename — identical path expected

    src_group_map = {g["rel_path"]: g for g in src_groups}
    tgt_group_map = {g["rel_path"]: g for g in tgt_groups}

    # Drop empty nested duplicate source groups so they are neither compared nor
    # cause collisions. Keep the flat groups that actually hold the epics.
    all_paths = sorted(p for p in src_group_map if p not in SOURCE_SKIP)
    skipped = sorted(p for p in src_group_map if p in SOURCE_SKIP)
    if skipped:
        print(f"  Skipping empty nested duplicate source groups: {skipped}")

    # Report any mapped path whose target does not actually exist (typo / stale map)
    for old_rel, new_rel in GROUP_PATH_MAP.items():
        if old_rel not in src_group_map:
            print(f"  [MAP WARN] '{old_rel}' in GROUP_PATH_MAP not found on SOURCE.")
        if new_rel not in tgt_group_map:
            print(f"  [MAP WARN] mapped target '{new_rel}' not found on TARGET.")

    # Safety net: detect any remaining SOURCE collision (should be none now).
    resolved = {}
    for s in all_paths:
        r = resolve_target_rel(s)
        resolved.setdefault(r, []).append(s)
    for tgt_rel, srcs in resolved.items():
        if len(srcs) > 1:
            print(f"  [COLLISION] source groups {srcs} all map to target '{tgt_rel}' "
                  f"— check GROUP_PATH_MAP / SOURCE_SKIP.")
    # Target-only groups are intentionally ignored entirely (new repos).

    # Epic comparison
    print("\n[3/7] Comparing epics per group...")
    all_results       = []
    drift_records     = []
    orphan_records    = []
    board_results     = []
    board_actions     = []
    missing_epics_detail = []

    for path in all_paths:
        sg = src_group_map[path]
        tgt_rel = resolve_target_rel(path)
        tg = tgt_group_map.get(tgt_rel)
        # Friendly display label. Show the rename explicitly when paths differ.
        if path == "":
            label = f"{sg['full_path']} → {tg['full_path']}" if tg else f"{sg['full_path']} (TOP)"
        elif tgt_rel != path:
            label = f"{path} → {tgt_rel}"  # renamed subgroup
        else:
            label = path
        if not tg:
            print(f"  [WARN] Group '{label}' missing on target — skipping epic compare.")
            all_results.append({
                "group": label, "src_total": "?", "tgt_total": 0,
                "src_open": "?", "tgt_open": 0,
                "src_closed": "?", "tgt_closed": 0,
                "missing_iids": ["GROUP MISSING ON TARGET"],
                "extra_iids": [], "drift": [], "count_match": False
            })
            continue

        src_epics = get_epics_for_group(SOURCE_URL, SOURCE_TOKEN, sg["id"])
        tgt_epics = get_epics_for_group(TARGET_URL, TARGET_TOKEN, tg["id"])

        res = compare_epics(src_epics, tgt_epics, label)
        all_results.append(res)
        drift_records.extend(res["drift"])

        # Detail rows for missing epics
        src_iid_map = {e["iid"]: e for e in src_epics}
        for iid in res["missing_iids"]:
            e = src_iid_map.get(iid, {})
            missing_epics_detail.append({
                "group": label, "iid": iid,
                "title": e.get("title", "?"),
                "state": e.get("state", "?"),
                "created_at": e.get("created_at", "?"),
            })

        # Orphan check on target
        orphans = check_hierarchy(TARGET_URL, TARGET_TOKEN, tg["id"], tgt_epics)
        for o in orphans:
            o["group"] = label
        orphan_records.extend(orphans)

        # Epic boards
        src_boards = get_epic_boards(SOURCE_URL, SOURCE_TOKEN, sg["id"])
        tgt_boards = get_epic_boards(TARGET_URL, TARGET_TOKEN, tg["id"])
        board_results.append(compare_boards(src_boards, tgt_boards, label))

        # Optional: recreate missing boards on target (write operation)
        if recreate_boards_flag and src_boards:
            acts = recreate_boards(
                SOURCE_URL, SOURCE_TOKEN, sg["id"],
                TARGET_URL, TARGET_TOKEN, tg["id"],
                dry_run=dry_run_flag)
            for a in acts:
                board_actions.append({"group": label, "action": a})
                print(f"    [BOARD] {a}")

        print(f"  {label}: src={res['src_total']} tgt={res['tgt_total']} "
              f"missing={len(res['missing_iids'])} drift={len(res['drift'])} "
              f"orphans={len(orphans)}")

    # ── Write CSVs ─────────────────────────────────
    print("\n[4/7] Writing CSV reports...")
    p1 = write_csv(f"epic_count_summary_{RUN_TS}.csv", all_results,
                   ["group","src_total","tgt_total","src_open","tgt_open",
                    "src_closed","tgt_closed","count_match"])
    p2 = write_csv(f"missing_epics_{RUN_TS}.csv", missing_epics_detail,
                   ["group","iid","title","state","created_at"])
    p3 = write_csv(f"attribute_drift_{RUN_TS}.csv", drift_records,
                   ["group","epic_iid","title","drift"])
    p4 = write_csv(f"orphaned_epics_{RUN_TS}.csv", orphan_records,
                   ["group","epic_iid","title","parent_id","issue"])
    p5 = write_csv(f"epic_boards_{RUN_TS}.csv", board_results,
                   ["group","src_count","tgt_count","missing","extra"])
    csv_paths = [p1, p2, p3, p4, p5]
    if board_actions:
        p6 = write_csv(f"board_recreation_actions_{RUN_TS}.csv", board_actions,
                       ["group","action"])
        csv_paths.append(p6)
    for p in csv_paths:
        print(f"  Written: {p}")

    # ── Write Excel ────────────────────────────────
    print("\n[5/7] Writing Excel report...")
    xp = write_excel(all_results, drift_records, orphan_records, board_results,
                     f"{src_ver} ({src_rev})", f"{tgt_ver} ({tgt_rev})",
                     missing_epics_detail)
    if xp:
        print(f"  Written: {xp}")

    # ── Console Summary ────────────────────────────
    print("\n[6/7] Summary")
    total_src   = sum(r["src_total"] for r in all_results if isinstance(r["src_total"], int))
    total_tgt   = sum(r["tgt_total"] for r in all_results if isinstance(r["tgt_total"], int))
    total_miss  = sum(len(r["missing_iids"]) for r in all_results
                      if isinstance(r.get("missing_iids"), list)
                      and r["missing_iids"] != ["GROUP MISSING ON TARGET"])
    total_drift = len(drift_records)
    total_orph  = len(orphan_records)
    total_bmiss = sum(len(b["missing"]) for b in board_results)

    print(f"  Source epics   : {total_src}")
    print(f"  Target epics   : {total_tgt}")
    print(f"  Missing epics  : {total_miss}")
    print(f"  Drift records  : {total_drift}")
    print(f"  Orphaned epics : {total_orph}")
    print(f"  Missing boards : {total_bmiss}")

    verdict = "✅ PASS" if (total_miss == 0 and total_drift == 0 and total_orph == 0) else "❌ ISSUES FOUND — review reports"
    print(f"\n  VERDICT: {verdict}")
    print("\n[7/7] Done.")
    print(f"  All output in: {OUTPUT_DIR.resolve()}")

if __name__ == "__main__":
