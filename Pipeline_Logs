  stage: MirrorMaker2
  when: manual
  variables:
    GIT_STRATEGY:       none
    TARGET_ENV:         "prod-dc"
    MIRRORMAKER2_ENABLED: "false"
  rules:
    - if: '$DRILL_TIER == "prod"'
