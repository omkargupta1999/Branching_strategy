[root@loki1 ~]# # Fixed timestamps - same range both runs, ending ~2 hours ago (well outside the fresh zone)
END=$(date -d '2 hours ago' +%s)000000000
START=$(date -d '4 hours ago' +%s)000000000

for i in 1 2; do
  curl -s -G "http://10.189.35.10:3104/loki/api/v1/query_range" \
    --data-urlencode 'query=count_over_time({k8s_container_name="transactionservice"} |= `error` [5m])' \
    --data-urlencode "start=$START" \
    --data-urlencode "end=$END" \
    --data-urlencode "step=300000ms" -o /dev/null -w "run$i: time=%{time_total}s\n"
done
