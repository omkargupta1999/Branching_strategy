build:
  stage: build
  image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-virtual/custom-ci/epay-build-java-gradle:1.0.0
  tags:
  - common_runner
  variables:
    CACERT_PATH: "${CI_PROJECT_DIR}/cacerts-custom"
    JFROG_GRADLE_REPO: https://artifactory.jfrog.sbi:443/artifactory/itepaypg-sbiepay2-gradle-virtual/
    GRADLE_OPTS: "-Dorg.gradle.daemon=false"
    GRADLE_USER_HOME: "${CI_PROJECT_DIR}/.gradle"
  before_script:
  - java -version
  - gradle --version
  - mkdir -p "${CI_PROJECT_DIR}/.gradle/init.d"
  - |
    cat > "${CI_PROJECT_DIR}/.gradle/init.d/epay-artifactory.init.gradle" << 'EOF'
    // ── epay-artifactory.init.gradle ─────────────────────────────────────────
    // Injected by ci/build/java.gradle.yml — DO NOT ADD TO APP REPOS
    // Centralised Artifactory resolution config for all SBIePay 2.0 services
    // Credentials resolved from environment at runtime — never stored in file
    // ─────────────────────────────────────────────────────────────────────────

    settingsEvaluated { settings ->

        // ── Plugin Resolution (Initialization Phase — pluginManagement) ───────
        // Routes plugins {} DSL in app repo build.gradle through Artifactory.
        // Artifactory virtual repo aggregates:
        //   devsecops-maven-plugins            → plugins.gradle.org/m2/      (plugin markers)
        //   devsecops-plugins-artifacts-remote → plugins-artifacts.gradle.org (plugin JARs)
        //   devsecops-maven-remote             → repo1.maven.org/maven2/      (plugin JARs via Maven Central)
        settings.pluginManagement {
            repositories {
                maven {
                    url System.getenv("JFROG_GRADLE_REPO")
                    credentials {
                        username = System.getenv("JF_USER")
                        password = System.getenv("JF_TOKEN")
                    }
                }
            }
        }

        // ── Dependency Resolution (Configuration Phase — repositories) ────────
        // FAIL_ON_PROJECT_REPOS: app repo build.gradle must NOT define repositories {}.
        // All repos resolve dependencies exclusively through Artifactory virtual repo.
        // Internal SBI JARs (logging-service, cache-management-service etc.) must be
        // published to itepaypg-sbiepay2-gradle-local — resolved via virtual repo above.
        settings.dependencyResolutionManagement {
            repositoriesMode.set(RepositoriesMode.FAIL_ON_PROJECT_REPOS)
            repositories {
                maven {
                    url System.getenv("JFROG_GRADLE_REPO")
                    credentials {
                        username = System.getenv("JF_USER")
                        password = System.getenv("JF_TOKEN")
                    }
                }
                flatDir {
                  dirs "libs"
                }
            }
        }
    }
    EOF
  - cp "$JAVA_HOME/lib/security/cacerts" "$CACERT_PATH"
  - chmod 644 "$CACERT_PATH"
  - keytool -importcert -keystore "$CACERT_PATH" -storepass changeit -alias jfrog-internal
    -file "$JF_ARTIFACTORY_CERT" -noprompt
  - export JAVA_TOOL_OPTIONS="-Djavax.net.ssl.trustStore=${CI_PROJECT_DIR}/cacerts-custom
    -Djavax.net.ssl.trustStorePassword=changeit"
  - keytool -list -keystore "$CACERT_PATH" -storepass changeit -alias jfrog-internal
  extends:
  - ".build"
  - ".rules"
  script:
  - |
    set -eo pipefail

    # ── Validate VERSION ──────────────────────────────────────────────────
    if [ -z "$VERSION" ]; then
      echo "❌ ERROR: VERSION is empty — semver.yml dotenv artifact not loaded"
      echo "   Check: semver.yml is included before java.gradle.yml in orchestrator"
      exit 1
    fi
    echo "Building VERSION: ${VERSION}"

    # ── Gradle build ──────────────────────────────────────────────────────
    # Dependencies resolved from JFrog via settings.gradle in app repo
    # -x test: unit tests run separately in test stage (java.unit.yml)
    # -Pversion: sets project version used in bootJar archiveFileName
    gradle build -x test -Pversion="${VERSION}"

    # ── Verify output ─────────────────────────────────────────────────────
    echo "Build output:"
    ls -lh build/libs/

    if [ -z "$(ls -A build/libs/*.jar 2>/dev/null)" ]; then
      echo "❌ ERROR: No JAR found in build/libs/ — build may have failed silently"
      exit 1
    fi

    # ── Build metadata for downstream stages ────────────────────────────────
    # JAR_FILE: consumed by image-build stage for COPY instruction in Dockerfile
    # BUILD_TIME: consumed by image-build stage for OCI image labels
    JAR_FILE=$(ls build/libs/*.jar | grep -v plain | head -1)
    echo "✅ JAR: ${JAR_FILE}"
    echo "JAR_FILE=${JAR_FILE}"                         >> build.env
    echo "BUILD_TIME=$(date -u +%Y-%m-%dT%H:%M:%SZ)"    >> build.env
  artifacts:
    paths:
    - build/libs/
    - build/classes/
    - build/resources/
    - build/tmp/
    reports:
      dotenv:
      - build.env
    when: on_success
    expire_in: 1 day
  rules:
  - if: $CI_PIPELINE_SOURCE == "merge_request_event" && $CI_MERGE_REQUEST_TARGET_BRANCH_NAME
      =~ /^(main|develop|release)(\/.*)*$/
  - if: "$CI_COMMIT_BRANCH =~ /^(main|develop|release|hotfix|bugfix|feature)(\\/.*)*$/"
  - when: never
