regenerate-lock:
  stage: build
  image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-virtual/ubi9/php-82:1-1778488703
  tags:
    - common_runner
  variables:
    JF_ARTIFACTORY_URL: "https://artifactory.jfrog.sbi/artifactory"
    PHP_VIRTUAL_REPO: "itepaypg-sbiepay2-php-virtual"
    COMPOSER_ALLOW_SUPERUSER: "1"
    # ── KEY FIX: Override COMPOSER_HOME so we bypass the image's
    # pre-baked config at /opt/app-root/src/.config/composer/ ──────────────
    COMPOSER_HOME: "${CI_PROJECT_DIR}/.composer-home"
    COMPOSER_CACHE_DIR: "${CI_PROJECT_DIR}/.composer-cache"
  script:
    - git config --global --add safe.directory "${CI_PROJECT_DIR}"
    - php --version

    # Download Composer from JFrog
    - |
      set -eo pipefail
      echo "── Downloading Composer from JFrog ──"
      curl -f \
        --cacert "$JF_ARTIFACTORY_CERT" \
        -u "${JF_USER}:${JF_TOKEN}" \
        "${JF_ARTIFACTORY_URL}/${PHP_VIRTUAL_REPO}/composer.phar" \
        -o composer.phar
      SIZE=$(stat -c%s composer.phar)
      echo "Downloaded size: $SIZE bytes"
      if [ "$SIZE" -lt 1000000 ]; then
        echo "ERROR: composer.phar too small"
        exit 1
      fi
      chmod +x composer.phar
      mv composer.phar composer
      export PATH="$CI_PROJECT_DIR:$PATH"
      composer --version

    # Configure Composer with a clean COMPOSER_HOME — no inherited config
    - |
      set -eo pipefail
      export PATH="$CI_PROJECT_DIR:$PATH"
      export COMPOSER_HOME="${CI_PROJECT_DIR}/.composer-home"

      echo "── Configuring Composer (clean home: $COMPOSER_HOME) ──"
      mkdir -p "$COMPOSER_HOME"

      # Write config.json directly — more reliable than composer config --global
      cat > "$COMPOSER_HOME/config.json" <<EOF
      {
          "config": {
              "use-github-api": false,
              "preferred-install": "dist",
              "secure-http": true,
              "cafile": "${JF_ARTIFACTORY_CERT}"
          },
          "repositories": {
              "packagist": {
                  "type": "composer",
                  "url": "${JF_ARTIFACTORY_URL}/api/composer/${PHP_VIRTUAL_REPO}"
              }
          },
          "disable-tls": false
      }
      EOF

      # Write auth.json directly
      cat > "$COMPOSER_HOME/auth.json" <<EOF
      {
          "http-basic": {
              "artifactory.jfrog.sbi": {
                  "username": "${JF_USER}",
                  "password": "${JF_TOKEN}"
              }
          }
      }
      EOF

      echo "── Config written ──"
      echo "── config.json contents: ──"
      cat "$COMPOSER_HOME/config.json"

      # Verify Composer now reads our config
      composer config --list | grep -E "repo|packagist|github|preferred" || true

    # Regenerate composer.lock via JFrog and commit back
    - |
      set -eo pipefail
      export PATH="$CI_PROJECT_DIR:$PATH"
      export COMPOSER_HOME="${CI_PROJECT_DIR}/.composer-home"

      echo "===== DELETING OLD composer.lock ====="
      rm -f composer.lock

      echo "===== REGENERATING composer.lock VIA JFROG ====="
      composer update \
        --no-install \
        --no-interaction \
        --prefer-dist \
        --no-source-fallback \
        -vvv

      echo "===== VERIFYING URLS IN LOCK FILE ====="
      JFROG_COUNT=$(grep -c "artifactory.jfrog.sbi" composer.lock 2>/dev/null || echo 0)
      GITHUB_COUNT=$(grep -c "api.github.com" composer.lock 2>/dev/null || echo 0)
      echo "JFrog URLs found  : $JFROG_COUNT"
      echo "GitHub URLs found : $GITHUB_COUNT"

      if [ "$GITHUB_COUNT" -gt 0 ]; then
        echo "WARNING: GitHub URLs still present"
        grep "api.github.com" composer.lock | head -5
      else
        echo "SUCCESS: All dist URLs point to JFrog"
      fi

      echo "===== COMMITTING NEW composer.lock TO REPO ====="
      git config user.email "ci-bot@sbi.com"
      git config user.name "GitLab CI"
      git add composer.lock
      git diff --cached --stat
      git commit -m "chore: regenerate composer.lock with JFrog dist URLs [skip ci]"
      git push \
        "https://oauth2:${CI_JOB_TOKEN}@${CI_SERVER_HOST}/${CI_PROJECT_PATH}.git" \
        HEAD:${CI_COMMIT_REF_NAME}

      echo "===== composer.lock COMMITTED SUCCESSFULLY ====="

  rules:
    - when: manual
