#!/usr/bin/env python3
"""
jfrog_delete_image_tag.py

Deletes a single Docker image TAG (the whole tag folder: manifest + config + layer refs)
from a JFrog Artifactory Docker repo. Layer blobs are reclaimed later by Artifactory GC.

SAFETY DESIGN (audit-first house style):
  - DRY-RUN IS THE DEFAULT. Nothing is deleted unless you pass --apply.
  - One tag per invocation. You must give BOTH --image and --tag explicitly.
  - Pre-delete it GETs the folder to confirm the tag exists and shows what will go.
  - Every real delete is journalled to a JSONL rollback record (path, digest, timestamp,
    HTTP status) so you have an audit trail of exactly what was removed.
  - Refuses to touch anything outside the configured PATH_PREFIX unless --allow-any-path.

  NOTE: Artifactory tag deletion is PERMANENT (no recycle bin unless trashcan is enabled
  on the instance). There is no automated 'undo' — the JSONL journal is a record, not a
  restore. Re-pushing the image from the pipeline is the recovery path.

House style: pure stdlib, ssl._create_unverified_context(), CONFIG block, log() to console +
dated file, argparse flags, env-var cred override.

Usage:
  # 1. Dry-run (default) — shows what WOULD be deleted, deletes nothing:
  python311\\python.exe jfrog_delete_image_tag.py --image epay_admin_portal_service --tag feature-epay-151-masters-framework-desig-71b5c33d

  # 2. Actually delete (requires --apply AND interactive yes):
  python311\\python.exe jfrog_delete_image_tag.py --image epay_admin_portal_service --tag feature-epay-151-masters-framework-desig-71b5c33d --apply
"""

import argparse
import json
import os
import ssl
import sys
import urllib.request
import urllib.error
from datetime import datetime
from pathlib import Path

# ---------------------------------------------------------------------------
# CONFIG
# ---------------------------------------------------------------------------
CONFIG = {
    "JFROG_HOST": "https://artifactory.jfrog.sbi:443",
    "JFROG_USER": "v1021577",                      # <-- used for AUTH_METHOD=basic
    "JFROG_API_KEY": "REPLACE_ME",                 # <-- prefer env var override below
    "AUTH_METHOD": "basic",                        # "basic" or "bearer"
    "DOCKER_REPO": "itepaypg-sbiepay2-docker-local",
    "PATH_PREFIX": "app/backend",                  # deletions confined to under here by default
    "LOG_DIR": r"D:\Mr Om\Python_script",
    "JOURNAL_DIR": r"D:\Mr Om\Python_script\delete_journals",
    "TIMEOUT_SEC": 30,
}

CONFIG["JFROG_USER"] = os.environ.get("JFROG_USER", CONFIG["JFROG_USER"])
CONFIG["JFROG_API_KEY"] = os.environ.get("JFROG_API_KEY", CONFIG["JFROG_API_KEY"])
CONFIG["AUTH_METHOD"] = os.environ.get("JFROG_AUTH_METHOD", CONFIG["AUTH_METHOD"])

SSL_CTX = ssl._create_unverified_context()


# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
def log(msg, level="INFO"):
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    line = f"[{ts}] [{level}] {msg}"
    print(line)
    try:
        log_dir = Path(CONFIG["LOG_DIR"])
        log_dir.mkdir(parents=True, exist_ok=True)
        log_file = log_dir / f"jfrog_delete_image_tag_{datetime.now().strftime('%Y%m%d')}.log"
        with open(log_file, "a", encoding="utf-8") as f:
            f.write(line + "\n")
    except Exception as e:
        print(f"[{ts}] [WARN] could not write to log file: {e}")


# ---------------------------------------------------------------------------
# HTTP
# ---------------------------------------------------------------------------
def _auth_header():
    if CONFIG["AUTH_METHOD"].lower() == "bearer":
        return {"Authorization": f"Bearer {CONFIG['JFROG_API_KEY']}"}
    import base64
    token = base64.b64encode(
        f"{CONFIG['JFROG_USER']}:{CONFIG['JFROG_API_KEY']}".encode()
    ).decode()
    return {"Authorization": f"Basic {token}"}


def _request(url, method="GET", accept=None):
    headers = _auth_header()
    if accept:
        headers["Accept"] = accept
    req = urllib.request.Request(url, headers=headers, method=method)
    try:
        with urllib.request.urlopen(req, timeout=CONFIG["TIMEOUT_SEC"], context=SSL_CTX) as resp:
            return resp.status, resp.read()
    except urllib.error.HTTPError as e:
        return e.code, e.read()
    except urllib.error.URLError as e:
        log(f"URL error calling {url}: {e}", "ERROR")
        return None, b""


# ---------------------------------------------------------------------------
# Inspect the tag folder before deleting
# ---------------------------------------------------------------------------
def get_tag_info(repo, folder_path):
    """folder_path e.g. app/backend/epay_admin_portal_service/<tag>."""
    url = f"{CONFIG['JFROG_HOST']}/artifactory/api/storage/{repo}/{folder_path}"
    status, raw = _request(url, accept="application/json")
    if status != 200:
        return status, None
    try:
        return status, json.loads(raw)
    except json.JSONDecodeError:
        return status, None


def get_manifest_digest(repo, image, tag):
    """Best-effort fetch of the manifest digest for the audit record."""
    url = f"{CONFIG['JFROG_HOST']}/artifactory/api/docker/{repo}/v2/{image}/manifests/{tag}"
    headers = _auth_header()
    headers["Accept"] = "application/vnd.docker.distribution.manifest.v2+json"
    req = urllib.request.Request(url, headers=headers, method="HEAD")
    try:
        with urllib.request.urlopen(req, timeout=CONFIG["TIMEOUT_SEC"], context=SSL_CTX) as resp:
            return resp.headers.get("Docker-Content-Digest")
    except Exception:
        return None


# ---------------------------------------------------------------------------
# Journal
# ---------------------------------------------------------------------------
def journal_write(record):
    jdir = Path(CONFIG["JOURNAL_DIR"])
    jdir.mkdir(parents=True, exist_ok=True)
    jpath = jdir / f"delete_journal_{datetime.now().strftime('%Y%m%d')}.jsonl"
    with open(jpath, "a", encoding="utf-8") as f:
        f.write(json.dumps(record) + "\n")
    return jpath


# ---------------------------------------------------------------------------
# Delete
# ---------------------------------------------------------------------------
def delete_tag(repo, folder_path):
    url = f"{CONFIG['JFROG_HOST']}/artifactory/{repo}/{folder_path}"
    status, raw = _request(url, method="DELETE")
    return status, raw, url


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
def main():
    parser = argparse.ArgumentParser(description="Delete a single JFrog Docker image tag (dry-run by default)")
    parser.add_argument("--repo", default=CONFIG["DOCKER_REPO"], help="Docker repo name")
    parser.add_argument("--path-prefix", default=CONFIG["PATH_PREFIX"],
                        help='Base folder, e.g. "app/backend". Deletions confined here unless --allow-any-path.')
    parser.add_argument("--image", required=True,
                        help="Service/image name under path-prefix, e.g. epay_admin_portal_service "
                             "(you may also pass the full path; prefix is de-duped).")
    parser.add_argument("--tag", required=True, help="Exact tag to delete (the folder name).")
    parser.add_argument("--apply", action="store_true",
                        help="Actually delete. Without this, runs dry-run and deletes nothing.")
    parser.add_argument("--allow-any-path", action="store_true",
                        help="Permit deleting outside path-prefix (off by default as a guardrail).")
    parser.add_argument("--yes", action="store_true",
                        help="Skip the interactive confirmation prompt (for scripted use). Still needs --apply.")
    args = parser.parse_args()

    if CONFIG["JFROG_API_KEY"] == "REPLACE_ME":
        log("JFROG_API_KEY not set — export JFROG_API_KEY env var or edit CONFIG block", "ERROR")
        sys.exit(1)

    CONFIG["DOCKER_REPO"] = args.repo

    # Normalise image path (de-dupe prefix)
    image = args.image
    prefix = (args.path_prefix or "").rstrip("/")
    if prefix and image.startswith(prefix + "/"):
        image = image[len(prefix) + 1:]
    image = image.strip("/")
    full_image = f"{prefix}/{image}" if prefix else image
    folder_path = f"{full_image}/{args.tag}"

    log(f"Target repo='{args.repo}' image='{full_image}' tag='{args.tag}'")
    log(f"Full folder path to delete: {args.repo}/{folder_path}")

    # Guardrail: confine to prefix
    if prefix and not folder_path.startswith(prefix + "/") and not args.allow_any_path:
        log(f"Refusing: target is outside path-prefix '{prefix}'. Use --allow-any-path to override.", "ERROR")
        sys.exit(1)

    # Confirm the tag exists first
    status, info = get_tag_info(args.repo, folder_path)
    if status == 404:
        log(f"Tag folder not found (404): {args.repo}/{folder_path}. Nothing to delete. "
            f"Check the exact tag spelling.", "ERROR")
        sys.exit(1)
    if status in (401, 403):
        log(f"AUTH FAILED (status={status}) — check creds / AUTH_METHOD.", "ERROR")
        sys.exit(1)
    if status != 200:
        log(f"Could not inspect tag folder (status={status}). Aborting for safety.", "ERROR")
        sys.exit(1)

    children = info.get("children", []) if info else []
    log(f"Tag folder exists. Contains {len(children)} file(s): "
        f"{[c.get('uri') for c in children][:10]}")

    digest = get_manifest_digest(args.repo, full_image, args.tag)
    log(f"Manifest digest: {digest or 'unavailable'}")

    if not args.apply:
        log("DRY-RUN (default): no deletion performed. Re-run with --apply to actually delete.", "WARN")
        log(f"Would DELETE: {CONFIG['JFROG_HOST']}/artifactory/{args.repo}/{folder_path}")
        return

    # Interactive confirmation
    if not args.yes:
        print("")
        print("  !!! PERMANENT DELETE — no recycle bin unless trashcan is enabled !!!")
        print(f"  Repo : {args.repo}")
        print(f"  Image: {full_image}")
        print(f"  Tag  : {args.tag}")
        print(f"  Digest: {digest or 'unavailable'}")
        confirm = input("  Type the exact tag name to confirm deletion: ").strip()
        if confirm != args.tag:
            log("Confirmation did not match tag name. Aborting — nothing deleted.", "WARN")
            sys.exit(1)

    # Journal BEFORE delete (record intent), then update with result
    record = {
        "timestamp": datetime.now().isoformat(),
        "action": "delete_tag",
        "repo": args.repo,
        "image": full_image,
        "tag": args.tag,
        "folder_path": folder_path,
        "manifest_digest": digest,
        "children_count": len(children),
        "status": "attempting",
    }
    jpath = journal_write(record)

    status, raw, url = delete_tag(args.repo, folder_path)
    record["status"] = "deleted" if status in (200, 202, 204) else f"failed_{status}"
    record["response"] = (raw[:200].decode("utf-8", "replace") if raw else "")
    journal_write(record)

    if status in (200, 202, 204):
        log(f"DELETED successfully (status={status}): {args.repo}/{folder_path}")
        log(f"Journalled to: {jpath}")
        log("Note: layer blobs are reclaimed later by Artifactory garbage collection.")
    else:
        log(f"DELETE FAILED (status={status}): {raw[:300]}", "ERROR")
        log(f"Journalled the failed attempt to: {jpath}")
        sys.exit(1)


if __name__ == "__main__":
    main()
