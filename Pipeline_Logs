# 🔥 FINAL WORKING DOCKERFILE (USE THIS)

```dockerfile
FROM registry.dev.sbiepay.sbi:8443/ubi9/openjdk-21-runtime:1.24-2.1776357028

ENV GRADLE_VERSION=9.3.0

USER root

# --- Set EXACT JAVA_HOME (verified working path) ---
ENV JAVA_HOME=/usr/lib/jvm/java-21-openjdk-21.0.10.0.7-1.el9.x86_64
ENV PATH=$JAVA_HOME/bin:$PATH

# --- Copy Gradle (offline setup: pre-extracted folder) ---
COPY gradle-9.3.0 /opt/gradle-9.3.0

# --- Create symlink ---
RUN ln -s /opt/gradle-${GRADLE_VERSION} /opt/gradle

ENV GRADLE_HOME=/opt/gradle
ENV PATH=$PATH:$GRADLE_HOME/bin

# --- Create non-root user ---
RUN useradd -u 1001 -m gradle

# --- Gradle cache directory ---
ENV GRADLE_USER_HOME=/home/gradle/.gradle

RUN mkdir -p $GRADLE_USER_HOME \
    && chown -R gradle:gradle /home/gradle /opt/gradle*

# --- 🔥 CRITICAL FIX: Gradle Toolchain Configuration ---
# Force Gradle to use local JDK (prevents download failure)
RUN mkdir -p /home/gradle/.gradle && \
    echo "org.gradle.java.installations.auto-download=false" >> /home/gradle/.gradle/gradle.properties && \
    echo "org.gradle.java.installations.auto-detect=true" >> /home/gradle/.gradle/gradle.properties && \
    echo "org.gradle.java.installations.paths=/usr/lib/jvm/java-21-openjdk-21.0.10.0.7-1.el9.x86_64" >> /home/gradle/.gradle/gradle.properties && \
    chown -R gradle:gradle /home/gradle/.gradle

# --- Import certificate ---
COPY jfrog-chain.crt /tmp/

RUN keytool -import -trustcacerts \
    -cacerts \
    -file /tmp/jfrog-chain.crt \
    -alias sbi-internal \
    -storepass changeit -noprompt \
    && rm -f /tmp/jfrog-chain.crt

# --- Switch to non-root ---
USER gradle
WORKDIR /workspace

CMD ["gradle", "--version"]
```

