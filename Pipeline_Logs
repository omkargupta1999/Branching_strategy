# ci/version/semver.yml  |  Stage: version
# ──────────────────────────────────────────────────────────────────────────────
# Computes the VERSION string from branch / pipeline context and exports it to
# version.env. Consumed by ALL downstream jobs via the dotenv artifact.
# This job ONLY computes the version — git tags are created in ci/release/tag.yml.
#
# ── VERSION output per context ────────────────────────────────────────────────
# Pipeline Source      Branch / Context          VERSION
# ──────────────────── ───────────────────────── ─────────────────────────────────
# merge_request_event  <any src> → <any tgt>     mr-<src>-<tgt>-<MR IID>-<short-sha>
# push                 feature/*                 <branch-name>-<short-sha>
# push                 bugfix/*                  <branch-name>-<short-sha>
# push                 hotfix/*                  <branch-name>-<short-sha>
# push                 release/*                 <branch-name>-<short-sha>
# push                 develop                   dev-<short-sha>
# push                 sit-integration           sit-<short-sha>
# push                 main ← release/major-*     major bump  (last_tag + 1.0.0)
# push                 main ← release/minor-*     minor bump  (last_tag + 0.1.0)
# push                 main ← hotfix/*            patch bump  (last_tag + 0.0.1)
# push                 unrecognised branch       unknown-<short-sha>
#
# ── Branch naming contract (enforced by the GitLab Push Rule) ─────────────────
#   release/(major|minor)-DM<digits>-EPAY-<desc>
#   feature|bugfix|hotfix/EPAY-<digits>-<desc>
#   main | develop | sit-integration
# The bump level is read from the SOURCE BRANCH NAME only — never from the
# commit message body or the MR title.
#
# ── Tag format: BARE semver (1.2.0) — no 'v' prefix ───────────────────────────
# Three places must agree on this, or retries double-bump:
#   1. the idempotency guard below   (git tag --points-at HEAD)
#   2. the LAST_TAG lookup below
#   3. ci/release/tag.yml            (creates the tag)
#
# ── Branch-name cleaning (clean_branch) ───────────────────────────────────────
#   non [a-zA-Z0-9._-] → '-'   |   lowercase   |   collapse '--' → '-'
#   trim leading/trailing '-'  |   truncate to 40 chars
# Keeps every VERSION well inside the 128-char Docker image tag limit.
#
# ── main merge: how the source branch is identified ───────────────────────────
# CI_MERGE_REQUEST_SOURCE_BRANCH_NAME does NOT exist on a post-merge push
# pipeline. CI_COMMIT_TITLE does — GitLab sets it to the merge commit subject:
#   "Merge branch 'release/minor-DM…-EPAY-…' into 'main'"
#   "Merge branch 'hotfix/EPAY-…' into 'main'"
# The branch name is parsed out of that subject (Gate 1).
#
# LOAD-BEARING SETTING: Settings → Merge requests → Merge method = 'Merge commit'
# (squash and rebase MUST be disabled on protected 'main'). A squash/rebase merge
# produces no "Merge branch '…'" subject → Gate 3 fails the pipeline by design,
# rather than silently computing a wrong production version.
#
# ── Failure gates on main ─────────────────────────────────────────────────────
#   Gate 1a  title matched but branch name not extractable  → fail
#   Gate 1   source branch is not release/major|minor or hotfix → fail
#   Gate 2   a merge commit, but from a forbidden source branch → fail
#   Gate 3   not a standard merge commit (squash/rebase used)   → fail
# ──────────────────────────────────────────────────────────────────────────────

version:
  stage: version
  image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-local/custom-ci/rhelgit-oc-helm:1.0
  variables:
    GIT_DEPTH: "0"            # full clone — required for a complete tag list
    INITIAL_VERSION: "1.0.0"  # baseline when the repo has no semver tag yet
  tags:
    - common_runner
  before_script:
    - git config --global http.sslVerify false
    - git config --global --add safe.directory '*'
  script:
    - |
      set -eo pipefail
      git fetch --tags

      # ── Helper: clean a branch name for use inside a VERSION string ───────
      clean_branch() {
        echo "$1"                        \
          | sed 's/[^a-zA-Z0-9._-]/-/g' \
          | tr '[:upper:]' '[:lower:]'   \
          | sed 's/--*/-/g'              \
          | sed 's/^-//; s/-$//'         \
          | cut -c1-40
      }

      # ── MR pipeline — src + tgt embedded for traceability ──────────────────
      if [[ "$CI_PIPELINE_SOURCE" == "merge_request_event" ]]; then
        SRC_CLEAN=$(clean_branch "$CI_MERGE_REQUEST_SOURCE_BRANCH_NAME")
        TGT_CLEAN=$(clean_branch "$CI_MERGE_REQUEST_TARGET_BRANCH_NAME")
        VERSION="mr-${SRC_CLEAN}-${TGT_CLEAN}-${CI_MERGE_REQUEST_IID}-${CI_COMMIT_SHORT_SHA}"

      # ── feature/*, bugfix/*, hotfix/*, release/* push ──────────────────────
      # One condition covers all four — identical pattern: <branch>-<sha>
      elif [[ "$CI_COMMIT_BRANCH" =~ ^(feature|bugfix|hotfix|release)\/ ]]; then
        BRANCH_CLEAN=$(clean_branch "$CI_COMMIT_BRANCH")
        VERSION="${BRANCH_CLEAN}-${CI_COMMIT_SHORT_SHA}"

      # ── develop push ───────────────────────────────────────────────────────
      elif [[ "$CI_COMMIT_BRANCH" == "develop" ]]; then
        VERSION="dev-${CI_COMMIT_SHORT_SHA}"

      # ── sit-integration push — stable formal SIT surface ───────────────────
      elif [[ "$CI_COMMIT_BRANCH" == "sit-integration" ]]; then
        VERSION="sit-${CI_COMMIT_SHORT_SHA}"

      # ── main push — the only path that produces a production semver ────────
      elif [[ "$CI_COMMIT_BRANCH" == "main" ]]; then
        echo "Merge commit title: $CI_COMMIT_TITLE"

        # ── Idempotency guard ────────────────────────────────────────────────
        # Pipeline retry after ci/release/tag.yml already tagged this SHA:
        # reuse that semver — never compute a second bump.
        # BARE tags only — must match the LAST_TAG lookup and tag.yml.
        EXISTING_TAG=$(git tag --points-at HEAD | grep -E '^[0-9]+\.[0-9]+\.[0-9]+$' | head -1 || true)
        if [[ -n "$EXISTING_TAG" ]]; then
          VERSION="$EXISTING_TAG"
          echo "Semver tag ${EXISTING_TAG} already points at HEAD — reusing (pipeline retry)."

        # ── Gate 1: standard merge commit from an ALLOWED source ─────────────
        elif echo "$CI_COMMIT_TITLE" | grep -qE "^Merge branch '(release|hotfix)/"; then
          SRC_BRANCH=$(echo "$CI_COMMIT_TITLE" | sed -n "s/^Merge branch '\([^']*\)'.*/\1/p")

          # ── Gate 1a: title matched the grep but yielded no branch name ──────
          # Without this, an empty SRC_BRANCH falls to the case default and
          # reports a confusing "Unsupported source branch ''".
          if [[ -z "$SRC_BRANCH" ]]; then
            echo "   ERROR: Malformed merge commit title — source branch not extractable."
            echo "   Title was : $CI_COMMIT_TITLE"
            exit 1
          fi

          # Bump level comes from the source branch name only
          case "$SRC_BRANCH" in
            release/major-*)  BUMP="major" ;;
            release/minor-*)  BUMP="minor" ;;
            hotfix/*)         BUMP="patch" ;;
            *)
              echo "   ERROR: Unsupported source branch '${SRC_BRANCH}' merged to main."
              echo "   Only release/major-*, release/minor-* and hotfix/* may merge to main."
              exit 1
              ;;
          esac

          # ── Latest BARE semver tag (no v-prefix) ───────────────────────────
          LAST_TAG=$(git tag -l | grep -E '^[0-9]+\.[0-9]+\.[0-9]+$' | sort -V | tail -1 || true)

          if [[ -z "$LAST_TAG" ]]; then
            VERSION="${INITIAL_VERSION}"
            echo "No prior semver tag found — starting at ${VERSION}"
          else
            IFS=. read -r MAJ MIN PAT <<< "$LAST_TAG"
            case "$BUMP" in
              major) MAJ=$((MAJ + 1)); MIN=0; PAT=0 ;;
              minor) MIN=$((MIN + 1)); PAT=0 ;;
              patch) PAT=$((PAT + 1)) ;;
            esac
            VERSION="${MAJ}.${MIN}.${PAT}"
          fi
          echo "Semver: ${LAST_TAG:-<none>} → ${VERSION}  (${BUMP} bump from ${SRC_BRANCH})"
          echo "VERSION_BUMP=${BUMP}"                >> version.env
          echo "VERSION_SOURCE_BRANCH=${SRC_BRANCH}" >> version.env

          # ── Source branch tip SHA, for ci/image/image.retag.yml ──────────────
          # The retag job runs in a podman image that has NO git binary, so it
          # cannot read HEAD^2 itself. This job DOES have git, so compute the
          # merge commit's 2nd parent here and hand it downstream via dotenv.
          # HEAD^2 = tip of the merged release/hotfix branch = the commit the
          # bank-approved image was built from.
          # Computed with `git log --format=%P` rather than `git rev-parse HEAD^2`
          # to avoid any shell handling of the '^' character.
          PARENT_SHA=$(git log -1 --format='%P' | awk '{print substr($2,1,8)}')
          if [[ -z "$PARENT_SHA" ]]; then
            echo "❌ ERROR: merge commit has no 2nd parent — cannot identify the"
            echo "   tested release/hotfix image for production retagging."
            echo "   Parents: $(git log -1 --format='%P')"
            echo "   Root cause : squash or fast-forward merge was used on main."
            echo "   Fix        : Settings → Merge requests → Merge method →"
            echo "                'Merge commit', and disable squash."
            exit 1
          fi
          echo "MERGE_PARENT_SHA=${PARENT_SHA}" >> version.env
          echo "Merge parent-2 (tested tip): ${PARENT_SHA}"

        # ── Gate 2: a merge commit, but from a FORBIDDEN source branch ───────
        # e.g. feature/* or develop merged straight to main — a policy breach,
        # distinct from the squash/rebase case below.
        elif echo "$CI_COMMIT_TITLE" | grep -qE "^Merge branch '"; then
          echo "   ERROR: Merge to main from unsupported source branch."
          echo "   Title was : $CI_COMMIT_TITLE"
          echo "   Only release/* (minor/major bump) and hotfix/* (patch bump)"
          echo "   may merge to main."
          echo ""
          echo "   Root cause : Protected-branch / MR-approval policy breach."
          echo "   Fix        : Review MR approval rules and protected branch"
          echo "                settings for 'main'; revert the offending merge."
          exit 1

        # ── Gate 3: not a standard merge commit at all ───────────────────────
        # No "Merge branch '…'" subject → squash or rebase merge was used.
        else
          echo "   ERROR: Cannot determine source branch from merge commit title."
          echo "   Title was  : $CI_COMMIT_TITLE"
          echo "   Expected   : \"Merge branch 'release/…' into 'main'\""
          echo "   OR         : \"Merge branch 'hotfix/…' into 'main'\""
          echo ""
          echo "   Root cause : Squash or rebase merge was used on Protected branch 'main'."
          echo "   Fix        : GitLab → Project → Settings → General → Merge requests"
          echo "                Merge method → select 'Merge commit'"
          echo "                Re-raise the MR and merge again."
          exit 1
        fi

      # ── Unrecognised branch ────────────────────────────────────────────────
      # Should not occur — the Push Rule blocks non-conforming branch names.
      # Catches a manual pipeline run on an unexpected branch.
      else
        echo "  WARNING: Unrecognised branch '${CI_COMMIT_BRANCH}' — using SHA"
        VERSION="unknown-${CI_COMMIT_SHORT_SHA}"
      fi

      # ── Write dotenv ────────────────────────────────────────────────────────
      # BRANCH_USED: CI_COMMIT_BRANCH is empty on an MR pipeline — use the source.
      if [[ "$CI_PIPELINE_SOURCE" == "merge_request_event" ]]; then
        echo "BRANCH_USED=${CI_MERGE_REQUEST_SOURCE_BRANCH_NAME}" >> version.env
      else
        echo "BRANCH_USED=${CI_COMMIT_BRANCH}"                    >> version.env
      fi
      echo "VERSION=$VERSION"                           >> version.env
      echo "CI_COMMIT_SHORT_SHA=$CI_COMMIT_SHORT_SHA"   >> version.env

      # ── Summary ─────────────────────────────────────────────────────────────
      echo "──────────────────────────────────────────────────────"
      echo "Source  : ${CI_PIPELINE_SOURCE}"
      if [[ "$CI_PIPELINE_SOURCE" == "merge_request_event" ]]; then
        echo "MR      : ${CI_MERGE_REQUEST_SOURCE_BRANCH_NAME} → ${CI_MERGE_REQUEST_TARGET_BRANCH_NAME}"
      else
        echo "Branch  : ${CI_COMMIT_BRANCH}"
      fi
      echo "VERSION : ${VERSION}"
      echo "──────────────────────────────────────────────────────"

  artifacts:
    reports:
      dotenv: version.env
    expire_in: 1 day
  rules:                    # runs on every pipeline type — all branches + MRs
    - when: on_success










