# =============================================================================
#  Governance - APPLY job  (WRITES TO GITLAB)
# =============================================================================
#  Makes the actual changes, then auto-runs verify and prints the result.
#
#  Runs when ALL of these are true:
#    - RUN_GOVERNANCE == "true"        explicit gate
#    - GOV_MODE       == "apply"       explicit mode
#    - CI_COMMIT_REF_PROTECTED         protected branch only
#    - a human clicks the manual play button
#
#  Multi-repo runs via subgroup/batch are FAIL-STOP: the job halts on the first
#  repo that errors, so a bad config cannot propagate across repos. Repos
#  completed before the failure are listed in the job log and artifact.
#
#  The run log is saved as a build artifact for 90 days for the audit trail.
# =============================================================================

governance:apply:
  extends: .governance_base
  script:
    - 'echo "===== GOVERNANCE APPLY - WRITES ENABLED ====="'
    - 'echo "Triggered by : $GITLAB_USER_LOGIN"'
    - 'echo "Pipeline     : $CI_PIPELINE_ID"'
    - 'echo "Branch       : $CI_COMMIT_REF_NAME"'
    - 'echo "Protected    : $CI_COMMIT_REF_PROTECTED"'
    - 'python3 "$GOV_SCRIPT" $GOV_FLAG "$GOV_TARGET"'
    - 'echo "===== APPLY COMPLETE - review the VERIFY block above ====="'
  rules:
    - if: '$RUN_GOVERNANCE == "true" && $GOV_MODE == "apply" && $CI_COMMIT_REF_PROTECTED == "true"'
      when: manual
      allow_failure: false
    - when: never
  environment:
    name: governance







