# ci/image/image.retag.yml  |  Stage: image-retag (main only)
# ──────────────────────────────────────────────────────────────────────────────
# GOAL: production runs the EXACT image (same digest, same bytes) that the bank
# approved after SIT / UAT / PreProd testing. Production NEVER rebuilds from
# source — a rebuild could produce different bytes than what was approved.
#
# On a release/* → main (or hotfix/* → main) merge this job:
#   1. takes the source branch name + tested tip SHA from the version job
#   2. reconstructs the approved image tag  = <clean-branch>-<short-sha>
#   3. pulls that approved image from JFrog  (FAILS HARD if missing — no rebuild)
#   4. re-tags it with the production semver
#   5. pushes — same digest, new tag
#
# ── WHY THIS JOB USES NO GIT ──────────────────────────────────────────────────
# The podman image used here (podman-jf:9.7) does NOT contain a git binary —
# verified in a live pipeline run ("git: command not found"). Earlier versions of
# this job called `git rev-parse HEAD^2`, which silently returned empty and was
# misreported as "not a merge commit".
#
# Instead, ci/version/semver.yml — which runs in rhelgit-oc-helm:1.0 and DOES
# have git — computes the merge commit's 2nd parent and exports it as
# MERGE_PARENT_SHA via the version.env dotenv artifact. This job simply reads it.
#
# Required dotenv inputs from the `version` job:
#   VERSION               prod semver, e.g. 2.1.0
#   VERSION_SOURCE_BRANCH source branch, e.g. release/minor-DM…-EPAY-…
#   MERGE_PARENT_SHA      tested release/hotfix branch tip, 8-char short SHA
#
# LOAD-BEARING: requires MERGE-COMMIT method (--no-ff) on main. semver.yml fails
# the pipeline if the merge commit has no 2nd parent, so this job never runs on a
# squashed or fast-forwarded merge.
# ──────────────────────────────────────────────────────────────────────────────

.image_retag:
  stage: image-push
  # podman only — this template intentionally requires NO git.
  image: artifactory.jfrog.sbi:443/dso-docker-base-images/ubi9/podman-jf:9.7
  tags:
    - common_runner
  before_script:
    - mkdir -p /etc/containers/certs.d/${CI_TEMPLATE_REGISTRY_HOST}
    - cp "$ARTIFACTORY_CERT" /etc/containers/certs.d/${CI_TEMPLATE_REGISTRY_HOST}/ca.crt
    - podman login "$CI_TEMPLATE_REGISTRY_HOST" -u "$JF_USER" -p "$JF_TOKEN"
  script:
    - |
      # SOURCE_TAG and TARGET_TAG must be set by the calling job
      if [ -z "$SOURCE_TAG" ] || [ -z "$TARGET_TAG" ]; then
        echo "ERROR: SOURCE_TAG and TARGET_TAG required"
        exit 1
      fi
      SOURCE="$CI_TEMPLATE_REGISTRY_HOST/$IMAGE_NAME:$SOURCE_TAG"
      TARGET="$CI_TEMPLATE_REGISTRY_HOST/$IMAGE_NAME:$TARGET_TAG"
      echo "Retagging: $SOURCE -> $TARGET"
      podman pull "$SOURCE" --tls-verify=false
      podman tag  "$SOURCE" "$TARGET"
      podman push "$TARGET" --tls-verify=false
      echo "Retagged: $TARGET"

# NOTE: the reusable retag logic lives in the hidden .image_retag template above.
# There is intentionally NO concrete "image:retag" job — a bare job with no rules
# runs on every pipeline (that is why it once appeared on release/* branches).
# The only concrete retag job is image:retag-prod below, gated to main push only.

# ── Main-merge retag → prod semver (anti-rebuild guard) ────────────────────────
image:retag-prod:
  extends: .image_retag
  stage: image-retag
  variables:
    # No git is used, so no working tree is needed. This also makes the job
    # faster and removes any clone-depth / checkout failure mode entirely.
    GIT_STRATEGY: none
  needs:
    - job: version
      artifacts: true    # VERSION, VERSION_SOURCE_BRANCH, MERGE_PARENT_SHA
  script:
    - |
      set -eo pipefail

      # ── Inputs (all from the version job's dotenv — no git required) ────────
      echo "VERSION               : ${VERSION:-<unset>}"
      echo "VERSION_SOURCE_BRANCH : ${VERSION_SOURCE_BRANCH:-<unset>}"
      echo "MERGE_PARENT_SHA      : ${MERGE_PARENT_SHA:-<unset>}"
      echo "IMAGE_NAME            : ${IMAGE_NAME:-<unset>}"

      # VERSION must be a clean prod semver (main path only)
      if ! echo "$VERSION" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+$'; then
        echo "ERROR: VERSION '$VERSION' is not clean semver — retag runs on main only." >&2
        exit 1
      fi

      SRC_BRANCH="${VERSION_SOURCE_BRANCH}"
      SRC_SHA="${MERGE_PARENT_SHA}"

      if [ -z "$SRC_BRANCH" ] || [ -z "$SRC_SHA" ]; then
        echo "ERROR: missing input from the version job." >&2
        echo "  VERSION_SOURCE_BRANCH='${SRC_BRANCH}'  MERGE_PARENT_SHA='${SRC_SHA}'" >&2
        echo "  Both are exported by ci/version/semver.yml on the main merge path." >&2
        echo "  Check that the 'version' job succeeded and its dotenv was consumed." >&2
        exit 1
      fi

      case "$SRC_BRANCH" in
        release/*|hotfix/*) : ;;
        *) echo "ERROR: source '$SRC_BRANCH' is not release/* or hotfix/* — nothing approved to retag." >&2; exit 1 ;;
      esac

      # clean_branch() — MUST stay byte-identical to ci/version/semver.yml
      clean_branch() {
        echo "$1"                        \
          | sed 's/[^a-zA-Z0-9._-]/-/g' \
          | tr '[:upper:]' '[:lower:]'   \
          | sed 's/--*/-/g'              \
          | sed 's/^-//; s/-$//'         \
          | cut -c1-40
      }

      # Reconstruct the approved image tag = <clean-branch>-<short-sha>
      APPROVED_TAG="$(clean_branch "$SRC_BRANCH")-${SRC_SHA}"
      SOURCE="$CI_TEMPLATE_REGISTRY_HOST/$IMAGE_NAME:${APPROVED_TAG}"
      TARGET="$CI_TEMPLATE_REGISTRY_HOST/$IMAGE_NAME:${VERSION}"

      echo "Source branch : $SRC_BRANCH"
      echo "Tested tip SHA: $SRC_SHA"
      echo "Tested image  : $SOURCE"
      echo "Prod semver   : $VERSION"
      echo "Target image  : $TARGET"

      # ── ANTI-REBUILD GUARD: the approved image MUST already exist ───────────
      if ! podman pull "$SOURCE" --tls-verify=false; then
        echo "ERROR: tested image $SOURCE not found. Retag must not rebuild. Aborting." >&2
        echo "  The release/hotfix pipeline did not leave this tag, or it expired."      >&2
        echo "  DO NOT rebuild. Re-run the release/hotfix pipeline to republish, then"   >&2
        echo "  re-run this main pipeline."                                              >&2
        exit 1
      fi

      # Retag the SAME digest — no rebuild
      podman tag  "$SOURCE" "$TARGET"
      podman push "$TARGET" --tls-verify=false

      echo "PROD_IMAGE=$TARGET"       >> retag.env
      echo "APPROVED_SOURCE=$SOURCE"  >> retag.env
      echo "TESTED_TIP_SHA=$SRC_SHA"  >> retag.env
      echo "Retagged tested image -> prod: $TARGET"
  artifacts:
    reports:
      dotenv: retag.env
    expire_in: 1 week
  rules:
    - if: '$CI_PIPELINE_SOURCE == "push" && $CI_COMMIT_BRANCH == "main"'
      when: on_success
    - when: never



