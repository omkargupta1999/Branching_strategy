#!/usr/bin/env python3
"""
audit_access_tree.py
====================

Walks an entire GitLab group hierarchy and reports, for every subgroup and
project, exactly who has access -- distinguishing DIRECT members from
INHERITED ones (and, for projects, members inherited from ancestor groups).

Purpose: pinpoint *where* a group/user grant actually lives so you can revoke
it at the correct source instead of chasing it across child repos.

House style: Python standard library ONLY (urllib, json, getpass). No pip.
Secrets prompted at runtime. Idempotent / read-only -- this script never
modifies anything.

GitLab access_level reference:
    0   No access
   10   Guest
   20   Reporter
   30   Developer
   40   Maintainer
   50   Owner
"""

import json
import sys
import ssl
import getpass
import urllib.request
import urllib.parse
import urllib.error

# ---------------------------------------------------------------------------
# Configuration -- edit these two, or accept the prompts at runtime.
# ---------------------------------------------------------------------------

# Path-only (NOT a full URL). For the screenshot this is the top-level group.
ROOT_GROUP = "itepaypg-sbiepay2"

# Base API URL of THIS instance. No trailing slash. Must match the PAT's instance.
GITLAB_BASE = "https://gitlab.sbi"

# Set to False ONLY if the instance uses an internal CA your Python doesn't
# trust and you cannot point REQUESTS_CA_BUNDLE / SSL_CERT_FILE at it.
VERIFY_TLS = True

ACCESS_LEVELS = {
    0: "No access",
    5: "Minimal",
    10: "Guest",
    20: "Reporter",
    30: "Developer",
    40: "Maintainer",
    50: "Owner",
}


# ---------------------------------------------------------------------------
# Low-level HTTP helpers
# ---------------------------------------------------------------------------

def _ssl_context():
    if VERIFY_TLS:
        return ssl.create_default_context()
    ctx = ssl.create_default_context()
    ctx.check_hostname = False
    ctx.verify_mode = ssl.CERT_NONE
    return ctx


def api_get(token, path, params=None):
    """
    GET /api/v4/<path>. Transparently follows GitLab keyset/offset pagination
    via the Link header and returns the concatenated list (or single dict).
    """
    if params is None:
        params = {}
    params.setdefault("per_page", 100)

    url = "{base}/api/v4/{path}?{qs}".format(
        base=GITLAB_BASE.rstrip("/"),
        path=path.lstrip("/"),
        qs=urllib.parse.urlencode(params),
    )

    results = []
    ctx = _ssl_context()

    while url:
        req = urllib.request.Request(url, method="GET")
        req.add_header("PRIVATE-TOKEN", token)
        try:
            with urllib.request.urlopen(req, context=ctx, timeout=60) as resp:
                body = resp.read().decode("utf-8")
                data = json.loads(body) if body else []
                if isinstance(data, list):
                    results.extend(data)
                else:
                    return data  # single object endpoint
                # pagination via Link header
                link = resp.headers.get("Link", "")
                url = _next_link(link)
        except urllib.error.HTTPError as e:
            detail = e.read().decode("utf-8", "replace")
            raise RuntimeError(
                "HTTP {code} on {u}\n  -> {d}".format(code=e.code, u=url, d=detail)
            )
        except urllib.error.URLError as e:
            raise RuntimeError("Network/TLS error on {u}\n  -> {r}".format(u=url, r=e.reason))

    return results


def _next_link(link_header):
    """Extract the rel="next" URL from an RFC 5988 Link header, or None."""
    if not link_header:
        return None
    for part in link_header.split(","):
        segs = part.split(";")
        if len(segs) < 2:
            continue
        url_part = segs[0].strip().lstrip("<").rstrip(">")
        for seg in segs[1:]:
            if 'rel="next"' in seg:
                return url_part
    return None


# ---------------------------------------------------------------------------
# Domain helpers
# ---------------------------------------------------------------------------

def lvl(n):
    return "{:>2} {}".format(n, ACCESS_LEVELS.get(n, "Custom/Unknown"))


def get_group(token, group_ref):
    enc = urllib.parse.quote(str(group_ref), safe="")
    return api_get(token, "groups/{}".format(enc))


def get_subgroups(token, group_id):
    return api_get(token, "groups/{}/subgroups".format(group_id))


def get_group_projects(token, group_id):
    # include_subgroups=False: we recurse the tree ourselves so each project
    # is listed under its true parent rather than flattened to the root.
    return api_get(token, "groups/{}/projects".format(group_id),
                   {"include_subgroups": "false", "with_shared": "false"})


def get_group_members_all(token, group_id):
    """All members INCLUDING inherited from ancestor groups."""
    return api_get(token, "groups/{}/members/all".format(group_id))


def get_group_members_direct(token, group_id):
    """Only members added DIRECTLY to this group."""
    return api_get(token, "groups/{}/members".format(group_id))


def get_project_members_all(token, project_id):
    return api_get(token, "projects/{}/members/all".format(project_id))


def get_project_members_direct(token, project_id):
    return api_get(token, "projects/{}/members".format(project_id))


def get_project_shared_groups(token, project_id):
    """Groups the project has been shared with (group-invited-to-project)."""
    proj = api_get(token, "projects/{}".format(project_id))
    if isinstance(proj, dict):
        return proj.get("shared_with_groups", []) or []
    return []


# ---------------------------------------------------------------------------
# Reporting
# ---------------------------------------------------------------------------

def member_line(m, direct_ids):
    """Format one member; mark DIRECT vs INHERITED using direct_ids set."""
    uid = m.get("id")
    name = m.get("name", "?")
    username = m.get("username", "?")
    access = m.get("access_level", 0)
    tag = "DIRECT   " if uid in direct_ids else "INHERITED"
    return "        [{tag}] {name} (@{user})  ->  {acc}".format(
        tag=tag, name=name, user=username, acc=lvl(access)
    )


def report_group(token, group, depth):
    pad = "  " * depth
    gid = group["id"]
    print("{p}GROUP  {full}  (id={gid})".format(
        p=pad, full=group["full_path"], gid=gid))

    all_m = get_group_members_all(token, gid)
    direct_m = get_group_members_direct(token, gid)
    direct_ids = {m["id"] for m in direct_m}

    if all_m:
        for m in sorted(all_m, key=lambda x: (-x.get("access_level", 0), x.get("username", ""))):
            print(pad + member_line(m, direct_ids))
    else:
        print(pad + "        (no members)")

    # projects directly under this group
    for proj in get_group_projects(token, gid):
        report_project(token, proj, depth + 1)

    # recurse subgroups
    for sub in get_subgroups(token, gid):
        full_sub = get_group(token, sub["id"])  # full obj for full_path
        report_group(token, full_sub, depth + 1)


def report_project(token, proj, depth):
    pad = "  " * depth
    pid = proj["id"]
    print("{p}PROJECT  {full}  (id={pid})".format(
        p=pad, full=proj["path_with_namespace"], pid=pid))

    all_m = get_project_members_all(token, pid)
    direct_m = get_project_members_direct(token, pid)
    direct_ids = {m["id"] for m in direct_m}

    if all_m:
        for m in sorted(all_m, key=lambda x: (-x.get("access_level", 0), x.get("username", ""))):
            print(pad + member_line(m, direct_ids))
    else:
        print(pad + "        (no members)")

    shared = get_project_shared_groups(token, pid)
    for sg in shared:
        print("{p}        [SHARED-GROUP] {name} (id={gid})  ->  {acc}".format(
            p=pad,
            name=sg.get("group_full_path", sg.get("group_name", "?")),
            gid=sg.get("group_id"),
            acc=lvl(sg.get("group_access_level", 0)),
        ))


# ---------------------------------------------------------------------------
# Focused lookup: trace one user across the whole tree
# ---------------------------------------------------------------------------

def trace_user(token, root_group, username):
    """
    Walk the tree and print every place `username` appears, flagged DIRECT
    or INHERITED. The DIRECT hits are the grants you actually need to remove.
    """
    print("\n" + "=" * 70)
    print("TRACE for user @{u} -- DIRECT hits are the real source grants".format(u=username))
    print("=" * 70)

    hits = {"direct": [], "inherited": []}

    def walk_group(group, depth):
        gid = group["id"]
        all_m = get_group_members_all(token, gid)
        direct_ids = {m["id"] for m in get_group_members_direct(token, gid)}
        for m in all_m:
            if m.get("username") == username:
                bucket = "direct" if m["id"] in direct_ids else "inherited"
                hits[bucket].append(("GROUP", group["full_path"], m.get("access_level", 0)))
        for proj in get_group_projects(token, gid):
            pid = proj["id"]
            pall = get_project_members_all(token, pid)
            pdir = {x["id"] for x in get_project_members_direct(token, pid)}
            for m in pall:
                if m.get("username") == username:
                    bucket = "direct" if m["id"] in pdir else "inherited"
                    hits[bucket].append(("PROJECT", proj["path_with_namespace"], m.get("access_level", 0)))
        for sub in get_subgroups(token, gid):
            walk_group(get_group(token, sub["id"]), depth + 1)

    walk_group(root_group, 0)

    print("\n-- DIRECT grants (REMOVE THESE to revoke access) --")
    if hits["direct"]:
        for kind, path, acc in hits["direct"]:
            print("   {k:8} {p}  ->  {a}".format(k=kind, p=path, a=lvl(acc)))
    else:
        print("   (none -- all access is inherited; remove at the parent group below)")

    print("\n-- INHERITED grants (consequences of the above; do NOT touch these) --")
    if hits["inherited"]:
        for kind, path, acc in hits["inherited"]:
            print("   {k:8} {p}  ->  {a}".format(k=kind, p=path, a=lvl(acc)))
    else:
        print("   (none)")
    print("=" * 70)


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    print("GitLab Access Tree Auditor (read-only)")
    print("Instance: {}".format(GITLAB_BASE))
    print("Root group: {}".format(ROOT_GROUP))
    print("-" * 70)

    token = getpass.getpass("GitLab PAT (api scope, hidden input): ").strip()
    if not token:
        print("No token provided. Aborting.")
        sys.exit(1)

    # sanity check the token + instance match before walking the whole tree
    try:
        me = api_get(token, "user")
        print("Authenticated as: @{u} (id={i})\n".format(
            u=me.get("username"), i=me.get("id")))
    except RuntimeError as e:
        print("AUTH/CONNECT FAILED:\n  {}".format(e))
        print("\nCommon causes:")
        print("  * PAT belongs to a DIFFERENT instance than GITLAB_BASE")
        print("  * PAT lacks 'api' (or at least 'read_api') scope")
        print("  * GITLAB_BASE wrong / proxy intercepting TLS / internal CA untrusted")
        sys.exit(2)

    try:
        root = get_group(token, ROOT_GROUP)
    except RuntimeError as e:
        print("Could not resolve root group '{}':\n  {}".format(ROOT_GROUP, e))
        print("Make sure ROOT_GROUP is the PATH (e.g. 'itepaypg-sbiepay2'), not a URL.")
        sys.exit(3)

    print("FULL ACCESS TREE")
    print("=" * 70)
    report_group(token, root, 0)

    # Optional focused trace.
    target = input("\nTrace a specific username? (blank to skip): ").strip()
    if target:
        trace_user(token, root, target)


if __name__ == "__main__":
    main()
