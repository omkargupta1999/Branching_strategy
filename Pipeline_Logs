def risk_fill_font(risk):
    mapping = {
        "HIGH":     (C_HIGH,     C_HIGH_TXT),
        "MEDIUM":   (C_MEDIUM,   C_MEDIUM_TXT),
        "LOW":      (C_LOW,      C_LOW_TXT),
        "ARCHIVED": (C_ARCHIVED, C_ARCHIVED_TXT),
    }
    bg, fg = mapping.get(risk, (C_WHITE, C_BLACK))
    return fill(bg), Font(name="Arial", bold=True, color=fg, size=9)


def set_col_widths(ws, widths):
    """widths = list of (col_letter_or_idx, width)"""
