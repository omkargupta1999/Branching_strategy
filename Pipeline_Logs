# ci/build/python.yml  |  Stage: build
# Python microservice build
#
# ── Dependency resolution — JFrog Python virtual repository ──────────────────
# Registry: https://artifactory.jfrog.sbi/artifactory/api/pypi/itepaypg-sbiepay2-python-virtual/simple
# Auth: JF_USER + JF_TOKEN embedded in index-url
# SSL: JFrog internal CA added to OS trust store (update-ca-trust) and pip
#      pointed at the extracted PEM bundle — trusted-host NOT used (security risk)
#
# ── Prerequisites (GitLab CI/CD Variables) ───────────────────────────────────
# ARTIFACTORY_CERT  — Type: File — PEM-encoded JFrog internal CA certificate
#                     Settings → CI/CD → Variables → Add variable (Type = File)
# JF_USER           — JFrog username
# JF_TOKEN          — JFrog identity token / API key
#
# ── Cache ─────────────────────────────────────────────────────────────────────
# pip downloads cached in .pip-cache/ (project-relative, Docker executor safe)
# PIP_CACHE_DIR redirects ~/.cache/pip → .pip-cache/
# pip re-uses downloaded tarballs on next run — avoids re-downloading from JFrog
#
# ── App repo requirements ─────────────────────────────────────────────────────
# requirements.txt  — runtime dependencies
# pyproject.toml    — build config (PEP 517/518)  OR  setup.py
#
# Produces: dist/*.whl — consumed by Dockerfile (COPY + pip install dist/*.whl)
# Version injected via --metadata-version or pyproject.toml dynamic versioning

.build:
  stage: build
  image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-virtual/ubi9/python-39:1-1778000668
  tags:
    - common_runner
  variables:
    # Redirect pip cache to project-relative path — required for Docker executor cache
    PIP_CACHE_DIR: "${CI_PROJECT_DIR}/.pip-cache"
  cache:
    key: "${CI_PROJECT_NAME}-pip-${CI_COMMIT_REF_SLUG}"
    paths:
      - .pip-cache/   # pip downloaded package cache
  before_script:
    - python3 --version
    - pip3 --version

    # ── Trust JFrog internal CA ───────────────────────────────────────────
    # ARTIFACTORY_CERT is a GitLab CI/CD File variable containing the PEM cert.
    # 1. Copy it into the OS CA anchor directory
    # 2. Rebuild the system trust store (update-ca-trust extract)
    # 3. Point pip at the rebuilt PEM bundle — avoids SSLCertVerificationError
    - cp "$ARTIFACTORY_CERT" /etc/pki/ca-trust/source/anchors/jfrog-internal.crt
    - update-ca-trust extract
    - pip3 config set global.cert /etc/pki/ca-trust/extracted/pem/tls-ca-bundle.pem

    # ── Configure pip to use JFrog Python virtual repository ──────────────
    # Credentials embedded in index-url — standard JFrog pip pattern
    # Note: URL with credentials may appear in verbose pip output;
    #       use --quiet flag in pip commands to reduce log verbosity
    - pip3 config set global.index-url "https://${JF_USER}:${JF_TOKEN}@artifactory.jfrog.sbi/artifactory/api/pypi/itepaypg-sbiepay2-python-virtual/simple"

  script:
    - |
      set -eo pipefail

      # ── Validate VERSION ──────────────────────────────────────────────────
      if [ -z "$VERSION" ]; then
        echo "❌ ERROR: VERSION is empty — semver.yml dotenv artifact not loaded"
        exit 1
      fi
      echo "Building VERSION: ${VERSION}"

      # ── Install runtime dependencies ──────────────────────────────────────
      pip3 install --quiet -r requirements.txt

      # ── Install build tools from JFrog ─────────────────────────────────────
      pip3 install --quiet build wheel setuptools

      # ── Build wheel package ───────────────────────────────────────────────
      # --no-isolation: builds without creating a virtual environment
      #                 faster — build tools already installed above
      # Version injection: SETUPTOOLS_SCM_PRETEND_VERSION works with setuptools-scm
      # For other build backends (hatch, flit, poetry): set version differently
      #   hatch:  HATCH_BUILD_HOOK_ENABLE_VERSION=1 (or set in pyproject.toml)
      #   flit:   version in pyproject.toml [tool.flit.metadata] version field
      #   poetry: version in pyproject.toml [tool.poetry] version field
      SETUPTOOLS_SCM_PRETEND_VERSION="${VERSION}" python3 -m build --wheel --no-isolation

      # ── Validate build output ─────────────────────────────────────────────
      if [ -z "$(ls dist/*.whl 2>/dev/null)" ]; then
        echo "❌ ERROR: No .whl found in dist/ — build may have failed"
        echo "   Check pyproject.toml [build-system] configuration"
        exit 1
      fi

      echo "Build output:"
      ls -lh dist/
      echo "✅ Build complete"

  artifacts:
    paths:
      - dist/
    expire_in: 1 day
