def resolve_project(full_path):
    # Accept either a numeric project ID or a full path.
    ident = str(full_path).strip()
    if ident.isdigit():
        enc = ident
    else:
        enc = urllib.parse.quote(ident, safe="")
    proj = api_get(f"/projects/{enc}")
    if not proj:
        log(f"\n[ERROR] Project not found: {full_path}")
        log("  Tip: pass the numeric project ID instead of the path, e.g.")
        log("       --project 2754")
        log("  Or copy the exact 'Full Path' from your repo_list CSV "
            "(paths are case-sensitive).")
        sys.exit(1)
    return proj["id"], proj["path_with_namespace"]

def resolve_groups(_unused=None):
    """Validate each hardcoded group ID exists & is visible (READ-ONLY).
       Returns the same name->id map. Aborts if any ID is unreachable."""
    resolved, missing = {}, []
    for name, gid in GROUP_IDS.items():
        g = api_get(f"/groups/{gid}")
        if g and g.get("id") == gid:
            resolved[name] = gid
        else:
            missing.append(f"{name} (id={gid})")
    if missing:
        log("\n[ERROR] These GitLab groups could not be reached by ID:")
        for m in missing:
            log(f"   - {m}")
        log("Aborting without making any changes. Re-run find_ldap_groups.py "
            "and update GROUP_IDS if IDs have changed on this instance.")
        sys.exit(2)
    return resolved

# =============================================================================
#  STEP 1 — GROUP INVITES (project share)
# =============================================================================

def apply_group_invites(pid, dry_run):
    log("\n=== Step 1: Group Invites (project share) ===")
    # Existing shared groups on the project, to make this idempotent.
    proj = api_get(f"/projects/{pid}")
    shared = {g.get("group_id"): g.get("group_access_level")
              for g in (proj.get("shared_with_groups", []) if proj else [])}

    for inv in GROUP_INVITES:
        gid, lvl, name = inv["id"], inv["access"], inv["name"]
        if shared.get(gid) == lvl:
            log(f"  '{name}' already shared at level {lvl} -> skip")
            continue
        if gid in shared:
            # Re-share at the correct level: unshare then share.
            api_delete(f"/projects/{pid}/share/{gid}", dry_run=dry_run)
        api_post(f"/projects/{pid}/share",
                 data={"group_id": gid, "group_access": lvl},
                 dry_run=dry_run, as_json=True)
        log(f"  shared '{name}' (id={gid}) at access level {lvl}")

# =============================================================================
#  STEP 2 — PUSH RULES
# =============================================================================

def apply_push_rules(pid, dry_run):
    log("\n=== Step 2: Push Rules ===")
    existing = api_get(f"/projects/{pid}/push_rule")
    if dry_run:
        verb = "update" if existing else "create"
        log(f"    [dry-run] would {verb} push rules")
        log(f"    branch_name_regex   : {PUSH_RULES['branch_name_regex']}")
        log(f"    commit_message_regex: {PUSH_RULES['commit_message_regex']}")
        return

    if existing:
        resp = api_put(f"/projects/{pid}/push_rule", data=PUSH_RULES, as_json=True)
        verb = "updated"
    else:
        resp = api_post(f"/projects/{pid}/push_rule", data=PUSH_RULES, as_json=True)
        verb = "created"

    # Read back to CONFIRM the write actually persisted (the create endpoint
    # can return 2xx without persisting on some 18.x configs). Trust the
    # read-back, not the POST response.
    after = api_get(f"/projects/{pid}/push_rule")
    persisted = (after
                 and after.get("branch_name_regex") == PUSH_RULES["branch_name_regex"]
                 and after.get("commit_message_regex") == PUSH_RULES["commit_message_regex"])

    # Fallback: push_rules is a flat-field endpoint; some 18.x builds only
    # accept form-encoded (not JSON) here. If JSON didn't persist, retry as form.
    if not persisted:
        log("  [info] JSON write did not persist; retrying form-encoded ...")
        existing2 = api_get(f"/projects/{pid}/push_rule")
        if existing2:
            resp = api_put(f"/projects/{pid}/push_rule", data=PUSH_RULES, as_json=False)
            verb = "updated"
        else:
            resp = api_post(f"/projects/{pid}/push_rule", data=PUSH_RULES, as_json=False)
            verb = "created"
        after = api_get(f"/projects/{pid}/push_rule")
        persisted = (after
                     and after.get("branch_name_regex") == PUSH_RULES["branch_name_regex"]
                     and after.get("commit_message_regex") == PUSH_RULES["commit_message_regex"])

    if persisted:
        log(f"  {verb} push rules — CONFIRMED on read-back")
        log(f"    branch_name_regex   : {after.get('branch_name_regex')}")
        log(f"    commit_message_regex: {after.get('commit_message_regex')}")
    else:
        log("  [WARN] push rules did NOT persist as expected.")
        log(f"    POST/PUT response: {json.dumps(resp) if resp else 'empty'}")
        log(f"    read-back: {json.dumps(after) if after else 'none'}")
        log("    -> push rules may require a different endpoint/permission on "
            "this instance; see notes.")

# =============================================================================
#  STEP 3 — PROTECTED BRANCHES
# =============================================================================

def get_protected_branch(pid, name):
    enc = urllib.parse.quote(name, safe="")
    return api_get(f"/projects/{pid}/protected_branches/{enc}")

def get_protected_branch_id(pid, name):
    """Resolve a protected branch's numeric ID reliably, including wildcard
       names like 'release/*'. The single-name GET endpoint is unreliable for
       wildcards on 18.1.x, so list all protected branches and match by name."""
    for pb in (api_get_all(f"/projects/{pid}/protected_branches") or []):
        if pb.get("name") == name:
            return pb.get("id")
    return None

def apply_protected_branches(pid, groups, dry_run):
    log("\n=== Step 3: Protected Branch Rules ===")
    for spec in PROTECTED_BRANCHES:
        name = spec["name"]
        enc  = urllib.parse.quote(name, safe="")
        if get_protected_branch_id(pid, name) is not None:
            log(f"  '{name}' already protected -> deleting to re-apply cleanly")
            api_delete(f"/projects/{pid}/protected_branches/{enc}", dry_run=dry_run)

        # push_access_level 0 = "No one" (an empty allowed_to_push array is
        # interpreted by GitLab as the default Maintainers level, NOT nobody,
        # so we set the level explicitly). allowed_to_merge stays a group array.
        data = {
            "name": name,
            "allow_force_push": False,
            "push_access_level": NO_ACCESS,   # 0 = No one
            "allowed_to_merge": [{"group_id": groups[gname]}
                                 for gname in spec["merge_groups"]],
        }

        api_post(f"/projects/{pid}/protected_branches", data=data,
                 dry_run=dry_run, as_json=True)
        log(f"  protected '{name}' | push: No one | merge: {', '.join(spec['merge_groups'])}")

# =============================================================================
#  STEP 4 — MR APPROVAL RULES
# =============================================================================

def apply_approval_rules(pid, groups, dry_run):
    log("\n=== Step 4: MR Approval Rules ===")
    # protected-branch name -> id (needed to target a rule at a branch)
    pb_ids = {}
    for spec in PROTECTED_BRANCHES:
        if dry_run:
            pb_ids[spec["name"]] = f"<pb-id:{spec['name']}>"
        else:
            pb_ids[spec["name"]] = get_protected_branch_id(pid, spec["name"])

    existing = {} if dry_run else {
        r["name"]: r for r in (api_get_all(f"/projects/{pid}/approval_rules") or [])
    }

    # --- Reconcile: delete any approval rule whose name is NOT in our spec ---
    # Keeps the repo's final state EXACTLY the 7 spec rules (no orphans from
    # earlier manual/UI config or prior script versions). GitLab's built-in
    # 'Any approver' default rule (rule_type 'any_approver') is left untouched.
    spec_names = {r["name"] for r in APPROVAL_RULES}
    if dry_run:
        log("  [reconcile] would delete any existing rule not in spec "
            "(dry-run cannot list live rules reliably; see real run)")
    else:
        for name, r in existing.items():
            if name in spec_names:
                continue
            if r.get("rule_type") == "any_approver":
                continue  # don't remove GitLab's default fallback rule
            api_delete(f"/projects/{pid}/approval_rules/{r['id']}", dry_run=dry_run)
            log(f"  [reconcile] deleted non-spec rule '{name}' (id={r['id']})")
        # Refresh after deletions so we don't try to PUT a just-deleted rule.
        existing = {
            r["name"]: r for r in (api_get_all(f"/projects/{pid}/approval_rules") or [])
        }

    for rule in APPROVAL_RULES:
        branch = rule["branch"]
        pbid   = pb_ids.get(branch)
        if pbid is None and not dry_run:
            log(f"  SKIP '{rule['name']}' (target branch '{branch}' not protected)")
            continue

        data = {
            "name": rule["name"],
            "approvals_required": rule["required"],
            "rule_type": "regular",
            "group_ids": [groups[rule["group"]]],
        }
        if pbid is not None:
            data["protected_branch_ids"] = [pbid]

        prev = existing.get(rule["name"])
        if prev:
            api_put(f"/projects/{pid}/approval_rules/{prev['id']}", data=data,
                    dry_run=dry_run, as_json=True)
            verb = "updated"
        else:
            api_post(f"/projects/{pid}/approval_rules", data=data,
                     dry_run=dry_run, as_json=True)
            verb = "created"
        log(f"  {verb} '{rule['name']}' -> '{branch}' | group {rule['group']} | required {rule['required']}")

