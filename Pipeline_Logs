ARG BASE_IMAGE_DEV_ENV
FROM ${BASE_IMAGE_DEV_ENV}

ARG ENV
ARG VERSION

ENV ENV=$ENV
ENV VERSION=$VERSION

# FIX 1: Relative path (no leading /)
COPY build/libs/epay_transaction_service-${VERSION}.jar .

ENTRYPOINT sh -c 'java -jar "epay_transaction_service-$VERSION.jar"'

USER root

# Copy certificates to their respective trust locations
COPY ./eissiuat.crt              /etc/pki/tls/certs/
COPY ./SBI-PROD-RCA.crt         /etc/pki/ca-trust/source/anchors/
COPY ./uat_sbiepay_sbi.crt      /etc/pki/ca-trust/source/anchors/
COPY ./epaycert.cer             /tmp

# Set correct ownership and permissions on CA trust certs
RUN chown root:root /etc/pki/ca-trust/source/anchors/SBI-PROD-RCA.crt && \
    chmod 644       /etc/pki/ca-trust/source/anchors/SBI-PROD-RCA.crt && \
    chown root:root /etc/pki/ca-trust/source/anchors/uat_sbiepay_sbi.crt && \
    chmod 644       /etc/pki/ca-trust/source/anchors/uat_sbiepay_sbi.crt

# Rebuild system CA trust store
RUN update-ca-trust enable && \
    update-ca-trust extract && \
    update-ca-trust

# FIX 2: Removed "RUN cd /usr/lib/jvm/java-21/bin" — no-op per shell, path doesn't exist
# FIX 3: Dynamic cacerts resolution — openjdk-21-runtime (UBI9) uses /etc/pki/java/cacerts
# FIX 4: -noprompt suppresses verbose certificate dump in build logs
RUN CACERTS=$(find /usr/lib/jvm -name "cacerts" 2>/dev/null | head -1) && \
    [ -z "$CACERTS" ] && CACERTS=/etc/pki/java/cacerts ; \
    keytool -import -trustcacerts -noprompt \
      -file /tmp/epaycert.cer \
      -keystore "$CACERTS" \
      -alias S3_EPAY_CERT \
      -storepass changeit
