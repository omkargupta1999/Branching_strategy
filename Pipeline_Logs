ARG BASE_IMAGE_DEV_ENV
FROM ${BASE_IMAGE_DEV_ENV}

ARG ENV
ARG VERSION

ENV ENV=$ENV
ENV VERSION=$VERSION

COPY ./epaycert.cer  /tmp
COPY ./sms.cer  /tmp

COPY build/libs/epay_reports_service-${VERSION}.jar .

ENTRYPOINT sh -c 'java -jar "epay_reports_service-$VERSION.jar"'

USER root

RUN mkdir -p /home/default/merchantreports && \
    chmod 777 -R /home/default/merchantreports

# FIX: Removed pointless "RUN cd /usr/lib/jvm/java-21/bin" lines.
#      Each RUN runs in a new shell so cd has no effect, and the path
#      doesn't exist anyway. keytool is already on $PATH in the JDK image.
RUN yes | keytool -import -trustcacerts \
      -file /tmp/epaycert.cer \
      -keystore /usr/lib/jvm/java-21/lib/security/cacerts \
      -alias S3_EPAY_CERT \
      -storepass changeit

RUN yes | keytool -import -trustcacerts \
      -file /tmp/sms.cer \
      -keystore /usr/lib/jvm/java-21/lib/security/cacerts \
      -alias DEV_EPAY_SMS \
      -storepass changeit
