.build:
  stage: build
  image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-virtual/ubi9/php-82:1-1778488703

  tags:
    - common_runner

  variables:
    COMPOSER_CACHE_DIR: "${CI_PROJECT_DIR}/.composer-cache"
    JF_ARTIFACTORY_URL: "https://artifactory.jfrog.sbi/artifactory"
    PHP_VIRTUAL_REPO: "itepaypg-sbiepay2-php-virtual"

  cache:
    key: "${CI_PROJECT_NAME}-composer-${CI_COMMIT_REF_SLUG}"
    paths:
      - .composer-cache/

  before_script:
    - php --version

    # ── Download Composer from JFrog ───────────────────────────────
    - |
      echo "Downloading Composer from JFrog..."

      curl -k -f \
        -u "${JF_USER}:${JF_TOKEN}" \
        "${JF_ARTIFACTORY_URL}/${PHP_VIRTUAL_REPO}/composer.phar" \
        -o composer.phar

      echo "Checking composer.phar..."
      ls -lh composer.phar

      SIZE=$(stat -c%s composer.phar)
      echo "File size: $SIZE"

      if [ "$SIZE" -lt 1000000 ]; then
        echo "ERROR: composer.phar too small — download likely failed"
        echo "Response content:"
        cat composer.phar
        exit 1
      fi

      chmod +x composer.phar
      mv composer.phar composer
      export PATH="$CI_PROJECT_DIR:$PATH"

      echo "Composer version:"
      composer --version

    # ── Configure Composer to use Artifactory Packagist proxy ──────
    - |
      composer config --global \
        repos.packagist composer \
        ${JF_ARTIFACTORY_URL}/api/composer/${PHP_VIRTUAL_REPO}

      composer config --global \
        http-basic.artifactory.jfrog.sbi "${JF_USER}" "${JF_TOKEN}"

  script:
    - |
      set -eo pipefail

      echo "===== SYSTEM INFO ====="
      free -h || true
      df -h || true

      echo "===== INSTALLING DEPENDENCIES ====="

      composer install \
        --no-dev \
        --optimize-autoloader \
        --no-interaction \
        --prefer-dist

      if [ ! -d "vendor" ]; then
        echo "ERROR: vendor folder not created"
        exit 1
      fi

      echo "Vendor count: $(ls vendor | wc -l)"
      echo "Build complete"

  artifacts:
    paths:
      - vendor/
    expire_in: 1 day
