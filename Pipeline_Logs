#!/usr/bin/env python3
"""
remove_direct_members.py
========================

Phase 1 (LIST):   Fetch and display EVERY direct member of a single project,
                  showing the "added by" source and role -- this is the
                  "Direct member by *" set you see in the GitLab UI.

Phase 2 (REMOVE): After you review the list, the script asks for an explicit
                  typed confirmation before deleting. Nothing is removed
                  unless you type the confirmation phrase. Inherited members
                  and shared-group members are NEVER touched (they are not
                  direct members and won't appear in the list).

House style: Python standard library ONLY. Secrets via getpass.

DEFAULTS:
  * DRY_RUN = True  -> lists only, removes NOTHING, even if you confirm.
    Set DRY_RUN = False to enable actual deletion (still gated by typed confirm).
  * Bots/service accounts are listed but EXCLUDED from removal by default
    (SKIP_BOTS = True) so you don't delete CI_BOT_TOKEN etc. by accident.

access_level: 10 Guest / 20 Reporter / 30 Developer / 40 Maintainer / 50 Owner
"""

import json
import sys
import ssl
import getpass
import urllib.request
import urllib.parse
import urllib.error

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------

GITLAB_BASE = "https://gitlab.sbi"          # must match the PAT's instance

# Project PATH (namespace/.../project). NOT a URL, NOT a numeric id here.
TARGET_PROJECT = "itepaypg-sbiepay2/infra/devops/ci-templates"

DRY_RUN = True          # True = never deletes. Set False to allow deletion.
SKIP_BOTS = True        # True = keep bot/service-account direct members.
VERIFY_TLS = True       # False only if internal CA untrusted and no CA bundle.

CONFIRM_PHRASE = "REMOVE"   # you must type this exactly to proceed in Phase 2.

ACCESS_LEVELS = {
    0: "No access", 5: "Minimal", 10: "Guest", 20: "Reporter",
    30: "Developer", 40: "Maintainer", 50: "Owner",
}


# ---------------------------------------------------------------------------
# HTTP helpers
# ---------------------------------------------------------------------------

def _ssl_context():
    if VERIFY_TLS:
        return ssl.create_default_context()
    ctx = ssl.create_default_context()
    ctx.check_hostname = False
    ctx.verify_mode = ssl.CERT_NONE
    return ctx


def _request(token, method, path, params=None):
    if params is None:
        params = {}
    params.setdefault("per_page", 100)
    url = "{base}/api/v4/{path}?{qs}".format(
        base=GITLAB_BASE.rstrip("/"),
        path=path.lstrip("/"),
        qs=urllib.parse.urlencode(params),
    )
    results = []
    ctx = _ssl_context()
    while url:
        req = urllib.request.Request(url, method=method)
        req.add_header("PRIVATE-TOKEN", token)
        try:
            with urllib.request.urlopen(req, context=ctx, timeout=60) as resp:
                if method == "DELETE":
                    return resp.status  # 204 on success
                body = resp.read().decode("utf-8")
                data = json.loads(body) if body else []
                if isinstance(data, list):
                    results.extend(data)
                else:
                    return data
                link = resp.headers.get("Link", "")
                url = _next_link(link)
        except urllib.error.HTTPError as e:
            detail = e.read().decode("utf-8", "replace")
            raise RuntimeError("HTTP {c} on {m} {u}\n  -> {d}".format(
                c=e.code, m=method, u=url, d=detail))
        except urllib.error.URLError as e:
            raise RuntimeError("Network/TLS error on {u}\n  -> {r}".format(
                u=url, r=e.reason))
    return results


def api_get(token, path, params=None):
    return _request(token, "GET", path, params)


def api_delete(token, path):
    return _request(token, "DELETE", path)


def _next_link(link_header):
    if not link_header:
        return None
    for part in link_header.split(","):
        segs = part.split(";")
        if len(segs) < 2:
            continue
        url_part = segs[0].strip().lstrip("<").rstrip(">")
        for seg in segs[1:]:
            if 'rel="next"' in seg:
                return url_part
    return None


def lvl(n):
    return "{} ({})".format(n, ACCESS_LEVELS.get(n, "Custom/Unknown"))


def is_bot(member):
    """Heuristic: GitLab bots/service accounts."""
    if member.get("bot"):
        return True
    uname = (member.get("username") or "")
    return uname.startswith("group_") or uname.startswith("project_") \
        or "_bot_" in uname


# ---------------------------------------------------------------------------
# Phase 1 -- LIST
# ---------------------------------------------------------------------------

def get_project(token, project_path):
    enc = urllib.parse.quote(project_path, safe="")
    return api_get(token, "projects/{}".format(enc))


def get_direct_members(token, project_id):
    """
    /projects/:id/members  -> DIRECT members only (the 'Direct member by *' set).
    Does NOT include inherited or shared-group members.
    """
    return api_get(token, "projects/{}/members".format(project_id))


def list_direct_members(token, project_id):
    members = get_direct_members(token, project_id)
    members.sort(key=lambda m: (-m.get("access_level", 0), m.get("username", "")))

    print("\n" + "=" * 74)
    print("DIRECT MEMBERS of project id={}".format(project_id))
    print("=" * 74)
    print("{:<3} {:<28} {:<14} {:<10} {}".format(
        "#", "username", "role", "kind", "name"))
    print("-" * 74)

    removable, skipped = [], []
    for i, m in enumerate(members, 1):
        bot = is_bot(m)
        kind = "BOT/SVC" if bot else "human"
        print("{:<3} @{:<27} {:<14} {:<10} {}".format(
            i,
            m.get("username", "?"),
            ACCESS_LEVELS.get(m.get("access_level", 0), "?"),
            kind,
            m.get("name", "?"),
        ))
        if bot and SKIP_BOTS:
            skipped.append(m)
        else:
            removable.append(m)

    print("-" * 74)
    print("Total direct members : {}".format(len(members)))
    print("Will target for removal: {}".format(len(removable)))
    print("Protected (bot/svc, kept): {}".format(len(skipped)))
    print("=" * 74)
    return removable, skipped


# ---------------------------------------------------------------------------
# Phase 2 -- REMOVE (gated)
# ---------------------------------------------------------------------------

def remove_members(token, project_id, removable):
    if DRY_RUN:
        print("\nDRY_RUN is ON -> no deletions performed.")
        print("To actually remove, set DRY_RUN = False at the top of the script.")
        return

    print("\nYou are about to REMOVE {} direct members from project id={}.".format(
        len(removable), project_id))
    print("This is PERMANENT (members can be re-invited later if needed).")
    ans = input("Type '{}' to proceed, anything else to abort: ".format(
        CONFIRM_PHRASE)).strip()
    if ans != CONFIRM_PHRASE:
        print("Aborted. Nothing removed.")
        return

    ok, fail = 0, 0
    for m in removable:
        uid = m["id"]
        uname = m.get("username", "?")
        try:
            status = api_delete(token, "projects/{}/members/{}".format(project_id, uid))
            if status in (200, 204):
                print("  removed @{} (id={})".format(uname, uid))
                ok += 1
            else:
                print("  unexpected status {} for @{}".format(status, uname))
                fail += 1
        except RuntimeError as e:
            print("  FAILED @{}: {}".format(uname, e))
            fail += 1

    print("\nDone. Removed: {}  Failed: {}".format(ok, fail))


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    print("GitLab Direct-Member Remover")
    print("Instance : {}".format(GITLAB_BASE))
    print("Project  : {}".format(TARGET_PROJECT))
    print("DRY_RUN  : {}   SKIP_BOTS : {}".format(DRY_RUN, SKIP_BOTS))
    print("-" * 74)

    token = getpass.getpass("GitLab PAT (api scope, hidden input): ").strip()
    if not token:
        print("No token. Aborting.")
        sys.exit(1)

    try:
        me = api_get(token, "user")
        print("Authenticated as: @{} (id={})".format(
            me.get("username"), me.get("id")))
    except RuntimeError as e:
        print("AUTH FAILED:\n  {}".format(e))
        sys.exit(2)

    try:
        proj = get_project(token, TARGET_PROJECT)
        pid = proj["id"]
        print("Resolved project: {} (id={})".format(
            proj.get("path_with_namespace"), pid))
    except (RuntimeError, KeyError) as e:
        print("Could not resolve project '{}':\n  {}".format(TARGET_PROJECT, e))
        print("Ensure TARGET_PROJECT is the PATH, not a URL, and PAT can see it.")
        sys.exit(3)

    # Phase 1
    removable, _skipped = list_direct_members(token, pid)

    if not removable:
        print("\nNothing to remove. Exiting.")
        return

    # Phase 2 (gated by DRY_RUN + typed confirmation)
    remove_members(token, pid, removable)


if __name__ == "__main__":
    main()
