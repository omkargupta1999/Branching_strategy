.build:
  stage: build
  image:
    name: registry.dev.sbiepay.sbi:8443/ubi9/reactjs_npm:20241113
    pull_policy: always

  script:
    - echo "=== BUILD STARTED ==="
    - pwd
    - ls -la

    # No internet proxy — deps come from internal Artifactory mirror
    # (every entry in package-lock.json resolves to artifactory.jfrog.sbi)
    - npm config delete proxy || true
    - npm config delete https-proxy || true
    - npm config set registry https://artifactory.jfrog.sbi:443/artifactory/api/npm/itepaypg-sbiepay2-npm-virtual/

    # If the Artifactory TLS cert isn't trusted by the image, either mount
    # the CA bundle, or (less ideal) disable strict-ssl:
    # - npm config set strict-ssl false

    # Install strictly from the lockfile (no public fallback)
    - npm ci --legacy-peer-deps

    - npm run build

    - |
      if [ -d "out" ]; then
        rm -rf dist && mkdir -p dist && cp -r out/* dist/
      elif [ -d "dist" ]; then
        echo "Using existing dist/"
      else
        echo "ERROR: No dist or out folder found"; exit 1
      fi

    - echo "=== FINAL DIST CONTENT ==="
    - ls -la dist
    - echo "=== BUILD COMPLETED ==="

  artifacts:
    paths:
      - dist/
    when: on_success
    expire_in: 1 week
