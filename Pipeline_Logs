stages:
  - build

# ─────────────────────────────────────────────────────────────
# STEP 1: Run this job ONCE manually to fix composer.lock
# After it succeeds, delete this job from the yaml
# ─────────────────────────────────────────────────────────────
regenerate-lock:
  stage: build
  image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-virtual/ubi9/php-82:1-1778488703
  tags:
    - common_runner
  variables:
    JF_ARTIFACTORY_URL: "https://artifactory.jfrog.sbi/artifactory"
    PHP_VIRTUAL_REPO: "itepaypg-sbiepay2-php-virtual"
    COMPOSER_ALLOW_SUPERUSER: "1"
  script:
    - git config --global --add safe.directory "${CI_PROJECT_DIR}"
    - php --version

    # Download Composer from JFrog
    - |
      set -eo pipefail
      echo "── Downloading Composer from JFrog ──"
      curl -f \
        --cacert "$JF_ARTIFACTORY_CERT" \
        -u "${JF_USER}:${JF_TOKEN}" \
        "${JF_ARTIFACTORY_URL}/${PHP_VIRTUAL_REPO}/composer.phar" \
        -o composer.phar
      SIZE=$(stat -c%s composer.phar)
      echo "Downloaded size: $SIZE bytes"
      if [ "$SIZE" -lt 1000000 ]; then
        echo "ERROR: composer.phar too small"
        exit 1
      fi
      chmod +x composer.phar
      mv composer.phar composer
      export PATH="$CI_PROJECT_DIR:$PATH"
      composer --version

    # Configure Composer to use JFrog only
    - |
      set -eo pipefail
      export PATH="$CI_PROJECT_DIR:$PATH"
      echo "── Configuring Composer ──"
      composer config --global repos.packagist composer \
        ${JF_ARTIFACTORY_URL}/api/composer/${PHP_VIRTUAL_REPO}
      composer config --global \
        http-basic.artifactory.jfrog.sbi "${JF_USER}" "${JF_TOKEN}"
      composer config --global cafile "$JF_ARTIFACTORY_CERT"
      composer config --global repo.packagist false
      composer config --global use-github-api false
      composer config --global preferred-install dist
      echo "── Composer configured ──"

    # Regenerate composer.lock via JFrog and commit it back
    - |
      set -eo pipefail
      export PATH="$CI_PROJECT_DIR:$PATH"

      echo "===== DELETING OLD composer.lock ====="
      rm -f composer.lock

      echo "===== REGENERATING composer.lock VIA JFROG ====="
      # --lock regenerates lock file only, keeping versions
      # that satisfy composer.json constraints — no version drift
      composer update --lock \
        --no-interaction \
        --prefer-dist \
        --no-source-fallback \
        -vvv

      echo "===== VERIFYING URLS IN LOCK FILE ====="
      JFROG_COUNT=$(grep -c "artifactory.jfrog.sbi" composer.lock || true)
      GITHUB_COUNT=$(grep -c "api.github.com" composer.lock || true)
      echo "JFrog URLs found   : $JFROG_COUNT"
      echo "GitHub URLs found  : $GITHUB_COUNT"

      if [ "$GITHUB_COUNT" -gt 0 ]; then
        echo "WARNING: Some GitHub URLs still present — check JFrog remote repo config"
      else
        echo "SUCCESS: All dist URLs point to JFrog"
      fi

      echo "===== COMMITTING NEW composer.lock TO REPO ====="
      git config user.email "ci-bot@sbi.com"
      git config user.name "GitLab CI"
      git add composer.lock
      git diff --cached --stat
      git commit -m "chore: regenerate composer.lock with JFrog dist URLs [skip ci]"
      git push \
        "https://oauth2:${CI_JOB_TOKEN}@${CI_SERVER_HOST}/${CI_PROJECT_PATH}.git" \
        HEAD:${CI_COMMIT_REF_NAME}

      echo "===== composer.lock COMMITTED SUCCESSFULLY ====="

  rules:
    - when: manual  # ← IMPORTANT: Only runs when you manually trigger it


# ─────────────────────────────────────────────────────────────
# STEP 2: This is your permanent build job
# It runs on every pipeline after composer.lock is fixed
# ─────────────────────────────────────────────────────────────
.build:
  stage: build
  image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-virtual/ubi9/php-82:1-1778488703
  tags:
    - common_runner
  variables:
    COMPOSER_CACHE_DIR: "${CI_PROJECT_DIR}/.composer-cache"
    JF_ARTIFACTORY_URL: "https://artifactory.jfrog.sbi/artifactory"
    PHP_VIRTUAL_REPO: "itepaypg-sbiepay2-php-virtual"
    COMPOSER_ALLOW_SUPERUSER: "1"
  cache:
    key: "${CI_PROJECT_NAME}-composer-${CI_COMMIT_REF_SLUG}"
    paths:
      - .composer-cache/
  before_script:
    - git config --global --add safe.directory "${CI_PROJECT_DIR}"
    - php --version

    # Download Composer from JFrog
    - |
      set -eo pipefail
      echo "── Downloading Composer from JFrog ──"
      curl -f \
        --cacert "$JF_ARTIFACTORY_CERT" \
        -u "${JF_USER}:${JF_TOKEN}" \
        "${JF_ARTIFACTORY_URL}/${PHP_VIRTUAL_REPO}/composer.phar" \
        -o composer.phar
      SIZE=$(stat -c%s composer.phar)
      echo "Downloaded size: $SIZE bytes"
      if [ "$SIZE" -lt 1000000 ]; then
        echo "ERROR: composer.phar too small"
        exit 1
      fi
      chmod +x composer.phar
      mv composer.phar composer
      export PATH="$CI_PROJECT_DIR:$PATH"
      composer --version

    # Configure Composer to use JFrog only
    - |
      set -eo pipefail
      export PATH="$CI_PROJECT_DIR:$PATH"
      echo "── Configuring Composer ──"
      composer config --global repos.packagist composer \
        ${JF_ARTIFACTORY_URL}/api/composer/${PHP_VIRTUAL_REPO}
      composer config --global \
        http-basic.artifactory.jfrog.sbi "${JF_USER}" "${JF_TOKEN}"
      composer config --global cafile "$JF_ARTIFACTORY_CERT"
      composer config --global repo.packagist false
      composer config --global use-github-api false
      composer config --global preferred-install dist
      echo "── Composer configured ──"

  script:
    - |
      set -eo pipefail
      export PATH="$CI_PROJECT_DIR:$PATH"

      echo "===== SYSTEM INFO ====="
      free -h || true
      df -h   || true

      echo "===== INSTALLING DEPENDENCIES ====="
      # composer install uses the fixed composer.lock with JFrog URLs
      composer install \
        --no-dev \
        --optimize-autoloader \
        --no-interaction \
        --prefer-dist \
        --no-source-fallback \
        -vvv

      if [ ! -d "vendor" ]; then
        echo "ERROR: vendor directory not created"
        exit 1
      fi

      echo "Vendor count: $(ls vendor | wc -l)"
      echo "===== BUILD COMPLETE ====="

  artifacts:
    paths:
      - vendor/
    expire_in: 1 day
