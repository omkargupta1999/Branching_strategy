#FROM registry.dev.sbiepay.sbi:8443/ubi9/openjdk-21:1.23-6.1755674728
ARG BASE_IMAGE_DEV_ENV
FROM ${BASE_IMAGE_DEV_ENV}
ARG ENV
ARG VERSION
ENV ENV=$ENV
ENV VERSION=$VERSION
ENV JAVA_OPTS="--add-exports=java.base/sun.nio.ch=ALL-UNNAMED --add-opens=java.base/sun.nio.ch=ALL-UNNAMED"
COPY /build/libs/epay_operations_service-${VERSION}.jar .
ENTRYPOINT sh -c 'java $JAVA_OPTS -jar "epay_operations_service-$VERSION.jar"'
#ENTRYPOINT ["java", "$JAVA_OPTS", "-jar", "epay_operations_service-$VERSION.jar"]
COPY ./sms.cer  /tmp
COPY ./epaycert.cer  /tmp
RUN ls -lrth /tmp/
USER 0
RUN cd /usr/lib/jvm/java-21/bin
RUN yes | keytool -import -trustcacerts -file /tmp/sms.cer -keystore /usr/lib/jvm/java-21/lib/security/cacerts -alias DEV_EPAY_SMS -storepass changeit
RUN yes | keytool -import -trustcacerts -file /tmp/epaycert.cer -keystore /usr/lib/jvm/java-21/lib/security/cacerts -alias S3_EPAY_CERT -storepass changeit



