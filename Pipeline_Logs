=============trigger.cd.yml

# ci/deploy/trigger.cd.yml
# Single hidden template for CI → CD pipeline trigger.
# All deploy jobs in deploy.jobs.yml extend this one template.
# Job-specific behaviour (manual_confirmation, variables) stays in each job.

.trigger_cd:
  stage: deploy
  variables:
    DEPLOYMENT_BRANCH: "feature/deploy-cicd"
    # DEPLOYMENT_BRANCH: "deploy_cicd"
    SERVICE_NAME: "${CI_PROJECT_NAME}"
    VERSION: "${VERSION}"
  trigger:
    project: "itepaypg-sbiepay2/infra/devops/deployment"
    branch:  "$DEPLOYMENT_BRANCH"
    strategy: depend            # CI pipeline waits for CD result — pass/fail shown inline
    forward:
      pipeline_variables: true  # forwards VERSION, ENV, SERVICE_NAME, CHART_NAME etc.
      yaml_variables: true


================ deploy.jobs.yml


# ci/deploy/deploy.jobs.yml
# All deploy trigger jobs — tech-stack agnostic.
# Included by EVERY CI orchestrator template (java, nodejs, python, php, dotnet, react).
#
# All jobs extend .trigger_cd (single base template in trigger.cd.yml).
# Job-specific behaviour sits here: rules, manual_confirmation, variables.
#
# ── CHART_NAME ────────────────────────────────────────────────────────────────
# Defined in each APP REPO's .gitlab-ci.yml, not in orchestrators.
#
#   # epay_transaction_service/.gitlab-ci.yml
#   include:
#     - project: 'itepaypg-sbiepay2/infra/devops/cicd-templates'
#       ref: main
#       file: 'templates/ci/backend/java.yml'
#   variables:
#     RELEASE_NAME: epay-txn            # Helm release name (cluster-unique)
#     CHART_NAME:   transactionservice  # Helm chart name in deployment repo charts/

# ── DEV — auto on develop push ────────────────────────────────────────────────
deploy-dev:
  extends: .trigger_cd
  variables:
    ENV:          dev
    SERVICE_NAME: "$CI_PROJECT_NAME"
    CHART_NAME:   "$CHART_NAME"
  rules:
    - if: '$CI_COMMIT_BRANCH == "develop" && $CI_PIPELINE_SOURCE == "push"'
      when: on_success
    - if: '$CI_COMMIT_BRANCH == "feature/deploy-cicd" && $CI_PIPELINE_SOURCE == "push"'
      when: on_success
    - when: never

# ── SIT — manual, Release Manager ─────────────────────────────────────────────
deploy-sit:
  extends: .trigger_cd
  variables:
    ENV:          sit
    SERVICE_NAME: "$CI_PROJECT_NAME"
    CHART_NAME:   "$CHART_NAME"
  rules:
    - if: '$CI_COMMIT_BRANCH =~ /^release\/[0-9]+\.[0-9]+\.[0-9]+$/'
      when: manual
      allow_failure: true
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event" && $CI_MERGE_REQUEST_TARGET_BRANCH_NAME =~ /^release\//'
      when: manual
      allow_failure: true
    - when: never

# ── UAT — manual, Release Manager ─────────────────────────────────────────────
deploy-uat:
  extends: .trigger_cd
  variables:
    ENV:          uat
    SERVICE_NAME: "$CI_PROJECT_NAME"
