def build_workbook(projects, counts):
    print(f"\n[3/3] Building Excel workbook: {OUTPUT_FILE} ...")

    wb = Workbook()
    wb.remove(wb.active)   # Remove default sheet

    # ── Prepare enriched rows ────────────────────────────────────────────────
    rows = []
    for p in projects:
        pid   = p["id"]
        stats = p.get("statistics") or {}
        c     = counts.get(pid, {})
        risk  = risk_level(p, c.get("mrs_open", 0))

        migration_notes = []
        if c.get("mrs_open", 0) > 0:
            migration_notes.append(f"{c['mrs_open']} open MR(s) — author attribution risk")
        if p.get("lfs_enabled"):
            migration_notes.append("LFS objects need separate migration")
        if p.get("mirror"):
            migration_notes.append("Mirror config — re-setup post-migration")
        if p.get("container_registry_enabled"):
            migration_notes.append("Container images — re-push to new registry")
        if p.get("packages_enabled") and c.get("releases", 0) > 0:
            migration_notes.append("Package registry data migration needed")
        if p.get("ci_config_path"):
            migration_notes.append(f"Custom CI path: {p['ci_config_path']}")
        elif p.get("jobs_enabled"):
            migration_notes.append("Review .gitlab-ci.yml — hardcoded registry/template paths")
        if c.get("webhooks", 0) > 0:
            migration_notes.append(f"{c['webhooks']} webhook(s) — re-configure post-migration")
        if c.get("deploy_keys", 0) > 0:
            migration_notes.append(f"{c['deploy_keys']} deploy key(s) — re-add post-migration")
        if c.get("environments", 0) > 0:
            migration_notes.append(f"{c['environments']} environment(s) — re-configure")
        if p.get("archived"):
            migration_notes.append("Archived — confirm if migration is needed")
        if p.get("empty_repo"):
            migration_notes.append("Empty repository — no commits")

        rows.append({
            "id":           pid,
            "name":         s(p.get("name")),
            "path":         s(p.get("path_with_namespace")),
            "namespace":    s(p.get("namespace", {}).get("full_path")),
            "description":  s(p.get("description")),
            "visibility":   s(p.get("visibility")),
            "default_branch": s(p.get("default_branch"), "N/A"),
            "empty":        yn(p.get("empty_repo")),
            "archived":     yn(p.get("archived")),
            "created":      to_date(p.get("created_at")),
            "last_activity":to_date(p.get("last_activity_at")),
            "days_inactive":days_ago(p.get("last_activity_at")),
            "repo_size":    fmt_size(stats.get("repository_size")),
            "lfs_enabled":  yn(p.get("lfs_enabled")),
            "lfs_size":     fmt_size(stats.get("lfs_objects_size")),
            "branches":     c.get("branches", 0),
            "tags":         c.get("tags", 0),
            "mrs_open":     c.get("mrs_open", 0),
            "mrs_merged":   c.get("mrs_merged", 0),
            "mrs_closed":   c.get("mrs_closed", 0),
            "issues_open":  c.get("issues_open", 0),
            "issues_closed":c.get("issues_closed", 0),
            "group_epics":  c.get("group_epics", 0),
            "milestones":   c.get("milestones", 0),
            "labels":       c.get("labels", 0),
            "pipelines":    c.get("pipelines", 0),
            "releases":     c.get("releases", 0),
            "environments": c.get("environments", 0),
            "snippets":     c.get("snippets", 0),
            "deploy_keys":  c.get("deploy_keys", 0),
            "webhooks":     c.get("webhooks", 0),
            "members":      c.get("members", 0),
            "protected_branches": c.get("protected_branches", 0),
            "ci_enabled":   yn(p.get("jobs_enabled")),
            "ci_config":    s(p.get("ci_config_path"), ".gitlab-ci.yml (default)"),
            "shared_runners": yn(p.get("shared_runners_enabled")),
            "auto_devops":  yn(p.get("auto_devops_enabled")),
            "container_registry": yn(p.get("container_registry_enabled")),
            "packages":     yn(p.get("packages_enabled")),
            "wiki":         yn(p.get("wiki_enabled")),
            "issues_feature": yn(p.get("issues_enabled")),
            "merge_method": s(p.get("merge_method")),
            "pipeline_required": yn(p.get("only_allow_merge_if_pipeline_succeeds")),
            "mirror":       yn(p.get("mirror")),
            "http_url":     s(p.get("http_url_to_repo")),
            "ssh_url":      s(p.get("ssh_url_to_repo")),
            "risk":         risk,
            "migration_notes": " | ".join(migration_notes) if migration_notes else "Standard migration",
        })

    # Sort by risk for plan sheet
    rows_by_risk = sorted(rows, key=lambda r: (RISK_ORDER.get(r["risk"], 9), r["path"]))

    # ── SHEET 1: Dashboard ───────────────────────────────────────────────────
    build_dashboard(wb, rows)

    # ── SHEET 2: Full Audit ──────────────────────────────────────────────────
    build_full_audit(wb, rows)

    # ── SHEET 3: Migration Plan ──────────────────────────────────────────────
    build_migration_plan(wb, rows_by_risk)

    # ── SHEET 4: CI-CD Repos ────────────────────────────────────────────────
    build_cicd_sheet(wb, rows)

    # ── SHEET 5: Open Items ──────────────────────────────────────────────────
    build_open_items(wb, rows)

    wb.save(OUTPUT_FILE)
    print(f"       → {OUTPUT_FILE} saved successfully.")


