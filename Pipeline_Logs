// ============================================================================
// FIX: Strip embedded Jackson 2.9.0.pr3 classes from SBINEWPG_2023.jar
// ----------------------------------------------------------------------------
// SBINEWPG_2023 is a vendored third-party PG SDK (flat-file dependency, no
// POM metadata) that ships its own shaded copy of com.fasterxml.jackson.*
// classes from 2017 (Jackson 2.9.0.pr3). Because it's an opaque jar, Gradle's
// dependency resolution cannot see or manage this embedded Jackson — it is
// physically baked into the jar's bytecode, not declared as a transitive
// dependency. At runtime, Spring Boot's loader can load these stale shaded
// classes instead of the correctly BOM-managed jackson-annotations:2.17.2,
// causing:
//   java.lang.NoSuchFieldError: Class com.fasterxml.jackson.annotation.JsonFormat$Feature
//   does not have member field '...READ_UNKNOWN_ENUM_VALUES_USING_DEFAULT_VALUE'
// (that field was only added in Jackson 2.16).
//
// We cannot modify SBINEWPG_2023.jar's source (third-party, vendor-supplied).
// Instead, this build step extracts the jar's contents, strips out every
// com/fasterxml/jackson/** class (and the stale Maven metadata describing
// them), and repacks a clean copy. bootJar then excludes the original jar
// and bundles the cleaned one instead, so BOOT-INF/lib ends up with exactly
// one Jackson version line: 2.17.2.
// ============================================================================

task stripJacksonFromVendorJars(type: Copy) {
	description = 'Strips embedded Jackson 2.9.0.pr3 classes from SBINEWPG_2023, which conflict with the 2.17.2 BOM-managed stack'
	from {
		configurations.runtimeClasspath.files.findAll {
			it.name.startsWith('SBINEWPG_2023')
		}.collect { zipTree(it) }
	}
	into "$buildDir/stripped-libs/SBINEWPG_2023"
	exclude 'com/fasterxml/jackson/**'
	exclude 'META-INF/maven/com.fasterxml.jackson.core/**'
}

task repackVendorJar(type: Jar, dependsOn: stripJacksonFromVendorJars) {
	description = 'Repacks SBINEWPG_2023 without the conflicting Jackson classes'
	from "$buildDir/stripped-libs/SBINEWPG_2023"
	archiveFileName = 'SBINEWPG_2023-cleaned.jar'
	destinationDirectory = file("$buildDir/cleaned-libs")
}

bootJar {
	dependsOn repackVendorJar
	exclude '**/SBINEWPG_2023-*.jar'
	from(files("$buildDir/cleaned-libs/SBINEWPG_2023-cleaned.jar")) {
		into 'BOOT-INF/lib'
	}
}
