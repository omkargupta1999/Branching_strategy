    else
      echo "Branch  : ${CI_COMMIT_BRANCH}"
    fi
    echo "VERSION : ${VERSION}"
    echo "──────────────────────────────────────────────────────"
  artifacts:
    reports:
      dotenv:
      - version.env
    expire_in: 1 day
  rules:
  - when: on_success
