FROM registry.dev.sbiepay.sbi:8443/openjdk:03
ARG ENV
ARG VERSION

ENV ENV=$ENV
ENV VERSION=$VERSION

COPY /build/libs/epay_transaction_service-${VERSION}.jar .
#ENTRYPOINT sh -c 'java -jar "epay_transaction_service-$VERSION.jar"'
#ENTRYPOINT sh -c 'java -XX:+UseZGC -XX:+ZGenerational -XX:+AlwaysPreTouch -XX:MaxRAMPercentage=75.0 -jar "epay_transaction_service-$VERSION.jar"'
ENTRYPOINT sh -c 'java -XX:+UseG1GC -XX:+AlwaysPreTouch -XX:MaxRAMPercentage=80.0 -jar "epay_transaction_service-$VERSION.jar"'
USER 0
COPY ./eissiuat.crt /etc/pki/tls/certs/
COPY ./SBI-PROD-RCA.crt /etc/pki/ca-trust/source/anchors/
RUN chown root:root /etc/pki/ca-trust/source/anchors/SBI-PROD-RCA.crt
RUN chmod 644 /etc/pki/ca-trust/source/anchors/SBI-PROD-RCA.crt
RUN update-ca-trust enable
RUN update-ca-trust extract
RUN update-ca-trust


