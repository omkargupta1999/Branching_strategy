# deployment-repo/.gitlab-ci.yml
# =============================================================================
# Minimal include router — all logic inside each template.
# Discriminated by DEPLOY_TYPE variable (or DRILL_TIER for drills).
#
# ── Use Case 1: App service deployment ────────────────────────────────────────
#   Trigger: App CI pipeline → deploy.jobs.yml → pipeline trigger
#   Variable: DEPLOY_TYPE=app   (set inside trigger.cd.yml)
#   Template: templates/cd/deploy.single.yml
#   Flow:     values:update → validate → helm:deploy → verify → notify
#
# ── Use Case 2: Config-only deployment ────────────────────────────────────────
#   Trigger: Config repo CI → config.deploy.yml → pipeline trigger
#   Variable: DEPLOY_TYPE=config   (set inside config.deploy.yml)
#   Template: templates/cd/deploy.config.yml
#   Flow:     config:compute → config:apply → [restart:rollout MANUAL] → verify:health
#   Repos:    Epay_Backend_Config / Epay_Frontend_Config
#   Note:     SAME pipeline trigger mechanism as Use Case 1 (source=pipeline)
#             Discriminated by DEPLOY_TYPE value — NOT by pipeline source
#
# ── Use Case 3: DC/DR Drill ───────────────────────────────────────────────────
#   Trigger: Manual — GitLab UI → Run pipeline → set DRILL_TIER variable
#   Variable: DRILL_TIER=prod|preprod|nonprod
#   Template: templates/cd/deploy.drill.yml
#   Flow:     Drill-specific failover and verification stages
#
# ── Discriminator logic ───────────────────────────────────────────────────────
#   Use Case 1 vs Use Case 2: Both triggered by pipeline (CI_PIPELINE_SOURCE=pipeline)
#   Distinguished by DEPLOY_TYPE:
#     DEPLOY_TYPE=app    → deploy.single.yml   (set by app CI trigger.cd.yml)
#     DEPLOY_TYPE=config → deploy.config.yml   (set by config CI config.deploy.yml)
#   Use Case 3: DRILL_TIER != "" → deploy.drill.yml
#               (manually set in Run Pipeline dialog — never set by CI triggers)
# =============================================================================

include:
  # ── Use Case 1: App service deployment ──────────────────────────────────────
  - project: 'itepaypg-sbiepay2/infra/devops/cicd-templates'
    ref: main
    file: 'templates/cd/deploy.single.yml'
    rules:
      - if: '$CI_PIPELINE_SOURCE == "pipeline" && $DEPLOY_TYPE == "app"'

  # ── Use Case 2: Config-only deployment ──────────────────────────────────────
  # Triggered by Epay_Backend_Config or Epay_Frontend_Config CI pipeline
  # DEPLOY_TYPE=config set by templates/ci/config/config.deploy.yml trigger jobs
  # - project: 'itepaypg-sbiepay2/infra/devops/cicd-templates'
  #   ref: main
  #   file: 'templates/cd/deploy.config.yml'
  #   rules:
  #     - if: '$CI_PIPELINE_SOURCE == "pipeline" && $DEPLOY_TYPE == "config"'

  # ── Use Case 3: DC/DR Drill ─────────────────────────────────────────────────
  # Triggered manually: GitLab UI → Run pipeline → DRILL_TIER=prod|preprod|nonprod
  # DRILL_TIER is NEVER set by any CI trigger — safe discriminator from Use Cases 1 & 2
  - project: 'itepaypg-sbiepay2/infra/devops/cicd-templates'
    ref: main
    file: 'templates/cd/deploy.drill.yml'
    rules:
      - if: '$DRILL_TIER != ""'


