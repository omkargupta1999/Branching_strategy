# ci/deploy/deploy.jobs.yml
# ──────────────────────────────────────────────────────────────────────────────
# All deploy trigger jobs — tech-stack agnostic.
# Included by EVERY CI orchestrator template (java, nodejs, php, dotnet, react,
# html). Each job extends .trigger_cd (ci/deploy/trigger.cd.yml), which fires a
# multi-project trigger into the deployment repo and waits for its result.
#
# These jobs do NOT deploy anything themselves — they hand ENV + VERSION to the
# deployment repo's pipeline, which performs the actual Helm rollout.
#
# ── Deploy matrix (source → target) ───────────────────────────────────────────
#   Source            Target                MR pipeline          Post-merge push
#   ───────────────── ───────────────────── ──────────────────── ────────────────────
#   feature/*         develop               deploy-dev (manual)  deploy-dev  (AUTO)
#   feature/*         feature/*             —                    —
#   bugfix/*          feature/*             —                    —
#   develop           sit-integration       deploy-sit (manual)  deploy-sit  (AUTO)
#   feature/*         release/*             deploy-uat (manual)  uat,int,perf,
#   bugfix/*          release/*             deploy-uat (manual)  pre-prod-dc,
#                                                                pre-prod-dr (manual)
#   hotfix/*          main                  pre-prod + pre-prod  prod-dc, prod-dr,
#                                           -dc smoke (manual)   int (manual)
#   release/*         main                  prod-dc, prod-dr,    prod-dc, prod-dr,
#                                           int (manual)         int (manual)
#
# AUTO  = when: on_success — deploys with no human click (dev and SIT only).
# All other environments, including every production target, stay MANUAL.
#
# ── Release branch gating ─────────────────────────────────────────────────────
# Deploy rules match on the PREFIX only:  /^release\//
# The exact release naming (release/(major|minor)-DM<digits>-EPAY-<desc>) is
# enforced ONCE, by the GitLab Push Rule branch regex — a malformed release
# branch cannot be created in the first place. Do NOT duplicate that regex here:
# it would have to stay in lockstep across every rule + the push rule, and a
# missed edit silently removes a deploy button (this exact drift caused the old
# release/0.0.0 incident). Push rule = single source of truth for branch names.
#
# ── Environment map (ENV → target) ────────────────────────────────────────────
#   dev          development
#   sit          system integration test
#   uat          user acceptance test
#   int          integration
#   perf         performance test
#   pre-prod-dc  pre-production, DC cluster
#   pre-prod     pre-production, DR cluster
#   prod-dc      production, DC cluster       (Bank only)
#   prod-dr      production, DR cluster       (Bank only)
#
# ── Protected branches ────────────────────────────────────────────────────────
# main and sit-integration are protected — MR only, no direct push. Rules below
# therefore key on the post-merge push pipeline that a merge produces.
#
# ── CHART_NAME ────────────────────────────────────────────────────────────────
# Defined in each APP REPO's .gitlab-ci.yml, not in the orchestrators:
#
#   # epay_transaction_service/.gitlab-ci.yml
#   include:
#     - project: 'itepaypg-sbiepay2/infra/devops/cicd-templates'
#       ref: main
#       file: 'templates/ci/backend/java.yml'
#   variables:
#     RELEASE_NAME: epay-txn            # Helm release name (cluster-unique)
#     CHART_NAME:   transactionservice  # Helm chart name in deployment repo charts/
# ──────────────────────────────────────────────────────────────────────────────

# ── DEV ───────────────────────────────────────────────────────────────────────
# MR feature/* → develop : manual
# push to develop        : AUTO (on_success)
deploy-dev:
  extends: .trigger_cd
  variables:
    ENV:          dev
    SERVICE_NAME: "$CI_PROJECT_NAME"
    CHART_NAME:   "$CHART_NAME"
    VERSION: "${VERSION}"
  rules:
    # MR opened/updated: feature/* → develop
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event" &&
           $CI_MERGE_REQUEST_SOURCE_BRANCH_NAME =~ /^feature\/.*$/ &&
           $CI_MERGE_REQUEST_TARGET_BRANCH_NAME == "develop"'
      when: manual
    # Post-merge: push to develop → AUTO deploy
    - if: '$CI_PIPELINE_SOURCE == "push" && $CI_COMMIT_BRANCH == "develop"'
      when: on_success
    - when: never

# ── SIT ───────────────────────────────────────────────────────────────────────
# MR develop → sit-integration : manual
# push to sit-integration      : AUTO (on_success)
# release/* push and MR → release/* : manual (release testing path)
deploy-sit:
  extends: .trigger_cd
  variables:
    ENV:          sit
    SERVICE_NAME: "$CI_PROJECT_NAME"
    CHART_NAME:   "$CHART_NAME"
  rules:
    # MR opened/updated: develop → sit-integration
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event" &&
           $CI_MERGE_REQUEST_TARGET_BRANCH_NAME == "sit-integration"'
      when: manual
      allow_failure: true
    # Post-merge: push to sit-integration → AUTO deploy
    - if: '$CI_PIPELINE_SOURCE == "push" && $CI_COMMIT_BRANCH == "sit-integration"'
      when: on_success
      allow_failure: true
    - when: never

# ── UAT — manual, Release Manager ─────────────────────────────────────────────
# MR (feature/*|bugfix/*) → release/* : manual
# release/* post-merge push           : manual
deploy-uat:
  extends: .trigger_cd
  variables:
    ENV:          uat
    SERVICE_NAME: "$CI_PROJECT_NAME"
    CHART_NAME:   "$CHART_NAME"
  rules:
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event" && $CI_MERGE_REQUEST_TARGET_BRANCH_NAME =~ /^release\//'
      when: manual
      allow_failure: true
    - if: '$CI_COMMIT_BRANCH =~ /^release\//'
      when: manual
      allow_failure: true
    - when: never

# ── INT — manual, Release Manager ─────────────────────────────────────────────
# release/* post-merge push : manual
# main post-merge push      : manual  (ships with the prod-dc/prod-dr set)
deploy-int:
  extends: .trigger_cd
  variables:
    ENV:          int
    SERVICE_NAME: "$CI_PROJECT_NAME"
    CHART_NAME:   "$CHART_NAME"
  rules:
    - if: '$CI_COMMIT_BRANCH == "main"'
      when: manual
      allow_failure: true
    - if: '$CI_COMMIT_BRANCH =~ /^release\//'
      when: manual
      allow_failure: true
    - when: never

# ── Performance Testing — manual, Release Manager ─────────────────────────────
# release/* post-merge push only.
deploy-perf:
  extends: .trigger_cd
  variables:
    ENV:          perf
    SERVICE_NAME: "$CI_PROJECT_NAME"
    CHART_NAME:   "$CHART_NAME"
  rules:
    - if: '$CI_COMMIT_BRANCH =~ /^release\//'
      when: manual
      allow_failure: true
    - when: never

# ── Preprod DC — manual, Release Manager ──────────────────────────────────────
# release/* post-merge push only.
deploy-preprod-dc:
  extends: .trigger_cd
  allow_failure: true
  variables:
    ENV:          pre-prod-dc
    SERVICE_NAME: "$CI_PROJECT_NAME"
    CHART_NAME:   "$CHART_NAME"
  rules:
    - if: '$CI_COMMIT_BRANCH =~ /^release\//'
      when: manual
      allow_failure: true
    - when: never

# ── Preprod DR — manual, Release Manager ──────────────────────────────────────
# release/* post-merge push only.
# ENV is 'pre-prod' — that is the DR cluster's environment name (preprod DC uses
# 'pre-prod-dc').
deploy-preprod-dr:
  extends: .trigger_cd
  allow_failure: true
  variables:
    ENV:          pre-prod
    SERVICE_NAME: "$CI_PROJECT_NAME"
    CHART_NAME:   "$CHART_NAME"
  rules:
    - if: '$CI_COMMIT_BRANCH =~ /^release\//'
      when: manual
      allow_failure: true
    - when: never

# ── Hotfix preprod smoke (DR) — manual, Release Manager ───────────────────────
# MR hotfix/* → main only. Exists on the MR pipeline BEFORE the merge lands, so a
# hotfix can be smoke-tested on preprod DR first. Never on a post-merge pipeline.
deploy-hotfix-preprod-smoke:
  extends: .trigger_cd
  allow_failure: true
  variables:
    ENV: pre-prod
    SERVICE_NAME: "$CI_PROJECT_NAME"
    CHART_NAME:   "$CHART_NAME"
  rules:
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event" && $CI_MERGE_REQUEST_TARGET_BRANCH_NAME == "main" && $CI_MERGE_REQUEST_SOURCE_BRANCH_NAME =~ /^hotfix\//'
      when: manual
      allow_failure: true
    - when: never

# ── Hotfix preprod smoke (DC) — manual, Release Manager ───────────────────────
# MR hotfix/* → main only. Same gate as the DR smoke job above, targeting the DC
# preprod cluster.
deploy-hotfix-preprod-smoke-dc:
  extends: .trigger_cd
  allow_failure: true
  variables:
    ENV: pre-prod-dc
    SERVICE_NAME: "$CI_PROJECT_NAME"
    CHART_NAME:   "$CHART_NAME"
  rules:
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event" && $CI_MERGE_REQUEST_TARGET_BRANCH_NAME == "main" && $CI_MERGE_REQUEST_SOURCE_BRANCH_NAME =~ /^hotfix\//'
      when: manual
      allow_failure: true
    - when: never

# ── Prod DC — manual, Bank team only ──────────────────────────────────────────
# MR release/* → main : manual (pre-merge visibility)
# main post-merge push : manual
# Access is gated by the user's role on this project — .trigger_cd defines no
# environment: key, so GitLab cannot use Protected Environments to gate it.
deploy-prod-dc:
  extends: .trigger_cd
  allow_failure: true
  variables:
    ENV:          prod-dc
    SERVICE_NAME: "$CI_PROJECT_NAME"
    CHART_NAME:   "$CHART_NAME"
  rules:
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event" && $CI_MERGE_REQUEST_TARGET_BRANCH_NAME == "main" && $CI_MERGE_REQUEST_SOURCE_BRANCH_NAME =~ /^release\//'
      when: manual
      allow_failure: true
    - if: '$CI_COMMIT_BRANCH == "main"'
      when: manual
      allow_failure: true
    - when: never

# ── Prod DR — manual, Bank team only ──────────────────────────────────────────
# MR release/* → main : manual (pre-merge visibility)
# main post-merge push : manual
deploy-prod-dr:
  extends: .trigger_cd
  allow_failure: true
  variables:
    ENV:          prod-dr
    SERVICE_NAME: "$CI_PROJECT_NAME"
    CHART_NAME:   "$CHART_NAME"
  rules:
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event" && $CI_MERGE_REQUEST_TARGET_BRANCH_NAME == "main" && $CI_MERGE_REQUEST_SOURCE_BRANCH_NAME =~ /^release\//'
      when: manual
      allow_failure: true
    - if: '$CI_COMMIT_BRANCH == "main"'
      when: manual
      allow_failure: true
    - when: never













