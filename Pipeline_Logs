  when: manual
  allow_failure: true
  variables:
    ENV:          pre-prod       # was "pre-prod" (missing -dr) — fixed
    SERVICE_NAME: "$CI_PROJECT_NAME"
    CHART_NAME:   "$CHART_NAME"
  rules:
    - if: '$CI_COMMIT_BRANCH =~ /^release\/[0-9]+\.[0-9]+\.[0-9]+$/'
      when: manual
      allow_failure: true
