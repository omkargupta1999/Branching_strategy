# ci/build/php.yml  |  Stage: build
# PHP microservice build with Composer
#
# ── Dependency resolution — JFrog Composer virtual repository ────────────────
# Repository: https://artifactory.jfrog.sbi/artifactory/api/composer/itepaypg-sbiepay2-php-virtual
# Auth: JF_USER + JF_TOKEN (HTTP basic via Composer global config)
# SSL: SBI internal CA extracted from JFrog TLS handshake at runtime,
#      merged with system CA bundle, passed to Composer via cafile config
#
# ── Composer PHAR ─────────────────────────────────────────────────────────────
# ubi9/php-82 does not include Composer. PHAR is downloaded from JFrog at runtime.
# composer.phar is served via the JFrog PHP virtual repo (devsecops-composer-remote proxy).
# Path: https://artifactory.jfrog.sbi/artifactory/itepaypg-sbiepay2-php-virtual/composer.phar
#
# ── Cache ─────────────────────────────────────────────────────────────────────
# vendor/          NOT cached — resolved fresh from composer.lock each run
# .composer-cache/ CACHED — Composer package tarballs (COMPOSER_CACHE_DIR)
#
# ── App repo requirements ─────────────────────────────────────────────────────
# composer.json — dependency declarations
# composer.lock — locked versions (must be committed to repo)
#
# ── GitLab CI Variables required ─────────────────────────────────────────────
# JF_USER  — Artifactory username (e.g. v1021495)
# JF_TOKEN — Artifactory API key (generated from Artifactory UI → Edit Profile)

.build:
  stage: build
  image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-virtual/ubi9/php-82:1-1778488703

  tags:
    - common_runner

  variables:
    COMPOSER_CACHE_DIR: "${CI_PROJECT_DIR}/.composer-cache"
    JF_ARTIFACTORY_URL: "https://artifactory.jfrog.sbi/artifactory"
    PHP_VIRTUAL_REPO: "itepaypg-sbiepay2-php-virtual"
    JFROG_HOST: "artifactory.jfrog.sbi"
    JFROG_PORT: "443"
    COMPOSER_ALLOW_SUPERUSER: "1"

  cache:
    key: "${CI_PROJECT_NAME}-composer-${CI_COMMIT_REF_SLUG}"
    paths:
      - .composer-cache/

  before_script:
    # ── Git safe directory (required when runner user differs from repo owner) ─
    - git config --global --add safe.directory "${CI_PROJECT_DIR}"
    - php --version

    # ── Extract SBI CA chain from JFrog and build combined CA bundle ──────────
    # Container does not have write access to system trust store (/etc/pki),
    # so CA is injected directly into Composer and curl via env vars + cafile.
    - |
      set -eo pipefail

      echo "── Extracting CA chain from ${JFROG_HOST}:${JFROG_PORT} ──"

      openssl s_client \
        -connect "${JFROG_HOST}:${JFROG_PORT}" \
        -showcerts \
        </dev/null 2>/dev/null \
      | awk '
          /-----BEGIN CERTIFICATE-----/ { count++; capture=1 }
          capture && count > 1          { print }
          /-----END CERTIFICATE-----/   { capture=0 }
        ' > "${CI_PROJECT_DIR}/jfrog-ca-chain.crt"

      cat /etc/pki/tls/certs/ca-bundle.crt \
        "${CI_PROJECT_DIR}/jfrog-ca-chain.crt" \
        > "${CI_PROJECT_DIR}/combined-ca-bundle.crt"

      export SSL_CERT_FILE="${CI_PROJECT_DIR}/combined-ca-bundle.crt"
      export CURL_CA_BUNDLE="${CI_PROJECT_DIR}/combined-ca-bundle.crt"

      echo "── CA bundle ready: $(wc -l < ${CI_PROJECT_DIR}/combined-ca-bundle.crt) lines ──"

    # ── Download Composer PHAR from JFrog virtual repo ───────────────────────
    - |
      set -eo pipefail

      export SSL_CERT_FILE="${CI_PROJECT_DIR}/combined-ca-bundle.crt"
      export CURL_CA_BUNDLE="${CI_PROJECT_DIR}/combined-ca-bundle.crt"

      echo "── Downloading Composer from JFrog ──"

      curl -k -f \
        -u "${JF_USER}:${JF_TOKEN}" \
        "${JF_ARTIFACTORY_URL}/${PHP_VIRTUAL_REPO}/composer.phar" \
        -o composer.phar

      SIZE=$(stat -c%s composer.phar)
      echo "Downloaded size: $SIZE bytes"

      if [ "$SIZE" -lt 1000000 ]; then
        echo "ERROR: composer.phar too small — download failed"
        cat composer.phar
        exit 1
      fi

      chmod +x composer.phar
      mv composer.phar composer
      export PATH="$CI_PROJECT_DIR:$PATH"
      composer --version

    # ── Configure Composer — Artifactory as sole package source ─────────────
    - |
      set -eo pipefail

      export PATH="$CI_PROJECT_DIR:$PATH"
      export SSL_CERT_FILE="${CI_PROJECT_DIR}/combined-ca-bundle.crt"
      export CURL_CA_BUNDLE="${CI_PROJECT_DIR}/combined-ca-bundle.crt"

      echo "── Configuring Composer ──"

      # Route all package resolution through JFrog Composer virtual repo
      composer config --global \
        repos.packagist composer \
        ${JF_ARTIFACTORY_URL}/api/composer/${PHP_VIRTUAL_REPO}

      # Artifactory credentials for package downloads
      composer config --global \
        http-basic.artifactory.jfrog.sbi "${JF_USER}" "${JF_TOKEN}"

      # Trust SBI internal CA — avoids SSL cert errors on package downloads
      composer config --global \
        cafile "${CI_PROJECT_DIR}/combined-ca-bundle.crt"

      # Disable fallback to public packagist.org — enforce JFrog-only resolution
      composer config --global repo.packagist false

      echo "── Composer configured ──"

  script:
    # ── Install dependencies from composer.lock ──────────────────────────────
    - |
      set -eo pipefail

      export PATH="$CI_PROJECT_DIR:$PATH"
      export SSL_CERT_FILE="${CI_PROJECT_DIR}/combined-ca-bundle.crt"
      export CURL_CA_BUNDLE="${CI_PROJECT_DIR}/combined-ca-bundle.crt"

      echo "===== SYSTEM INFO ====="
      free -h || true
      df -h || true

      echo "===== INSTALLING DEPENDENCIES ====="

      composer install \
        --no-dev \
        --optimize-autoloader \
        --no-interaction \
        --prefer-dist

      if [ ! -d "vendor" ]; then
        echo "ERROR: vendor directory not created"
        exit 1
      fi

      echo "Vendor count: $(ls vendor | wc -l)"
      echo "===== BUILD COMPLETE ====="

  artifacts:
    paths:
      - vendor/
    expire_in: 1 day
