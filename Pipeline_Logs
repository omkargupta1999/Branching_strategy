# ci/release/tag.yml  |  Stage: release
# Creates git tags on post-merge pipelines ONLY — never on MR pipelines.
# Prod tag → auto on merge to main (marks deployment approval — already CAB approved).
#
# CHANGES for Approach-1 / new branch strategy / bare tags:
#   * Prod tag is now BARE (X.Y.Z), NOT v-prefixed — matches semver.yml's tag
#     lookup + idempotency guard and the branch-name regex (no 'v' allowed).
#   * create-rc-tag is DISABLED: the new release branch names carry no version,
#     and Approach-1 versioning drops RC tags entirely (release push = <branch>-<sha>).
#     Kept below (commented) for reference only.

.git_tag_base:
  stage: release
  image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-local/custom-ci/rhelgit-oc-helm:1.0
  tags:
    - common_runner
  before_script:
    - git config --global http.sslVerify false
    - git config --global --add safe.directory '*'
    - git config --global user.name "ci"
    - git config --global user.email "ci.cedge@sbi.co.in"
    - git remote set-url origin "https://oauth2:$GITLAB_CI_DEPLOY_TOKEN@gitlab.sbi/$CI_PROJECT_PATH.git"
    - git fetch --tags

# ── RC tag — DISABLED (RC versioning dropped under Approach-1) ─────────────────
# Old logic parsed the branch name for a version; new release names
# (release/minor-DM…-EPAY-…) carry none, so this is intentionally removed.
