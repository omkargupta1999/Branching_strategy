# Check Gradle version
podman run --rm registry.dev.sbiepay.sbi:8443/gradle:9.3.0-jdk21 gradle --version

# Confirm running as non-root
podman run --rm registry.dev.sbiepay.sbi:8443/gradle:9.3.0-jdk21 whoami
# Expected: gradle

# Confirm certificate is in truststore
podman run --rm registry.dev.sbiepay.sbi:8443/gradle:9.3.0-jdk21 \
  bash -c 'keytool -list -keystore $JAVA_HOME/lib/security/cacerts -storepass changeit | grep -i sbi'
# Expected: SBI-INTERNAL, ...
