    print("\n[1/3] Fetching projects ...")
    projects = api_all(ep)
    print(f"       → {len(projects)} projects found.")
    return projects


def fetch_per_project_counts(projects):
    """
    For each project fetch counts of every artifact type.
    All READ-ONLY (GET requests only).
    Returns dict: { project_id: { metric: count, ... } }
    """
    total = len(projects)
    counts = {}

    print(f"\n[2/3] Fetching per-project artifact counts ({total} repos) ...")
    print("      This may take a few minutes depending on instance size.\n")

    for i, p in enumerate(projects, start=1):
        pid  = p["id"]
        name = p.get("path_with_namespace", str(pid))
        print(f"      [{i:>3}/{total}] {name}", end="\r")

        c = {}

        # --- Branches & Tags ---
        c["branches"]     = count_endpoint(pid, "repository/branches")
        c["tags"]         = count_endpoint(pid, "repository/tags")

        # --- Merge Requests ---
        c["mrs_open"]     = count_endpoint(pid, "merge_requests", "&state=opened")
        c["mrs_merged"]   = count_endpoint(pid, "merge_requests", "&state=merged")
        c["mrs_closed"]   = count_endpoint(pid, "merge_requests", "&state=closed")

        # --- Issues ---
        c["issues_open"]  = count_endpoint(pid, "issues", "&state=opened")
        c["issues_closed"]= count_endpoint(pid, "issues", "&state=closed")

        # --- Milestones ---
        c["milestones"]   = count_endpoint(pid, "milestones")

        # --- Labels ---
        c["labels"]       = count_endpoint(pid, "labels")

        # --- Pipelines ---
        c["pipelines"]    = count_endpoint(pid, "pipelines")

        # --- Releases ---
        c["releases"]     = count_endpoint(pid, "releases")

        # --- Environments ---
        c["environments"] = count_endpoint(pid, "environments")

        # --- Snippets ---
        c["snippets"]     = count_endpoint(pid, "snippets")

        # --- Deploy Keys ---
        c["deploy_keys"]  = count_endpoint(pid, "deploy_keys")

        # --- Webhooks ---
        c["webhooks"]     = count_endpoint(pid, "hooks")

        # --- Members (direct) ---
        c["members"]      = count_endpoint(pid, "members/all")

        # --- Protected Branches ---
        c["protected_branches"] = count_endpoint(pid, "protected_branches")

        # --- Epics (only available if group-level — handled below) ---
        c["epics"] = 0

        counts[pid] = c

    # --- Epics are group-level, not project-level ---
    # Fetch group epics if TARGET_GROUP is set
    if TARGET_GROUP:
        print(f"\n      Fetching group epics for {TARGET_GROUP} ...")
        epics = api_all(f"/api/v4/groups/{TARGET_GROUP}/epics")
        # Distribute epic count to all projects (group-level metric)
        for pid in counts:
            counts[pid]["group_epics"] = len(epics)
    else:
        for pid in counts:
            counts[pid]["group_epics"] = 0

    print(f"\n       → Artifact counts collected for {len(counts)} projects.")
    return counts


