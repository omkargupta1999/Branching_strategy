# ci/security/sast/sast.fortify.yml  |  Stage: sast
# HP Fortify SCA — allow_failure:true (informational, non-blocking initially)

.sast_fortify:
  stage: sast
  tags:
    - common_runner
  variables:
    FORTIFY_IMAGE: "artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-local/custom-ci/fortify_sca_23.1.0:v2-04072025"
    FORTIFY_PROJECT: $CI_PROJECT_NAME
    SOURCE_ANALYZER: "/opt/Fortify/Fortify_SCA_23.1.0/bin/sourceanalyzer"
    BIRTReportGenerator: "/opt/Fortify/Fortify_Apps_and_Tools_23.1.0/bin/BIRTReportGenerator"
    FORTIFY_PROJECT_DIR: "."
    EXCLUDE_DIRS: "./src/test/**/*"
    INCLUDE_DIRS: "./**/*.java"
    FORTIFY_MEM: "8G"
  image: $FORTIFY_IMAGE
  allow_failure: true
  script:
    - $SOURCE_ANALYZER -b $FORTIFY_PROJECT -clean
    - $SOURCE_ANALYZER -b $FORTIFY_PROJECT "$INCLUDE_DIRS" -exclude "$EXCLUDE_DIRS" -verbose
    - $SOURCE_ANALYZER -b $FORTIFY_PROJECT -scan -format fpr -f "${FORTIFY_PROJECT_DIR}/${CI_PROJECT_NAME}.fpr"
    - $BIRTReportGenerator
        -template "Developer Workbook"
        -source "${FORTIFY_PROJECT_DIR}/${CI_PROJECT_NAME}.fpr"
        -format PDF
        -output "${FORTIFY_PROJECT_DIR}/${CI_PROJECT_NAME}_report.pdf"
        -Xmx${FORTIFY_MEM}
  artifacts:
    paths:
      - "./*.fpr"
      - "./*.pdf"
    expire_in: 1 week

sast:fortify:
  extends: .sast_fortify
