.build:
  stage: build
  image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-local/custom-ci/dotnet-90:130526
  tags:
    - common_runner

  variables:
    NUGET_PACKAGES: "${CI_PROJECT_DIR}/.nuget/packages"
    JFROG_HOST: "artifactory.jfrog.sbi"
    JFROG_PORT: "443"

  cache:
    key: "${CI_PROJECT_NAME}-nuget-${CI_COMMIT_REF_SLUG}"
    paths:
      - .nuget/packages/

  before_script:
    - dotnet --version
    - update-ca-trust --help || true
    
    # Extract JFrog certificate chain
    - |
        set -eo pipefail
    
        echo "=== Extracting CA chain ==="
    
        openssl s_client \
          -connect "${JFROG_HOST}:${JFROG_PORT}" \
          -showcerts \
          </dev/null 2>/dev/null \
        | sed -ne '/-BEGIN CERTIFICATE-/,/-END CERTIFICATE-/p' \
        > /tmp/jfrog-chain.crt
    
        echo "=== Extracted certs ==="
    
        grep "BEGIN CERTIFICATE" /tmp/jfrog-chain.crt
    
    # Register into OS trust store
    - |
        cp /tmp/jfrog-chain.crt /etc/pki/ca-trust/source/anchors/jfrog-chain.crt
    
        update-ca-trust
    
        echo "=== Trust store updated ==="
    
    # Verify trust
    - |
        openssl s_client \
          -connect "${JFROG_HOST}:${JFROG_PORT}" \
          -CApath /etc/ssl/certs \
          </dev/null
    
    # Create NuGet config
    - |
        cat > /tmp/nuget.config <<EOF
        <?xml version="1.0" encoding="utf-8"?>
        <configuration>
    
          <packageSources>
            <clear />
            <add key="jfrog" value="https://${JFROG_HOST}/artifactory/api/nuget/itepaypg-sbiepay2-nuget-virtual/index.json" />
          </packageSources>
    
          <packageSourceCredentials>
            <jfrog>
              <add key="Username" value="${JF_USER}" />
              <add key="ClearTextPassword" value="${JF_TOKEN}" />
            </jfrog>
          </packageSourceCredentials>
    
        </configuration>
        EOF
  script:
    - |
      set -eo pipefail

      if [ -z "$VERSION" ]; then
        echo "ERROR: VERSION missing"
        exit 1
      fi

      echo "Building VERSION: $VERSION"

      dotnet restore --configfile /tmp/nuget.config

      cat /tmp/nuget.config

      dotnet build \
        --configuration Release \
        --no-restore \
        /p:Version="$VERSION"

      dotnet publish \
        --configuration Release \
        --no-build \
        --output ./publish

      echo "Publish output:"
      ls -lh publish/

  artifacts:
    paths:
      - publish/
    expire_in: 1 day


