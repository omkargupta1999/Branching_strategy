def fetch_all_projects():
    if TOKEN == "":
        print("[ERROR] TOKEN is not set. Fill in your admin Personal Access Token.")
        sys.exit(1)

    print("=" * 65)
    print("  GitLab Repository Audit — Migration Planning")
    print(f"  Source  : {GITLAB_URL}")
    print(f"  Group   : {TARGET_GROUP or 'ALL (instance-wide)'}")
    print("=" * 65)

    if TARGET_GROUP:
        ep = (f"/api/v4/groups/{TARGET_GROUP}/projects"
              f"?include_subgroups=true&with_statistics=true")
    else:
