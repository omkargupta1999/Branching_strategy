# =============================================================================
#  API HELPERS  (READ-ONLY)
# =============================================================================

def api_get(url):
    req = urllib.request.Request(url)
    for k, v in HEADERS.items():
        req.add_header(k, v)
    try:
        resp = urllib.request.urlopen(req, context=ssl_ctx)
        return json.loads(resp.read()), resp
    except urllib.error.HTTPError as e:
        if e.code == 401:
            print(f"\n[ERROR] 401 Unauthorized — check TOKEN is set and is an admin token.")
            sys.exit(1)
        if e.code == 403:
            print(f"\n[ERROR] 403 Forbidden — token valid but lacks admin scope.")
            sys.exit(1)
        if e.code == 404:
            print(f"\n[ERROR] 404 Not Found — {url}")
            return [], None
        print(f"\n[WARN] HTTP {e.code} on {url} — skipping.")
        return [], None


def api_all(endpoint, extra_params=""):
    """Paginate through all pages. Returns list. GET-only."""
    results, page = [], 1
    while True:
        sep = "&" if "?" in endpoint else "?"
        url = f"{GITLAB_URL}{endpoint}{sep}per_page=100&page={page}{extra_params}"
        data, resp = api_get(url)
        if not data:
            break
        results.extend(data)
        if resp:
            total = resp.headers.get("X-Total-Pages", "1")
            if page >= int(total):
                break
        page += 1
    return results


def count_endpoint(pid, path, extra=""):
    """Return the X-Total header count for a project sub-resource."""
    url = f"{GITLAB_URL}/api/v4/projects/{pid}/{path}?per_page=1&page=1{extra}"
    req = urllib.request.Request(url)
    for k, v in HEADERS.items():
        req.add_header(k, v)
    try:
        resp = urllib.request.urlopen(req, context=ssl_ctx)
        val  = resp.headers.get("X-Total", "0")
        return int(val) if str(val).isdigit() else 0
    except Exception:
        return 0


# =============================================================================
#  UTILITY FUNCTIONS
# =============================================================================

def s(val, default=""):
    return val if val not in (None, "", [], {}) else default


def yn(val):
    if val is True:  return "Yes"
    if val is False: return "No"
    return ""


def fmt_size(kb):
    if kb in (None, "", 0): return "0 KB"
    try:
        kb = int(kb)
        if kb >= 1048576: return f"{kb/1048576:.1f} GB"
        if kb >= 1024:    return f"{kb/1024:.1f} MB"
        return f"{kb} KB"
    except Exception:
        return str(kb)


def to_date(ts):
    return ts[:10] if ts else ""


def days_ago(ts):
    if not ts: return ""
    try:
        dt    = datetime.fromisoformat(ts.replace("Z", "+00:00"))
        delta = datetime.now(timezone.utc) - dt
        return delta.days
    except Exception:
        return ""


def risk_level(p, open_mrs):
    if p.get("archived"):           return "ARCHIVED"
    if p.get("jobs_enabled"):       return "HIGH"
    if open_mrs > 0:                return "HIGH"
    if (p.get("issues_enabled") or
        p.get("wiki_enabled") or
        p.get("packages_enabled")): return "MEDIUM"
    return "LOW"


RISK_ORDER = {"HIGH": 0, "MEDIUM": 1, "LOW": 2, "ARCHIVED": 3}


