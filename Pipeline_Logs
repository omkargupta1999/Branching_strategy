#!/usr/bin/env python3

"""
=========================================================
GitLab Repository Size Report
=========================================================

Purpose:
    Fetch all repositories from a GitLab group and
    generate a repository size report.

Features:
    - Group + Subgroups
    - Repository Path
    - Repository Size
    - Total Size Summary
    - TXT Output
    - Read Only (GET APIs only)
    - No External Packages Required

Python:
    Python 3.6+

=========================================================
"""

import urllib.request
import urllib.error
import json
import ssl
import sys
from datetime import datetime

# =========================================================
# CONFIGURATION
# =========================================================

GITLAB_URL = "https://gitlab.epay.sbi"

TOKEN = "YOUR_PERSONAL_ACCESS_TOKEN"

GROUP_PATH = "itepaypg-sbiepay2"

OUTPUT_FILE = "gitlab_repo_size_report.txt"

# =========================================================
# SSL
# =========================================================

ssl_ctx = ssl._create_unverified_context()

HEADERS = {
    "PRIVATE-TOKEN": TOKEN
}

# =========================================================
# API HELPERS
# =========================================================

def api_get(url):

    req = urllib.request.Request(url)

    for key, value in HEADERS.items():
        req.add_header(key, value)

    try:
        response = urllib.request.urlopen(
            req,
            context=ssl_ctx
        )

        data = json.loads(response.read())

        return data, response

    except urllib.error.HTTPError as e:

        print(f"HTTP Error: {e.code}")
        sys.exit(1)

    except Exception as e:

        print(f"Error: {e}")
        sys.exit(1)

# =========================================================
# FETCH ALL PROJECTS
# =========================================================

def get_all_projects():

    projects = []
    page = 1

    while True:

        url = (
            f"{GITLAB_URL}/api/v4/groups/{GROUP_PATH}/projects"
            f"?include_subgroups=true"
            f"&with_statistics=true"
            f"&per_page=100"
            f"&page={page}"
        )

        data, response = api_get(url)

        if not data:
            break

        projects.extend(data)

        total_pages = int(
            response.headers.get(
                "X-Total-Pages",
                "1"
            )
        )

        if page >= total_pages:
            break

        page += 1

    return projects

# =========================================================
# SIZE FORMATTER
# =========================================================

def format_size(kb):

    try:

        kb = int(kb)

        if kb >= 1048576:
            return f"{kb / 1048576:.2f} GB"

        elif kb >= 1024:
            return f"{kb / 1024:.2f} MB"

        else:
            return f"{kb} KB"

    except Exception:
        return "0 KB"

# =========================================================
# MAIN
# =========================================================

def main():

    if not TOKEN:
        print("PAT Token not provided")
        sys.exit(1)

    print("=" * 60)
    print("GitLab Repository Size Report")
    print("=" * 60)

    print(f"GitLab URL : {GITLAB_URL}")
    print(f"Group      : {GROUP_PATH}")

    print("\nFetching repositories...\n")

    projects = get_all_projects()

    print(f"Repositories Found : {len(projects)}")

    total_size_kb = 0

    rows = []

    for index, project in enumerate(projects, start=1):

        path = project.get(
            "path_with_namespace",
            "N/A"
        )

        repo_size_kb = (
            project.get("statistics", {})
                   .get("repository_size", 0)
        )

        total_size_kb += repo_size_kb

        rows.append(
            (
                index,
                path,
                format_size(repo_size_kb)
            )
        )

    with open(
        OUTPUT_FILE,
        "w",
        encoding="utf-8"
    ) as report:

        report.write("\n")
        report.write("=" * 120 + "\n")
        report.write("GitLab Repository Size Report\n")
        report.write("=" * 120 + "\n")

        report.write(
            f"Generated On : {datetime.now()}\n"
        )

        report.write(
            f"GitLab URL   : {GITLAB_URL}\n"
        )

        report.write(
            f"Group        : {GROUP_PATH}\n"
        )

        report.write(
            f"Repositories : {len(projects)}\n"
        )

        report.write(
            f"Total Size   : {format_size(total_size_kb)}\n"
        )

        report.write("\n")

        report.write(
            "+" + "-" * 6 +
            "+" + "-" * 80 +
            "+" + "-" * 20 +
            "+\n"
        )

        report.write(
            "| {:<4} | {:<78} | {:<18} |\n".format(
                "Sr",
                "Repository Path",
                "Repository Size"
            )
        )

        report.write(
            "+" + "-" * 6 +
            "+" + "-" * 80 +
            "+" + "-" * 20 +
            "+\n"
        )

        for sr, repo_path, repo_size in rows:

            report.write(
                "| {:<4} | {:<78} | {:<18} |\n".format(
                    sr,
                    repo_path[:78],
                    repo_size
                )
            )

        report.write(
            "+" + "-" * 6 +
            "+" + "-" * 80 +
            "+" + "-" * 20 +
            "+\n"
        )

        report.write("\n")

        report.write(
            f"TOTAL REPOSITORIES : {len(projects)}\n"
        )

        report.write(
            f"TOTAL SIZE         : {format_size(total_size_kb)}\n"
        )

    print("\nReport Generated Successfully")
    print(f"Output File : {OUTPUT_FILE}")
    print(f"Total Size  : {format_size(total_size_kb)}")

    print("\nCompleted Successfully.")

# =========================================================
# START
# =========================================================

if __name__ == "__main__":
    main()
