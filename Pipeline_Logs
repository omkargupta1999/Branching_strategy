# ops/drill/drill.scale.yml
# Scale ALL application services DOWN or UP — GitOps approach
# Clones deployment repo → updates all service values.yaml → git push → ArgoCD syncs
#
# Called by: templates/cd/deploy.drill.yml
# Trigger:   DRILL_TIER variable set at pipeline run time
#
# What it changes per service:
#   Scale Down: replicaCount=0, autoscaling.enabled=false
#   Scale Up:   replicaCount=1, autoscaling.enabled=true
#
# Tiers:
#   prod:    prod-dc / prod-dr
#   preprod: pre-prod-dc / pre-prod
#   nonprod: dev (scale test — no DC/DR concept)

# ── Shared script — reused by all scale jobs via YAML anchor ──────────────────
.scale_script: &scale_script
  - |
    set -eo pipefail

    git clone "$DEPLOYMENT_REPO_URL" deployment
    cd deployment
    git checkout "$DEPLOYMENT_BRANCH"

    IFS=',' read -ra SERVICES <<< "$CHARTS"
    CHANGED=false

    for SERVICE in "${SERVICES[@]}"; do
      FILE="${TARGET_ENV}/charts/${SERVICE}/values.yaml"
      echo "Processing: $FILE"
      [ -f "$FILE" ] || { echo "WARNING: $FILE not found — skipping"; continue; }

      sed -i -E \
        "s/^([[:space:]]*)replicaCount:[[:space:]]*[0-9]+/\1replicaCount: ${REPLICA_COUNT}/" \
        "$FILE"
      sed -i -E \
        "/^[[:space:]]*autoscaling:/,/^[^[:space:]]/ \
         s/^([[:space:]]*)enabled:[[:space:]]*(true|false)/\1enabled: ${AUTOSCALING_ENABLED}/" \
        "$FILE"

      if ! git diff --quiet "$FILE"; then
        git add "$FILE"
        CHANGED=true
      fi
    done

    if [ "$CHANGED" = false ]; then
      echo "No changes — already at target state"
      exit 0
    fi

    git commit \
      -m "drill(${TARGET_ENV}): replicas=${REPLICA_COUNT} autoscaling=${AUTOSCALING_ENABLED} [ci skip]"

    for i in 1 2 3; do
      git push origin "$DEPLOYMENT_BRANCH" && break
      echo "Push failed — retrying ($i/3)"
      sleep 2
      git pull --rebase origin "$DEPLOYMENT_BRANCH"
    done
    echo "✅ Scaled ${TARGET_ENV}: replicas=${REPLICA_COUNT} autoscaling=${AUTOSCALING_ENABLED}"

# ── Prod DC ───────────────────────────────────────────────────────────────────
