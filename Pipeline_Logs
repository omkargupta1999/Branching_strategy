#!/usr/bin/env python3

import urllib.request
import urllib.parse
import json
import ssl

GITLAB_URL = "https://gitlab.sbi"
TOKEN = "YOUR_TOKEN"

USERNAME = "affected_username"
PROJECT_PATH = "itepaypg-sbiepay2/application/backend/epay-admin-services"

HEADERS = {"PRIVATE-TOKEN": TOKEN}
ssl_ctx = ssl._create_unverified_context()


def api_get(path):
    url = f"{GITLAB_URL}/api/v4{path}"

    req = urllib.request.Request(url)

    for k, v in HEADERS.items():
        req.add_header(k, v)

    resp = urllib.request.urlopen(req, context=ssl_ctx)

    return json.loads(resp.read())


def get_user():
    users = api_get(
        f"/users?username={urllib.parse.quote(USERNAME)}"
    )

    if not users:
        raise Exception(f"User {USERNAME} not found")

    return users[0]


def get_project():
    encoded = urllib.parse.quote(PROJECT_PATH, safe="")
    return api_get(f"/projects/{encoded}")


def get_members(project_id):
    return api_get(
        f"/projects/{project_id}/members/all"
    )


def get_direct_members(project_id):
    return api_get(
        f"/projects/{project_id}/members"
    )


def get_shared_groups(project_id):
    return api_get(
        f"/projects/{project_id}/groups"
    )


ROLE = {
    10: "Guest",
    20: "Reporter",
    30: "Developer",
    40: "Maintainer",
    50: "Owner"
}


print("\n==============================")
print("PROJECT DETAILS")
print("==============================")

project = get_project()

project_id = project["id"]

print("Project :", project["path_with_namespace"])
print("Project ID :", project_id)
print("Visibility :", project["visibility"])

print("\n==============================")
print("SHARED GROUPS")
print("==============================")

groups = get_shared_groups(project_id)

if not groups:
    print("No shared groups found")

for g in groups:

    role = ROLE.get(
        g.get(
            "group_access_level",
            g.get("access_level", 0)
        ),
        "Unknown"
    )

    print(
        f"{g.get('full_path')} "
        f"=> {role}"
    )

print("\n==============================")
print("USER CHECK")
print("==============================")

user = get_user()

uid = user["id"]

print("Username :", user["username"])
print("Name     :", user["name"])
print("User ID  :", uid)

direct_members = get_direct_members(project_id)
effective_members = get_members(project_id)

direct_ids = {m["id"] for m in direct_members}

user_direct = False
user_effective = False

for m in effective_members:

    if m["id"] == uid:

        user_effective = True

        role = ROLE.get(
            m["access_level"],
            str(m["access_level"])
        )

        print("\nEffective Access Found")
        print("Role :", role)

        if uid in direct_ids:
            print("Source : Direct Member")
        else:
            print("Source : Inherited")

if uid in direct_ids:
    user_direct = True

print("\nSummary")
print("---------------------")
print("Direct Member    :", user_direct)
print("Effective Access :", user_effective)

if not user_effective:
    print(
        "\nROOT CAUSE: User has no access "
        "to this project."
    )
