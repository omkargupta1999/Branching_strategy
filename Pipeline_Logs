# =============================================================================
#  API HELPERS — GET ONLY
# =============================================================================

def api_get(url):
    """Single GET request. Returns (data, response). Never sends data body."""
    req = urllib.request.Request(url)          # No data= arg = GET method
    for k, v in HEADERS.items():
        req.add_header(k, v)
    try:
        resp = urllib.request.urlopen(req, context=ssl_ctx)
        return json.loads(resp.read()), resp
    except urllib.error.HTTPError as e:
        if e.code == 401:
            print("\n[ERROR] 401 Unauthorized — TOKEN is empty or invalid.")
            sys.exit(1)
        if e.code == 403:
            print("\n[ERROR] 403 Forbidden — token lacks admin scope.")
            sys.exit(1)
        if e.code == 404:
            return [], None
        return [], None
    except Exception as e:
        print(f"\n[WARN] Request failed: {url} — {e}")
        return [], None


def api_all(endpoint, extra=""):
    """Paginate all pages of a GET endpoint. Returns full list."""
    results, page = [], 1
    while True:
        sep  = "&" if "?" in endpoint else "?"
        url  = f"{GITLAB_URL}{endpoint}{sep}per_page=100&page={page}{extra}"
        data, resp = api_get(url)
        if not data:
            break
        results.extend(data)
        if resp:
            total_pages = resp.headers.get("X-Total-Pages", "1")
            try:
                if page >= int(total_pages):
                    break
            except ValueError:
                break
        page += 1
    return results


def count_only(pid, path, extra=""):
    """
    Fetch only X-Total header from a list endpoint (per_page=1).
    This avoids downloading full payloads — just the count.
    GET-only.
    """
    url = (f"{GITLAB_URL}/api/v4/projects/{pid}/{path}"
           f"?per_page=1&page=1{extra}")
    req = urllib.request.Request(url)          # GET — no data body
    for k, v in HEADERS.items():
        req.add_header(k, v)
    try:
        resp = urllib.request.urlopen(req, context=ssl_ctx)
        val  = resp.headers.get("X-Total", "0")
        return int(val) if str(val).isdigit() else 0
    except Exception:
        return 0


# =============================================================================
#  UTILITIES
# =============================================================================

def safe(val, default=""):
    return val if val not in (None, "", [], {}) else default


def yn(val):
    if val is True:  return "Yes"
    if val is False: return "No"
    return ""


def fmt_kb(kb):
    if kb in (None, "", 0): return "0 KB"
    try:
        kb = int(kb)
        if kb >= 1048576: return f"{kb/1048576:.1f} GB"
        if kb >= 1024:    return f"{kb/1024:.1f} MB"
        return f"{kb} KB"
    except Exception:
        return str(kb)


def to_date(ts):
    return ts[:10] if ts else ""


def days_ago(ts):
    if not ts: return ""
    try:
        dt    = datetime.fromisoformat(ts.replace("Z", "+00:00"))
        delta = datetime.now(timezone.utc) - dt
        return str(delta.days)
    except Exception:
        return ""


def risk_level(p, open_mrs):
    if p.get("archived"):            return "ARCHIVED"
    if p.get("jobs_enabled"):        return "HIGH"
    if int(open_mrs) > 0:            return "HIGH"
    if (p.get("issues_enabled") or
        p.get("wiki_enabled")    or
        p.get("packages_enabled")):  return "MEDIUM"
    return "LOW"


def migration_notes(p, c):
    notes = []
    if c["mrs_open"] > 0:
        notes.append(f"{c['mrs_open']} open MR(s) — author attribution risk")
    if p.get("lfs_enabled"):
        notes.append("LFS — objects need separate migration")
    if p.get("mirror"):
        notes.append("Mirror config — re-setup post-migration")
    if p.get("container_registry_enabled"):
        notes.append("Container images — re-push to new registry")
    if p.get("packages_enabled") and c["releases"] > 0:
        notes.append("Package registry data migration needed")
    if p.get("ci_config_path"):
        notes.append(f"Custom CI path: {p['ci_config_path']}")
    elif p.get("jobs_enabled"):
        notes.append("Review .gitlab-ci.yml — check hardcoded registry/template paths")
    if c["webhooks"] > 0:
        notes.append(f"{c['webhooks']} webhook(s) — re-configure post-migration")
    if c["deploy_keys"] > 0:
        notes.append(f"{c['deploy_keys']} deploy key(s) — re-add post-migration")
    if c["environments"] > 0:
        notes.append(f"{c['environments']} environment(s) — re-configure")
    if p.get("archived"):
        notes.append("Archived — confirm if migration is needed")
    if p.get("empty_repo"):
        notes.append("Empty repository")
    return " | ".join(notes) if notes else "Standard migration"


def write_csv(filename, headers, rows):
    path = os.path.join(OUT_DIR, filename)
    with open(path, "w", newline="", encoding="utf-8") as f:
        w = csv.writer(f)
        w.writerow(headers)
        w.writerows(rows)
    return path


def progress(current, total, label=""):
    bar_len  = 30
    filled   = int(bar_len * current / total) if total else 0
    bar      = "█" * filled + "░" * (bar_len - filled)
    pct      = int(100 * current / total) if total else 0
    print(f"  [{bar}] {pct:>3}%  {current}/{total}  {label:<40}", end="\r")


