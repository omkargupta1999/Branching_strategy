# ci/security/sast/sast.fortify.yml  |  Stage: sast

.sast_fortify:
  stage: sast
  image: artifactory.jfrog.sbi:443/dso-base-image/ubi9/ubi9-java21-fortify-24.4:2.0
  tags:
    - common_runner
  variables:
    FORTIFY_BUILD_ID: "$CI_PROJECT_PATH_SLUG"
    FORTIFY_MEM: "8G"
    CACERT_PATH: "${CI_PROJECT_DIR}/cacerts-custom"
    JFROG_GRADLE_REPO: "https://artifactory.jfrog.sbi:443/artifactory/itepaypg-sbiepay2-gradle-virtual/"
    GRADLE_OPTS: "-Dorg.gradle.daemon=false"
    GRADLE_USER_HOME: "${CI_PROJECT_DIR}/.gradle"
  allow_failure: true
  before_script:
    - java -version
    - gradle --version
    - mkdir -p "${GRADLE_USER_HOME}/init.d"
    - |
      cat > "${GRADLE_USER_HOME}/init.d/epay-artifactory.init.gradle" << 'EOF'
      settingsEvaluated { settings ->
          settings.pluginManagement {
              repositories {
                  maven {
                      url System.getenv("JFROG_GRADLE_REPO")
                      credentials {
                          username = System.getenv("JF_USER")
                          password = System.getenv("JF_TOKEN")
                      }
                  }
              }
          }
          settings.dependencyResolutionManagement {
              repositoriesMode.set(RepositoriesMode.FAIL_ON_PROJECT_REPOS)
              repositories {
                  maven {
                      url System.getenv("JFROG_GRADLE_REPO")
                      credentials {
                          username = System.getenv("JF_USER")
                          password = System.getenv("JF_TOKEN")
                      }
                  }
                  flatDir { dirs "libs" }
              }
          }
      }
      EOF
    - cp "$JAVA_HOME/lib/security/cacerts" "$CACERT_PATH"
    - chmod 644 "$CACERT_PATH"
    - keytool -importcert -keystore "$CACERT_PATH" -storepass changeit
        -alias jfrog-internal -file "$JF_ARTIFACTORY_CERT" -noprompt
    - export JAVA_TOOL_OPTIONS="-Djavax.net.ssl.trustStore=${CACERT_PATH} -Djavax.net.ssl.trustStorePassword=changeit"
  script:
    - sourceanalyzer -b "$FORTIFY_BUILD_ID" -clean
    - sourceanalyzer -b "$FORTIFY_BUILD_ID" -Xmx${FORTIFY_MEM}
        gradle --no-daemon clean compileJava -x test
    - sourceanalyzer -b "$FORTIFY_BUILD_ID" -scan -Xmx${FORTIFY_MEM} -f "${CI_PROJECT_PATH_SLUG}.fpr"
    - BIRTReportGenerator -template "Developer Workbook"
        -source "${CI_PROJECT_PATH_SLUG}.fpr"
        -format PDF -output "${CI_PROJECT_PATH_SLUG}_report.pdf"
    - |
      FPRUtility -information -search \
        -query "[fortify priority order]:critical OR [fortify priority order]:high" \
        -project "${CI_PROJECT_PATH_SLUG}.fpr" > sca_gate.txt || true
      cat sca_gate.txt
      ISSUES=$(grep -i "matched search query" sca_gate.txt | awk '{print $1}')
      ISSUES=${ISSUES:-0}
      if [ "$ISSUES" -gt 0 ]; then
        echo -e "\e[31m QUALITY GATE FAILED — High/Critical: $ISSUES\e[0m"
        exit 1
      fi
      echo -e "\e[32m QUALITY GATE PASSED — High/Critical: 0\e[0m"
  artifacts:
    paths:
      - "${CI_PROJECT_PATH_SLUG}.fpr"
      - "${CI_PROJECT_PATH_SLUG}_report.pdf"
      - sca_gate.txt
    expire_in: 1 day
    when: always

.fortify_to_gitlab:
  stage: sast
  image: artifactory.jfrog.sbi:443/dso-docker-base-images/py-fortify:0.0.1
  tags:
    - common_runner
  needs:
    - job: "sast:fortify"
      artifacts: true
  allow_failure: true
  before_script:
    - git config --global http.sslVerify false
  script:
    - git clone https://oauth2:${CLONE_TOKEN}@gitlab.sbi/centraliseddevsecops/common-utility/utility.git
    - python3 utility/script/fortify_to_gitlab.py "${CI_PROJECT_PATH_SLUG}.fpr"
  artifacts:
    reports:
      sast: gl-sast-report.json
    paths:
      - gl-sast-report.json
    expire_in: 1 week
    when: always

sast:fortify:
  extends: .sast_fortify

sast:fortify:report:
  extends: .fortify_to_gitlab
