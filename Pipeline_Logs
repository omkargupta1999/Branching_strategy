=============================== build.gradle  for logging-services -----------------


plugins {
	id 'java'
	id 'maven-publish'
}
group = 'com.sbi.epay'
version = '1.0.0'
ext.versions = [ logback : '1.5.22', logback_encoder: '9.0' ]

// repositories {
// 	mavenCentral()
// }

publishing {
    publications {
        mavenJava(MavenPublication) {
            from components.java
        }
    }
    repositories {
        maven {
            url 'https://artifactory.jfrog.sbi:443/artifactory/itepaypg-sbiepay2-maven-local/'
            credentials(PasswordCredentials) {
                username = System.getenv("JF_USER")
                password = System.getenv("JF_TOKEN")
            }
            authentication {
                basic(BasicAuthentication)
            }
        }
    }               
}


dependencies {
	implementation "ch.qos.logback:logback-classic:${versions.logback}"
	implementation "net.logstash.logback:logstash-logback-encoder:${versions.logback_encoder}"
}

tasks.named('test') {
	useJUnitPlatform()
}

