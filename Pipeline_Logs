#!/usr/bin/env python3
"""
GitLab Repository Audit (Air-Gapped Version)
- No third-party dependencies
- Uses only Python standard library
- Generates:
    1. gitlab_repo_audit.html
    2. gitlab_full_audit.csv
    3. gitlab_cicd_repos.csv
    4. gitlab_open_items.csv
"""

import csv
import json
import ssl
import sys
import urllib.request
import urllib.error
from datetime import datetime, timezone
from html import escape

# ================= CONFIG =================

GITLAB_URL = "https://gitlab.epay.sbi"
TOKEN = "REPLACE_WITH_PAT"
TARGET_GROUP = "itepaypg-sbiepay2"

HTML_REPORT = "gitlab_repo_audit.html"

# ===========================================

ssl_ctx = ssl._create_unverified_context()
HEADERS = {"PRIVATE-TOKEN": TOKEN}


def api_get(url):
    req = urllib.request.Request(url)
    for k, v in HEADERS.items():
        req.add_header(k, v)

    try:
        resp = urllib.request.urlopen(req, context=ssl_ctx, timeout=60)
        return json.loads(resp.read()), resp
    except Exception as e:
        print(f"[WARN] {url} -> {e}")
        return [], None


def api_all(endpoint):
    results = []
    page = 1

    while True:
        sep = "&" if "?" in endpoint else "?"
        url = f"{GITLAB_URL}{endpoint}{sep}per_page=100&page={page}"

        data, resp = api_get(url)

        if not data:
            break

        results.extend(data)

        total_pages = int(resp.headers.get("X-Total-Pages", "1"))

        if page >= total_pages:
            break

        page += 1

    return results


def count_endpoint(pid, path, extra=""):
    url = (
        f"{GITLAB_URL}/api/v4/projects/{pid}/{path}"
        f"?per_page=1&page=1{extra}"
    )

    req = urllib.request.Request(url)

    for k, v in HEADERS.items():
        req.add_header(k, v)

    try:
        resp = urllib.request.urlopen(req, context=ssl_ctx, timeout=60)
        return int(resp.headers.get("X-Total", "0"))
    except Exception:
        return 0


def days_ago(ts):
    if not ts:
        return ""
    try:
        dt = datetime.fromisoformat(ts.replace("Z", "+00:00"))
        return (datetime.now(timezone.utc) - dt).days
    except Exception:
        return ""


def risk_level(ci_enabled, open_mrs, archived):
    if archived:
        return "ARCHIVED"
    if ci_enabled or open_mrs > 0:
        return "HIGH"
    return "MEDIUM"


def fetch_projects():
    if not TOKEN or TOKEN == "REPLACE_WITH_PAT":
        print("Update TOKEN before execution.")
        sys.exit(1)

    endpoint = (
        f"/api/v4/groups/{TARGET_GROUP}/projects"
        f"?include_subgroups=true&with_statistics=true"
    )

    return api_all(endpoint)


def collect_rows(projects):
    rows = []

    for idx, p in enumerate(projects, start=1):

        pid = p["id"]

        print(f"[{idx}/{len(projects)}] {p.get('path_with_namespace')}")

        branches = count_endpoint(pid, "repository/branches")
        tags = count_endpoint(pid, "repository/tags")
        mrs_open = count_endpoint(pid, "merge_requests", "&state=opened")
        issues_open = count_endpoint(pid, "issues", "&state=opened")
        pipelines = count_endpoint(pid, "pipelines")
        members = count_endpoint(pid, "members/all")
        webhooks = count_endpoint(pid, "hooks")
        deploy_keys = count_endpoint(pid, "deploy_keys")

        row = {
            "id": pid,
            "name": p.get("name"),
            "path": p.get("path_with_namespace"),
            "namespace": p.get("namespace", {}).get("full_path"),
            "visibility": p.get("visibility"),
            "default_branch": p.get("default_branch"),
            "branches": branches,
            "tags": tags,
            "mrs_open": mrs_open,
            "issues_open": issues_open,
            "pipelines": pipelines,
            "members": members,
            "webhooks": webhooks,
            "deploy_keys": deploy_keys,
            "ci_enabled": "Yes" if p.get("jobs_enabled") else "No",
            "archived": "Yes" if p.get("archived") else "No",
            "last_activity": p.get("last_activity_at", "")[:10],
            "days_inactive": days_ago(p.get("last_activity_at")),
            "risk": risk_level(
                p.get("jobs_enabled"),
                mrs_open,
                p.get("archived")
            ),
            "http_url": p.get("http_url_to_repo", "")
        }

        rows.append(row)

    return rows


def write_csv(filename, rows):
    if not rows:
        return

    with open(filename, "w", newline="", encoding="utf-8") as f:
        writer = csv.DictWriter(f, fieldnames=list(rows[0].keys()))
        writer.writeheader()
        writer.writerows(rows)


def generate_html(rows):

    total = len(rows)
    high = len([r for r in rows if r["risk"] == "HIGH"])
    medium = len([r for r in rows if r["risk"] == "MEDIUM"])
    archived = len([r for r in rows if r["risk"] == "ARCHIVED"])

    html = f"""
<html>
<head>
<title>GitLab Audit</title>
<style>
body {{font-family:Arial;margin:20px;}}
table {{border-collapse:collapse;width:100%;}}
th {{background:#1c3557;color:white;padding:8px;}}
td {{border:1px solid #ddd;padding:6px;}}
tr:nth-child(even) {{background:#f2f2f2;}}
.card {{display:inline-block;padding:10px 20px;margin:5px;color:white;}}
.total {{background:#1c3557;}}
.high {{background:red;}}
.medium {{background:orange;}}
.archived {{background:gray;}}
</style>
</head>
<body>

<h1>GitLab Repository Audit</h1>

<div class="card total">Total Repos: {total}</div>
<div class="card high">High Risk: {high}</div>
<div class="card medium">Medium Risk: {medium}</div>
<div class="card archived">Archived: {archived}</div>

<table>
<tr>
<th>ID</th>
<th>Repository</th>
<th>Branches</th>
<th>Tags</th>
<th>Open MRs</th>
<th>Issues</th>
<th>Pipelines</th>
<th>Members</th>
<th>Risk</th>
</tr>
"""

    for r in rows:
        html += f"""
<tr>
<td>{r['id']}</td>
<td>{escape(str(r['path']))}</td>
<td>{r['branches']}</td>
<td>{r['tags']}</td>
<td>{r['mrs_open']}</td>
<td>{r['issues_open']}</td>
<td>{r['pipelines']}</td>
<td>{r['members']}</td>
<td>{r['risk']}</td>
</tr>
"""

    html += "</table></body></html>"

    with open(HTML_REPORT, "w", encoding="utf-8") as f:
        f.write(html)


def main():
    projects = fetch_projects()

    rows = collect_rows(projects)

    write_csv("gitlab_full_audit.csv", rows)

    write_csv(
        "gitlab_cicd_repos.csv",
        [r for r in rows if r["ci_enabled"] == "Yes"]
    )

    write_csv(
        "gitlab_open_items.csv",
        [r for r in rows if r["mrs_open"] > 0 or r["issues_open"] > 0]
    )

    generate_html(rows)

    print("Reports generated successfully.")


if __name__ == "__main__":
    main()
