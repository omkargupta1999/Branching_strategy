apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ include "Epay_Communication_Service.fullname" . }}
  labels:
    {{- include "Epay_Communication_Service.labels" . | nindent 4 }}
spec:
  {{- if not .Values.autoscaling.enabled }}
  replicas: {{ .Values.replicaCount }}
  {{- end }}
  selector:
    matchLabels:
      {{- include "Epay_Communication_Service.selectorLabels" . | nindent 6 }}
  template:
    metadata:
      annotations:
        checksum/configmap: {{ include (print $.Template.BasePath "/configmap.yaml") . | sha256sum }}
        {{- with .Values.podAnnotations }}
        {{- toYaml . | nindent 8 }}
        {{- end }}
      labels:
        {{- include "Epay_Communication_Service.labels" . | nindent 8 }}
        {{- with .Values.podLabels }}
        {{- toYaml . | nindent 8 }}
        {{- end }}
    spec:
      {{- with .Values.imagePullSecrets }}
      imagePullSecrets:
        {{- toYaml . | nindent 8 }}
      {{- end }}
      serviceAccountName: {{ include "Epay_Communication_Service.serviceAccountName" . }}
      securityContext:
        {{- toYaml .Values.podSecurityContext | nindent 8 }}
      {{- if .Values.initContainer.enabled }}
      initContainers:
        - name: import-certs
          image: {{ .Values.initContainer.image }}
          securityContext:
            runAsNonRoot: true
            #runAsUser: 1001190000    
            allowPrivilegeEscalation: false
            #runAsUser: 0
            capabilities:
              drop: ["ALL"]
            seccompProfile:
              type: RuntimeDefault
          command: ["/bin/sh", "-c"]
          args:
            - |
              set -euo pipefail

              echo "[INFO] Preparing shared cacerts volume..."
              for C in \
                "$JAVA_HOME/lib/security/cacerts" \
                "/usr/lib/jvm/java-21/lib/security/cacerts" \
                "/etc/pki/java/cacerts"; do
                if [ -r "$C" ]; then
                  echo "[INFO] Using truststore at $C"
                  mkdir -p /cacerts/data
                  cp "$C" /cacerts/data/cacerts
                  chmod 660 /cacerts/data/cacerts
                  break
                fi
              done
              
              echo "[INFO] Importing custom certificates..."
              for f in /etc/custom-certs-communication/*.crt /etc/custom-certs-communication/*.cer /certs/*.crt /certs/*.cer; do
                [ -e "$f" ] || continue
                base="$(basename "$f")"
                alias="$(echo "$base" | tr '[:upper:]' '[:lower:]' | tr -c 'a-z0-9' '-')"
                echo "[INFO] Importing $base as alias $alias"
                keytool -import -trustcacerts -file "$f" \
                  -alias "$alias" \
                  -keystore /cacerts/data/cacerts \
                  -storepass {{ .Values.initContainer.truststorePassword }} -noprompt || true
              done
              
          volumeMounts:
            # - name: dcms-txn-cert
            #   mountPath: /certs
            - name: custom-certs-communication
              mountPath: /etc/custom-certs-communication
            - name: cacerts
              mountPath: /cacerts            
      {{- end }}
      containers:
        - name: {{ .Chart.Name }}
          securityContext:
            {{- toYaml .Values.securityContext | nindent 12 }}
          image: "{{ tpl .Values.image.repository $ }}:{{ .Values.image.tag | default .Chart.AppVersion }}"
          imagePullPolicy: {{ .Values.image.pullPolicy }}
          ports:
            - name: http
              containerPort: {{ .Values.service.port }}
              protocol: TCP
          env:
          - name: JAVA_TOOL_OPTIONS
            value: "-Djavax.net.ssl.trustStore=/cacerts/data/cacerts -Djavax.net.ssl.trustStorePassword=changeit"
          - name: SPRING_CONFIG_LOCATION
            value: file:/opt/gradle/
            # - name: DB_USERNAME
            #   valueFrom:
            #     secretKeyRef:
            #       name: my-secrets-operation-service-secret
            #       key: DB_USERNAME
            # - name: DB_PASSWORD
            #   valueFrom:
            #     secretKeyRef:
            #       name: my-secrets-operation-service-secret
            #       key: DB_PASSWORD
            #- name: JAVA_OPTS
              #value: "--add-exports=java.base/sun.nio.ch=ALL-UNNAMED --add-opens=java.base/sun.nio.ch=ALL-UNNAMED"
              #value: "--add-exports=java.base/sun.nio.ch=ALL-UNNAMED --add-exports=java.base/sun.util.calendar=ALL-UNNAMED --add-exports=java.base/sun.security.action=ALL-UNNAMED"
          volumeMounts:
            - mountPath: /opt/gradle
              name: config
            - mountPath: /certs
              name: eiscert
              readOnly: true
            {{- if .Values.customCertsCommunication.enabled }}
            - name: custom-certs-communication
              mountPath: {{ .Values.customCertsCommunication.mountPaths }}
              readOnly: true
            {{- end }}
            - name: cacerts
              mountPath: /cacerts
              readOnly: true
      volumes:
        - name: config
          configMap:
            defaultMode: 420
            name: comm-config
        - name: eiscert
          secret:
            secretName: eiscert
        {{- if .Values.customCertsCommunication.enabled }}
        - name: custom-certs-communication
          secret:
            secretName: {{ .Values.customCertsCommunication.secretName }} 
        {{- end }}
        - name: cacerts
          emptyDir: {}

