# ci/version/semver.yml  |  Stage: version
# Computes VERSION string based on branch/pipeline context → version.env
# Consumed by ALL downstream jobs via dotenv artifact
# NOTE: This job ONLY computes the version. Git tags created in ci/release/tag.yml
#
# ── VERSION output per context ────────────────────────────────────────────────
#
# Pipeline Source      Branch / Context                   VERSION
# ──────────────────── ────────────────────────────────── ──────────────────────────────────────
# merge_request_event  <any source> → <any target>        mr-<src branch>-<tgt branch>-<MR ID>-<short-sha>
# push                 feature/*                          <branch-name>-<short-sha>
# push                 bugfix/*                           <branch-name>-<short-sha>
# push                 hotfix/*                           <branch-name>-<short-sha>
# push                 release/*                          <branch-name>-<short-sha>
# push                 develop                            dev-<short-sha>
# push                 sit-integration                    sit-<short-sha>
# push                 main ← release/major-*             major bump (last_tag + 1.0.0)
# push                 main ← release/minor-*             minor bump (last_tag + 0.1.0)
# push                 main ← hotfix/*                    patch bump (last_tag + 0.0.1)
# unknown              any                                unknown-<short-sha>
#
# ── Tag format ────────────────────────────────────────────────────────────────
# Tags are BARE semver: 1.2.0  (NO 'v' prefix — branch/tag regex disallows it).
# Both the idempotency guard and the LAST_TAG lookup below match bare-only, and
# ci/release/tag.yml creates bare tags. These three MUST stay consistent.
#
# ── Branch name cleaning ──────────────────────────────────────────────────────
#   /  → -    Special chars → -    Uppercase → lowercase
#   Consecutive dashes collapsed    Max 40 chars
# Keeps all VERSION strings well within the Docker image tag limit of 128 chars.
#
# ── main merge — how source branch is identified (Approach 1) ─────────────────
# CI_MERGE_REQUEST_SOURCE_BRANCH_NAME is NOT available in post-merge push pipeline.
# CI_COMMIT_TITLE IS available — GitLab sets it to the merge commit subject:
#   "Merge branch 'release/minor-DM…-EPAY-…' into 'main'"
#   "Merge branch 'hotfix/EPAY-…' into 'main'"
# Squash/rebase merges are NOT permitted on Protected branch 'main' (bank policy).
# LOAD-BEARING: Settings → Merge requests → Merge method MUST be 'Merge commit'.
# If commit title does not match expected format → version job fails → pipeline fails.

version:
  stage: version
  image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-local/custom-ci/rhelgit-oc-helm:1.0
  variables:
    GIT_DEPTH: "0"            # full clone required — accurate tag lookup
    INITIAL_VERSION: "1.0.0"  # baseline when repo has no semver tag yet
  tags:
    - common_runner
  before_script:
    - git config --global http.sslVerify false
    - git config --global --add safe.directory '*'
  script:
    - |
      set -eo pipefail
      git fetch --tags

      # ── Helper: clean branch name for use in VERSION string ───────────────
      clean_branch() {
        echo "$1"                        \
          | sed 's/[^a-zA-Z0-9._-]/-/g' \
          | tr '[:upper:]' '[:lower:]'   \
          | sed 's/--*/-/g'              \
          | sed 's/^-//; s/-$//'         \
          | cut -c1-40
      }

      # ── MR pipeline ────────────────────────────────────────────────────────
      if [[ "$CI_PIPELINE_SOURCE" == "merge_request_event" ]]; then
        SRC_CLEAN=$(clean_branch "$CI_MERGE_REQUEST_SOURCE_BRANCH_NAME")
        TGT_CLEAN=$(clean_branch "$CI_MERGE_REQUEST_TARGET_BRANCH_NAME")
        VERSION="mr-${SRC_CLEAN}-${TGT_CLEAN}-${CI_MERGE_REQUEST_IID}-${CI_COMMIT_SHORT_SHA}"

      # ── feature/*, bugfix/*, hotfix/*, release/* push ──────────────────────
      # One condition covers all four — same pattern: <branch>-<sha>
      elif [[ "$CI_COMMIT_BRANCH" =~ ^(feature|bugfix|hotfix|release)\/ ]]; then
        BRANCH_CLEAN=$(clean_branch "$CI_COMMIT_BRANCH")
        VERSION="${BRANCH_CLEAN}-${CI_COMMIT_SHORT_SHA}"

      # ── develop push ───────────────────────────────────────────────────────
      elif [[ "$CI_COMMIT_BRANCH" == "develop" ]]; then
        VERSION="dev-${CI_COMMIT_SHORT_SHA}"

      # ── sit-integration push ───────────────────────────────────────────────
      elif [[ "$CI_COMMIT_BRANCH" == "sit-integration" ]]; then
        VERSION="sit-${CI_COMMIT_SHORT_SHA}"

      # ── main push ──────────────────────────────────────────────────────────
      elif [[ "$CI_COMMIT_BRANCH" == "main" ]]; then
        echo "Merge commit title: $CI_COMMIT_TITLE"

        # ── Idempotency guard ────────────────────────────────────────────────
        # Retry after ci/release/tag.yml already tagged this SHA:
        # reuse the existing semver — never compute a second bump.
        # BARE tags only (no v-prefix) — must match LAST_TAG lookup + tag.yml.
        EXISTING_TAG=$(git tag --points-at HEAD | grep -E '^[0-9]+\.[0-9]+\.[0-9]+$' | head -1 || true)
        if [[ -n "$EXISTING_TAG" ]]; then
          VERSION="$EXISTING_TAG"
          echo "Semver tag ${EXISTING_TAG} already points at HEAD — reusing (pipeline retry)."

        # ── Gate 1: merge commit from an ALLOWED source (release/* | hotfix/*) ─
        elif echo "$CI_COMMIT_TITLE" | grep -qE "^Merge branch '(release|hotfix)/"; then
          SRC_BRANCH=$(echo "$CI_COMMIT_TITLE" | sed -n "s/^Merge branch '\([^']*\)'.*/\1/p")

          # ── Gate 1a: extraction sanity — title matched but yielded nothing ──
          # Guards against malformed/unusual titles that pass the grep but whose
          # quoted branch name cannot be extracted (empty SRC_BRANCH would
          # otherwise fall to the case default with a confusing message).
          if [[ -z "$SRC_BRANCH" ]]; then
            echo "❌ ERROR: Malformed merge commit title — source branch not extractable."
            echo "   Title was : $CI_COMMIT_TITLE"
            exit 1
          fi

          case "$SRC_BRANCH" in
            release/major-*)  BUMP="major" ;;
            release/minor-*)  BUMP="minor" ;;
            hotfix/*)         BUMP="patch" ;;
            *)
              echo "❌ ERROR: Unsupported source branch '${SRC_BRANCH}' merged to main."
              echo "   Only release/major-*, release/minor-* and hotfix/* may merge to main."
              exit 1
              ;;
          esac

          # ── Latest BARE semver tag (no v-prefix) ─────────────────────────────
          LAST_TAG=$(git tag -l | grep -E '^[0-9]+\.[0-9]+\.[0-9]+$' | sort -V | tail -1 || true)

          if [[ -z "$LAST_TAG" ]]; then
            VERSION="${INITIAL_VERSION}"
            echo "No prior semver tag found — starting at ${VERSION}"
          else
            IFS=. read -r MAJ MIN PAT <<< "$LAST_TAG"
            case "$BUMP" in
              major) MAJ=$((MAJ + 1)); MIN=0; PAT=0 ;;
              minor) MIN=$((MIN + 1)); PAT=0 ;;
              patch) PAT=$((PAT + 1)) ;;
            esac
            VERSION="${MAJ}.${MIN}.${PAT}"
          fi
          echo "Semver: ${LAST_TAG:-<none>} → ${VERSION}  (${BUMP} bump from ${SRC_BRANCH})"
          echo "VERSION_BUMP=${BUMP}"                >> version.env
          echo "VERSION_SOURCE_BRANCH=${SRC_BRANCH}" >> version.env

        # ── Gate 2: merge commit, but from a FORBIDDEN source branch ─────────
        elif echo "$CI_COMMIT_TITLE" | grep -qE "^Merge branch '"; then
          echo "❌ ERROR: Merge to main from unsupported source branch."
          echo "   Title was : $CI_COMMIT_TITLE"
          echo "   Only release/* (minor/major bump) and hotfix/* (patch bump)"
          echo "   may merge to main."
          echo ""
          echo "   Root cause : Protected-branch / MR-approval policy breach."
          echo "   Fix        : Review MR approval rules and protected branch"
          echo "                settings for 'main'; revert the offending merge."
          exit 1

        # ── Gate 3: not a standard merge commit at all ───────────────────────
        else
          echo "❌ ERROR: Cannot determine source branch from merge commit title."
          echo "   Title was  : $CI_COMMIT_TITLE"
          echo "   Expected   : \"Merge branch 'release/…' into 'main'\""
          echo "   OR         : \"Merge branch 'hotfix/…' into 'main'\""
          echo ""
          echo "   Root cause : Squash or rebase merge was used on Protected branch 'main'."
          echo "   Fix        : GitLab → Project → Settings → General → Merge requests"
          echo "                Merge method → select 'Merge commit'"
          echo "                Re-raise the MR and merge again."
          exit 1
        fi

      # ── Unknown branch ─────────────────────────────────────────────────────
      else
        echo "⚠️  WARNING: Unrecognised branch '${CI_COMMIT_BRANCH}' — using SHA"
        VERSION="unknown-${CI_COMMIT_SHORT_SHA}"
      fi

      # ── Write dotenv ────────────────────────────────────────────────────────
      if [[ "$CI_PIPELINE_SOURCE" == "merge_request_event" ]]; then
        echo "BRANCH_USED=${CI_MERGE_REQUEST_SOURCE_BRANCH_NAME}" >> version.env
      else
        echo "BRANCH_USED=${CI_COMMIT_BRANCH}"                    >> version.env
      fi
      echo "VERSION=$VERSION"                           >> version.env
      echo "CI_COMMIT_SHORT_SHA=$CI_COMMIT_SHORT_SHA"   >> version.env

      # ── Summary ─────────────────────────────────────────────────────────────
      echo "──────────────────────────────────────────────────────"
      echo "Source  : ${CI_PIPELINE_SOURCE}"
      if [[ "$CI_PIPELINE_SOURCE" == "merge_request_event" ]]; then
        echo "MR      : ${CI_MERGE_REQUEST_SOURCE_BRANCH_NAME} → ${CI_MERGE_REQUEST_TARGET_BRANCH_NAME}"
      else
        echo "Branch  : ${CI_COMMIT_BRANCH}"
      fi
      echo "VERSION : ${VERSION}"
      echo "──────────────────────────────────────────────────────"

  artifacts:
    reports:
      dotenv: version.env
    expire_in: 1 day
  rules:                             ## version job runs in all pipeline types
    - when: on_success



