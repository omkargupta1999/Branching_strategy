# --- Disable JDK auto-download (critical for restricted env) ---
org.gradle.java.installations.auto-download=false

# --- Allow Gradle to detect local JDK ---
org.gradle.java.installations.auto-detect=true

# --- Explicit JDK path (matches your container) ---
org.gradle.java.installations.paths=/usr/lib/jvm/java-21-openjdk-21.0.10.0.7-1.el9.x86_64

# --- Recommended for CI stability ---
org.gradle.daemon=false
org.gradle.jvmargs=-Xmx2g -Dfile.encoding=UTF-8
