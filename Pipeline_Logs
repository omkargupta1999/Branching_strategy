# ============================================================
if __name__ == "__main__":
    ap = argparse.ArgumentParser(
        description="GitLab epic validator + full-fidelity board mirror + rollback (stdlib).")
    ap.add_argument("--mirror-boards", action="store_true",
                    help="Mirror source epic boards onto target (full fidelity).")
    ap.add_argument("--rollback", action="store_true",
                    help="Undo a previous board mirror using a journal file.")
    ap.add_argument("--journal", default=None,
                    help="Path to rollback journal (.jsonl). Required for --rollback "
                         "unless exactly one journal exists in the output dir.")
    ap.add_argument("--apply", action="store_true",
                    help="Actually perform writes. Without it, mirror/rollback are DRY RUN.")
    args = ap.parse_args()

    if args.rollback:
        jf = args.journal
        if not jf:
            cands = sorted(OUTPUT_DIR.glob("rollback_journal_*.jsonl"))
            if len(cands) == 1:
                jf = str(cands[0])
                print(f"  Using only journal found: {jf}")
            elif not cands:
                print("  No journal found. Pass --journal <path>.")
                sys.exit(1)
            else:
                print("  Multiple journals found — specify one with --journal:")
                for c in cands:
                    print(f"    {c}")
                sys.exit(1)
        if args.apply:
            print("!! ROLLBACK WRITE MODE: will destroy boards/lists this script created.")
        else:
            print("-- ROLLBACK DRY RUN: no writes. Add --apply to execute.")
        run_rollback(jf, dry_run=not args.apply)
    else:
        if args.mirror_boards and args.apply:
            print("!! MIRROR WRITE MODE: epic boards WILL be created on target.")
        elif args.mirror_boards:
            print("-- MIRROR DRY RUN: no writes. Add --apply to execute.")
        run_validation(mirror_flag=args.mirror_boards, dry_run=not args.apply)
