regenerate-lock:
  stage: build
  image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-virtual/ubi9/php-82:1-1778488703
  tags:
    - common_runner
  variables:
    JF_ARTIFACTORY_URL: "https://artifactory.jfrog.sbi/artifactory"
    PHP_VIRTUAL_REPO: "itepaypg-sbiepay2-php-virtual"
    COMPOSER_ALLOW_SUPERUSER: "1"
  script:
    - git config --global --add safe.directory "${CI_PROJECT_DIR}"
    - php --version

    # Download Composer from JFrog
    - |
      set -eo pipefail
      echo "── Downloading Composer from JFrog ──"
      curl -f \
        --cacert "$JF_ARTIFACTORY_CERT" \
        -u "${JF_USER}:${JF_TOKEN}" \
        "${JF_ARTIFACTORY_URL}/${PHP_VIRTUAL_REPO}/composer.phar" \
        -o composer.phar
      SIZE=$(stat -c%s composer.phar)
      echo "Downloaded size: $SIZE bytes"
      if [ "$SIZE" -lt 1000000 ]; then
        echo "ERROR: composer.phar too small"
        exit 1
      fi
      chmod +x composer.phar
      mv composer.phar composer
      export PATH="$CI_PROJECT_DIR:$PATH"
      composer --version

    # Configure Composer to use JFrog only
    - |
      set -eo pipefail
      export PATH="$CI_PROJECT_DIR:$PATH"
      echo "── Configuring Composer ──"
      composer config --global repos.packagist composer \
        ${JF_ARTIFACTORY_URL}/api/composer/${PHP_VIRTUAL_REPO}
      composer config --global \
        http-basic.artifactory.jfrog.sbi "${JF_USER}" "${JF_TOKEN}"
      composer config --global cafile "$JF_ARTIFACTORY_CERT"
      composer config --global repo.packagist false
      composer config --global use-github-api false
      composer config --global preferred-install dist
      echo "── Composer configured ──"

    # ── DIAGNOSTIC: Test JFrog Composer API responses ──────────────────────
    - |
      set -eo pipefail
      export PATH="$CI_PROJECT_DIR:$PATH"

      echo "===== DIAGNOSING JFROG COMPOSER API ====="

      # Test 1: Can we reach the packages.json endpoint at all?
      echo ""
      echo "--- Test 1: packages.json root endpoint ---"
      curl -s \
        --cacert "$JF_ARTIFACTORY_CERT" \
        -u "${JF_USER}:${JF_TOKEN}" \
        -o /tmp/packages.json \
        -w "HTTP Status: %{http_code}\n" \
        "${JF_ARTIFACTORY_URL}/api/composer/${PHP_VIRTUAL_REPO}/packages.json" || true
      echo "Response size: $(stat -c%s /tmp/packages.json 2>/dev/null || echo 0) bytes"
      echo "Response content (first 500 chars):"
      head -c 500 /tmp/packages.json || true
      echo ""

      # Test 2: Can we find laravel/framework specifically?
      echo ""
      echo "--- Test 2: laravel/framework package lookup ---"
      curl -s \
        --cacert "$JF_ARTIFACTORY_CERT" \
        -u "${JF_USER}:${JF_TOKEN}" \
        -o /tmp/laravel_framework.json \
        -w "HTTP Status: %{http_code}\n" \
        "${JF_ARTIFACTORY_URL}/api/composer/${PHP_VIRTUAL_REPO}/p2/laravel/framework.json" || true
      echo "Response size: $(stat -c%s /tmp/laravel_framework.json 2>/dev/null || echo 0) bytes"
      echo "Response content (first 500 chars):"
      head -c 500 /tmp/laravel_framework.json || true
      echo ""

      # Test 3: Check what Composer diagnose says about the repo
      echo ""
      echo "--- Test 3: Composer diagnose ---"
      composer diagnose || true

      # Test 4: Show Composer's view of configured repos
      echo ""
      echo "--- Test 4: Composer config repos ---"
      composer config --list --global | grep -E "repo|packagist|github" || true

      echo "===== DIAGNOSIS COMPLETE ====="
      echo "Share the output above with your JFrog admin"

  rules:
    - when: manual
