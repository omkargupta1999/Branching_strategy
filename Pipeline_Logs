# ci/deploy/deploy.jobs.yml
# All deploy trigger jobs — tech-stack agnostic.
# Included by EVERY CI orchestrator template (java, nodejs, python, php, dotnet, react).
#
# All jobs extend .trigger_cd (single base template in trigger.cd.yml).
# Job-specific behaviour sits here: rules, manual_confirmation, variables.
#
# ── Release branch gating ─────────────────────────────────────────────────────
# Deploy rules match on the PREFIX only:  /^release\//
# The exact release naming (release/(major|minor)-DM<digits>-EPAY-<desc>) is
# enforced ONCE, by the GitLab Push Rule branch regex — a malformed release
# branch cannot be created in the first place. Do NOT duplicate that regex here:
# it would have to stay in lockstep across 6 rules + the push rule, and a missed
# edit silently removes a deploy button (this exact drift caused the old
# release/0.0.0 incident). Push rule = single source of truth for branch names.
#
# ── CHART_NAME ────────────────────────────────────────────────────────────────
# Defined in each APP REPO's .gitlab-ci.yml, not in orchestrators.
#
#   # epay_transaction_service/.gitlab-ci.yml
#   include:
#     - project: 'itepaypg-sbiepay2/infra/devops/cicd-templates'
#       ref: main
#       file: 'templates/ci/backend/java.yml'
#   variables:
#     RELEASE_NAME: epay-txn            # Helm release name (cluster-unique)
#     CHART_NAME:   transactionservice  # Helm chart name in deployment repo charts/

# ── DEV — auto on develop push ────────────────────────────────────────────────
deploy-dev:
  extends: .trigger_cd
  variables:
    ENV:          dev
    SERVICE_NAME: "$CI_PROJECT_NAME"
    CHART_NAME:   "$CHART_NAME"
    VERSION: "${VERSION}"
  rules:
    # # - if: '$CI_COMMIT_BRANCH == "develop" && $CI_PIPELINE_SOURCE == "push"'
    # #   when: on_success
    # - if: '$CI_COMMIT_BRANCH =~ /^feature\/.*$/ &&  $CI_PIPELINE_SOURCE == "push"'
    #   when: on_success
    # - if: '$CI_PIPELINE_SOURCE =~ "merge_request_event" && $CI_MERGE_REQUEST_SOURCE_BRANCH_NAME =~ /^feature\/.*$/ && $CI_MERGE_REQUEST_TARGET_BRANCH_NAME == "develop"'
    #   when: on_success
    # - when: never

    # MR opened/updated
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event" && 
           $CI_MERGE_REQUEST_SOURCE_BRANCH_NAME =~ /^feature\/.*$/ && 
           $CI_MERGE_REQUEST_TARGET_BRANCH_NAME == "develop"'
      when: manual

    # MR merged -> develop push
    - if: '$CI_PIPELINE_SOURCE == "push" && 
           $CI_COMMIT_BRANCH == "develop"'
      when: manual
    - when: never

# ── SIT — manual, Release Manager ─────────────────────────────────────────────
deploy-sit:
  extends: .trigger_cd
  variables:
    ENV:          sit
    SERVICE_NAME: "$CI_PROJECT_NAME"
    CHART_NAME:   "$CHART_NAME"
  rules:
    - if: '$CI_COMMIT_BRANCH =~ /^release\//'
      when: manual
      allow_failure: true
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event" && $CI_MERGE_REQUEST_TARGET_BRANCH_NAME =~ /^release\//'
      when: manual
      allow_failure: true
    - when: never

# ── UAT — manual, Release Manager ─────────────────────────────────────────────
deploy-uat:
  extends: .trigger_cd
  variables:
    ENV:          uat
    SERVICE_NAME: "$CI_PROJECT_NAME"
    CHART_NAME:   "$CHART_NAME"
  rules:
    - if: '$CI_COMMIT_BRANCH =~ /^release\//'
      when: manual
      allow_failure: true
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event" && $CI_MERGE_REQUEST_TARGET_BRANCH_NAME =~ /^release\//'
      when: manual
      allow_failure: true
    - when: never

# ── INT — manual, Release Manager ─────────────────────────────────────────────
deploy-int:
  extends: .trigger_cd
  variables:
    ENV:          int
    SERVICE_NAME: "$CI_PROJECT_NAME"
    CHART_NAME:   "$CHART_NAME"
  rules:
    - if: '$CI_COMMIT_BRANCH =~ /^release\//'
      when: manual
      allow_failure: true
    - when: never

# ── Performance Testing — manual, Release Manager ─────────────────────────────
deploy-perf:
  extends: .trigger_cd
  variables:
    ENV:          perf
    SERVICE_NAME: "$CI_PROJECT_NAME"
    CHART_NAME:   "$CHART_NAME"
  rules:
    - if: '$CI_COMMIT_BRANCH =~ /^release\//'
      when: manual
      allow_failure: true
    - when: never

# ── Preprod DC — manual, RM with confirmation ─────────────────────────────────
deploy-preprod-dc:
  extends: .trigger_cd
  when: manual
  allow_failure: true
  variables:
    ENV:          pre-prod-dc
    SERVICE_NAME: "$CI_PROJECT_NAME"
    CHART_NAME:   "$CHART_NAME"
  rules:
    - if: '$CI_COMMIT_BRANCH =~ /^release\//'
      when: manual
      allow_failure: true
    - when: never

# ── Preprod DR — manual, RM with confirmation ─────────────────────────────────
deploy-preprod-dr:
  extends: .trigger_cd
  when: manual
  allow_failure: true
  variables:
    ENV:          pre-prod       # correct: 'pre-prod' IS the DR cluster env name
                                 # (deploy-preprod-dc targets 'pre-prod-dc')
    SERVICE_NAME: "$CI_PROJECT_NAME"
    CHART_NAME:   "$CHART_NAME"
  rules:
    - if: '$CI_COMMIT_BRANCH =~ /^release\//'
      when: manual
      allow_failure: true
    - when: never

# ── Hotfix preprod smoke — manual, RM on hotfix MR pipeline only ──────────────
# Triggered on MR from hotfix/* → main (before merge)
# Allows smoke test on preprod before hotfix merges to main
deploy-hotfix-preprod-smoke:
  extends: .trigger_cd
  when: manual
  allow_failure: true
  variables:
    # ENV:          pre-prod-dc  ## changing pre-prod-dc to pre-prod
    ENV: pre-prod
    SERVICE_NAME: "$CI_PROJECT_NAME"
    CHART_NAME:   "$CHART_NAME"
  rules:
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event" && $CI_MERGE_REQUEST_TARGET_BRANCH_NAME == "main" && $CI_MERGE_REQUEST_SOURCE_BRANCH_NAME =~ /^hotfix\//'
      when: manual
      allow_failure: true
    - when: never

# ── Prod DC — manual, Bank team only (Protected Environment enforces gate) ─────
deploy-prod-dc:
  extends: .trigger_cd
  when: manual
  allow_failure: true
  variables:
    ENV:          prod-dc
    SERVICE_NAME: "$CI_PROJECT_NAME"
    CHART_NAME:   "$CHART_NAME"
  rules:
    - if: '$CI_COMMIT_BRANCH == "main"'
      when: manual
      allow_failure: true
    - when: never

# ── Prod DR — manual, Bank team only ──────────────────────────────────────────
deploy-prod-dr:
  extends: .trigger_cd
  when: manual
  allow_failure: true
  variables:
    ENV:          prod-dr
    SERVICE_NAME: "$CI_PROJECT_NAME"
    CHART_NAME:   "$CHART_NAME"
  rules:
    - if: '$CI_COMMIT_BRANCH == "main"'
      when: manual
      allow_failure: true
    - when: never
