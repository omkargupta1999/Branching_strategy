# ── Shared branch/MR filter ───────────────────────────────────────────────────
# Applied via `extends` to build, test, sast:fortify and image:build — every job
# the stage matrix shows on ALL rows.
#   MR pipeline   → target is main | develop | sit-integration | release/* | feature/*
#   Branch push   → main | develop | sit-integration | release/* | hotfix/* | bugfix/* | feature/*
#   anything else → never
# NOTE: image:push does NOT use this filter — it is narrower (never publishes to
# a feature target). Its rules live in ci/image/image.push.yml.
.rules:
  rules:
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event" &&
            (
              $CI_MERGE_REQUEST_TARGET_BRANCH_NAME =~ /^(main|develop|sit-integration|release)(\/.*)*$/
              ||
              $CI_MERGE_REQUEST_TARGET_BRANCH_NAME =~ /^feature(\/.*)*$/
            )'
    - if: '$CI_COMMIT_BRANCH =~ /^(main|develop|sit-integration|release|hotfix|bugfix|feature)(\/.*)*$/'
    - when: never


