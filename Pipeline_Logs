# ============================================================
# HTTP LAYER (urllib only)
# ============================================================
def _ssl_context():
    if VERIFY_TLS:
        return None
    ctx = ssl.create_default_context()
    ctx.check_hostname = False
    ctx.verify_mode = ssl.CERT_NONE
    return ctx


def _http(method, full_url, token, params=None, json_body=None, _retries=2):
    """Generic request. Returns (status, parsed_json_or_None, headers)."""
    url = full_url
    if params:
        url += "?" + urllib.parse.urlencode(params)
    data = None
    headers = {"PRIVATE-TOKEN": token}
    if json_body is not None:
        data = json.dumps(json_body).encode("utf-8")
        headers["Content-Type"] = "application/json"
    req = urllib.request.Request(url, data=data, headers=headers, method=method)
    ctx = _ssl_context()
    for attempt in range(_retries + 1):
        try:
            with urllib.request.urlopen(req, timeout=30, context=ctx) as resp:
                raw = resp.read().decode("utf-8")
                parsed = json.loads(raw) if raw.strip() else None
                return resp.status, parsed, dict(resp.headers)
        except urllib.error.HTTPError as e:
            body = ""
            try:
                body = e.read().decode("utf-8")
            except Exception:
                pass
            parsed = None
            if body.strip().startswith(("{", "[")):
                try:
                    parsed = json.loads(body)
                except Exception:
                    parsed = None
            return e.code, parsed, dict(e.headers or {})
        except (urllib.error.URLError, ConnectionError, TimeoutError, OSError) as e:
            if attempt < _retries:
                time.sleep(1.0 * (attempt + 1))
                continue
            print(f"  [NETWORK ERROR] {method} {url} -> {e} (after {_retries+1} tries)")
            return 0, None, {}
    return 0, None, {}


# ---- REST helpers (read) ----
def rest_get(base_url, token, endpoint, params=None):
    status, data, _ = _http("GET", f"{base_url}/api/v4/{endpoint}", token, params=params)
    if status in (0, 404):
        return None
    if status >= 400:
        print(f"  [HTTP {status}] GET {endpoint}")
        return None
    return data


def rest_get_all(base_url, token, endpoint, params=None):
    results = []
    page = 1
    base_params = dict(params or {})
    while True:
        p = dict(base_params)
        p["per_page"] = 100
        p["page"] = page
        status, data, _ = _http("GET", f"{base_url}/api/v4/{endpoint}", token, params=p)
        if status in (0, 404):
            return results
        if status >= 400:
            print(f"  [HTTP {status}] GET {endpoint} (page {page})")
            return results
        if not data:
            break
        results.extend(data)
        if len(data) < 100:
            break
        page += 1
        time.sleep(0.05)
    return results


# ---- GraphQL helper (epic board WRITES go here) ----
def graphql(base_url, token, query, variables):
    """Execute a GraphQL query/mutation. Returns (data, errors)."""
    status, parsed, _ = _http("POST", f"{base_url}/api/graphql", token,
                              json_body={"query": query, "variables": variables})
    if status == 0 or parsed is None:
        return None, [f"transport failure (HTTP {status})"]
    if status >= 400:
        return None, [f"HTTP {status}: {parsed}"]
    return parsed.get("data"), parsed.get("errors")


# ============================================================
# JOURNAL (rollback log)
# ============================================================
def journal_write(entry):
    entry["ts"] = datetime.now().isoformat()
    with open(JOURNAL_PATH, "a", encoding="utf-8") as f:
        f.write(json.dumps(entry) + "\n")
        f.flush()


def journal_read(path):
    entries = []
    p = Path(path)
    if not p.exists():
        return entries
    with open(p, "r", encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if line:
                entries.append(json.loads(line))
    return entries


# ============================================================
# GROUP ENUMERATION
# ============================================================
def get_all_groups(base_url, token, top_group):
    enc = urllib.parse.quote(top_group, safe="")
    top = rest_get(base_url, token, f"groups/{enc}")
    if not top:
        raise RuntimeError(f"Top group '{top_group}' not found on {base_url} "
                           f"(check URL / token / group path).")
    top_full = top["full_path"]
    descendants = rest_get_all(base_url, token, f"groups/{enc}/descendant_groups",
                               {"all_available": "true"})
    groups = [top] + descendants
    for g in groups:
        fp = g["full_path"]
        if fp == top_full:
            g["rel_path"] = ""
        elif fp.startswith(top_full + "/"):
            g["rel_path"] = fp[len(top_full) + 1:]
        else:
            g["rel_path"] = fp
    return groups


# ============================================================
# EPIC / BOARD READERS
# ============================================================
def get_epics_for_group(base_url, token, group_id, state="all"):
    return rest_get_all(base_url, token, f"groups/{group_id}/epics",
                        {"state": state, "include_descendant_groups": "false"})


def get_epic_boards(base_url, token, group_id):
    return rest_get_all(base_url, token, f"groups/{group_id}/epic_boards")


def get_epic_board_detail(base_url, token, group_id, board_id):
    return rest_get(base_url, token, f"groups/{group_id}/epic_boards/{board_id}")


def get_labels(base_url, token, group_id):
    return rest_get_all(base_url, token, f"groups/{group_id}/labels",
                        {"include_ancestor_groups": "true"})


def get_version(base_url, token):
    v = rest_get(base_url, token, "version")
    if v:
        return v.get("version", "unknown"), v.get("revision", "unknown")
    return "unknown", "unknown"


# ============================================================
# COMPARISON LOGIC
# ============================================================
def compare_epics(src_epics, tgt_epics, group_label):
    src_map = {e["iid"]: e for e in src_epics}
    tgt_map = {e["iid"]: e for e in tgt_epics}
    missing = set(src_map) - set(tgt_map)
    extra   = set(tgt_map) - set(src_map)
    common  = set(src_map) & set(tgt_map)
    drift = []
    for iid in common:
        s, t = src_map[iid], tgt_map[iid]
        issues = []
        if s.get("state") != t.get("state"):
            issues.append(f"state {s.get('state')}->{t.get('state')}")
        if s.get("title") != t.get("title"):
            issues.append("title mismatch")
        if s.get("parent_id") != t.get("parent_id"):
            issues.append(f"parent_id {s.get('parent_id')}->{t.get('parent_id')}")
        if s.get("start_date") != t.get("start_date"):
            issues.append(f"start_date {s.get('start_date')}->{t.get('start_date')}")
        if s.get("due_date") != t.get("due_date"):
            issues.append(f"due_date {s.get('due_date')}->{t.get('due_date')}")
        if issues:
            drift.append({"group": group_label, "epic_iid": iid,
                          "title": s.get("title"), "drift": "; ".join(issues)})
    return {
        "group": group_label,
        "src_total": len(src_epics), "tgt_total": len(tgt_epics),
        "src_open": sum(1 for e in src_epics if e.get("state") == "opened"),
        "tgt_open": sum(1 for e in tgt_epics if e.get("state") == "opened"),
        "src_closed": sum(1 for e in src_epics if e.get("state") == "closed"),
        "tgt_closed": sum(1 for e in tgt_epics if e.get("state") == "closed"),
        "missing_iids": sorted(missing), "extra_iids": sorted(extra),
        "drift": drift, "count_match": len(src_epics) == len(tgt_epics),
    }


def check_hierarchy(tgt_epics):
    ids = {e["id"] for e in tgt_epics}
    out = []
    for e in tgt_epics:
        pid = e.get("parent_id")
        if pid and pid not in ids:
            out.append({"epic_iid": e["iid"], "title": e.get("title"),
                        "parent_id": pid,
                        "issue": "parent epic not present in this group on target"})
    return out


def compare_boards(src_boards, tgt_boards, group_label):
    src_names = {b.get("name") for b in src_boards}
    tgt_names = {b.get("name") for b in tgt_boards}
    return {"group": group_label, "src_count": len(src_boards),
            "tgt_count": len(tgt_boards),
            "missing": sorted(src_names - tgt_names),
            "extra": sorted(tgt_names - src_names)}


# ============================================================
# BOARD MIRROR  (full fidelity, journaled)  — GraphQL writes
# ============================================================
GID_LABEL = "gid://gitlab/GroupLabel/{}"

MUT_BOARD_CREATE = """
mutation($groupPath: ID!, $name: String!, $hideBacklog: Boolean, $hideClosed: Boolean, $labelIds: [LabelID!]) {
  epicBoardCreate(input: {groupPath: $groupPath, name: $name,
                          hideBacklogList: $hideBacklog, hideClosedList: $hideClosed,
                          labelIds: $labelIds}) {
    epicBoard { id name }
    errors
  }
}"""

MUT_LIST_CREATE = """
mutation($boardId: BoardsEpicBoardID!, $labelId: LabelID!) {
  epicBoardListCreate(input: {boardId: $boardId, labelId: $labelId}) {
    list { id }
    errors
  }
}"""

MUT_LIST_DESTROY = """
mutation($listId: BoardsEpicListID!) {
  epicBoardListDestroy(input: {listId: $listId}) {
    list { id }
    errors
  }
}"""

MUT_BOARD_DESTROY = """
mutation($id: BoardsEpicBoardID!) {
  epicBoardDestroy(input: {id: $id}) {
    errors
  }
}"""


def _numeric_id_from_gid(gid):
    return str(gid).rstrip("/").split("/")[-1]


def mirror_boards_for_group(src_url, src_tok, src_gid, src_group_path,
                            tgt_url, tgt_tok, tgt_gid, tgt_group_path,
                            group_label, dry_run=True):
    actions = []
    src_boards = get_epic_boards(src_url, src_tok, src_gid)
    if not src_boards:
        return actions

    tgt_existing = {b["name"]: b for b in get_epic_boards(tgt_url, tgt_tok, tgt_gid)}
    tgt_label_ids = {l["name"]: l["id"] for l in get_labels(tgt_url, tgt_tok, tgt_gid)}

    for b in src_boards:
        name = b["name"]
        if name in tgt_existing:
            actions.append(f"SKIP board '{name}' (already exists on target)")
            continue

        detail = get_epic_board_detail(src_url, src_tok, src_gid, b["id"]) or b
        hide_backlog = detail.get("hide_backlog_list", False)
        hide_closed  = detail.get("hide_closed_list", False)
        board_labels = detail.get("labels", []) or []
        lists        = detail.get("lists", []) or []

        board_label_gids = []
        for lbl in board_labels:
            lname = lbl.get("title") or lbl.get("name")
            tid = tgt_label_ids.get(lname)
            if tid:
                board_label_gids.append(GID_LABEL.format(tid))
            else:
                actions.append(f"  WARN board label '{lname}' missing on target — scope dropped")

        if dry_run:
            actions.append(f"WOULD CREATE board '{name}' "
                           f"(hide_backlog={hide_backlog}, hide_closed={hide_closed}, "
                           f"board_labels={len(board_label_gids)}, lists={len(lists)})")
            for lst in sorted(lists, key=lambda x: (x.get("position") is None, x.get("position") or 0)):
                lbl = lst.get("label") or {}
                lname = lbl.get("name")
                ok = "ok" if lname in tgt_label_ids else "MISSING LABEL"
                actions.append(f"    WOULD ADD list '{lname}' (pos {lst.get('position')}) [{ok}]")
            continue

        # WRITE: create board
        data, errs = graphql(tgt_url, tgt_tok, MUT_BOARD_CREATE, {
            "groupPath": tgt_group_path,
            "name": name,
            "hideBacklog": bool(hide_backlog),
            "hideClosed": bool(hide_closed),
            "labelIds": board_label_gids or None,
        })
        created = (data or {}).get("epicBoardCreate", {}) if data else {}
        if errs or not created.get("epicBoard"):
            actions.append(f"ERROR creating board '{name}': {errs or created.get('errors')}")
            continue
        new_board_gid = created["epicBoard"]["id"]
        new_board_num = _numeric_id_from_gid(new_board_gid)
        journal_write({"op": "create_board", "group": group_label,
                       "tgt_group_id": tgt_gid, "tgt_group_path": tgt_group_path,
                       "board_gid": new_board_gid, "board_id": new_board_num,
                       "board_name": name})
        actions.append(f"CREATED board '{name}' (id={new_board_num})")

        # WRITE: create lists in source order
        for lst in sorted(lists, key=lambda x: (x.get("position") is None, x.get("position") or 0)):
            lbl = lst.get("label") or {}
            lname = lbl.get("name")
            tid = tgt_label_ids.get(lname)
            if not tid:
                actions.append(f"  WARN list label '{lname}' missing on target — list skipped")
                continue
            ldata, lerrs = graphql(tgt_url, tgt_tok, MUT_LIST_CREATE, {
                "boardId": new_board_gid, "labelId": GID_LABEL.format(tid)})
            lcreated = (ldata or {}).get("epicBoardListCreate", {}) if ldata else {}
            if lerrs or not lcreated.get("list"):
                actions.append(f"  ERROR adding list '{lname}': {lerrs or lcreated.get('errors')}")
                continue
            new_list_gid = lcreated["list"]["id"]
            journal_write({"op": "create_list", "group": group_label,
                           "board_gid": new_board_gid, "list_gid": new_list_gid,
                           "label_name": lname})
            actions.append(f"  added list '{lname}'")
    return actions


# ============================================================
# ROLLBACK
# ============================================================
def rollback(journal_file, tgt_url, tgt_tok, dry_run=True):
    entries = journal_read(journal_file)
    if not entries:
        print(f"  No journal entries in {journal_file}. Nothing to roll back.")
        return []
    actions = []
    lists  = [e for e in entries if e.get("op") == "create_list"]
    boards = [e for e in entries if e.get("op") == "create_board"]

    for e in reversed(lists):
        if dry_run:
            actions.append(f"WOULD DESTROY list {e['list_gid']} (label '{e.get('label_name')}')")
            continue
        data, errs = graphql(tgt_url, tgt_tok, MUT_LIST_DESTROY, {"listId": e["list_gid"]})
        mut_errs = (data or {}).get("epicBoardListDestroy", {}).get("errors") if data else None
        actions.append(f"DESTROYED list {e['list_gid']}" if not (errs or mut_errs)
                       else f"ERROR destroying list {e['list_gid']}: {errs or mut_errs}")

    for e in reversed(boards):
        if dry_run:
            actions.append(f"WOULD DESTROY board {e['board_gid']} ('{e.get('board_name')}')")
            continue
        data, errs = graphql(tgt_url, tgt_tok, MUT_BOARD_DESTROY, {"id": e["board_gid"]})
        mut_errs = (data or {}).get("epicBoardDestroy", {}).get("errors") if data else None
        if errs or mut_errs:
            actions.append(f"ERROR destroying board {e['board_gid']}: {errs or mut_errs}")
            actions.append(f"  -> If epicBoardDestroy is unsupported on this version, delete board "
                           f"'{e.get('board_name')}' (id {e.get('board_id')}) manually in "
                           f"{e.get('tgt_group_path')} > Plan > Epic boards.")
        else:
            actions.append(f"DESTROYED board {e['board_gid']} ('{e.get('board_name')}')")
    return actions


# ============================================================
# CSV + RESOLVER
# ============================================================
def write_csv(filename, rows, fieldnames):
    path = OUTPUT_DIR / filename
    with open(path, "w", newline="", encoding="utf-8") as f:
        w = csv.DictWriter(f, fieldnames=fieldnames, extrasaction="ignore")
        w.writeheader()
        for r in rows:
            row = {k: (",".join(map(str, v)) if isinstance(v, list) else v)
                   for k, v in r.items()}
            w.writerow(row)
    return path


def resolve_target_rel(src_rel):
    if src_rel in GROUP_PATH_MAP:
        return GROUP_PATH_MAP[src_rel]
    if MAP_CHILDREN_BY_PREFIX:
        for prefix in sorted(GROUP_PATH_MAP, key=len, reverse=True):
            if src_rel.startswith(prefix + "/"):
                return GROUP_PATH_MAP[prefix] + src_rel[len(prefix):]
    return src_rel


# ============================================================
# VALIDATION (+ optional mirror)
# ============================================================
def run_validation(mirror_flag=False, dry_run=True):
    print("=" * 70)
    print("  GitLab Epic Validator + Board Mirror  (air-gapped / stdlib)")
    print(f"  Run: {RUN_TS}")
    print("=" * 70)

    if SOURCE_TOKEN == "SOURCE_PAT_HERE" or TARGET_TOKEN == "TARGET_PAT_HERE":
        print("\n[!] Set SOURCE_TOKEN and TARGET_TOKEN at the top of the script.")
        sys.exit(1)

    print("\n[1/6] Versions...")
    sv, sr = get_version(SOURCE_URL, SOURCE_TOKEN)
    tv, tr = get_version(TARGET_URL, TARGET_TOKEN)
    print(f"  Source: {sv} ({sr})")
    print(f"  Target: {tv} ({tr})")

    print("\n[2/6] Enumerating groups...")
    src_groups = get_all_groups(SOURCE_URL, SOURCE_TOKEN, SOURCE_TOP_GROUP)
    tgt_groups = get_all_groups(TARGET_URL, TARGET_TOKEN, TARGET_TOP_GROUP)
    print(f"  Source '{SOURCE_TOP_GROUP}': {len(src_groups)} groups")
    print(f"  Target '{TARGET_TOP_GROUP}': {len(tgt_groups)} groups")

    src_map = {g["rel_path"]: g for g in src_groups}
    tgt_map = {g["rel_path"]: g for g in tgt_groups}
    all_paths = sorted(p for p in src_map if p not in SOURCE_SKIP)
    skipped = sorted(p for p in src_map if p in SOURCE_SKIP)
    if skipped:
        print(f"  Skipping empty nested duplicates: {skipped}")

    for old_rel, new_rel in GROUP_PATH_MAP.items():
        if old_rel not in src_map:
            print(f"  [MAP WARN] '{old_rel}' not found on SOURCE.")
        if new_rel not in tgt_map:
            print(f"  [MAP WARN] mapped target '{new_rel}' not found on TARGET.")
    resolved = {}
    for s in all_paths:
        resolved.setdefault(resolve_target_rel(s), []).append(s)
    for tr_, ss in resolved.items():
        if len(ss) > 1:
            print(f"  [COLLISION] {ss} -> '{tr_}' (check config).")

    if mirror_flag:
        mode = "DRY RUN (no writes)" if dry_run else "WRITE MODE (boards will be created)"
        print(f"\n  Board mirror: {mode}")

    print("\n[3/6] Comparing epics...")
    all_results, drift_records, orphan_records = [], [], []
    board_results, board_actions, missing_detail = [], [], []

    for path in all_paths:
        sg = src_map[path]
        trel = resolve_target_rel(path)
        tg = tgt_map.get(trel)
        if path == "":
            label = f"{sg['full_path']} -> {tg['full_path']}" if tg else f"{sg['full_path']} (TOP)"
        elif trel != path:
            label = f"{path} -> {trel}"
        else:
            label = path

        if not tg:
            print(f"  [WARN] '{label}' has no target match — skipping.")
            all_results.append({"group": label, "src_total": "?", "tgt_total": 0,
                                "src_open": "?", "tgt_open": 0, "src_closed": "?",
                                "tgt_closed": 0, "missing_iids": ["GROUP MISSING ON TARGET"],
                                "extra_iids": [], "drift": [], "count_match": False})
            continue

        src_epics = get_epics_for_group(SOURCE_URL, SOURCE_TOKEN, sg["id"])
        tgt_epics = get_epics_for_group(TARGET_URL, TARGET_TOKEN, tg["id"])
        res = compare_epics(src_epics, tgt_epics, label)
        all_results.append(res)
        drift_records.extend(res["drift"])

        src_iid_map = {e["iid"]: e for e in src_epics}
        for iid in res["missing_iids"]:
            e = src_iid_map.get(iid, {})
            missing_detail.append({"group": label, "iid": iid,
                                   "title": e.get("title", "?"),
                                   "state": e.get("state", "?"),
                                   "created_at": e.get("created_at", "?")})

        orphans = check_hierarchy(tgt_epics)
        for o in orphans:
            o["group"] = label
        orphan_records.extend(orphans)

        src_boards = get_epic_boards(SOURCE_URL, SOURCE_TOKEN, sg["id"])
        tgt_boards = get_epic_boards(TARGET_URL, TARGET_TOKEN, tg["id"])
        board_results.append(compare_boards(src_boards, tgt_boards, label))

        if mirror_flag and src_boards:
            for a in mirror_boards_for_group(
                    SOURCE_URL, SOURCE_TOKEN, sg["id"], sg["full_path"],
                    TARGET_URL, TARGET_TOKEN, tg["id"], tg["full_path"],
                    label, dry_run=dry_run):
                board_actions.append({"group": label, "action": a})
                print(f"    [BOARD] {a}")

        print(f"  {label}: src={res['src_total']} tgt={res['tgt_total']} "
              f"missing={len(res['missing_iids'])} drift={len(res['drift'])} "
              f"orphans={len(orphans)}")

    print("\n[4/6] Writing CSV reports...")
    paths = [
        write_csv(f"epic_count_summary_{RUN_TS}.csv", all_results,
                  ["group","src_total","tgt_total","src_open","tgt_open",
                   "src_closed","tgt_closed","missing_iids","count_match"]),
        write_csv(f"missing_epics_{RUN_TS}.csv", missing_detail,
                  ["group","iid","title","state","created_at"]),
        write_csv(f"attribute_drift_{RUN_TS}.csv", drift_records,
                  ["group","epic_iid","title","drift"]),
        write_csv(f"orphaned_epics_{RUN_TS}.csv", orphan_records,
                  ["group","epic_iid","title","parent_id","issue"]),
        write_csv(f"epic_boards_{RUN_TS}.csv", board_results,
                  ["group","src_count","tgt_count","missing","extra"]),
    ]
    if board_actions:
        paths.append(write_csv(f"board_actions_{RUN_TS}.csv", board_actions,
                               ["group","action"]))
    for p in paths:
        print(f"  Written: {p}")

    print("\n[5/6] Summary")
    tsrc = sum(r["src_total"] for r in all_results if isinstance(r["src_total"], int))
    ttgt = sum(r["tgt_total"] for r in all_results if isinstance(r["tgt_total"], int))
    tmiss = sum(len(r["missing_iids"]) for r in all_results
                if isinstance(r.get("missing_iids"), list)
                and r["missing_iids"] != ["GROUP MISSING ON TARGET"])
    print(f"  Source epics  : {tsrc}")
    print(f"  Target epics  : {ttgt}")
    print(f"  Missing       : {tmiss}")
    print(f"  Drift         : {len(drift_records)}")
    print(f"  Orphaned      : {len(orphan_records)}")
    print(f"  Boards missing: {sum(len(b['missing']) for b in board_results)}")
    if mirror_flag and not dry_run and JOURNAL_PATH.exists():
        print(f"\n  Rollback journal written: {JOURNAL_PATH}")
        print(f"  To undo: python {Path(sys.argv[0]).name} --rollback "
              f"--journal {JOURNAL_PATH} --apply")
    ok = tmiss == 0 and not drift_records and not orphan_records
    print(f"\n  VERDICT: {'PASS' if ok else 'ISSUES FOUND - review CSVs'}")
    print("\n[6/6] Done. Output:", OUTPUT_DIR.resolve())


def run_rollback(journal_file, dry_run=True):
    print("=" * 70)
    print("  ROLLBACK  —  undo board mirror on TARGET")
    print(f"  Journal: {journal_file}")
    print("=" * 70)
    if TARGET_TOKEN == "TARGET_PAT_HERE":
        print("\n[!] Set TARGET_TOKEN at the top of the script.")
        sys.exit(1)
    acts = rollback(journal_file, TARGET_URL, TARGET_TOKEN, dry_run=dry_run)
    for a in acts:
        print(f"  {a}")
    print("\n  DRY RUN — nothing changed. Add --apply to execute." if dry_run
          else "\n  Rollback complete.")


