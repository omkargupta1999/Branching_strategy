# cd/helm/helm.deploy.yml
# Stage: validate + deploy + verify
# Single-service Helm upgrade to OCP cluster
# Runs in DEPLOYMENT REPO pipeline

include:
  - local: 'config/services.yaml'

# Prevents Gitlab auto-cancelling the pipeline 
workflow:
  auto_cancel:
    on_new_commit: "none"

stages:
  - publish
  - validate
  - deploy
  - verify
  # - notify

variables:
  DEV_CLUSTER:        "https://api.dev.sbiepay.sbi:6443"
  PREPROD_CLUSTER:    "https://api.preprod.epay.sbi:6443"
  PREPROD_DC_CLUSTER: "https://api.dcpreprod.epay.sbi:6443"
  PROD_DR_CLUSTER:    "https://api.dr.prod.epay.sbi:6443"
  PROD_DC_CLUSTER:    "https://api.dc.prod.epay.sbi:6443"
  # SERVICE_NAME:       ""
  # ENV:                ""
  HELM_HISTORY_MAX:   "10"
  DEPLOYMENT_TIMEOUT: "15m"
  GIT_STRATEGY: clone
  GIT_DEPTH: 0

.validate_inputs:
  before_script:
    - |
      set -eo pipefail
      if [ -z "$SERVICE_NAME" ] || [ -z "$ENV" ]; then
        echo "ERROR: SERVICE_NAME and ENV required"; exit 1
      fi
      if [[ ! "$ENV" =~ ^(dev|sit|uat|int|perf|pre-prod|pre-prod-dc|prod-dr|prod-dc)$ ]]; then
        echo "ERROR: Invalid ENV '$ENV'"; exit 1
      fi
      echo "Service=$SERVICE_NAME | ENV=$ENV | VERSION=$VERSION"

validate_service:
  stage: validate
  #image: registry.dev.sbiepay.sbi:8443/ubi9/ochelm:03122024
  image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-local/custom-ci/rhelgit-oc-helm:1.0
  tags:
    - deploy_runner
  # extends: .validate_inputs
  script:
    - |
      set -eo pipefail
      echo "$SERVICES_CONFIG" > /tmp/services.yml
      echo "VERSION=$VERSION" >> build.env

      if [ -z "$SERVICE_NAME" ]; then
        CHANGED_FILE=$(git diff --name-only HEAD~1 HEAD 2>/dev/null | grep charts | head -1 || true)
        
        if [ -z "$CHANGED_FILE" ]; then
          CHANGED_FILE=$(git ls-files | grep charts | head -1 || true)
        fi

        if [ -z "$CHANGED_FILE" ]; then
          echo "No chart changes found"
          exit 1
        fi

        ENV=$(echo "$CHANGED_FILE" | cut -d'/' -f1)
        SERVICE_NAME=$(echo "$CHANGED_FILE" | cut -d'/' -f3)

        echo "Detected SERVICE_NAME=$SERVICE_NAME"
        echo "Detected ENV=$ENV"
      fi

      # RELEASE_NAME extract from services.yaml
      RELEASE_NAME=$(awk -v svc="$SERVICE_NAME" '
        $0 ~ "name: "svc {found=1}
        found && /release:/ {print $2; exit}
      ' /tmp/services.yml)

      RELEASE_NAME=${RELEASE_NAME:-$(echo "$SERVICE_NAME" | tr '_' '-')}

      NAMESPACE=$(awk -v svc="$SERVICE_NAME" '
        /namespace:/ {ns=$3}
        $0 ~ "name: "svc {print ns; exit}
      ' /tmp/services.yml)

      NAMESPACE="${ENV}-${NAMESPACE}"

      echo "RAW NAMESPACE=$NAMESPACE"
      echo "FINAL VALUES:"
      echo "SERVICE_NAME=$SERVICE_NAME"
      echo "ENV=$ENV"
      echo "RELEASE_NAME=$RELEASE_NAME"
      echo "NAMESPACE=$NAMESPACE"

      # --- PERMANENT FIX: sync values.yaml to tip of main ---
      # update-tag commits a NEW commit (with [skip ci]) AFTER this pipeline's
      # SHA was frozen, so this checkout is one commit behind and still holds the
      # OLD tag. Re-sync the chart's values.yaml from origin/main so we read the
      # tag update-tag just wrote, not the stale frozen-SHA copy.
      # Internal GitLab CA is not trusted in this image -> disable SSL verify
      # (same as the update-tag job) and authenticate with the deploy token.
      git config --global http.sslVerify false
      git config --global --add safe.directory '*'
      git remote set-url origin "https://oauth2:${GITLAB_CI_DEPLOY_TOKEN}@gitlab.sbi/${CI_PROJECT_PATH}.git"
      # Use the ref this pipeline actually ran on (could be main OR a feature
      # branch), NOT a hardcoded main — otherwise a feature-branch edit gets
      # clobbered by main's older values.yaml.
      SYNC_REF="${CI_COMMIT_REF_NAME:-main}"
      git fetch --quiet origin "$SYNC_REF"
      git checkout "origin/${SYNC_REF}" -- "${ENV}/charts/${SERVICE_NAME}/values.yaml"
      echo "Synced ${ENV}/charts/${SERVICE_NAME}/values.yaml to origin/${SYNC_REF}"
       
      [ -d "${ENV}/charts/${SERVICE_NAME}" ] || { echo "Chart not found"; exit 1; }

      # Helm validation
      helm lint ${ENV}/charts/${SERVICE_NAME}/

      # values.yaml is the single source of truth for image.tag — no runtime override.
      TAG_IN_FILE=$(grep -E '^[[:space:]]*tag:[[:space:]]' "${ENV}/charts/${SERVICE_NAME}/values.yaml" \
        | grep -vE '^[[:space:]]*#' \
        | head -1 \
        | sed -E 's/^[[:space:]]*tag:[[:space:]]*"?([^"#]*)"?.*$/\1/' \
        | sed -E 's/[[:space:]]+$//')
      if [ -z "$TAG_IN_FILE" ]; then
        echo "FATAL: image.tag is empty or missing in ${ENV}/charts/${SERVICE_NAME}/values.yaml — refusing to deploy"
        exit 1
      fi
      echo "Validating with image tag from values.yaml: ${TAG_IN_FILE}"

      helm template ${RELEASE_NAME} ${ENV}/charts/${SERVICE_NAME}/ \
        -f ${ENV}/charts/${SERVICE_NAME}/values.yaml
      echo "✅ Validation passed"

      # Export for next stages
      echo "SERVICE_NAME=$SERVICE_NAME" >> build.env
      echo "ENV=$ENV" >> build.env
      echo "RELEASE_NAME=$RELEASE_NAME" >> build.env
      echo "NAMESPACE=$NAMESPACE" >> build.env
  artifacts:
    reports:
      dotenv: build.env

helm:deploy:
  stage: deploy
  dependencies:
    - validate_service
  needs:
    - job: validate_service
      artifacts: true
  #image: registry.dev.sbiepay.sbi:8443/ubi9/ochelm:03122024
  image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-local/custom-ci/rhelgit-oc-helm:1.0
  tags:
    - deploy_runner
  extends: .validate_inputs
  script:
    - |
      echo "RELEASE_NAME=$RELEASE_NAME"
      echo "SERVICE_NAME=$SERVICE_NAME"
      echo "ENV=$ENV"
      
      case "$ENV" in
        dev|sit|uat|int|perf) CLUSTER=$DEV_CLUSTER;        TOKEN=$OCP_TOKEN_DEV_CLUSTER ;;
        pre-prod)              CLUSTER=$PREPROD_CLUSTER;    TOKEN=$OCP_TOKEN_PREPROD_DR ;;
        pre-prod-dc)           CLUSTER=$PREPROD_DC_CLUSTER; TOKEN=$OCP_TOKEN_PREPROD_DC ;;
        prod-dr)               CLUSTER=$PROD_DR_CLUSTER;    TOKEN=$OCP_TOKEN_PROD_DR ;;
        prod-dc)               CLUSTER=$PROD_DC_CLUSTER;    TOKEN=$OCP_TOKEN_PROD_DC ;;
      esac
      oc login "$CLUSTER" --token="$TOKEN" --insecure-skip-tls-verify

      # --- PERMANENT FIX: sync values.yaml to tip of main ---
      # Same reason as validate_service: this job is still checked out at the
      # pipeline's frozen SHA, which predates the update-tag commit. Re-sync so
      # the helm upgrade uses the freshly-written image tag, not the old one.
      # Requires fetch access to origin (deploy token) and trust of the internal
      # GitLab CA. The deploy image does not trust it, so disable SSL verify
      # (same as the update-tag job).
      git config --global http.sslVerify false
      git config --global --add safe.directory '*'
      git remote set-url origin "https://oauth2:${GITLAB_CI_DEPLOY_TOKEN}@gitlab.sbi/${CI_PROJECT_PATH}.git"
      # Use the ref this pipeline actually ran on (could be main OR a feature
      # branch), NOT a hardcoded main — otherwise a feature-branch edit gets
      # clobbered by main's older values.yaml.
      SYNC_REF="${CI_COMMIT_REF_NAME:-main}"
      git fetch --quiet origin "$SYNC_REF"
      git checkout "origin/${SYNC_REF}" -- "${ENV}/charts/${SERVICE_NAME}/values.yaml"
      echo "Synced ${ENV}/charts/${SERVICE_NAME}/values.yaml to origin/${SYNC_REF}"

      # values.yaml is the single source of truth for image.tag — no runtime override.
      TAG_IN_FILE=$(grep -E '^[[:space:]]*tag:[[:space:]]' "${ENV}/charts/${SERVICE_NAME}/values.yaml" \
        | grep -vE '^[[:space:]]*#' \
        | head -1 \
        | sed -E 's/^[[:space:]]*tag:[[:space:]]*"?([^"#]*)"?.*$/\1/' \
        | sed -E 's/[[:space:]]+$//')
      if [ -z "$TAG_IN_FILE" ]; then
        echo "FATAL: image.tag is empty or missing in ${ENV}/charts/${SERVICE_NAME}/values.yaml — refusing to deploy"
        exit 1
      fi
      echo "Deploying with image tag from values.yaml: ${TAG_IN_FILE}"

      helm upgrade --install ${RELEASE_NAME} \
        ${ENV}/charts/${SERVICE_NAME} \
        -n ${NAMESPACE} \
        --create-namespace \
        -f ${ENV}/charts/${SERVICE_NAME}/values.yaml \
        --history-max=${HELM_HISTORY_MAX}
      echo "✅ Deployed ${SERVICE_NAME} with tag ${TAG_IN_FILE} to ${ENV}"
