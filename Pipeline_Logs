## Step 1 — List all groups on gitlab.sbi

Run this to see every group available:

```cmd
python311\python.exe -c "
import urllib.request, json, ssl
GITLAB_URL = 'https://gitlab.sbi'
TOKEN = 'glpat-your-token-here'
ssl_ctx = ssl._create_unverified_context()
page = 1
all_groups = []
while True:
    url = f'{GITLAB_URL}/api/v4/groups?per_page=100&page={page}&all_available=true'
    req = urllib.request.Request(url)
    req.add_header('PRIVATE-TOKEN', TOKEN)
    resp = urllib.request.urlopen(req, context=ssl_ctx)
    data = json.loads(resp.read())
    if not data: break
    all_groups.extend(data)
    if page >= int(resp.headers.get('X-Total-Pages','1')): break
    page += 1
print(f'Total groups found: {len(all_groups)}')
print()
for g in sorted(all_groups, key=lambda x: x.get('full_path','')):
    print(f'  ID={g[\"id\"]:<6} path={g[\"full_path\"]}')
"
```

Replace `glpat-your-token-here` with your actual token.

