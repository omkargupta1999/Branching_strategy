#!/usr/bin/env python3
"""
=============================================================================
 Script      : remove_direct_members.py
 Purpose     : Safely remove ALL direct project memberships from GitLab repos
               in the Application > Backend subgroup, preserving LDAP-group-
               based access as the single source of truth.

               SAFETY GUARANTEE:
               - unassign_issuables is NEVER set to true (API default = false)
               - Issues, MRs, comments, commits, pipelines, artifacts remain
                 100% intact — only the membership record is deleted.
               - Users are ONLY removed if they have confirmed LDAP group
                 coverage at the Application subgroup level.
               - Any user without LDAP coverage is flagged as ORPHAN and
                 SKIPPED — never removed.
               - Bot/service accounts (matching BOT_PATTERNS) are ALWAYS
                 skipped regardless of LDAP coverage.

 PHASES:
   Phase 1 — AUDIT (always runs first, safe read-only)
             Walk all backend repos, list direct members per project,
             cross-reference against LDAP group inherited members.
             Writes: audit_direct_members_<timestamp>.txt

   Phase 2 — CLEANUP (only runs with --execute flag)
             Remove only SAFE members (confirmed LDAP coverage).
             ORPHAN members are listed but never touched.
             Writes: cleanup_direct_members_<timestamp>.txt

 Dependencies: NONE — Python standard library only (no pip)
               Python 3.6+ / RHEL / air-gapped bastion compatible.

 Modes:
   (default)  Phase 1 AUDIT only — read-only, safe to run anytime.
   --execute  Phase 1 AUDIT + Phase 2 CLEANUP (removes direct members).
   --verify   Post-cleanup read-only check — shows remaining direct members.

 Usage:
   python remove_direct_members.py              # Audit only (safe)
   python remove_direct_members.py --execute    # Audit + Remove
   python remove_direct_members.py --verify     # Post-removal check

 Config:
   GITLAB_URL          : Base URL of your GitLab instance
   TOKEN               : PAT with api + read_api scopes (Owner level)
   BACKEND_SUBGROUP    : Path to the Backend subgroup
   APPLICATION_SUBGROUP: Path to Application subgroup (for LDAP coverage check)
   BOT_PATTERNS        : Substrings in username that mark service accounts
=============================================================================
"""

import json
import ssl
import sys
import getpass
import urllib.request
import urllib.parse
import urllib.error
from datetime import datetime

# =============================================================================
# CONFIGURATION — edit before running
# =============================================================================

GITLAB_URL          = "https://gitlab.sbi"
TOKEN               = ""   # Leave blank → prompted securely at runtime

# Subgroup path for Backend repos (all repos inside will be processed)
BACKEND_SUBGROUP    = "itepaypg-sbiepay2/application/backend"

# Application subgroup — used to enumerate who has LDAP-inherited access
APPLICATION_SUBGROUP = "itepaypg-sbiepay2/application"

# Bot / service accounts — NEVER removed, regardless of LDAP coverage
BOT_PATTERNS        = [
    "bot", "svc", "service", "ci-", "deploy", "automation",
    "gitlab-ci", "runner", "orchestrator"
]

# Repos to explicitly SKIP (e.g., Config repos per your governance spec)
SKIP_REPOS          = [
    "epay_backend_config",
    "epay_frontend_config",
]

# =============================================================================
# RUNTIME STATE
# =============================================================================

_token   = TOKEN
_logfile = None

def init_log(prefix):
    global _logfile
    ts = datetime.now().strftime("%Y%m%d_%H%M%S")
    fname = f"{prefix}_{ts}.txt"
    _logfile = open(fname, "w", encoding="utf-8")
    return fname

def log(msg=""):
    print(msg)
    if _logfile:
        _logfile.write(msg + "\n")
        _logfile.flush()

def log_section(title):
    bar = "=" * 70
    log(bar)
    log(f"  {title}")
    log(bar)

def log_sub(title):
    log(f"\n--- {title} " + "-" * (65 - len(title)))

# =============================================================================
# HTTP HELPERS (house style — ssl unverified, pagination, error handling)
# =============================================================================

def _ctx():
    ctx = ssl.create_default_context()
    ctx.check_hostname = False
    ctx.verify_mode    = ssl.CERT_NONE
    return ctx

def api_get(path, params=None):
    """Single GET — returns parsed JSON or raises on error."""
    url = f"{GITLAB_URL}/api/v4{path}"
    if params:
        url += "?" + urllib.parse.urlencode(params)
    req = urllib.request.Request(url, headers={"PRIVATE-TOKEN": _token})
    try:
        with urllib.request.urlopen(req, context=_ctx()) as r:
            return json.loads(r.read().decode())
    except urllib.error.HTTPError as e:
        body = e.read().decode(errors="replace")
        raise RuntimeError(f"HTTP {e.code} on GET {path}: {body}") from e

def api_get_all(path, extra_params=None):
    """Paginated GET — returns all pages combined into one list."""
    results = []
    page    = 1
    while True:
        params = {"per_page": 100, "page": page}
        if extra_params:
            params.update(extra_params)
        url = f"{GITLAB_URL}/api/v4{path}?" + urllib.parse.urlencode(params)
        req = urllib.request.Request(url, headers={"PRIVATE-TOKEN": _token})
        try:
            with urllib.request.urlopen(req, context=_ctx()) as r:
                data  = json.loads(r.read().decode())
                total = int(r.headers.get("X-Total-Pages", 1))
        except urllib.error.HTTPError as e:
            body = e.read().decode(errors="replace")
            raise RuntimeError(f"HTTP {e.code} on GET {path}: {body}") from e
        if not data:
            break
        results.extend(data)
        if page >= total:
            break
        page += 1
    return results

def api_delete(path):
    """
    DELETE call — returns HTTP status code.
    NOTE: unassign_issuables is intentionally NOT passed → defaults to false.
    Issues, MRs, assignments are NEVER touched.
    """
    url = f"{GITLAB_URL}/api/v4{path}"
    req = urllib.request.Request(
        url,
        method="DELETE",
        headers={"PRIVATE-TOKEN": _token}
    )
    try:
        with urllib.request.urlopen(req, context=_ctx()) as r:
            return r.status
    except urllib.error.HTTPError as e:
        body = e.read().decode(errors="replace")
        raise RuntimeError(f"HTTP {e.code} on DELETE {path}: {body}") from e

# =============================================================================
# HELPERS
# =============================================================================

ACCESS_LABELS = {
    0: "No Access",
    10: "Guest",
    20: "Reporter",
    30: "Developer",
    40: "Maintainer",
    50: "Owner",
}

def access_label(level):
    return ACCESS_LABELS.get(level, f"Level-{level}")

def is_bot(username):
    u = username.lower()
    return any(p in u for p in BOT_PATTERNS)

def resolve_group_id(group_path):
    """Resolve a group path to its numeric ID."""
    encoded = urllib.parse.quote(group_path, safe="")
    data    = api_get(f"/groups/{encoded}")
    return data["id"]

def get_all_projects_in_subgroup(subgroup_path):
    """Return all projects recursively under a subgroup."""
    encoded = urllib.parse.quote(subgroup_path, safe="")
    return api_get_all(
        f"/groups/{encoded}/projects",
        {"include_subgroups": "true", "archived": "false"}
    )

def get_direct_project_members(project_id):
    """
    Direct members only (NOT inherited).
    /projects/:id/members  — direct only (excludes inherited).
    """
    return api_get_all(f"/projects/{project_id}/members")

def get_inherited_project_members(project_id):
    """
    ALL members including inherited from parent groups (LDAP groups).
    /projects/:id/members/all
    """
    return api_get_all(f"/projects/{project_id}/members/all")

def build_ldap_coverage_set(application_subgroup_path):
    """
    Returns a set of user_ids who have inherited access from the Application
    subgroup (i.e., confirmed LDAP group coverage).
    Uses /groups/:id/members/all to get all inherited members.
    """
    log(f"  Building LDAP coverage set from: {application_subgroup_path}")
    encoded = urllib.parse.quote(application_subgroup_path, safe="")
    members = api_get_all(f"/groups/{encoded}/members/all")
    covered = {m["id"] for m in members}
    log(f"  Users with LDAP group coverage: {len(covered)}")
    return covered

# =============================================================================
# PHASE 1 — AUDIT
# =============================================================================

def phase_audit(projects):
    """
    Walk all projects, enumerate direct vs inherited members,
    classify each as: SAFE_TO_REMOVE / ORPHAN / BOT / NO_DIRECT.
    Returns audit_results dict keyed by project_id.
    """
    log_section("PHASE 1 — AUDIT (Read-Only)")
    log(f"  Building LDAP coverage set...")
    ldap_covered = build_ldap_coverage_set(APPLICATION_SUBGROUP)

    audit = {}  # project_id -> { project, safe, orphan, bots, no_direct }

    for proj in projects:
        pid   = proj["id"]
        pname = proj["path_with_namespace"]

        direct_members   = get_direct_project_members(pid)
        inherited_members = get_inherited_project_members(pid)
        inherited_ids    = {m["id"] for m in inherited_members}

        safe_remove = []
        orphans     = []
        bots        = []

        for m in direct_members:
            uid      = m["id"]
            uname    = m["username"]
            role     = access_label(m.get("access_level", 0))

            if is_bot(uname):
                bots.append(m)
                continue

            in_ldap = uid in ldap_covered
            in_inherited = uid in inherited_ids

            if in_ldap or in_inherited:
                safe_remove.append(m)
            else:
                orphans.append(m)

        audit[pid] = {
            "project":    proj,
            "safe":       safe_remove,
            "orphan":     orphans,
            "bot":        bots,
            "no_direct":  len(direct_members) == 0,
        }

        # Print per-project summary
        log_sub(pname)
        log(f"  Direct members found : {len(direct_members)}")
        log(f"  SAFE to remove       : {len(safe_remove)}")
        log(f"  ORPHAN (no LDAP)     : {len(orphans)}  ← WILL NOT BE REMOVED")
        log(f"  Bot/service accounts : {len(bots)}     ← ALWAYS SKIPPED")

        if safe_remove:
            log("  [SAFE] Users that WILL be removed if --execute is passed:")
            for m in safe_remove:
                log(f"         uid={m['id']:6}  @{m['username']:<30}  "
                    f"role={access_label(m.get('access_level',0))}")

        if orphans:
            log("  [ORPHAN] Users with NO LDAP coverage — SKIPPED:")
            for m in orphans:
                log(f"           uid={m['id']:6}  @{m['username']:<30}  "
                    f"role={access_label(m.get('access_level',0))}")
            log("  ACTION REQUIRED: Add these users to an appropriate LDAP")
            log("                   group before removing their direct access.")

        if bots:
            log("  [BOT] Service accounts — ALWAYS SKIPPED:")
            for m in bots:
                log(f"        uid={m['id']:6}  @{m['username']}")

    return audit, ldap_covered

# =============================================================================
# PHASE 2 — CLEANUP
# =============================================================================

def phase_cleanup(audit):
    """
    For each project in audit, remove SAFE members via DELETE API.
    unassign_issuables is NOT passed → defaults to false (safe).
    ORPHAN and BOT members are never touched.
    """
    log_section("PHASE 2 — CLEANUP (DELETE direct memberships)")
    log("  SAFETY: unassign_issuables=false (default) — Issues/MRs preserved")
    log("  SAFETY: ORPHAN members are SKIPPED — not removed")
    log("  SAFETY: BOT accounts are SKIPPED — not removed")
    log()

    total_removed = 0
    total_skipped = 0
    total_failed  = 0
    errors        = []

    for pid, data in audit.items():
        proj  = data["project"]
        pname = proj["path_with_namespace"]
        safe  = data["safe"]

        if not safe:
            log(f"  [{pname}]  No safe members to remove — skipping.")
            continue

        log_sub(f"Cleaning: {pname}")

        for m in safe:
            uid   = m["id"]
            uname = m["username"]
            role  = access_label(m.get("access_level", 0))
            try:
                # DELETE /projects/:id/members/:user_id
                # NO query params → unassign_issuables stays false (safe)
                status = api_delete(f"/projects/{pid}/members/{uid}")
                log(f"  REMOVED  uid={uid:6}  @{uname:<30}  role={role}  "
                    f"HTTP={status}")
                total_removed += 1
            except RuntimeError as e:
                log(f"  FAILED   uid={uid:6}  @{uname:<30}  ERROR: {e}")
                errors.append((pname, uname, str(e)))
                total_failed += 1

        orphan_count = len(data["orphan"])
        bot_count    = len(data["bot"])
        if orphan_count:
            log(f"  SKIPPED  {orphan_count} ORPHAN user(s) — no LDAP coverage")
            total_skipped += orphan_count
        if bot_count:
            log(f"  SKIPPED  {bot_count} bot/service account(s)")
            total_skipped += bot_count

    log()
    log_section("CLEANUP SUMMARY")
    log(f"  Total removed  : {total_removed}")
    log(f"  Total skipped  : {total_skipped}")
    log(f"  Total failed   : {total_failed}")

    if errors:
        log()
        log("  ERRORS (require manual action):")
        for pname, uname, err in errors:
            log(f"    [{pname}]  @{uname}  →  {err}")

    return total_removed, total_skipped, total_failed

# =============================================================================
# PHASE 3 — VERIFY (post-cleanup check)
# =============================================================================

def phase_verify(projects):
    """
    Post-cleanup read-only pass. Lists any remaining direct members.
    Should show zero SAFE members if cleanup ran cleanly.
    """
    log_section("PHASE 3 — VERIFY (Post-Cleanup Check)")

    total_remaining = 0
    for proj in projects:
        pid   = proj["id"]
        pname = proj["path_with_namespace"]
        direct = get_direct_project_members(pid)

        non_bot = [m for m in direct if not is_bot(m["username"])]
        bots    = [m for m in direct if is_bot(m["username"])]

        if non_bot or bots:
            log_sub(pname)
            for m in non_bot:
                tag = "[BOT]" if is_bot(m["username"]) else "[DIRECT]"
                log(f"  {tag}  uid={m['id']:6}  @{m['username']:<30}  "
                    f"role={access_label(m.get('access_level',0))}")
            for m in bots:
                log(f"  [BOT]    uid={m['id']:6}  @{m['username']:<30}  "
                    f"role={access_label(m.get('access_level',0))}")
            total_remaining += len(non_bot)
        else:
            log(f"  [{pname}]  CLEAN — no direct members remaining")

    log()
    if total_remaining == 0:
        log("  RESULT: All direct memberships successfully cleared.")
        log("          LDAP group access is now the sole source of truth.")
    else:
        log(f"  RESULT: {total_remaining} direct member(s) remain "
            f"(ORPHAN or manual review required).")

# =============================================================================
# MAIN
# =============================================================================

def main():
    global _token

    mode = "audit"
    if "--execute" in sys.argv:
        mode = "execute"
    elif "--verify" in sys.argv:
        mode = "verify"

    # Choose log file prefix based on mode
    prefix_map = {
        "audit":   "audit_direct_members",
        "execute": "cleanup_direct_members",
        "verify":  "verify_direct_members",
    }
    log_fname = init_log(prefix_map[mode])

    log_section(f"GitLab Direct Membership Removal — {mode.upper()}")
    log(f"  GitLab        : {GITLAB_URL}")
    log(f"  Backend scope : {BACKEND_SUBGROUP}")
    log(f"  LDAP ref      : {APPLICATION_SUBGROUP}")
    log(f"  Mode          : {mode.upper()}")
    log(f"  Time          : {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    log(f"  Log file      : {log_fname}")
    log()

    # Token
    if not _token:
        _token = getpass.getpass("  Enter GitLab PAT (Owner, api+read_api scope): ")
    log()

    # Resolve token owner (sanity check)
    try:
        me = api_get("/user")
        log(f"  Authenticated as : @{me['username']}  ({me.get('name','')})  "
            f"id={me['id']}")
    except RuntimeError as e:
        log(f"  [ERROR] Token validation failed: {e}")
        log("  Aborting — check TOKEN, GITLAB_URL, and proxy settings.")
        sys.exit(1)
    log()

    # Fetch all backend projects
    log(f"  Fetching projects under: {BACKEND_SUBGROUP}")
    try:
        all_projects = get_all_projects_in_subgroup(BACKEND_SUBGROUP)
    except RuntimeError as e:
        log(f"  [ERROR] Could not fetch projects: {e}")
        sys.exit(1)

    # Filter out skip list
    projects = [
        p for p in all_projects
        if p["path"] not in SKIP_REPOS
    ]
    log(f"  Total projects found : {len(all_projects)}")
    log(f"  After skip filter    : {len(projects)}")
    log()

    if mode == "verify":
        phase_verify(projects)
        log()
        log(f"  Verify report written to: {log_fname}")
        return

    # Phase 1 — always runs
    audit, ldap_covered = phase_audit(projects)

    # Summary before execute
    total_safe   = sum(len(v["safe"])   for v in audit.values())
    total_orphan = sum(len(v["orphan"]) for v in audit.values())
    total_bot    = sum(len(v["bot"])    for v in audit.values())

    log()
    log_section("AUDIT SUMMARY")
    log(f"  Projects scanned         : {len(projects)}")
    log(f"  SAFE to remove           : {total_safe}")
    log(f"  ORPHAN (no LDAP, skip)   : {total_orphan}")
    log(f"  BOT/service (skip)       : {total_bot}")
    log()
    log(f"  Audit report written to  : {log_fname}")

    if mode == "execute":
        if total_safe == 0:
            log()
            log("  Nothing to remove — all direct memberships are either")
            log("  ORPHANs or BOTs. Exiting without any changes.")
            return

        log()
        log("  !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!")
        log("  !!  EXECUTE mode: About to DELETE direct memberships !!")
        log("  !!  unassign_issuables=false — Issues/MRs preserved  !!")
        log("  !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!")
        log()
        confirm = input("  Type 'YES' to proceed with cleanup: ").strip()
        if confirm != "YES":
            log("  Aborted by user. No changes made.")
            return

        log()
        removed, skipped, failed = phase_cleanup(audit)

        log()
        log("  Running post-cleanup verify pass...")
        log()
        phase_verify(projects)

        log()
        log(f"  Full cleanup+verify report written to: {log_fname}")

    if _logfile:
        _logfile.close()


if __name__ == "__main__":
    main()
