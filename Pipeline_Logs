.build:
  stage: build
  tags:
    - common_runner
  image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-local/custom-ci/reactjs_npm:20241113
  variables: 
    NG_PERSISTENT_BUILD_CACHE: "1"
    # NODE_OPTIONS: "--openssl-legacy-provider"
  cache:
    key: $CI_COMMIT_REF_SLUG
    paths:
      - .angular/cache
  # before_script:
  script:
    - node -v
    - npm -v
    - npm config set strict-ssl false
    - npm config set registry https://artifactory.jfrog.sbi/artifactory/api/npm/itepaypg-sbiepay2-npm-virtual/
 # Install dependencies
    - npm cache clean --force
    - npm ci --legacy-peer-deps || npm install --legacy-peer-deps

    # Build (Next.js / React / Angular)
    - npm run build

    # IMPORTANT: Skip export (Next.js latest uses output: export)
    - echo "Skipping export step (handled by Next.js build)"

    # Normalize output (SAFE FOR ALL APPS)
    - |
      if [ -d "out" ]; then
        echo "Next.js detected - copying out to dist"
        rm -rf dist
        mkdir -p dist
        cp -r out/* dist/
      elif [ -d "dist" ]; then
        echo "Using existing dist"
      else
        echo "ERROR: No dist or out folder found"
        exit 1
      fi

    # Verify
    - echo "FINAL DIST CONTENT"
    - ls -la dist

    - echo "BUILD COMPLETED"

  artifacts:
    paths:
      - dist/
    when: on_success
    expire_in: 1 week
