import json
import csv
import ssl
from datetime import datetime
from urllib.request import urlopen, Request
from urllib.parse import urlencode, quote

# ============== CONFIG ==============
GITLAB_URL = "https://gitlab.sbi"
TOKEN = "glpat-xxxxxxxxxxxxxxxxxxxx"   # PAT with api/read_api scope (admin token needed for private emails)

# The 3 GitLab subgroups where the 13 LDAP groups are linked
SUBGROUPS = [
    "itepaypg-sbiepay2",
    "itepaypg-sbiepay2/infra/devops",
    "itepaypg-sbiepay2/application",
]
# ======================================

TIMESTAMP = datetime.now().strftime("%Y%m%d_%H%M%S")
LOG_FILE = f"ldap_members_{TIMESTAMP}.txt"
OUTPUT_CSV = f"ldap_members_{TIMESTAMP}.csv"

ACCESS_LEVEL_MAP = {10: "Guest", 20: "Reporter", 30: "Developer", 40: "Maintainer", 50: "Owner"}

ctx = ssl._create_unverified_context()


def log(msg):
    print(msg)
    with open(LOG_FILE, "a", encoding="utf-8") as f:
        f.write(msg + "\n")


def api_get(path, params=None):
    url = f"{GITLAB_URL}/api/v4{path}"
    if params:
        url += "?" + urlencode(params)
    req = Request(url, headers={"PRIVATE-TOKEN": TOKEN})
    with urlopen(req, context=ctx, timeout=30) as resp:
        return json.loads(resp.read().decode()), resp.headers


def api_get_all(path, params=None):
    params = dict(params or {})
    params["per_page"] = 100
    page = 1
    results = []
    while True:
        params["page"] = page
        data, headers = api_get(path, params)
        if not data:
            break
        results.extend(data)
        total_pages = headers.get("X-Total-Pages")
        if not total_pages or page >= int(total_pages):
            break
        page += 1
    return results


def resolve_group(path):
    try:
        data, _ = api_get(f"/groups/{quote(path, safe='')}")
        return data
    except Exception as e:
        log(f"  [ERROR] Could not resolve '{path}': {e}")
        return None


def get_user_email(user_id, cache):
    if user_id in cache:
        return cache[user_id]
    try:
        data, _ = api_get(f"/users/{user_id}")
        email = data.get("email") or data.get("public_email") or ""
    except Exception as e:
        log(f"    [WARN] email fetch failed for user_id={user_id}: {e}")
        email = ""
    cache[user_id] = email
    return email


def get_ldap_identity(user_id, cache):
    """Returns the LDAP identity (provider/extern_uid) if present, else empty."""
    if user_id in cache:
        return cache[user_id]
    try:
        data, _ = api_get(f"/users/{user_id}")
        idents = data.get("identities", [])
        ldap_ident = next((i for i in idents if "ldap" in i.get("provider", "").lower()), None)
        result = ldap_ident.get("extern_uid", "") if ldap_ident else ""
    except Exception:
        result = ""
    cache[user_id] = result
    return result


def main():
    log("=== GitLab Member Export (LDAP-synced subgroups) ===")
    log(f"GitLab: {GITLAB_URL}  Timestamp: {TIMESTAMP}\n")

    email_cache = {}
    ldap_cache = {}
    all_rows = []
    seen = set()  # dedupe by (subgroup, user_id) — a user might inherit from a parent too

    for path in SUBGROUPS:
        log(f"[SUBGROUP] {path}")
        group = resolve_group(path)
        if not group:
            continue

        try:
            members = api_get_all(f"/groups/{group['id']}/members/all")
        except Exception as e:
            log(f"  [ERROR] members fetch failed: {e}")
            continue

        log(f"  Members: {len(members)}")
        for m in members:
            key = (path, m["id"])
            if key in seen:
                continue
            seen.add(key)

            email = get_user_email(m["id"], email_cache)
            extern_uid = get_ldap_identity(m["id"], ldap_cache)
            level = m.get("access_level", 0)

            all_rows.append({
                "subgroup": path,
                "user_id": m["id"],
                "username": m.get("username", ""),
                "name": m.get("name", ""),
                "email": email,
                "ldap_extern_uid": extern_uid,
                "access_level": level,
                "access_level_name": ACCESS_LEVEL_MAP.get(level, str(level)),
                "state": m.get("state", ""),
            })
        log("")

    fieldnames = ["subgroup", "user_id", "username", "name", "email",
                  "ldap_extern_uid", "access_level", "access_level_name", "state"]
    with open(OUTPUT_CSV, "w", newline="", encoding="utf-8") as f:
        writer = csv.DictWriter(f, fieldnames=fieldnames)
        writer.writeheader()
        writer.writerows(all_rows)

    log(f"=== DONE === Total records: {len(all_rows)}")
    log(f"CSV: {OUTPUT_CSV}")
    log(f"Log: {LOG_FILE}")


if __name__ == "__main__":
    main()
