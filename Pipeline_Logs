# NOTE: Fixes applied:
#   1. COPY path changed from absolute (/build/libs/) to relative (build/libs/)
#   2. JAR artifact name corrected: epay_reporting_service -> epay_reports_service
#   3. ENTRYPOINT jar name corrected to match above

ARG BASE_IMAGE_DEV_ENV
FROM ${BASE_IMAGE_DEV_ENV}

ARG ENV
ARG VERSION

ENV ENV=$ENV
ENV VERSION=$VERSION

COPY ./epaycert.cer  /tmp
COPY ./sms.cer  /tmp

# FIX 1: Relative path (no leading /)
# FIX 2: Artifact name corrected from epay_reporting_service -> epay_reports_service
COPY build/libs/epay_reports_service-${VERSION}.jar .

# FIX 3: ENTRYPOINT jar name corrected to match
ENTRYPOINT sh -c 'java -jar "epay_reports_service-$VERSION.jar"'

COPY ./sms.cer  /tmp

USER root
RUN mkdir -p /home/default/merchantreports
RUN chmod 777 -R /home/default/merchantreports
RUN cd /usr/lib/jvm/java-21/bin
RUN yes | keytool -import -trustcacerts -file /tmp/epaycert.cer \
      -keystore /usr/lib/jvm/java-21/lib/security/cacerts \
      -alias S3_EPAY_CERT -storepass changeit

USER 0
RUN cd /usr/lib/jvm/java-21/bin
RUN yes | keytool -import -trustcacerts -file /tmp/sms.cer \
      -keystore /usr/lib/jvm/java-21/lib/security/cacerts \
      -alias DEV_EPAY_SMS -storepass changeit
