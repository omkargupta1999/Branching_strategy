# ─────────────────────────────────────────────
# HTTP HELPERS
# ─────────────────────────────────────────────
def _headers(token):
    return {"PRIVATE-TOKEN": token, "Content-Type": "application/json"}

def _get_all(base_url, token, endpoint, params=None):
    """Paginate through all pages of a GitLab API endpoint."""
    results = []
    page = 1
    if params is None:
        params = {}
    while True:
        p = {**params, "per_page": 100, "page": page}
        resp = requests.get(
            f"{base_url}/api/v4/{endpoint}",
            headers=_headers(token),
            params=p,
            timeout=30,
            verify=False   # adjust for self-signed certs in air-gapped env
        )
        if resp.status_code == 404:
            return []
        resp.raise_for_status()
        data = resp.json()
        if not data:
            break
        results.extend(data)
        if len(data) < 100:
            break
        page += 1
        time.sleep(0.1)  # rate-limit courtesy
    return results

def _get(base_url, token, endpoint, params=None):
    resp = requests.get(
        f"{base_url}/api/v4/{endpoint}",
        headers=_headers(token),
        params=params or {},
        timeout=30,
        verify=False
    )
    if resp.status_code == 404:
        return None
    resp.raise_for_status()
    return resp.json()

# ─────────────────────────────────────────────
# GROUP ENUMERATION
# ─────────────────────────────────────────────
def get_all_groups(base_url, token, top_group):
    """Return list of all groups/subgroups under top_group.

    Each group dict is annotated with a 'rel_path' key: its full_path with the
    top group's full_path prefix stripped. This lets us pair source and target
    groups even when the two instances use different top-level group names.
    The top group itself gets rel_path == "" (empty string).
    """
    top = _get(base_url, token, f"groups/{requests.utils.quote(top_group, safe='')}")
    if not top:
        raise RuntimeError(f"Top group '{top_group}' not found on {base_url}")

    top_full = top["full_path"]  # e.g. "ITEPAYPG-SBIePay2-OLD"

    descendants = _get_all(
        base_url, token,
        f"groups/{requests.utils.quote(top_group, safe='')}/descendant_groups",
        {"include_subgroups": True, "all_available": True}
    )

    groups = [top] + descendants
    for g in groups:
        fp = g["full_path"]
        if fp == top_full:
            g["rel_path"] = ""  # the top group itself
        elif fp.startswith(top_full + "/"):
            g["rel_path"] = fp[len(top_full) + 1:]   # strip "TOP/"
        else:
            # Defensive: descendant API should never return out-of-tree groups
            g["rel_path"] = fp
    return groups

# ─────────────────────────────────────────────
# EPIC FETCHERS
# ─────────────────────────────────────────────
def get_epics_for_group(base_url, token, group_id, state="all"):
    return _get_all(base_url, token, f"groups/{group_id}/epics",
                    {"state": state, "include_descendant_groups": False})

def get_epic_issues(base_url, token, group_id, epic_iid):
    return _get_all(base_url, token, f"groups/{group_id}/epics/{epic_iid}/issues")

def get_epic_children(base_url, token, group_id, epic_iid):
    return _get_all(base_url, token, f"groups/{group_id}/epics/{epic_iid}/epics")

def get_epic_labels(base_url, token, group_id):
    return _get_all(base_url, token, f"groups/{group_id}/labels")

def get_epic_boards(base_url, token, group_id):
    """Epic boards are group-level. Returns [] on 404 (not supported / not present)."""
    try:
        return _get_all(base_url, token, f"groups/{group_id}/epic_boards")
    except requests.HTTPError:
        return []

def get_epic_board_detail(base_url, token, group_id, board_id):
    """Full board incl. lists (lists carry label info needed to recreate)."""
    return _get(base_url, token, f"groups/{group_id}/epic_boards/{board_id}")

def get_milestones(base_url, token, group_id):
    return _get_all(base_url, token, f"groups/{group_id}/milestones")

# ─────────────────────────────────────────────
# EPIC BOARD RECREATION  (write — only runs when --recreate-boards is passed)
# ─────────────────────────────────────────────
def _post(base_url, token, endpoint, payload):
    resp = requests.post(
        f"{base_url}/api/v4/{endpoint}",
        headers=_headers(token), json=payload, timeout=30, verify=False)
    resp.raise_for_status()
    return resp.json()

def label_name_to_id(base_url, token, group_id):
    """Map label name -> id on a group (labels IDs differ between instances)."""
    labels = _get_all(base_url, token, f"groups/{group_id}/labels")
    return {l["name"]: l["id"] for l in labels}

def recreate_boards(src_url, src_tok, src_gid,
                    tgt_url, tgt_tok, tgt_gid, dry_run=True):
    """Recreate source epic boards (and their label-based lists) on the target.

    Epic boards are NOT migrated by Export/Import, so they must be rebuilt.
    Label-based lists are re-pointed to the TARGET label IDs by matching label
    NAME (target IDs differ from source IDs). dry_run=True only prints actions.
    """
    actions = []
    src_boards = get_epic_boards(src_url, src_tok, src_gid)
    tgt_boards = {b["name"] for b in get_epic_boards(tgt_url, tgt_tok, tgt_gid)}
    tgt_label_ids = label_name_to_id(tgt_url, tgt_tok, tgt_gid)

    for b in src_boards:
        if b["name"] in tgt_boards:
            actions.append(f"SKIP board '{b['name']}' (already exists on target)")
            continue
        if dry_run:
            actions.append(f"WOULD CREATE board '{b['name']}' on target")
        else:
            new_board = _post(tgt_url, tgt_tok,
                              f"groups/{tgt_gid}/epic_boards",
                              {"name": b["name"]})
            actions.append(f"CREATED board '{b['name']}' (id={new_board['id']})")
            # Recreate label-based lists
            detail = get_epic_board_detail(src_url, src_tok, src_gid, b["id"]) or {}
            for lst in detail.get("lists", []):
                lbl = lst.get("label")
                if not lbl:
                    continue  # skip non-label lists (open/closed are automatic)
                tgt_lbl_id = tgt_label_ids.get(lbl["name"])
                if not tgt_lbl_id:
                    actions.append(f"  WARN list label '{lbl['name']}' not found on target — list skipped")
                    continue
                _post(tgt_url, tgt_tok,
                      f"groups/{tgt_gid}/epic_boards/{new_board['id']}/lists",
                      {"label_id": tgt_lbl_id})
                actions.append(f"  added list for label '{lbl['name']}'")
    return actions

# ─────────────────────────────────────────────
# INSTANCE VERSION
# ─────────────────────────────────────────────
def get_version(base_url, token):
    v = _get(base_url, token, "version")
    if v:
        return v.get("version", "unknown"), v.get("revision", "unknown")
    return "unknown", "unknown"

# ─────────────────────────────────────────────
# CORE COMPARISON LOGIC
# ─────────────────────────────────────────────
def build_epic_map(epics):
    """Key: (group_id, iid) → epic dict."""
    return {(e["group_id"], e["iid"]): e for e in epics}

def compare_epics(src_epics, tgt_epics, group_name):
    """Return comparison result dict for a single group."""
    src_map = {e["iid"]: e for e in src_epics}
    tgt_map = {e["iid"]: e for e in tgt_epics}

    src_iids = set(src_map.keys())
    tgt_iids = set(tgt_map.keys())

    missing   = src_iids - tgt_iids   # in source, not in target
    extra     = tgt_iids - src_iids   # in target, not in source (unexpected)
    common    = src_iids & tgt_iids

    drift_records = []
    for iid in common:
        s = src_map[iid]
        t = tgt_map[iid]
        issues = []
        if s.get("state") != t.get("state"):
            issues.append(f"state: {s.get('state')} → {t.get('state')}")
        if s.get("title") != t.get("title"):
            issues.append(f"title mismatch")
        if s.get("parent_id") != t.get("parent_id"):
            issues.append(f"parent_id drift: {s.get('parent_id')} → {t.get('parent_id')}")
        if s.get("start_date") != t.get("start_date"):
            issues.append(f"start_date: {s.get('start_date')} → {t.get('start_date')}")
        if s.get("due_date") != t.get("due_date"):
            issues.append(f"due_date: {s.get('due_date')} → {t.get('due_date')}")
        if issues:
            drift_records.append({
                "group": group_name,
                "epic_iid": iid,
                "title": s.get("title"),
                "drift": "; ".join(issues)
            })

    return {
        "group":        group_name,
        "src_total":    len(src_epics),
        "tgt_total":    len(tgt_epics),
        "src_open":     sum(1 for e in src_epics if e.get("state") == "opened"),
        "tgt_open":     sum(1 for e in tgt_epics if e.get("state") == "opened"),
        "src_closed":   sum(1 for e in src_epics if e.get("state") == "closed"),
        "tgt_closed":   sum(1 for e in tgt_epics if e.get("state") == "closed"),
        "missing_iids": sorted(missing),
        "extra_iids":   sorted(extra),
        "drift":        drift_records,
        "count_match":  len(src_epics) == len(tgt_epics),
    }

# ─────────────────────────────────────────────
# HIERARCHY CHECKER
# ─────────────────────────────────────────────
def check_hierarchy(base_url, token, group_id, epics):
    """Detect orphaned epics — parent_id set but parent not in group."""
    epic_ids = {e["id"] for e in epics}
    orphaned = []
    for e in epics:
        pid = e.get("parent_id")
        if pid and pid not in epic_ids:
            orphaned.append({
                "epic_iid":  e["iid"],
                "title":     e.get("title"),
                "parent_id": pid,
                "issue":     "parent_id references an epic not present in this group"
            })
    return orphaned

# ─────────────────────────────────────────────
# BOARD COMPARISON
# ─────────────────────────────────────────────
def compare_boards(src_boards, tgt_boards, group_name):
    src_names = {b.get("name") for b in src_boards}
    tgt_names = {b.get("name") for b in tgt_boards}
    return {
        "group":        group_name,
        "src_count":    len(src_boards),
        "tgt_count":    len(tgt_boards),
        "missing":      sorted(src_names - tgt_names),
        "extra":        sorted(tgt_names - src_names),
    }

# ─────────────────────────────────────────────
# CSV WRITERS
# ─────────────────────────────────────────────
def write_csv(filename, rows, fieldnames):
    path = OUTPUT_DIR / filename
    with open(path, "w", newline="", encoding="utf-8") as f:
        w = csv.DictWriter(f, fieldnames=fieldnames, extrasaction="ignore")
        w.writeheader()
        w.writerows(rows)
    return path

