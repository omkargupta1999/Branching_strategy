#!/usr/bin/env python3

import urllib.request
import urllib.error
import json
import ssl
from collections import defaultdict
from datetime import datetime

# ==========================================================
# CONFIGURATION
# ==========================================================

GITLAB_URL = "https://gitlab.epay.sbi"

TOKEN = "YOUR_PAT_TOKEN"

GROUP_PATH = "itepaypg-sbiepay2"

OUTPUT_FILE = "gitlab_group_repo_report.txt"

# ==========================================================

ssl_ctx = ssl._create_unverified_context()

HEADERS = {
    "PRIVATE-TOKEN": TOKEN
}

# ==========================================================

def api_get(url):

    req = urllib.request.Request(url)

    for k, v in HEADERS.items():
        req.add_header(k, v)

    response = urllib.request.urlopen(
        req,
        context=ssl_ctx
    )

    return json.loads(response.read()), response


# ==========================================================

def get_all_projects():

    projects = []

    page = 1

    while True:

        url = (
            f"{GITLAB_URL}/api/v4/groups/{GROUP_PATH}/projects"
            f"?include_subgroups=true"
            f"&per_page=100"
            f"&page={page}"
        )

        data, resp = api_get(url)

        if not data:
            break

        projects.extend(data)

        total_pages = int(
            resp.headers.get(
                "X-Total-Pages",
                "1"
            )
        )

        if page >= total_pages:
            break

        page += 1

    return projects


# ==========================================================

def get_project_size(project_id):

    try:

        url = (
            f"{GITLAB_URL}/api/v4/projects/"
            f"{project_id}?statistics=true"
        )

        data, _ = api_get(url)

        stats = data.get("statistics", {})

        return int(
            stats.get(
                "repository_size",
                0
            )
        )

    except Exception:

        return 0


# ==========================================================

def format_size(kb):

    if kb >= 1048576:
        return f"{kb / 1048576:.2f} GB"

    if kb >= 1024:
        return f"{kb / 1024:.2f} MB"

    return f"{kb} KB"


# ==========================================================

print("\nFetching repositories...\n")

projects = get_all_projects()

print(f"Repositories Found : {len(projects)}")

groups = defaultdict(list)

overall_size = 0

largest_repo_name = ""
largest_repo_size = 0

# ==========================================================
# Collect Data
# ==========================================================

for count, project in enumerate(projects, start=1):

    print(
        f"[{count}/{len(projects)}] "
        f"{project['path_with_namespace']}"
    )

    project_id = project["id"]

    full_path = project["path_with_namespace"]

    repo_name = full_path.split("/")[-1]

    subgroup = "/".join(
        full_path.split("/")[:-1]
    )

    repo_size_kb = get_project_size(project_id)

    overall_size += repo_size_kb

    if repo_size_kb > largest_repo_size:

        largest_repo_size = repo_size_kb
        largest_repo_name = full_path

    groups[subgroup].append({
        "repo_name": repo_name,
        "repo_size": repo_size_kb
    })

# ==========================================================
# Write Report
# ==========================================================

with open(
    OUTPUT_FILE,
    "w",
    encoding="utf-8"
) as report:

    report.write(
        "=" * 100 + "\n"
    )

    report.write(
        "GitLab Repository Storage Report\n"
    )

    report.write(
        "=" * 100 + "\n"
    )

    report.write(
        f"Generated : {datetime.now()}\n"
    )

    report.write(
        f"Group     : {GROUP_PATH}\n\n"
    )

    total_groups = len(groups)

    # ======================================================

    for subgroup in sorted(groups.keys()):

        repos = groups[subgroup]

        repos.sort(
            key=lambda x: x["repo_size"],
            reverse=True
        )

        report.write(
            "\n" + "=" * 100 + "\n"
        )

        report.write(
            f"GROUP : {subgroup}\n"
        )

        report.write(
            "=" * 100 + "\n\n"
        )

        report.write(
            "{:<5} {:<60} {:>15}\n".format(
                "No",
                "Repository",
                "Size"
            )
        )

        report.write(
            "-" * 100 + "\n"
        )

        group_size = 0

        for idx, repo in enumerate(
            repos,
            start=1
        ):

            group_size += repo["repo_size"]

            report.write(
                "{:<5} {:<60} {:>15}\n".format(
                    idx,
                    repo["repo_name"],
                    format_size(
                        repo["repo_size"]
                    )
                )
            )

        report.write(
            "-" * 100 + "\n"
        )

        report.write(
            f"Group Repository Count : {len(repos)}\n"
        )

        report.write(
            f"Group Total Size       : {format_size(group_size)}\n"
        )

    # ======================================================

    report.write(
        "\n\n" + "=" * 100 + "\n"
    )

    report.write(
        "OVERALL SUMMARY\n"
    )

    report.write(
        "=" * 100 + "\n"
    )

    report.write(
        f"Total Groups        : {total_groups}\n"
    )

    report.write(
        f"Total Repositories  : {len(projects)}\n"
    )

    report.write(
        f"Total Storage       : {format_size(overall_size)}\n"
    )

    report.write(
        f"Largest Repository  : {largest_repo_name}\n"
    )

    report.write(
        f"Largest Repo Size   : {format_size(largest_repo_size)}\n"
    )

print("\nDone")
print(f"Report Generated : {OUTPUT_FILE}")
