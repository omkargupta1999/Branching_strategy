# =============================================================================
#  API HELPERS
# =============================================================================

def _request(method, url, data=None, dry_run=False, as_json=False):
    """One HTTP call. data dict -> form-urlencoded body, OR JSON body when
       as_json=True (needed for nested arrays like allowed_to_merge that the
       form-encoded bracket syntax does not reliably express on 18.x).
       Honours dry_run for writes."""
    is_write = method in ("POST", "PUT", "DELETE")
    if is_write and dry_run:
        log(f"    [dry-run] {method} {url}")
        if data:
            log(f"              payload: {json.dumps(data)}")
        return {"__dry_run__": True}

    body = None
    req_headers = dict(HEADERS)
    if data is not None:
        if as_json:
            body = json.dumps(data).encode()
            req_headers["Content-Type"] = "application/json"
        else:
            body = urllib.parse.urlencode(data, doseq=True).encode()
            req_headers["Content-Type"] = "application/x-www-form-urlencoded"

    req = urllib.request.Request(url, data=body, method=method)
    for k, v in req_headers.items():
        req.add_header(k, v)
    try:
        resp = urllib.request.urlopen(req, context=ssl_ctx)
        raw = resp.read().decode()
        return json.loads(raw) if raw else {}
    except urllib.error.HTTPError as e:
        detail = e.read().decode(errors="replace")
        if e.code == 401:
            log("\n[ERROR] 401 Unauthorized — TOKEN invalid or empty.")
            sys.exit(1)
        if e.code == 403:
            log("\n[ERROR] 403 Forbidden — token lacks scope/role on this project.")
            sys.exit(1)
        if e.code == 404:
            return None   # let callers treat 404 as 'not found'
        log(f"\n[ERROR] HTTP {e.code} on {method} {url} -> {detail}")
        sys.exit(1)


def api_get(path, params=None):
    url = f"{GITLAB_URL}/api/v4{path}"
    if params:
        url += "?" + urllib.parse.urlencode(params)
    return _request("GET", url)

def api_get_all(path, params=None):
    """Paginated GET — returns the full list across pages."""
    results, page = [], 1
    base = f"{GITLAB_URL}/api/v4{path}"
    while True:
        q = dict(params or {})
        q.update({"per_page": 100, "page": page})
        url = base + "?" + urllib.parse.urlencode(q)
        req = urllib.request.Request(url)
        for k, v in HEADERS.items():
            req.add_header(k, v)
        try:
            resp = urllib.request.urlopen(req, context=ssl_ctx)
            data = json.loads(resp.read())
        except urllib.error.HTTPError as e:
            if e.code in (401, 403):
                log(f"\n[ERROR] HTTP {e.code} fetching {url}")
                sys.exit(1)
            break
        if not data:
            break
        results.extend(data)
        try:
            if page >= int(resp.headers.get("X-Total-Pages", "1")):
                break
        except ValueError:
            break
        page += 1
    return results

def api_post(path, data=None, dry_run=False, as_json=False):
    return _request("POST", f"{GITLAB_URL}/api/v4{path}", data=data,
                    dry_run=dry_run, as_json=as_json)

def api_put(path, data=None, dry_run=False, as_json=False):
    return _request("PUT", f"{GITLAB_URL}/api/v4{path}", data=data,
                    dry_run=dry_run, as_json=as_json)

def api_delete(path, dry_run=False):
    return _request("DELETE", f"{GITLAB_URL}/api/v4{path}", dry_run=dry_run)

# =============================================================================
#  RESOLUTION
# =============================================================================

def resolve_project(full_path):
    # Accept either a numeric project ID or a full path.
    ident = str(full_path).strip()
    if ident.isdigit():
        enc = ident
    else:
        enc = urllib.parse.quote(ident, safe="")
    proj = api_get(f"/projects/{enc}")
    if not proj:
        log(f"\n[ERROR] Project not found: {full_path}")
        log("  Tip: pass the numeric project ID instead of the path, e.g.")
        log("       --project 2754")
        log("  Or copy the exact 'Full Path' from your repo_list CSV "
            "(paths are case-sensitive).")
        sys.exit(1)
    return proj["id"], proj["path_with_namespace"]

def resolve_groups(_unused=None):
    """Validate each hardcoded group ID exists & is visible (READ-ONLY).
       Returns the same name->id map. Aborts if any ID is unreachable."""
    resolved, missing = {}, []
    for name, gid in GROUP_IDS.items():
        g = api_get(f"/groups/{gid}")
        if g and g.get("id") == gid:
            resolved[name] = gid
        else:
            missing.append(f"{name} (id={gid})")
    if missing:
        log("\n[ERROR] These GitLab groups could not be reached by ID:")
        for m in missing:
            log(f"   - {m}")
        log("Aborting without making any changes. Re-run find_ldap_groups.py "
            "and update GROUP_IDS if IDs have changed on this instance.")
        sys.exit(2)
    return resolved

# =============================================================================
#  STEP 1 — GROUP INVITES (project share)
# =============================================================================

def apply_group_invites(pid, dry_run):
    log("\n=== Step 1: Group Invites (project share) ===")
    # Existing shared groups on the project, to make this idempotent.
    proj = api_get(f"/projects/{pid}")
    shared = {g.get("group_id"): g.get("group_access_level")
              for g in (proj.get("shared_with_groups", []) if proj else [])}

    for inv in GROUP_INVITES:
        gid, lvl, name = inv["id"], inv["access"], inv["name"]
        if shared.get(gid) == lvl:
            log(f"  '{name}' already shared at level {lvl} -> skip")
            continue
        if gid in shared:
            # Re-share at the correct level: unshare then share.
            api_delete(f"/projects/{pid}/share/{gid}", dry_run=dry_run)
        api_post(f"/projects/{pid}/share",
                 data={"group_id": gid, "group_access": lvl},
                 dry_run=dry_run, as_json=True)
        log(f"  shared '{name}' (id={gid}) at access level {lvl}")

# =============================================================================
#  STEP 2 — PUSH RULES
# =============================================================================

def apply_push_rules(pid, dry_run):
    log("\n=== Step 2: Push Rules ===")
    existing = api_get(f"/projects/{pid}/push_rule")
    if dry_run:
        verb = "update" if existing else "create"
        log(f"    [dry-run] would {verb} push rules")
        log(f"    branch_name_regex   : {PUSH_RULES['branch_name_regex']}")
        log(f"    commit_message_regex: {PUSH_RULES['commit_message_regex']}")
        return

    if existing:
        resp = api_put(f"/projects/{pid}/push_rule", data=PUSH_RULES, as_json=True)
        verb = "updated"
    else:
        resp = api_post(f"/projects/{pid}/push_rule", data=PUSH_RULES, as_json=True)
        verb = "created"

    # Read back to CONFIRM the write actually persisted (the create endpoint
    # can return 2xx without persisting on some 18.x configs). Trust the
    # read-back, not the POST response.
    after = api_get(f"/projects/{pid}/push_rule")
    persisted = (after
                 and after.get("branch_name_regex") == PUSH_RULES["branch_name_regex"]
                 and after.get("commit_message_regex") == PUSH_RULES["commit_message_regex"])

    # Fallback: push_rules is a flat-field endpoint; some 18.x builds only
    # accept form-encoded (not JSON) here. If JSON didn't persist, retry as form.
    if not persisted:
        log("  [info] JSON write did not persist; retrying form-encoded ...")
        existing2 = api_get(f"/projects/{pid}/push_rule")
        if existing2:
            resp = api_put(f"/projects/{pid}/push_rule", data=PUSH_RULES, as_json=False)
            verb = "updated"
        else:
            resp = api_post(f"/projects/{pid}/push_rule", data=PUSH_RULES, as_json=False)
            verb = "created"
        after = api_get(f"/projects/{pid}/push_rule")
        persisted = (after
                     and after.get("branch_name_regex") == PUSH_RULES["branch_name_regex"]
                     and after.get("commit_message_regex") == PUSH_RULES["commit_message_regex"])

    if persisted:
        log(f"  {verb} push rules — CONFIRMED on read-back")
        log(f"    branch_name_regex   : {after.get('branch_name_regex')}")
        log(f"    commit_message_regex: {after.get('commit_message_regex')}")
    else:
        log("  [WARN] push rules did NOT persist as expected.")
        log(f"    POST/PUT response: {json.dumps(resp) if resp else 'empty'}")
        log(f"    read-back: {json.dumps(after) if after else 'none'}")
        log("    -> push rules may require a different endpoint/permission on "
            "this instance; see notes.")

# =============================================================================
#  STEP 3 — PROTECTED BRANCHES
# =============================================================================

def get_protected_branch(pid, name):
    enc = urllib.parse.quote(name, safe="")
    return api_get(f"/projects/{pid}/protected_branches/{enc}")

def get_protected_branch_id(pid, name):
    """Resolve a protected branch's numeric ID reliably, including wildcard
       names like 'release/*'. The single-name GET endpoint is unreliable for
       wildcards on 18.1.x, so list all protected branches and match by name."""
    for pb in (api_get_all(f"/projects/{pid}/protected_branches") or []):
        if pb.get("name") == name:
            return pb.get("id")
    return None

def apply_protected_branches(pid, groups, dry_run):
    log("\n=== Step 3: Protected Branch Rules ===")
    for spec in PROTECTED_BRANCHES:
        name = spec["name"]
        enc  = urllib.parse.quote(name, safe="")
        if get_protected_branch_id(pid, name) is not None:
            log(f"  '{name}' already protected -> deleting to re-apply cleanly")
            api_delete(f"/projects/{pid}/protected_branches/{enc}", dry_run=dry_run)

        # push_access_level 0 = "No one" (an empty allowed_to_push array is
        # interpreted by GitLab as the default Maintainers level, NOT nobody,
        # so we set the level explicitly). allowed_to_merge stays a group array.
        data = {
            "name": name,
            "allow_force_push": False,
            "push_access_level": NO_ACCESS,   # 0 = No one
            "allowed_to_merge": [{"group_id": groups[gname]}
                                 for gname in spec["merge_groups"]],
        }

        api_post(f"/projects/{pid}/protected_branches", data=data,
                 dry_run=dry_run, as_json=True)
        log(f"  protected '{name}' | push: No one | merge: {', '.join(spec['merge_groups'])}")

# =============================================================================
#  STEP 4 — MR APPROVAL RULES
# =============================================================================

def apply_approval_rules(pid, groups, dry_run):
    log("\n=== Step 4: MR Approval Rules ===")
    # protected-branch name -> id (needed to target a rule at a branch)
    pb_ids = {}
    for spec in PROTECTED_BRANCHES:
        if dry_run:
            pb_ids[spec["name"]] = f"<pb-id:{spec['name']}>"
        else:
            pb_ids[spec["name"]] = get_protected_branch_id(pid, spec["name"])

    existing = {} if dry_run else {
        r["name"]: r for r in (api_get_all(f"/projects/{pid}/approval_rules") or [])
    }

    # --- Reconcile: delete any approval rule whose name is NOT in our spec ---
    # Keeps the repo's final state EXACTLY the 7 spec rules (no orphans from
    # earlier manual/UI config or prior script versions). GitLab's built-in
    # 'Any approver' default rule (rule_type 'any_approver') is left untouched.
    spec_names = {r["name"] for r in APPROVAL_RULES}
    if dry_run:
        log("  [reconcile] would delete any existing rule not in spec "
            "(dry-run cannot list live rules reliably; see real run)")
    else:
        for name, r in existing.items():
            if name in spec_names:
                continue
            if r.get("rule_type") == "any_approver":
                continue  # don't remove GitLab's default fallback rule
            api_delete(f"/projects/{pid}/approval_rules/{r['id']}", dry_run=dry_run)
            log(f"  [reconcile] deleted non-spec rule '{name}' (id={r['id']})")
        # Refresh after deletions so we don't try to PUT a just-deleted rule.
        existing = {
            r["name"]: r for r in (api_get_all(f"/projects/{pid}/approval_rules") or [])
        }

    for rule in APPROVAL_RULES:
        branch = rule["branch"]
        pbid   = pb_ids.get(branch)
        if pbid is None and not dry_run:
            log(f"  SKIP '{rule['name']}' (target branch '{branch}' not protected)")
            continue

        data = {
            "name": rule["name"],
            "approvals_required": rule["required"],
            "rule_type": "regular",
            "group_ids": [groups[rule["group"]]],
        }
        if pbid is not None:
            data["protected_branch_ids"] = [pbid]

        prev = existing.get(rule["name"])
        if prev:
            api_put(f"/projects/{pid}/approval_rules/{prev['id']}", data=data,
                    dry_run=dry_run, as_json=True)
            verb = "updated"
        else:
            api_post(f"/projects/{pid}/approval_rules", data=data,
                     dry_run=dry_run, as_json=True)
            verb = "created"
        log(f"  {verb} '{rule['name']}' -> '{branch}' | group {rule['group']} | required {rule['required']}")

# =============================================================================
#  STEP 5 — PROJECT SETTING
# =============================================================================

def apply_pipeline_setting(pid, dry_run):
    """Step 5 — 'Pipelines must succeed before merge'.
       Idempotent: reads current value, skips if already enabled."""
    log("\n=== Step 5: Pipelines Must Succeed ===")
    proj = api_get(f"/projects/{pid}")
    current = proj.get("only_allow_merge_if_pipeline_succeeds") if proj else None
    if current is True:
        log("  already enabled -> skip")
        return
    log(f"  current={current} -> setting to True")
    api_put(f"/projects/{pid}",
            data={"only_allow_merge_if_pipeline_succeeds": "true"},
            dry_run=dry_run)
    log("  'Pipelines must succeed before merge' = enabled")

# =============================================================================
#  STEP 6 — MERGE METHOD  ("Merge commit" only)
# =============================================================================

def apply_merge_method(pid, dry_run):
    """Step 6 — force merge_method to MERGE_METHOD ('merge' = Merge commit).
       Idempotent: reads current value, skips if already correct."""
    log("\n=== Step 6: Merge Method ===")
    proj = api_get(f"/projects/{pid}")
    current = proj.get("merge_method") if proj else None
    if current == MERGE_METHOD:
        log(f"  already '{MERGE_METHOD}' (Merge commit) -> skip")
        return
    log(f"  current='{current}' -> setting to '{MERGE_METHOD}'")
    api_put(f"/projects/{pid}",
            data={"merge_method": MERGE_METHOD},
            dry_run=dry_run)
    log(f"  merge_method = '{MERGE_METHOD}' (Merge commit)")

# =============================================================================
#  STEP 7 — SQUASH OPTION  ("Do not allow")
# =============================================================================

def apply_squash_option(pid, dry_run):
    """Step 7 — force squash_option to SQUASH_OPTION ('never' = Do not allow).
       Idempotent: reads current value, skips if already correct."""
    log("\n=== Step 7: Squash Option ===")
    proj = api_get(f"/projects/{pid}")
    current = proj.get("squash_option") if proj else None
    if current == SQUASH_OPTION:
        log(f"  already '{SQUASH_OPTION}' (Do not allow) -> skip")
        return
    log(f"  current='{current}' -> setting to '{SQUASH_OPTION}'")
    api_put(f"/projects/{pid}",
            data={"squash_option": SQUASH_OPTION},
            dry_run=dry_run)
    log(f"  squash_option = '{SQUASH_OPTION}' (Do not allow)")

# =============================================================================
#  STEP 8 — DEFAULT BRANCH  (main)
# =============================================================================

def apply_default_branch(pid, dry_run):
    """Step 8 — set the repo's default branch to DEFAULT_BRANCH ('main').
       Idempotent: skips if already correct.
       SAFETY: only sets it if the branch actually EXISTS in the repo, so we
       never point default_branch at a non-existent ref."""
    log("\n=== Step 8: Default Branch ===")
    proj = api_get(f"/projects/{pid}")
    current = proj.get("default_branch") if proj else None
    if current == DEFAULT_BRANCH:
        log(f"  already '{DEFAULT_BRANCH}' -> skip")
        return

    # Confirm the target branch exists before switching to it.
    enc = urllib.parse.quote(DEFAULT_BRANCH, safe="")
    branch = api_get(f"/projects/{pid}/repository/branches/{enc}")
    if not branch:
        log(f"  SKIP: branch '{DEFAULT_BRANCH}' does not exist in this repo "
            f"(current default='{current}'). Create it first, then re-run.")
        return

    log(f"  current='{current}' -> setting to '{DEFAULT_BRANCH}'")
    api_put(f"/projects/{pid}",
            data={"default_branch": DEFAULT_BRANCH},
            dry_run=dry_run)
    log(f"  default_branch = '{DEFAULT_BRANCH}'")

# =============================================================================
#  VERIFY
# =============================================================================

def verify(pid, groups):
    log("\n=== VERIFY (read-only) ===")
    id_to_name = {v: k for k, v in groups.items()}
    invite_name = {inv["id"]: inv["name"] for inv in GROUP_INVITES}

    log("Shared groups (project members):")
    proj0 = api_get(f"/projects/{pid}")
    for g in (proj0.get("shared_with_groups", []) if proj0 else []):
        gid = g.get("group_id")
        log(f"  {invite_name.get(gid, g.get('group_name', gid))}: "
            f"access level {g.get('group_access_level')}")

    log("Protected branches:")
    pb_by_name = {pb.get("name"): pb
                  for pb in (api_get_all(f"/projects/{pid}/protected_branches") or [])}
    for spec in PROTECTED_BRANCHES:
        pb = pb_by_name.get(spec["name"])
        if not pb:
            log(f"  MISSING: {spec['name']}")
            continue
        push  = pb.get("push_access_levels", [])
        merge = pb.get("merge_access_levels", [])
        push_ok = bool(push) and all(p.get("access_level") == NO_ACCESS for p in push)
        merge_grp = [id_to_name.get(m.get("group_id"), m.get("group_id"))
                     for m in merge if m.get("group_id")]
        log(f"  {spec['name']}: push={'No one' if push_ok else push} | merge groups={merge_grp}")

    log("Approval rules:")
    for r in (api_get_all(f"/projects/{pid}/approval_rules") or []):
        grp      = [id_to_name.get(g.get("id"), g.get("name")) for g in r.get("groups", [])]
        branches = [b.get("name") for b in r.get("protected_branches", [])]
        log(f"  {r.get('name')}: required={r.get('approvals_required')} | groups={grp} | branches={branches}")

    log("Project settings:")
    proj = api_get(f"/projects/{pid}") or {}
    _mm = proj.get("merge_method")
    _sq = proj.get("squash_option")
    _db = proj.get("default_branch")
    _pp = proj.get("only_allow_merge_if_pipeline_succeeds")
    log(f"  Pipelines must succeed : {_pp}"
        f"{'' if _pp is True else '   <-- expected True'}")
    log(f"  Merge method           : {_mm}"
        f"{' (Merge commit)' if _mm == 'merge' else f'   <-- expected {MERGE_METHOD}'}")
    log(f"  Squash option          : {_sq}"
        f"{' (Do not allow)' if _sq == 'never' else f'   <-- expected {SQUASH_OPTION}'}")
    log(f"  Default branch         : {_db}"
        f"{'' if _db == DEFAULT_BRANCH else f'   <-- expected {DEFAULT_BRANCH}'}")

    log("Push rules:")
    pr = api_get(f"/projects/{pid}/push_rule")
    if pr:
        log(f"  branch_name_regex   : {pr.get('branch_name_regex')}")
        log(f"  commit_message_regex: {pr.get('commit_message_regex')}")
    else:
        log("  MISSING: no push rules set")

# =============================================================================
#  MAIN
# =============================================================================

def run_one(project, mode_verify, mode_dry_run):
    """Apply (or verify/dry-run) governance on ONE project. Returns (pid, ppath).
       On any API error the underlying calls sys.exit(1) -> fail-stop."""
    mode = "VERIFY" if mode_verify else ("DRY-RUN" if mode_dry_run else "APPLY")
    log("=" * 65)
    log("  GitLab Repo Governance")
    log(f"  Target  : {GITLAB_URL}")
    log(f"  Project : {project}")
    log(f"  Mode    : {mode}")
    log(f"  Time    : {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    log("=" * 65)

    pid, ppath = resolve_project(project)
    log(f"\nResolved project -> id={pid}  path={ppath}")

    log("\nValidating GitLab group IDs (read-only)...")
    groups = resolve_groups()
    for n, i in groups.items():
        log(f"  {n} -> {i}")

    if mode_verify:
        verify(pid, groups)
    else:
        # ------------------------------------------------------------------
        # STEP CALLS — comment out any line below to DISABLE that step.
        # Each step is independent and idempotent (skips if already correct).
        # ------------------------------------------------------------------
        apply_group_invites(pid, mode_dry_run)             # Step 1: group invites
        apply_push_rules(pid, mode_dry_run)                # Step 2: push rules
        apply_protected_branches(pid, groups, mode_dry_run)  # Step 3: protected branches
        apply_approval_rules(pid, groups, mode_dry_run)    # Step 4: MR approval rules
        apply_pipeline_setting(pid, mode_dry_run)          # Step 5: pipelines must succeed
        apply_merge_method(pid, mode_dry_run)              # Step 6: merge method = Merge commit
        apply_squash_option(pid, mode_dry_run)             # Step 7: squash = Do not allow
        apply_default_branch(pid, mode_dry_run)            # Step 8: default branch = main
        # ------------------------------------------------------------------

        if not mode_dry_run:
            verify(pid, groups)

    log(f"\nDone. Scope was project id={pid} only.")
    return pid, ppath


def load_batch_file(path):
    """Read project IDs/paths, one per line. Blank lines and #comments ignored."""
    ids = []
    with open(path, encoding="utf-8") as f:
        for raw in f:
            line = raw.strip()
            if not line or line.startswith("#"):
                continue
            # Strip any inline comment so annotated lines like
            # "2823    # itepaypg-sbiepay2/.../epay_admin_service" work too.
            # We take the first whitespace- or #-delimited token as the ID/path.
            token = line.split("#", 1)[0].strip().split()[0]
            if token:
                ids.append(token)
    return ids


def list_subgroup_projects(subgroup):
    """READ-ONLY: return [(id, path_with_namespace), ...] for every project under
       a subgroup, including all nested sub-subgroups. Archived repos excluded.
       Accepts a numeric group ID or a full group path."""
    ident = str(subgroup).strip()
    enc = ident if ident.isdigit() else urllib.parse.quote(ident, safe="")

    # Confirm the group exists first so we fail with a clear message.
    grp = api_get(f"/groups/{enc}")
    if not grp:
        log(f"\n[ERROR] Subgroup not found: {subgroup}")
        log("  Pass a numeric group ID or the exact full path, e.g.")
        log("    --subgroup itepaypg-sbiepay2/application/backend")
        sys.exit(1)

    projects = api_get_all(f"/groups/{enc}/projects",
                           params={"include_subgroups": "true",
                                   "archived": "false"})
    out = []
    for p in (projects or []):
        out.append((p.get("id"), p.get("path_with_namespace")))
    # Stable, predictable order.
    out.sort(key=lambda t: (t[1] or ""))
    return grp.get("full_path", ident), out


def run_many(targets, label, mode_verify, mode_dry_run):
    """Run governance across a list of targets, FAIL-STOP on first error.
       targets: list of project IDs/paths (strings or ints)."""
    total = len(targets)
    done = []
    print("=" * 65)
    print(f"  MULTI-REPO MODE — {total} repos — FAIL-STOP on first error")
    print(f"  Source: {label}")
    print("=" * 65)

    for idx, project in enumerate(targets, 1):
        log("")
        log("#" * 65)
        log(f"#  {idx}/{total}: {project}")
        log("#" * 65)
        # Any API error inside run_one() calls sys.exit(1) -> batch halts here.
        pid, ppath = run_one(project, mode_verify, mode_dry_run)
        done.append((pid, ppath))

    log("")
    log("=" * 65)
    log(f"  COMPLETE — {len(done)}/{total} repos succeeded")
    log("=" * 65)
    for pid, ppath in done:
        log(f"  OK  {ppath} (id={pid})")

    out_file = f"governance_BATCH_{TIMESTAMP}.txt"
    with open(out_file, "w", encoding="utf-8") as f:
        f.write("\n".join(_log_lines))
    print(f"\n  -> {out_file} written (consolidated audit log).")


def main():
    ap = argparse.ArgumentParser(
        description="Apply SBIePay repo governance to one repo (--project), "
                    "every repo in a subgroup (--subgroup), or a list of repos "
                    "(--batch). Multi-repo runs are FAIL-STOP on first error.",
        epilog="Examples:\n"
               "  %(prog)s --project 2823 --dry-run\n"
               "  %(prog)s --project itepaypg-sbiepay2/application/backend/epay_admin_service\n"
               "  %(prog)s --subgroup itepaypg-sbiepay2/application/backend --dry-run\n"
               "  %(prog)s --batch repos_to_apply.txt\n"
               "  %(prog)s --project 2823 --verify",
        formatter_class=argparse.RawDescriptionHelpFormatter)

    # Target selection — mutually exclusive so you can't mix modes by accident.
    tgt = ap.add_mutually_exclusive_group()
    tgt.add_argument("--project", metavar="ID_OR_PATH",
                     help="ONE repo: numeric project ID or full path. "
                          "Defaults to TARGET_PROJECT in CONFIG if no target given.")
    tgt.add_argument("--subgroup", metavar="ID_OR_PATH",
                     help="ALL repos under a subgroup (includes nested sub-subgroups, "
                          "excludes archived). Numeric group ID or full group path.")
    tgt.add_argument("--batch", metavar="FILE",
                     help="Text file of project IDs/paths, one per line "
                          "('#' comments and blank lines ignored).")

    # Mode selection — also mutually exclusive.
    mode_grp = ap.add_mutually_exclusive_group()
    mode_grp.add_argument("--dry-run", action="store_true",
                          help="Show every write that WOULD happen. Changes nothing.")
    mode_grp.add_argument("--verify", action="store_true",
                          help="Read current state only. Changes nothing.")

    args = ap.parse_args()

    # ---------------- SUBGROUP MODE ----------------
    if args.subgroup:
        grp_path, projects = list_subgroup_projects(args.subgroup)
        if not projects:
            print(f"[ERROR] No projects found under subgroup: {args.subgroup}")
            sys.exit(1)
        print("=" * 65)
        print(f"  SUBGROUP: {grp_path}")
        print(f"  Found {len(projects)} repo(s):")
        for pid, ppath in projects:
            print(f"    {pid:<8} {ppath}")
        print("=" * 65)
        run_many([p[0] for p in projects],
                 f"subgroup {grp_path}", args.verify, args.dry_run)
        return

    # ---------------- BATCH MODE ----------------
    if args.batch:
        targets = load_batch_file(args.batch)
        if not targets:
            print(f"[ERROR] No project IDs found in {args.batch}")
            sys.exit(1)
        run_many(targets, f"file {args.batch}", args.verify, args.dry_run)
        return

    # ---------------- SINGLE-REPO MODE ----------------
    project = args.project or TARGET_PROJECT
    pid, ppath = run_one(project, args.verify, args.dry_run)

    out_file = f"governance_{ppath.split('/')[-1]}_{TIMESTAMP}.txt"
    with open(out_file, "w", encoding="utf-8") as f:
        f.write("\n".join(_log_lines))
    print(f"\n  -> {out_file} written.")
    if args.verify:
        print("  READ-ONLY: no changes made to GitLab.")
    elif args.dry_run:
        print("  DRY-RUN: no changes made to GitLab.")
    else:
        print("  Changes were limited to the single project above.")


if __name__ == "__main__":
    main()
