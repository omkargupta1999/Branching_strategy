  stage: dockerbuild
  image: artifactory.jfrog.sbi:443/dso-docker-base-images/ubi9/podman-jf:9.7
  tags:
    - common_runner
  allow_failure: true
  script:
    | 
    echo $VERSION
    TAG="${VERSION}"
    echo "Generated Tag.. ${TAG}"
    COMPUTED_IMAGE_TAG="$CI_TEMPLATE_REGISTRY_HOST/$IMAGE_NAME:$TAG"
    echo "Image: ${COMPUTED_IMAGE_TAG}"
    echo "COMPUTED_IMAGE_TAG=${COMPUTED_IMAGE_TAG}" >> docker.env
    echo "Building Docker image for $COMPUTED_IMAGE_TAG"
    podman build -t "${COMPUTED_IMAGE_TAG}" -f Dockerfile --build-arg ENV=$ENV --build-arg VERSION=$TAG
    podman save -o "${TAR_NAME}" "${COMPUTED_IMAGE_TAG}"
    echo "Image built and saved to ${TAR_NAME}"
  artifacts:
    paths:
      - "$TAR_NAME"
    reports:
      dotenv: docker.env
    expire_in: 1 day
    when: on_success


# STEP 2 — Scan tar before pushing
.docker_scan_image:
  extends: .docker_base
  stage: docker_scan
  needs:
    - job: dockerbuild
      artifacts: true
  interruptible: true
  script:
    - |
      set -e
      echo "Scanning: ${COMPUTED_IMAGE_TAG}"
      jf scan "${TAR_NAME}" --watches=EPAY-WATCHER --fail=true
      echo "Image scan passed"

