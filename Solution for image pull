variables:
  FORTIFY_IMAGE: "artifactory.jfrog.sbi:443/dso-base-image/ubi9/ubi9-java17-fortify-24.4:2.0"
  FORTIFY_MEM: "8G"

  FORTIFY_PROJECT: "$CI_PROJECT_NAME"
  PROJECT_NAME: "$CI_PROJECT_NAME"
  FORTIFY_SCAN_OUTPUT: "$CI_PROJECT_NAME.fpr"
  FORTIFY_PROJECT_DIR: "."
  EXCLUDE_DIRS: "./src/test/**/*"

.HPFortify:
  image: "$FORTIFY_IMAGE"
  stage: hp-fortify
  tags:
    - common_runner
  interruptible: true

  before_script:
    - |
      keytool -import -alias jfrog-artifactory -file "$ARTIFACTORY_CERT" \
        -keystore /home/default/custom-truststore.jks \
        -storepass changeit -noprompt

      export JAVA_TOOL_OPTIONS="-Djavax.net.ssl.trustStore=/home/default/custom-truststore.jks \
      -Djavax.net.ssl.trustStorePassword=changeit"

  script:
    - |
      set -e

      echo "========== Fortify Scan Started =========="

      echo "Preparing exclude paths..."
      EXCLUDE_FILES=$(echo "$EXCLUDE_DIRS" | sed 's/,/:/g')
      echo "Exclude: $EXCLUDE_FILES"

      echo "Cleaning previous Fortify build..."
      sourceanalyzer -b "$FORTIFY_PROJECT" -clean

      echo "Verifying build artifacts (required for classpath)..."
      ls -ltrh build || true
      ls -ltrh build/classes/java/main || true

      echo "Constructing classpath..."
      CLASSPATH="build/classes/java/main"
      EXTRA_JARS=$(find build -name "*.jar" 2>/dev/null | tr '\n' ':')
      if [ -n "$EXTRA_JARS" ]; then
        CLASSPATH="$CLASSPATH:$EXTRA_JARS"
      fi

      echo "Classpath: $CLASSPATH"

      echo "Translating Java source with classpath (CRITICAL STEP)..."
      sourceanalyzer -b "$FORTIFY_PROJECT" \
        -source 17 \
        -cp "$CLASSPATH" \
        -exclude "$EXCLUDE_FILES" \
        src/main/java

      echo "Running Fortify scan..."
      sourceanalyzer -b "$FORTIFY_PROJECT" \
        -scan \
        -Xmx${FORTIFY_MEM} \
        -format fpr \
        -f "$FORTIFY_PROJECT_DIR/$FORTIFY_SCAN_OUTPUT"

      echo "Showing scanned files (debug)..."
      sourceanalyzer -b "$FORTIFY_PROJECT" -show-files || true

      echo "Generating PDF report..."
      BIRTReportGenerator \
        -template "Developer Workbook" \
        -source "$FORTIFY_PROJECT_DIR/$FORTIFY_SCAN_OUTPUT" \
        -format PDF \
        -output "$FORTIFY_PROJECT_DIR/${PROJECT_NAME}_report.pdf" \
        -showSuppressed \
        -showHidden

      echo "========== Fortify Scan Completed =========="

  artifacts:
    paths:
      - "*.fpr"
      - "*.pdf"
    expire_in: 1 week
    when: always

  allow_failure: true
