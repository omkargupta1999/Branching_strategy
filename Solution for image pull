variables:
  FORTIFY_IMAGE: "artifactory.jfrog.sbi:443/dso-base-image/ubi9/ubi9-java17-fortify-24.4:2.0"
  FORTIFY_MEM: "8G"
  FORTIFY_PROJECT: "$CI_PROJECT_NAME"
  PROJECT_NAME: "$CI_PROJECT_NAME"
  FORTIFY_SCAN_OUTPUT: "$CI_PROJECT_NAME.fpr"
  FORTIFY_PROJECT_DIR: "."
  EXCLUDE_DIRS: "./src/test/**/*"
  INCLUDE_DIRS: "./**/*.java"

.HPFortify:
  image: "$FORTIFY_IMAGE"
  stage: hp-fortify
  tags:
    - common_runner
  interruptible: true
  before_script:
    - |
      keytool -import -alias jfrog-artifactory -file "$ARTIFACTORY_CERT" \
        -keystore /home/default/custom-truststore.jks \
        -storepass changeit -noprompt
  script:
    - |
      set -e
      export JAVA_TOOL_OPTIONS="-Djavax.net.ssl.trustStore=/home/default/custom-truststore.jks -Djavax.net.ssl.trustStorePassword=changeit"

      echo "========== Fortify Scan Started =========="

      EXCLUDE_FILES=$(echo "$EXCLUDE_DIRS" | sed 's/,/:/g')
      echo "Excluding paths: ${EXCLUDE_FILES}"
      echo "Scanning paths: ${INCLUDE_DIRS}"

      # Build classpath from all available JARs (libs/ + gradle cache + build output)
      echo "Building classpath..."
      CP=""

      # libs/ folder (your local JARs)
      if [ -d "libs" ]; then
        for jar in libs/*.jar; do
          [ -f "$jar" ] && CP="${CP}:${jar}"
        done
        echo "Libs JARs added: $(ls libs/*.jar 2>/dev/null | wc -l)"
      fi

      # Gradle cache JARs (downloaded dependencies)
      GRADLE_CACHE="$HOME/.gradle/caches"
      if [ -d "$GRADLE_CACHE" ]; then
        GRADLE_JARS=$(find "$GRADLE_CACHE" -name "*.jar" -not -name "*sources*" -not -name "*javadoc*" 2>/dev/null | tr '\n' ':')
        CP="${CP}:${GRADLE_JARS}"
        echo "Gradle cache JARs added."
      fi

      # Build output classes (if pre-compiled)
      if [ -d "build/classes" ]; then
        CP="${CP}:build/classes"
        echo "Build classes added."
      fi

      # Strip leading colon
      CP=$(echo "$CP" | sed 's/^://')

      if [ -z "$CP" ]; then
        echo "WARNING: No classpath entries found — findings may be reduced"
      else
        echo "Classpath built successfully."
      fi

      echo "Cleaning..."
      sourceanalyzer -b "$FORTIFY_PROJECT" -clean

      echo "Translating source files..."
      sourceanalyzer -b "$FORTIFY_PROJECT" \
        -source 17 \
        -cp "$CP" \
        "${INCLUDE_DIRS}" \
        -exclude "${EXCLUDE_FILES}" \
        -verbose

      echo "Verifying translated files..."
      sourceanalyzer -b "$FORTIFY_PROJECT" -show-files

      echo "Running scan..."
      sourceanalyzer -b "$FORTIFY_PROJECT" \
        -scan \
        -Xmx${FORTIFY_MEM} \
        -format fpr \
        -f "$FORTIFY_PROJECT_DIR/$FORTIFY_SCAN_OUTPUT"

      echo "FPR size: $(ls -lh $FORTIFY_PROJECT_DIR/$FORTIFY_SCAN_OUTPUT)"

      echo "Generating report..."
      BIRTReportGenerator \
        -template "Developer Workbook" \
        -source "$FORTIFY_PROJECT_DIR/$FORTIFY_SCAN_OUTPUT" \
        -format PDF \
        -output "$FORTIFY_PROJECT_DIR/${PROJECT_NAME}_report.pdf" \
        -showSuppressed \
        -showHidden

      echo "PDF generation complete."
      ls -lrth "${FORTIFY_PROJECT_DIR}"
      echo "========== Fortify Scan Completed =========="

  artifacts:
    paths:
      - "./*.fpr"
      - "./*.pdf"
    expire_in: 1 week
    when: always
  allow_failure: true
