      podman tag "${COMPUTED_IMAGE_TAG}" "dev-registry-route-quay-enterprise.apps.dev.sbiepay.sbi/$IMAGE_NAME:$TAG"
      podman push dev-registry-route-quay-enterprise.apps.dev.sbiepay.sbi/$IMAGE_NAME:$TAG --tls-verify=false
  artifacts:
