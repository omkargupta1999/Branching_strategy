.publish:
  stage: publish
  image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-local/custom-ci/gradle-9.3.0-jdk-21-jfcli:v1-jfcli
  tags:
    - common_runner
  before_script:
    - |
      cp "$ARTIFACTORY_CERT" /etc/pki/ca-trust/source/anchors/artifactory.crt
      update-ca-trust extract
      keytool -importcert -alias artifactory -file "$ARTIFACTORY_CERT" \
        -keystore /etc/pki/java/cacerts -storepass changeit -noprompt
    - |
      jf config add \
        --url="$JF_URL" \
        --user="$JF_USER" \
        --access-token="$JF_TOKEN" \
        --interactive=false \
        epay-server
      jf config use epay-server
      jf rt ping
  script:
    - |
      echo "Publishing $CI_PROJECT_NAME version $VERSION to JFrog Artifactory"
      jf gradle-config \
        --repo-resolve="itepaypg-sbiepay2-gradle-virtual" \
        --repo-deploy="itepaypg-sbiepay2-maven-local" \
        --server-id-resolve="epay-server" \
        --server-id-deploy="epay-server" \
        --use-wrapper=false
      jf gradle publish \
        --build-name="$CI_PROJECT_NAME-$SERVICE" \
        --build-number="$VERSION"
      jf rt build-publish "$CI_PROJECT_NAME-$SERVICE" "$VERSION"
      jf xr build-scan "$CI_PROJECT_NAME-$SERVICE" "$VERSION" \
        --watches=EPAY-WATCHER \
        --fail=true
      echo "✅ Published: $SERVICE:$VERSION → itepaypg-sbiepay2-maven-local"
  rules:
    - if: '$CI_COMMIT_BRANCH == "main" && $CI_PIPELINE_SOURCE == "push"'
      when: on_success
    - if: '$CI_COMMIT_BRANCH =~ /^release\/.*/ && $CI_PIPELINE_SOURCE == "push"'
      when: on_success
    - when: never
