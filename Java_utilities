sast.gitlab.yaml -------------------

include:
  - template: Jobs/SAST.latest.gitlab-ci.yml

sast:
  stage: sast
  variables:
    SECURE_ANALYZERS_PREFIX: "registry.dev.sbiepay.sbi:8443/ubi9/security-products"
    CI_TEMPLATE_REGISTRY_HOST: "registry.dev.sbiepay.sbi:8443"
    SAST_ANALYZER_IMAGE_TAG: "5"
    DEFAULT_SAST_EXCLUDED_PATHS: "spec,test,tests,tmp"
    SAST_EXCLUDED_PATHS: "$DEFAULT_SAST_EXCLUDED_PATHS"
    SEARCH_MAX_DEPTH: 4

gitlab-advanced-sast:
  stage: sast
  variables:
    SECURE_ANALYZERS_PREFIX: "registry.dev.sbiepay.sbi:8443/ubi9/security-products"
    GITLAB_ADVANCED_SAST_ENABLED: "true"
    SAST_ANALYZER_IMAGE_TAG: "5"
  tags:
    - common_runner
  allow_failure: true
  artifacts:
    reports:
      sast: gl-sast-report.json

.sast:
  stage: sast
  tags:
    - common_runner
  allow_failure: true
