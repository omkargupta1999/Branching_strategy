# =============================================================================

FROM registry.dev.sbiepay.sbi:8443/ubi9/openjdk-21:1.24-2.1776357031

# ---------------------------------------------------------------------------

# Environment Variables (FIXED - single valid ENV instruction)

# ---------------------------------------------------------------------------

ENV GRADLE_VERSION=9.3.0 
GRADLE_HOME=/opt/gradle 
GRADLE_USER_HOME=/home/gradle/.gradle 
PATH=/opt/gradle/bin:/usr/local/bin:$PATH

# ---------------------------------------------------------------------------

# Switch to root for all setup steps

# ---------------------------------------------------------------------------

USER root

# ---------------------------------------------------------------------------

# Install Gradle

# ---------------------------------------------------------------------------

COPY gradle-9.3.0/ /opt/gradle-9.3.0/

RUN ln -s /opt/gradle-9.3.0 /opt/gradle 
&& chmod 0755 /opt/gradle-9.3.0/bin/gradle

# ---------------------------------------------------------------------------

# Add gradle user

# ---------------------------------------------------------------------------

RUN useradd -u 1001 -m -s /bin/bash gradle

# ---------------------------------------------------------------------------

# Create Gradle home and set permissions

# ---------------------------------------------------------------------------

RUN mkdir -p ${GRADLE_USER_HOME} 
&& chown -R gradle:gradle /home/gradle /opt/gradle-9.3.0 /opt/gradle

# ---------------------------------------------------------------------------

# Add JFrog CLI (jf)

# ---------------------------------------------------------------------------

COPY jf /usr/local/bin/jf

RUN chmod 0755 /usr/local/bin/jf 
&& chown gradle:gradle /usr/local/bin/jf

# Validate jf binary (fail fast)

RUN /usr/local/bin/jf --version

# ---------------------------------------------------------------------------

# Import JFrog / Internal CA certificate into JVM truststore

# ---------------------------------------------------------------------------

COPY jfrog-chain.crt /tmp/jfrog-chain.crt

RUN keytool -import 
-trustcacerts 
-file /tmp/jfrog-chain.crt 
-keystore "${JAVA_HOME}/lib/security/cacerts" 
-alias sbi-internal 
-storepass changeit 
-noprompt 
&& rm -f /tmp/jfrog-chain.crt

# ---------------------------------------------------------------------------

# Switch to non-root gradle user for runtime

# ---------------------------------------------------------------------------

USER gradle

WORKDIR /workspace

CMD ["gradle", "--version"]

