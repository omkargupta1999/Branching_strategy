gitlab-advanced-sast:
  stage: sast
  artifacts:
    reports:
      sast:
      - gl-sast-report.json
    access: developer
  rules:
  - if: "$SAST_DISABLED == 'true' || $SAST_DISABLED == '1'"
    when: never
  - if: "$SAST_EXCLUDED_ANALYZERS =~ /gitlab-advanced-sast/"
    when: never
  - if: "$GITLAB_ADVANCED_SAST_ENABLED != 'true' && $GITLAB_ADVANCED_SAST_ENABLED
      != '1'"
    when: never
  - if: $CI_PIPELINE_SOURCE == "merge_request_event" && $GITLAB_FEATURES =~ /\bsast_advanced\b/
    exists:
    - "**/*.py"
    - "**/*.go"
    - "**/*.java"
    - "**/*.jsp"
    - "**/*.js"
    - "**/*.jsx"
    - "**/*.ts"
    - "**/*.tsx"
    - "**/*.cjs"
    - "**/*.mjs"
    - "**/*.cs"
    - "**/*.rb"
  - if: "$CI_OPEN_MERGE_REQUESTS"
    when: never
  - if: "$CI_COMMIT_BRANCH && $GITLAB_FEATURES =~ /\\bsast_advanced\\b/"
    exists:
    - "**/*.py"
    - "**/*.go"
    - "**/*.java"
    - "**/*.jsp"
    - "**/*.js"
    - "**/*.jsx"
    - "**/*.ts"
    - "**/*.tsx"
    - "**/*.cjs"
    - "**/*.mjs"
    - "**/*.cs"
    - "**/*.rb"
  variables:
    SEARCH_MAX_DEPTH: 20
    GITLAB_ADVANCED_SAST_ENABLED: 'true'
    SECURE_ANALYZERS_PREFIX: "$CI_TEMPLATE_REGISTRY_HOST/ubi9/security-products"
    CI_TEMPLATE_REGISTRY_HOST: registry.dev.sbiepay.sbi:8443
    DEFAULT_SAST_EXCLUDED_PATHS: spec, test, tests, tmp
    SAST_EXCLUDED_PATHS: "$DEFAULT_SAST_EXCLUDED_PATHS"
    SAST_ANALYZER_IMAGE_TAG: '1'
    SAST_ANALYZER_IMAGE: "$SECURE_ANALYZERS_PREFIX/gitlab-advanced-sast:$SAST_ANALYZER_IMAGE_TAG$SAST_IMAGE_SUFFIX"
  cache: []
  script:
  - "/analyzer run"
  extends: ".sast-analyzer"
  allow_failure: true
  image:
    name: "$SAST_ANALYZER_IMAGE"
