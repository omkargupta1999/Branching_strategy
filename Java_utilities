  - git fetch --tags
create-rc-tag:
  stage: release
  image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-local/custom-ci/rhelgit-oc-helm:1.0
  tags:
  - common_runner
  before_script:
  - git config --global http.sslVerify false
  - git config --global --add safe.directory '*'
  - git config --global user.name "ci"
  - git config --global user.email "ci.cedge@sbi.co.in"
  - git remote set-url origin "https://oauth2:$GIT_PAT@gitlab.sbi/$CI_PROJECT_PATH.git"
  - git fetch --tags
  extends: ".git_tag_base"
  script:
  - |
    RELEASE_VERSION=$(echo "$CI_COMMIT_BRANCH" | sed 's|release/||')
    RC_COUNT=$(git tag -l "v${RELEASE_VERSION}-rc.*" | wc -l)
    NEW_RC=$((RC_COUNT + 1))
    RC_TAG="v${RELEASE_VERSION}-rc.${NEW_RC}"
    echo "Creating RC tag: $RC_TAG"
    git tag -a "$RC_TAG" -m "RC ${NEW_RC} — auto on merge to $CI_COMMIT_BRANCH"
    git push origin "$RC_TAG"
    echo "RC_TAG=$RC_TAG" >> rc.env
    echo "✅ RC tag created: $RC_TAG"
  artifacts:
    reports:
      dotenv:
      - rc.env
    expire_in: 1 week
  rules:
  - if: $CI_COMMIT_BRANCH =~ /^release\/.*/ && $CI_PIPELINE_SOURCE == "push"
    when: on_success
  - when: never
create-prod-tag:
  stage: release
  image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-local/custom-ci/rhelgit-oc-helm:1.0
  tags:
  - common_runner
  before_script:
  - git config --global http.sslVerify false
  - git config --global --add safe.directory '*'
  - git config --global user.name "ci"
  - git config --global user.email "ci.cedge@sbi.co.in"
  - git remote set-url origin "https://oauth2:$GIT_PAT@gitlab.sbi/$CI_PROJECT_PATH.git"
  - git fetch --tags
  extends: ".git_tag_base"
  script:
  - |
    PROD_TAG="v${VERSION}"
    echo "Creating production tag: $PROD_TAG"
    if git tag -l "$PROD_TAG" | grep -q "$PROD_TAG"; then
      echo "Tag $PROD_TAG already exists — skipping"
    else
      git tag -a "$PROD_TAG" -m "Production ${VERSION} — merged to main [$(date -u '+%Y-%m-%d %H:%M UTC')]"
      git push origin "$PROD_TAG"
      echo "✅ Production tag created: $PROD_TAG"
    fi
  rules:
  - if: $CI_COMMIT_BRANCH == "main" && $CI_PIPELINE_SOURCE == "push"
    when: on_success
  - when: never
