---
".build":
  stage: build
  image:
    name: registry.dev.sbiepay.sbi:8443/ubi9/gradle-8.9-jdk-21:v6
    pull_policy: always
  script:
  - pwd
  - ls -la
  - "if [ -n \"$VERSION\" ]; then\n  echo \"version ${VERSION}\"\n  gradle build -x
    test -Pversion=${VERSION}\nelse\n  gradle build -x test \nfi\n"
  - ls -lrth
  - ls -lrth build/libs
  artifacts:
    paths:
    - build/libs
    when: on_success
    expire_in: 1 week
".test":
  stage: test
  image:
    name: registry.dev.sbiepay.sbi:8443/ubi9/gradle-8.9-jdk-21:v6
    pull_policy: always
  script:
  - pwd
  - ls -lrth
  - gradle test
