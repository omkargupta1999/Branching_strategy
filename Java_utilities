---
version:
  stage: version
  image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-local/custom-ci/rhelgit-oc-helm:1.0
  tags:
  - common_runner
  before_script:
  - git config --global http.sslVerify false
  - git config --global --add safe.directory '*'
  script:
  - |
    set -e
    git fetch --tags

    if [[ "$CI_PIPELINE_SOURCE" == "merge_request_event" ]]; then
      VERSION="mr-${CI_MERGE_REQUEST_IID}-${CI_COMMIT_SHORT_SHA}"

    elif [[ "$CI_COMMIT_BRANCH" == "develop" ]]; then
      VERSION="dev-${CI_COMMIT_SHORT_SHA}"

    elif [[ "$CI_COMMIT_BRANCH" =~ ^release\/([0-9]+\.[0-9]+\.[0-9]+)$ ]]; then
      RELEASE_VERSION="${BASH_REMATCH[1]}"
      RC_COUNT=$(git tag -l "v${RELEASE_VERSION}-rc.*" | wc -l)
      NEW_RC=$((RC_COUNT + 1))
      VERSION="${RELEASE_VERSION}-rc.${NEW_RC}"

    elif [[ "$CI_COMMIT_BRANCH" =~ ^hotfix\/([0-9]+\.[0-9]+\.[0-9]+)$ ]]; then
      VERSION="${BASH_REMATCH[1]}"

    elif [[ "$CI_COMMIT_BRANCH" == "main" ]]; then
      LAST_TAG=$(git tag --sort=-v:refname | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' | head -1 || echo "v0.0.0")
      VERSION="${LAST_TAG#v}"

    else
      VERSION="${CI_COMMIT_SHORT_SHA}"
    fi

    echo "VERSION=$VERSION" >> version.env
    echo "CI_COMMIT_SHORT_SHA=$CI_COMMIT_SHORT_SHA" >> version.env
    echo "Generated VERSION=$VERSION"
  artifacts:
    reports:
      dotenv:
      - version.env
    expire_in: 1 week
".build":
  stage: build
  image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-local/custom-ci/gradle-9.3.0-jdk-21:1.24-2.1776357031
  tags:
  - common_runner
  variables:
    GRADLE_OPTS: "-Dorg.gradle.daemon=false"
  script:
  - |
    if [ -n "$VERSION" ]; then
      gradle build -x test -Pversion=${VERSION}
    else
      gradle build -x test
    fi
  - ls -lrth build/libs
  - echo "VERSION=$VERSION" >> build.env
  artifacts:
    paths:
    - build/libs
    reports:
      dotenv: build.env
    when: on_success
    expire_in: 1 week
".test":
  stage: test
  image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-local/custom-ci/gradle-9.3.0-jdk-21:v10
  tags:
  - common_runner
  script:
  - gradle test
  artifacts:
    reports:
      junit: build/test-results/test/TEST-*.xml
    when: always
    expire_in: 1 week
