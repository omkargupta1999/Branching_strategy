apiVersion: 1
datasources:
  # Default Prometheus (Aggregated)
  - name: Prometheus-Default
    type: prometheus
    access: proxy
    url: http://10.177.139.191:9090
    isDefault: true
    editable: true
    jsonData:
      timeInterval: 15s
      queryTimeout: 60s
      httpMethod: POST
    uid: prometheus-default
  # Default Loki (Aggregated)
  - name: Loki-Default
    type: loki
    access: proxy
    url: http://10.189.35.10:3104
    isDefault: false
    editable: true
    jsonData:
      maxLines: 5000
      timeout: 300              # ADDED: allow long (e.g. 24h | json) queries to finish; was Grafana default ~30s
      httpMethod: POST          # ADDED: POST handles large queries/payloads better than GET
      alertmanager:
        handleGrafanaManagedAlerts: true
        implementation: prometheus
        url: http://127.0.0.1:9093
    uid: loki-default
  # Loki Node 1 (Primary)
  - name: Loki-Node1
    type: loki
    access: proxy
    url: http://10.189.35.10:3104
    isDefault: false
    editable: true
    jsonData:
      maxLines: 5000
      timeout: 300              # ADDED
      httpMethod: POST          # ADDED
      derivedFields:
        - datasourceUid: prometheus-node1
          matcherRegex: "traceID=(\\w+)"
          name: TraceID
          url: "$${__value.raw}"
        - datasourceUid: prometheus-node1
          matcherRegex: "(?:user|userId|user_id)=([\\w.]+)"
          name: UserID
          url: "$${__value.raw}"
      alertmanager:
        handleGrafanaManagedAlerts: true
        implementation: prometheus
        url: http://127.0.0.1:9093
    uid: loki-node1
  # Loki Node 2 (Secondary)
  - name: Loki-Node2
    type: loki
    access: proxy
    url: http://10.189.35.11:3104
    isDefault: false
    editable: true
    jsonData:
      maxLines: 5000
      timeout: 300              # ADDED
      httpMethod: POST          # ADDED
      derivedFields:
        - datasourceUid: prometheus-node2
          matcherRegex: "traceID=(\\w+)"
          name: TraceID
          url: "$${__value.raw}"
        - datasourceUid: prometheus-node2
          matcherRegex: "(?:user|userId|user_id)=([\\w.]+)"
          name: UserID
          url: "$${__value.raw}"
      alertmanager:
        handleGrafanaManagedAlerts: true
        implementation: prometheus
        url: http://127.0.0.1:9093
    uid: loki-node2
  # Prometheus Node 1
  - name: Prometheus-Node1
    type: prometheus
    access: proxy
    url: http://10.189.35.10:9090
    isDefault: false
    editable: true
    jsonData:
      timeInterval: 15s
      queryTimeout: 60s
      httpMethod: POST
      exemplarTraceIdDestinations:
        - name: TraceID
          datasourceUid: loki-node1
    uid: prometheus-node1
  # Prometheus Node 2
  - name: Prometheus-Node2
    type: prometheus
    access: proxy
    url: http://10.189.35.11:9090
    isDefault: false
    editable: true
    jsonData:
      timeInterval: 15s
      queryTimeout: 60s
      httpMethod: POST
      exemplarTraceIdDestinations:
        - name: TraceID
          datasourceUid: loki-node2
    uid: prometheus-node2
  # AlertManager (Single Instance)
  - name: AlertManager
    type: alertmanager
    access: proxy
    url: http://10.189.35.10:9093
    isDefault: false
    editable: true
    implementation: prometheus
    uid: alertmanager



















