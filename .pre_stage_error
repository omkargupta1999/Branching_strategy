# Pull the image
docker pull artifactory.jfrog.sbi:443/dso-base-image/ubi9/ubi9-java17-fortify-24.4:2.0

# Run a quick inspection container
docker run --rm \
  artifactory.jfrog.sbi:443/dso-base-image/ubi9/ubi9-java17-fortify-24.4:2.0 \
  find /opt -name "sourceanalyzer" -o -name "BIRTReportGenerator" 2>/dev/null

# Or get an interactive shell to explore
docker run --rm -it \
  artifactory.jfrog.sbi:443/dso-base-image/ubi9/ubi9-java17-fortify-24.4:2.0 \
  /bin/bash



