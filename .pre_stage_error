####################################

.ui_build:
  stage: build
  tags:
    - common_runner
  #image: artifactory.jfrog.sbi:443/dso-base-image/node/nodejs-20:1-38
  variables: 
    NG_PERSISTENT_BUILD_CACHE: "1"
    NODE_OPTIONS: "--openssl-legacy-provider"
  cache:
    key: $CI_COMMIT_REF_SLUG
    paths:
      - .angular/cache
  before_script:
    - node -v
    - npm -v
    - npm config set strict-ssl false
    - npm config set registry https://artifactory.jfrog.sbi:443/artifactory/cbops-bsa-npm/
  script:
    - npm ci --prefer-offline --no-audit
    - npm run build
    - cd dist && tar -cvf dist.tar .
    - sha256sum *.tar > checksums.txt
    - cat checksums.txt
  artifacts:
    paths:
      - dist/dist.tar
    expire_in: 1 day

######################################


.build:
  variables: 
    NPM_CONFIG_REGISTRY: "https://artifactory.jfrog.sbi/artifactory/api/npm/itepaypg-sbiepay2-npm-virtual/"
    NPM_TOKEN: token   # Replace with real token via CI/CD variables

  stage: build

  image:
    name: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-local/custom-ci/reactjs_npm:20241113

  before_script:
    - unset http_proxy https_proxy HTTP_PROXY HTTPS_PROXY
    - echo "registry=https://artifactory.jfrog.sbi/artifactory/api/npm/itepaypg-sbiepay2-npm-virtual/" > .npmrc
    - echo "always-auth=true" >> .npmrc
    - echo "//artifactory.jfrog.sbi/artifactory/api/npm/itepaypg-sbiepay2-npm-virtual/:_authToken=${NPM_TOKEN}" >> .npmrc
    - cat .npmrc
  script:
    - echo "BUILD STARTED"

    - npm config set registry "https://artifactory.jfrog.sbi/artifactory/api/npm/itepaypg-sbiepay2-npm-virtual/"
    - npm config get registry

    - env | grep -i proxy || true
    - echo "Pipeline JF_USER ${JF_USER}"

    - pwd
    - ls -la

    # Install dependencies
    - npm cache clean --force
    - npm install --legacy-peer-deps

    # Build
    - npm run build

    - echo "Skipping export step (handled by build)"

    # Normalize output
    - |
      if [ -d "out" ]; then
        echo "Next.js detected - copying out to dist"
        rm -rf dist
        mkdir -p dist
        cp -r out/* dist/
      elif [ -d "dist" ]; then
        echo "Using existing dist"
      else
        echo "ERROR: No dist or out folder found"
        exit 1
      fi

    # Verify
    - echo "FINAL DIST CONTENT"
    - ls -la dist

    - echo "BUILD COMPLETED"

  artifacts:
    paths:
      - dist/
    when: on_success
    expire_in: 1 week
