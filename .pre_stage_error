.HPFortify:
  tags:
    - common_runner
  needs:
    - job: build
      artifacts: true
  variables:
    FORTIFY_IMAGE: "artifactory.jfrog.sbi:443/dso-base-image/ubi9/ubi9-java17-fortify-24.4:2.0"
    FORTIFY_PROJECT: $CI_PROJECT_NAME
    PROJECT_NAME: $CI_PROJECT_NAME
    FORTIFY_SCAN_OUTPUT: "$CI_PROJECT_NAME.fpr"
    SOURCE_ANALYZER: "/opt/Fortify/bin/sourceanalyzer"
    BIRTReportGenerator: "/opt/Fortify_SCA_and_Apps_21.1.4/bin/BIRTReportGenerator"
    FORTIFY_PROJECT_DIR: "."
    EXCLUDE_DIRS: "./src/test/**/*"
    INCLUDE_DIRS: "./**/*.java"
  stage: hp-fortify
  image: $FORTIFY_IMAGE
  before_script:
    - |
      keytool -import -alias jfrog-artifactory -file "$ARTIFACTORY_CERT" \
        -keystore /home/default/custom-truststore.jks \
        -storepass changeit -noprompt
  script:
    - |
      export JAVA_TOOL_OPTIONS="-Djavax.net.ssl.trustStore=/home/default/custom-truststore.jks -Djavax.net.ssl.trustStorePassword=changeit"

      echo "========== Fortify Scan Started =========="
      ls

      EXCLUDE_FILES=$(echo "$EXCLUDE_DIRS" | sed 's/,/:/g')
      echo "Scanning paths: ${INCLUDE_DIRS}"
      echo "Excluding paths: ${EXCLUDE_FILES}"

      # Step 1: Clean previous build
      echo "--- Step 1: Cleaning previous build ---"
      $SOURCE_ANALYZER -b $FORTIFY_PROJECT -clean

      # Step 2: Translate source files
      echo "--- Step 2: Translating source files ---"
      $SOURCE_ANALYZER -b $FORTIFY_PROJECT \
        "${INCLUDE_DIRS}" \
        -verbose \
        -exclude "${EXCLUDE_FILES}"

      # Step 3: Verify translated files
      echo "--- Step 3: Verifying translated files ---"
      $SOURCE_ANALYZER -b $FORTIFY_PROJECT -show-files

      # Step 4: Run scan
      echo "--- Step 4: Running scan ---"
      $SOURCE_ANALYZER -b $FORTIFY_PROJECT \
        -scan \
        -format fpr \
        -f "$FORTIFY_PROJECT_DIR/$FORTIFY_SCAN_OUTPUT"

      # Step 5: Verify FPR output
      echo "--- Step 5: FPR file info ---"
      ls -lh "$FORTIFY_PROJECT_DIR/$FORTIFY_SCAN_OUTPUT"

      # Step 6: Print scan summary using sourceanalyzer -scan-statistics
      echo "--- Step 6: Scan Summary ---"
      echo "===== SCAN SUMMARY ====="
      $SOURCE_ANALYZER -b $FORTIFY_PROJECT -show-build-warnings 2>/dev/null || true
      echo "FPR Location : $FORTIFY_PROJECT_DIR/$FORTIFY_SCAN_OUTPUT"
      echo "FPR Size     : $(du -sh $FORTIFY_PROJECT_DIR/$FORTIFY_SCAN_OUTPUT | cut -f1)"
      echo "Files Scanned: $(unzip -l $FORTIFY_PROJECT_DIR/$FORTIFY_SCAN_OUTPUT 2>/dev/null | grep -c '\.java' || echo 'N/A')"
      echo "======================="

      # Step 7: Generate PDF report
      echo "--- Step 7: Generating PDF report ---"
      $BIRTReportGenerator \
        -template "Developer Workbook" \
        -source "${FORTIFY_PROJECT_DIR}/${FORTIFY_SCAN_OUTPUT}" \
        -format PDF \
        -output "${FORTIFY_PROJECT_DIR}/${PROJECT_NAME}_report.pdf" \
        -showSuppressed \
        -showHidden \
        -Xmx4G

      # Step 8: Verify PDF output
      echo "--- Step 8: PDF file info ---"
      ls -lh "${FORTIFY_PROJECT_DIR}/${PROJECT_NAME}_report.pdf"

      echo "PDF generation complete."
      echo "========== Fortify Scan Completed =========="

      echo "--- Final workspace contents ---"
      pwd
      echo "Project Dir  : ${FORTIFY_PROJECT_DIR}"
      echo "Project Name : ${PROJECT_NAME}"
      ls -lrth "${FORTIFY_PROJECT_DIR}"
  allow_failure: true
  artifacts:
    paths:
      - "./*.fpr"
      - "./*.pdf"
    expire_in: 1 week
