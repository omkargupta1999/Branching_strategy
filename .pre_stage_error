  - local: 'ci/image/image.scan.xray.yml'
  # - local: 'ci/image/image.scan.rhacs.yml'
  # - local: 'ci/image/image.sign.yml'
  # - local: 'ci/image/image.sbom.attest.yml'
  - local: 'ci/image/image.push.yml'
  - local: 'ci/release/tag.yml'
  # - local: 'ci/release/back-merge.yml'
  - local: 'ci/deploy/trigger.cd.yml'
  - local: 'ci/deploy/deploy.jobs.yml'

stages:
  - version       # version generation
  - build         # gradle compile
  - test          # unit + integration
  - sast          # gitlab sast + fortify
  # - security      # sca + secrets + iac + license + sbom
  - image-build   # podman build (local only — no push)
  - image-scan    # trivy + xray + rhacs (gate before sign)
  # - image-attest  # cosign sign + sbom attestation
  - image-push    # push to JFrog (only after scan + sign)
  - release       # rc-tag (release/*) or prod-tag (main) — auto on merge
  - deploy        # trigger buttons → deployment repo CD pipeline

variables:
  CI_TEMPLATE_REGISTRY_HOST:           "artifactory.jfrog.sbi:443"
  CI_TEMPLATE_REGISTRY_HOST_PREPROD:   "epaynonprod-registry-quay-quay-enterprise.apps.preprod.epay.sbi"
  CI_TEMPLATE_REGISTRY_HOST_PREPRODDC: "dc-preprod-registry-quay-quay-enterprise.apps.dcpreprod.epay.sbi"
  CI_TEMPLATE_REGISTRY_HOST_PRODDR:    "epayproddr-registry-quay-quay-enterprise.apps.dr.prod.epay.sbi"
  CI_TEMPLATE_REGISTRY_HOST_PRODDC:    "proddc-registry-route-quay-enterprise.apps.dc.prod.epay.sbi"
  GIT_STRATEGY: clone
  RELEASE_NAME: ""
  CHART_NAME:   ""
  IMAGE_NAME:   "itepaypg-sbiepay2-docker-local/app/backend/${CI_PROJECT_NAME}"

# Branch + MR filter — applied to all jobs via extends
.rules:
  rules:
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event" && $CI_MERGE_REQUEST_TARGET_BRANCH_NAME =~ /^(main|develop|release)(\/.*)*$/'
    - if: '$CI_COMMIT_BRANCH =~ /^(main|develop|release|hotfix|bugfix|feature|feature_ci)(\/.*)*$/'
    - when: never

