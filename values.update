    strategy: depend
    forward:
      pipeline_variables: true
  extends: ".trigger_cd_preprod"
  rules:
  - if: "$CI_COMMIT_BRANCH =~ /^release\\/[0-9]+\\.[0-9]+\\.[0-9]+$/"
    when: manual
    allow_failure: true
  - when: never
deploy-hotfix-preprod-smoke:
  stage: deploy
  variables:
    DEPLOYMENT_BRANCH: main
    HOTFIX: 'true'
    ENV: pre-prod-dc
    SERVICE_NAME: "$CI_PROJECT_NAME"
  trigger:
    project: itepaypg-sbiepay2/infra/devops/deployment
    branch: "$DEPLOYMENT_BRANCH"
    strategy: depend
    forward:
      pipeline_variables: true
  extends: ".trigger_cd_hotfix"
  rules:
  - if: $CI_PIPELINE_SOURCE == "merge_request_event" && $CI_MERGE_REQUEST_TARGET_BRANCH_NAME
      == "main" && $CI_MERGE_REQUEST_SOURCE_BRANCH_NAME =~ /^hotfix\//
    when: manual
    allow_failure: true
  - when: never
deploy-prod-dc:
  stage: deploy
  variables:
    DEPLOYMENT_BRANCH: main
    ENV: prod-dc
    SERVICE_NAME: "$CI_PROJECT_NAME"
  trigger:
    project: itepaypg-sbiepay2/infra/devops/deployment
    branch: "$DEPLOYMENT_BRANCH"
    strategy: depend
    forward:
      pipeline_variables: true
  extends: ".trigger_cd_prod"
  rules:
  - if: $CI_COMMIT_BRANCH == "main"
    when: manual
    allow_failure: true
  - when: never
deploy-prod-dr:
  stage: deploy
  variables:
    DEPLOYMENT_BRANCH: main
    ENV: prod-dr
    SERVICE_NAME: "$CI_PROJECT_NAME"
  trigger:
    project: itepaypg-sbiepay2/infra/devops/deployment
    branch: "$DEPLOYMENT_BRANCH"
    strategy: depend
    forward:
      pipeline_variables: true
  extends: ".trigger_cd_prod"
  rules:
  - if: $CI_COMMIT_BRANCH == "main"
    when: manual
    allow_failure: true
  - when: never
default:
  tags:
  - common_runner
stages:
- ".pre"
- version
- build
- test
- sast
- security
- image-build
- image-scan
- image-push
- release
- deploy
- ".post"
".rules":
  rules:
  - if: $CI_PIPELINE_SOURCE == "merge_request_event" && $CI_MERGE_REQUEST_TARGET_BRANCH_NAME
      =~ /^(main|develop|release)(\/.*)*$/
  - if: "$CI_COMMIT_BRANCH =~ /^(main|develop|release|hotfix|bugfix|feature_ci)(\\/.*)*$/"
  - when: never
build:
  stage: build
  image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-local/custom-ci/gradle-9.3.0-jdk-21:1.24-2.1776357031
  tags:
  - common_runner
  variables:
    GRADLE_OPTS: "-Dorg.gradle.daemon=false"
  script:
  - |
    if [ -n "$VERSION" ]; then
      gradle build -x test -Pversion=${VERSION}
    else
      gradle build -x test
    fi
  - ls -lrth build/libs
  - echo "VERSION=$VERSION" >> build.env
  artifacts:
    paths:
    - build/libs
    reports:
      dotenv:
      - build.env
    when: on_success
    expire_in: 1 week
  rules:
  - if: $CI_PIPELINE_SOURCE == "merge_request_event" && $CI_MERGE_REQUEST_TARGET_BRANCH_NAME
      =~ /^(main|develop|release)(\/.*)*$/
  - if: "$CI_COMMIT_BRANCH =~ /^(main|develop|release|hotfix|bugfix|feature_ci)(\\/.*)*$/"
  - when: never
  extends:
  - ".build"
  - ".rules"
test:
  stage: test
  image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-local/custom-ci/gradle-9.3.0-jdk-21:v10
  tags:
  - common_runner
  script:
  - gradle test
  artifacts:
    reports:
      junit:
      - build/test-results/test/TEST-*.xml
    when: always
    expire_in: 1 week
  rules:
  - if: $CI_PIPELINE_SOURCE == "merge_request_event" && $CI_MERGE_REQUEST_TARGET_BRANCH_NAME
      =~ /^(main|develop|release)(\/.*)*$/
  - if: "$CI_COMMIT_BRANCH =~ /^(main|develop|release|hotfix|bugfix|feature_ci)(\\/.*)*$/"
  - when: never
  extends:
  - ".test"
  - ".rules"
deploy:
  stage: deploy
  variables:
    DEPLOYMENT_BRANCH: deploy_cicd
  trigger:
    project: itepaypg-sbiepay2/infra/devops/deployment
    branch: "$DEPLOYMENT_BRANCH"
    strategy: depend
    forward:
      pipeline_variables: true
  rules:
  - if: $CI_PIPELINE_SOURCE == "merge_request_event" && $CI_MERGE_REQUEST_TARGET_BRANCH_NAME
      =~ /^(main|develop|release)(\/.*)*$/
  - if: "$CI_COMMIT_BRANCH =~ /^(main|develop|release|hotfix|bugfix|feature_ci)(\\/.*)*$/"
  - when: never
  extends:
  - ".trigger_cd"
  - ".rules"
