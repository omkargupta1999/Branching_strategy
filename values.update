# Updated `values.update.yml`

Replace your script block with this:

```yaml
# cd/publish/values.update.yml

.update_tag:
  stage: publish

  tags:
    - deploy_runner

  image: artifactory.jfrog.sbi:443/itepaypg-sbiepay2-docker-local/custom-ci/rhelgit-oc-helm:1.0

  before_script:
    - git config --global http.sslVerify false
    - git config --global --add safe.directory '*'
    - git config --global user.name "ci"
    - git config --global user.email "ci.cedge@sbi.co.in"
    - git remote set-url origin "https://oauth2:$GITLAB_CI_DEPLOY_TOKEN@gitlab.sbi/$CI_PROJECT_PATH.git"

  script:
    - |
      set -eo pipefail

      echo "========== DEBUG =========="
      echo "APP_SERVICE_NAME=$APP_SERVICE_NAME"
      echo "APP_ENV=$APP_ENV"
      echo "APP_VERSION=$APP_VERSION"
      echo "APP_CHART_NAME=$APP_CHART_NAME"
      echo "APP_RELEASE_NAME=$APP_RELEASE_NAME"
      echo "==========================="

      if [ -z "$APP_SERVICE_NAME" ] || \
         [ -z "$APP_ENV" ] || \
         [ -z "$APP_VERSION" ]; then
        echo "ERROR: Required variables missing"
        exit 1
      fi

      TAG=$APP_VERSION

      SERVICE_PATH="${APP_ENV}/charts/${APP_SERVICE_NAME}"

      echo "Updating $SERVICE_PATH/values.yaml → image tag: $TAG"

      if [ ! -f "$SERVICE_PATH/values.yaml" ]; then
        echo "ERROR: values.yaml not found"

        echo "===== AVAILABLE CHARTS ====="
        find ${APP_ENV}/charts -maxdepth 2 -type f
        echo "============================"

        exit 1
      fi

      git fetch origin

      git checkout -B $CI_COMMIT_BRANCH origin/$CI_COMMIT_BRANCH

      for i in 1 2 3; do
        git pull --rebase origin $CI_COMMIT_BRANCH && break

        echo "Rebase failed...retrying ($i)"
        sleep 2

        if [ $i -eq 3 ]; then
          echo "Rebase failed after retries"
          exit 1
        fi
      done

      sed -i "s/\(tag:\).*/\1 \"${TAG}\"/" $SERVICE_PATH/values.yaml

      git add $SERVICE_PATH/values.yaml

      if [[ $(git status --porcelain) ]]; then

        git commit -m "chore: update image tag to $TAG [skip ci]"

        for i in 1 2 3; do

          git push origin $CI_COMMIT_BRANCH && break

          echo "Push failed...retrying ($i)"
          sleep 2

          git pull --rebase origin $CI_COMMIT_BRANCH

          if [ $i -eq 3 ]; then
            echo "Push failed after retries"
            exit 1
          fi
        done

        echo "✅ values.yaml updated successfully"

      else
        echo "No changes required"
      fi

      cat $SERVICE_PATH/values.yaml
```

---

# VERY IMPORTANT

You must ALSO update:

* `validate_service`
* `helm:deploy`

to use:

```bash
APP_SERVICE_NAME
APP_ENV
APP_VERSION
APP_RELEASE_NAME
```

instead of:

* SERVICE_NAME
* ENV
* VERSION
* RELEASE_NAME

Otherwise later stages will still break.
