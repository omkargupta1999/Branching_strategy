## Updated `trigger.cd.yml`

```yaml
# ci/deploy/trigger.cd.yml

.trigger_cd:
  stage: deploy

  inherit:
    variables: false

  variables:
    DEPLOYMENT_BRANCH: "deploy_cicd"

    # Materialized variables for downstream pipeline
    APP_SERVICE_NAME: "${CI_PROJECT_NAME}"
    APP_ENV: "${ENV}"
    APP_VERSION: "${VERSION}"
    APP_CHART_NAME: "${CHART_NAME}"
    APP_RELEASE_NAME: "${RELEASE_NAME}"

  trigger:
    project: "itepaypg-sbiepay2/infra/devops/deployment"
    branch: $DEPLOYMENT_BRANCH
    strategy: depend

    forward:
      pipeline_variables: true
      yaml_variables: true


# ── DEV / SIT / UAT / INT / Perf ─────────────────────────────

.trigger_cd_nonprod:
  extends: .trigger_cd
  variables:
    DEPLOYMENT_BRANCH: "deploy_cicd"

# ── PREPROD ──────────────────────────────────────────────────

.trigger_cd_preprod:
  extends: .trigger_cd
  variables:
    DEPLOYMENT_BRANCH: "main"

# ── HOTFIX ───────────────────────────────────────────────────

.trigger_cd_hotfix:
  extends: .trigger_cd
  variables:
    DEPLOYMENT_BRANCH: "main"
    HOTFIX: "true"

# ── PROD ─────────────────────────────────────────────────────

.trigger_cd_prod:
  extends: .trigger_cd
  variables:
    DEPLOYMENT_BRANCH: "main"
```

---

# Updated `deploy.jobs.yml`

Only environment-specific variables should remain here.

```yaml
# ci/deploy/deploy.jobs.yml

deploy-dev:
  extends: .trigger_cd_nonprod
  variables:
    ENV: "dev"
  rules:
    - if: '$CI_COMMIT_BRANCH == "develop" && $CI_PIPELINE_SOURCE == "push"'
      when: on_success

    - if: '$CI_COMMIT_BRANCH =~ /^feature_ci\/.*/'
      when: manual
      allow_failure: true

    - when: never


deploy-sit:
  extends: .trigger_cd_nonprod
  variables:
    ENV: "sit"
  rules:
    - if: '$CI_COMMIT_BRANCH =~ /^release\/[0-9]+\.[0-9]+\.[0-9]+$/'
      when: manual
      allow_failure: true

    - if: '$CI_PIPELINE_SOURCE == "merge_request_event" && $CI_MERGE_REQUEST_TARGET_BRANCH_NAME =~ /^release\//'
      when: manual
      allow_failure: true

    - when: never


deploy-uat:
  extends: .trigger_cd_nonprod
  variables:
    ENV: "uat"
  rules:
    - if: '$CI_COMMIT_BRANCH =~ /^release\/[0-9]+\.[0-9]+\.[0-9]+$/'
      when: manual
      allow_failure: true

    - when: never


deploy-int:
  extends: .trigger_cd_nonprod
  variables:
    ENV: "int"
  rules:
    - if: '$CI_COMMIT_BRANCH =~ /^release\/[0-9]+\.[0-9]+\.[0-9]+$/'
      when: manual
      allow_failure: true

    - when: never


deploy-perf:
  extends: .trigger_cd_nonprod
  variables:
    ENV: "perf"
  rules:
    - if: '$CI_COMMIT_BRANCH =~ /^release\/[0-9]+\.[0-9]+\.[0-9]+$/'
      when: manual
      allow_failure: true

    - when: never


deploy-preprod-dc:
  extends: .trigger_cd_preprod
  variables:
    ENV: "pre-prod-dc"
  rules:
    - if: '$CI_COMMIT_BRANCH =~ /^release\/[0-9]+\.[0-9]+\.[0-9]+$/'
      when: manual
      allow_failure: true

    - when: never


deploy-preprod-dr:
  extends: .trigger_cd_preprod
  variables:
    ENV: "pre-prod"
  rules:
    - if: '$CI_COMMIT_BRANCH =~ /^release\/[0-9]+\.[0-9]+\.[0-9]+$/'
      when: manual
      allow_failure: true

    - when: never


deploy-hotfix-preprod-smoke:
  extends: .trigger_cd_hotfix
  variables:
    ENV: "pre-prod-dc"
  rules:
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event" &&
            $CI_MERGE_REQUEST_TARGET_BRANCH_NAME == "main" &&
            $CI_MERGE_REQUEST_SOURCE_BRANCH_NAME =~ /^hotfix\//'
      when: manual
      allow_failure: true

    - when: never


deploy-prod-dc:
  extends: .trigger_cd_prod
  variables:
    ENV: "prod-dc"
  rules:
    - if: '$CI_COMMIT_BRANCH == "main"'
      when: manual
      allow_failure: true

    - when: never


deploy-prod-dr:
  extends: .trigger_cd_prod
  variables:
    ENV: "prod-dr"
  rules:
    - if: '$CI_COMMIT_BRANCH == "main"'
      when: manual
      allow_failure: true

    - when: never
```

